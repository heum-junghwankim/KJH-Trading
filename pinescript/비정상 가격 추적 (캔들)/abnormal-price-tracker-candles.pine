//@version=6
indicator("Abnormal-Price-Tracker-Candles (V2)", overlay=true, format=format.volume, precision=0, max_labels_count=500, max_boxes_count=500)

// =========================
// cRSI Inputs
// =========================
domCycle = input.int(20, minval=10, title="cRSI Dominant Cycle Length")
vibration = input.int(10, minval=1, title="cRSI Vibration")
leveling = input.float(10.0, minval=1.0, maxval=50.0, title="cRSI Leveling (%)")
absoluteOB = input.float(70.0, title="절대 과매수 값")
absoluteOS = input.float(30.0, title="절대 과매도 값")
paintBars = input.bool(true, title="비정상 과매수/과매도 캔들 시 색상 변경")
overboughtColor = input.color(color.rgb(255, 140, 60), title="과매수+상단 밴드 초과 캔들 색상")
oversoldColor = input.color(color.aqua, title="과매도+하단 밴드 초과 캔들 색상")
showCRSIPlots = input.bool(false, title="cRSI / 밴드 플롯 표시")
enableRepeatingOBOSAlert = input.bool(true, title="비정상 과매수/과매도 반복 알림 사용")

// =========================
// Abnormal Candle Inputs
// =========================
bbLength = input.int(20, minval=1, title="비정상 캔들 볼린저 기간")
bbMultiplier = input.float(2.0, minval=0.1, step=0.1, title="비정상 캔들 볼린저 배수")
bbBodyBreakRatio = input.float(0.3, minval=0.0, step=0.05, title="비정상 캔들 몸통 밴드 초과 비율")
bbVisualBreakRatio = input.float(0.15, minval=0.0, step=0.05, title="비정상 캔들 시각 표시 밴드 초과 비율")
showBBPlots = input.bool(false, title="비정상 캔들 볼린저 밴드 표시")

// =========================
// Volume Inputs
// =========================
enableSmartVolume = input.bool(true, title="스마트 비정상 거래량 사용")
abnormalVolLookback = input.int(5, minval=1, title="매수/매도 거래량 평균 기준 봉 수")
abnormalVolMultiplier = input.float(0.4, minval=0.0, title="비정상 거래량 배수 기준")
useCRSIFilterForVolume = input.bool(false, title="거래량 시그널에 cRSI 필터 적용")
showVolumeMA = input.bool(false, title="매수/매도 거래량 평균선 표시")
buyVolumeMAColor = input.color(color.teal, title="매수 거래량 평균선 색상")
sellVolumeMAColor = input.color(color.red, title="매도 거래량 평균선 색상")

// =========================
// RSI Divergence Inputs
// =========================
showRSIDivergence = input.bool(true, title="RSI 다이버전스 표시")
rsiDivLength = input.int(12, title="RSI 기간")
lbR = input.int(5, title="Pivot Right")
lbL = input.int(5, title="Pivot Left")
rangeUpper = input.int(60, title="최대 탐색 범위")
rangeLower = input.int(5, title="최소 탐색 범위")
showRegularBullDiv = input.bool(true, title="일반 강세 다이버전스")
showRegularBearDiv = input.bool(true, title="일반 약세 다이버전스")

// =========================
// Background Zone Inputs
// =========================
showBgZone = input.bool(true, title="배경 구간 표시")
useDivForBg = input.bool(true, title="다이버전스 기준 배경 사용")
useCandleForBg = input.bool(true, title="비정상 과매수/과매도 캔들 기준 배경 사용")
setupLookbackBars = input.int(36, minval=1, title="기준 신호 이후 추적 봉 수")
candleSetupLookbackBars = input.int(18, minval=1, title="비정상 캔들 기준 추적 봉 수")
atrLength = input.int(14, minval=1, title="ATR 기간")
atrMultiplier = input.float(0.8, minval=0.1, step=0.1, title="ATR 과도 이동 배수")
candleAtrMultiplier = input.float(1.2, minval=0.1, step=0.1, title="비정상 캔들 기준 ATR 과도 이동 배수")
strongBgAtrMultiplier = input.float(1.4, minval=1.0, step=0.1, title="강한 배경 판정 ATR 배수")
candleStrongBgAtrMultiplier = input.float(1.8, minval=1.0, step=0.1, title="비정상 캔들 기준 강한 배경 ATR 배수")
rsiMoveLimit = input.float(15.0, minval=0.1, step=0.1, title="RSI 추가 이동 제한값")
useCRSIFilterForBg = input.bool(true, title="배경 구간에 cRSI 필터 적용")
useVolumeFilterForBg = input.bool(false, title="배경 구간에 거래량 필터 적용")

bullBgBaseColor = input.color(color.green, title="강세 배경 색상")
bullBgStrongColor = input.color(color.blue, title="강한 강세 배경 색상")
bearBgBaseColor = input.color(color.orange, title="약세 배경 색상")
bearBgStrongColor = input.color(color.red, title="강한 약세 배경 색상")

bgTransparency = input.int(70, minval=0, maxval=100, title="배경 투명도")

// =========================
// Volume Pressure Tracker Inputs
// =========================
volumeCompositeGroup = "거래량 압력 종합 신호"
vpLength = input.int(20, title="거래량 비교 봉 수", minval=1, group=volumeCompositeGroup)
vpMultiplier = input.float(1.0, title="거래량 비정상 배수", minval=0, group=volumeCompositeGroup)
vpSwingPeriod = input.int(20, title="거래량 정렬 Swing Period", minval=2, group=volumeCompositeGroup)
vpBaseAPT = input.float(20.0, title="거래량 정렬 Adaptive Price Tracking", minval=1, step=1, group=volumeCompositeGroup)
vpUseAdapt = input.bool(false, title="거래량 정렬 APT 적응 사용", group=volumeCompositeGroup)
vpVolBias = input.float(10.0, title="거래량 정렬 Volatility Bias", minval=0.1, step=0.1, group=volumeCompositeGroup)
vpBasePeriods = input.int(20, minval=1, title="거래량 정렬 Base Line Length", group=volumeCompositeGroup)
vpMaLength = input.int(5, title="거래량 정렬 MA Length", minval=1, group=volumeCompositeGroup)

// =========================
// Helper Signal Inputs
// =========================
helperCompositeGroup = "보조 종합 신호"
helperMfiLength = input.int(14, minval=1, title="MFI Length", group=helperCompositeGroup)
helperGapThreshold = input.float(18.0, minval=1.0, title="Gap Background Threshold", group=helperCompositeGroup)
helperWeakGapThreshold = input.float(10.0, minval=0.0, title="Weak Gap Threshold", group=helperCompositeGroup)
helperStrongGapThreshold = input.float(14.0, minval=0.0, title="Strong Gap Threshold", group=helperCompositeGroup)
helperBearishZone = input.float(55.0, minval=0.0, maxval=100.0, title="Bearish Risk cRSI Zone", group=helperCompositeGroup)
helperBullishZone = input.float(45.0, minval=0.0, maxval=100.0, title="Bullish Risk cRSI Zone", group=helperCompositeGroup)
helperVolumeAvgLength = input.int(3, minval=1, title="보조 거래량 평균 길이", group=helperCompositeGroup)
helperVolumeMultiplier = input.float(1.0, minval=0.1, step=0.1, title="보조 거래량 배수", group=helperCompositeGroup)
helperTrendLength = input.int(5, minval=2, title="보조 추세 길이", group=helperCompositeGroup)
helperPriceStretchThreshold = input.float(1.5, minval=0.1, step=0.1, title="Price Stretch (%)", group=helperCompositeGroup)
helperUseGapFade = input.bool(true, title="Use Gap Fade Condition", group=helperCompositeGroup)
helperGapFadeLookback = input.int(1, minval=1, maxval=5, title="Gap Fade Lookback", group=helperCompositeGroup)
helperMinStrength = input.int(1, minval=1, maxval=3, title="보조 최소 강도", group=helperCompositeGroup)

// =========================
// L/S Signal Inputs
// =========================
lsSignalGroup = "L/S 진입 신호"
showStrongLSSignals = input.bool(true, title="롱/숏 기준 봉 표시", group=lsSignalGroup)
showLiquiditySweepSignals = input.bool(true, title="유동성 스윕 봉 색상 표시", group=lsSignalGroup)
lsSetupLookback = input.int(12, minval=1, title="세팅 유효 봉 수", group=lsSignalGroup)
lsMinScore = input.int(8, minval=1, maxval=15, title="최소 진입 점수", group=lsSignalGroup)
lsStrongScore = input.int(10, minval=1, maxval=15, title="점수 강화 기준", group=lsSignalGroup)
lsCooldownBars = input.int(8, minval=0, title="동일 방향 신호 쿨다운", group=lsSignalGroup)
lsRequireVolumeConfirm = input.bool(false, title="거래량 확인 필수", group=lsSignalGroup)
lsRequireOrderVolumeAvg = input.bool(true, title="총 거래량 MA 미만 신호 차단", group=lsSignalGroup)
lsOrderVolumeAvgLength = input.int(10, minval=1, title="총 거래량 MA 기준 봉 수", group=lsSignalGroup)
lsStrongBgBonusLookback = input.int(3, minval=1, maxval=20, title="강한 배경 근접 봉 수", group=lsSignalGroup)
lsStrongBgBonusScore = input.int(2, minval=0, maxval=5, title="강한 배경 가산점", group=lsSignalGroup)
lsUseStrongBgPullbackBonus = input.bool(true, title="ATR 강화 연속 눌림 가산점 사용", group=lsSignalGroup)
lsStrongBgPullbackMinStreak = input.int(2, minval=1, maxval=10, title="ATR 강화 연속 최소 봉 수", group=lsSignalGroup)
lsStrongBgPullbackLookback = input.int(3, minval=1, maxval=10, title="눌림 탐색 봉 수", group=lsSignalGroup)
lsStrongBgPullbackAtrRatio = input.float(0.6, minval=0.1, step=0.1, title="눌림 최소 ATR 비율", group=lsSignalGroup)
lsStrongBgPullbackBonusScore = input.int(2, minval=0, maxval=5, title="ATR 강화 연속 눌림 기본 가산점", group=lsSignalGroup)
lsStrongBgPullbackExtraStreakScore = input.int(1, minval=0, maxval=5, title="ATR 강화 추가 봉당 가산점", group=lsSignalGroup)
lsStrongBgPullbackRampEndStreak = input.int(4, minval=1, maxval=20, title="ATR 강화 가산 증가 종료 봉 수", group=lsSignalGroup)
lsStrongBgPullbackHoldEndStreak = input.int(6, minval=1, maxval=20, title="ATR 강화 가산 유지 종료 봉 수", group=lsSignalGroup)
lsStrongBgPullbackPenaltyScore = input.int(1, minval=0, maxval=5, title="ATR 강화 과열 감점", group=lsSignalGroup)
lsStrongBgPullbackMaxBonusScore = input.int(6, minval=0, maxval=15, title="ATR 강화 연속 눌림 최대 가산점", group=lsSignalGroup)
lsBgAbnormalVolumeLookback = input.int(3, minval=1, maxval=20, title="배경 근접 비정상 주문량 봉 수", group=lsSignalGroup)
lsBgAbnormalVolumeBonusScore = input.int(2, minval=0, maxval=5, title="배경 근접 비정상 주문량 가산점", group=lsSignalGroup)
lsFilterOrderVolumeLength = input.int(20, minval=1, title="L/S 비정상 주문량 비교 캔들 수", group=lsSignalGroup)
lsFilterOrderVolumeMultiplier = input.float(1.0, minval=0.0, title="L/S 비정상 주문량 배수", group=lsSignalGroup)
lsRequireAbnormalOrderVolume = input.bool(true, title="비정상 주문량 발생 필수", group=lsSignalGroup)
lsRequirePreviousBg = input.bool(true, title="이전 봉 배경 확인 필수", group=lsSignalGroup)
lsRequireOppositeBgReset = input.bool(true, title="반대 배경 전환 후 방향 전환", group=lsSignalGroup)
lsSweepConfirmVolumeRatio = input.float(0.5, minval=0.0, step=0.05, title="스윕 확인 최소 거래량 비율", group=lsSignalGroup)
lsUseTrendExtensionFilter = input.bool(true, title="강한 추세 연장 추가 진입 차단", group=lsSignalGroup)

visualGroup = "시각화"
strongLongSignalColorInput = input.color(color.rgb(0, 95, 0), title="롱 기준 봉 동그라미 색상", group=visualGroup)
strongShortSignalColorInput = input.color(color.rgb(150, 0, 0), title="숏 기준 봉 동그라미 색상", group=visualGroup)
bullSweepSignalColorInput = input.color(color.rgb(0, 255, 0), title="강세 스윕 다이아몬드/봉 색상", group=visualGroup)
bearSweepSignalColorInput = input.color(color.rgb(255, 0, 0), title="약세 스윕 다이아몬드/봉 색상", group=visualGroup)
divergenceBullMarkerColor = input.color(color.rgb(55, 145, 155), title="강세 다이버전스 삼각형 색상", group=visualGroup)
divergenceBearMarkerColor = input.color(color.rgb(170, 105, 45), title="약세 다이버전스 삼각형 색상", group=visualGroup)

referenceGroup = "기준봉"
showReferenceCandleZone = input.bool(true, title="기준봉 존 표시", group=referenceGroup)
keepHistoricalBoxes = input.bool(true, title="과거 박스 모두 유지", group=referenceGroup)
referenceExtendBars = input.int(30, minval=1, maxval=300, title="기준봉 우측 연장 봉 수", group=referenceGroup)
referenceMaxObjects = input.int(8, minval=1, maxval=500, title="최대 기준봉 표시 수", group=referenceGroup)
referenceBullZoneColor = input.color(color.new(color.rgb(0, 75, 0), 78), title="롱 기준봉 존 색상", group=referenceGroup)
referenceBearZoneColor = input.color(color.new(color.rgb(125, 0, 0), 78), title="숏 기준봉 존 색상", group=referenceGroup)
sweepBullZoneColor = input.color(color.new(color.rgb(0, 255, 0), 78), title="강세 스윕 존 색상", group=referenceGroup)
sweepBearZoneColor = input.color(color.new(color.rgb(255, 0, 0), 78), title="약세 스윕 존 색상", group=referenceGroup)
showDivergenceCandleZone = input.bool(true, title="다이버전스 기준봉 존 표시", group=referenceGroup)
divergenceExtendBars = input.int(30, minval=1, maxval=300, title="다이버전스 존 우측 연장 봉 수", group=referenceGroup)
divergenceMaxObjects = input.int(8, minval=1, maxval=500, title="최대 다이버전스 존 표시 수", group=referenceGroup)
divergenceBullZoneColor = input.color(color.new(color.rgb(55, 145, 155), 82), title="강세 다이버전스 존 색상", group=referenceGroup)
divergenceBearZoneColor = input.color(color.new(color.rgb(170, 105, 45), 82), title="약세 다이버전스 존 색상", group=referenceGroup)

reportGroup = "리포트"
showTradeReport = input.bool(true, title="리포트 표시", group=reportGroup)
reportPositionInput = input.string("우측 상단", title="리포트 표시 위치", options=["좌측 상단", "우측 상단", "좌측 하단", "우측 하단"], group=reportGroup)
reportTextSizeInput = input.string("작게", title="리포트 글자 크기", options=["아주 작게", "작게", "보통"], group=reportGroup)
reportHeaderColor = input.color(color.rgb(41, 54, 82), title="리포트 헤더 배경색", group=reportGroup)
reportLabelBgColor = input.color(color.rgb(34, 46, 68), title="리포트 항목 배경색", group=reportGroup)
reportFieldBgColor = input.color(color.rgb(18, 24, 38), title="리포트 일반 배경색", group=reportGroup)
reportBackgroundTransparency = input.int(78, minval=0, maxval=100, title="리포트 배경 투명도", group=reportGroup)
reportBullColor = input.color(color.rgb(120, 238, 178), title="리포트 롱 강조 색상", group=reportGroup)
reportBearColor = input.color(color.rgb(255, 150, 150), title="리포트 숏 강조 색상", group=reportGroup)
reportNeutralColor = input.color(color.rgb(223, 227, 235), title="리포트 중립 색상", group=reportGroup)
reportTimeZoneInput = input.string("Asia/Seoul", title="리포트 시간 표시 시간대", tooltip="차트 시간대는 Pine에서 직접 읽을 수 없습니다. 기본값은 KST(Asia/Seoul)입니다. 차트와 같은 현지시간으로 보려면 IANA 시간대(예: Asia/Seoul) 또는 UTC 표기(예: UTC+9)를 입력하세요.", group=reportGroup)
reportBoxContainmentModeInput = input.string("윅 포함", title="포지션 박스 유지 판정", options=["윅 포함", "몸통만", "종가만"], group=reportGroup)
reportBoxToleranceTicks = input.int(0, minval=0, title="포지션 박스 허용 틱 수", tooltip="박스 상단/하단에 허용할 최소 틱 여유입니다. 0이면 여유 없이 판정합니다.", group=reportGroup)

performanceGroup = "성능 / 반응 속도"
useFastCRSIBands = input.bool(true, title="빠른 cRSI 밴드 계산 사용", group=performanceGroup)
useLightweightRendering = input.bool(true, title="경량 렌더링 모드", group=performanceGroup)
lightweightMaxObjects = input.int(4, minval=1, maxval=50, title="경량 모드 최대 박스 수", group=performanceGroup)
lightweightMaxExtendBars = input.int(18, minval=5, maxval=100, title="경량 모드 최대 박스 길이", group=performanceGroup)

donchian(len) =>
    math.avg(ta.lowest(len), ta.highest(len))

alphaFromAPT(apt) =>
    decay = math.exp(-math.log(2.0) / math.max(1.0, apt))
    1.0 - decay

withinLookback(lastBarIndex, lookbackBars) =>
    not na(lastBarIndex) and bar_index - lastBarIndex <= lookbackBars

bullDivBoxTop(offset) =>
    open[offset]

bullDivBoxBottom(offset) =>
    low[offset]

bearDivBoxTop(offset) =>
    high[offset]

bearDivBoxBottom(offset) =>
    open[offset]

bullSignalBoxTop(offset) =>
    close[offset]

bullSignalBoxBottom(offset) =>
    low[offset]

bearSignalBoxTop(offset) =>
    high[offset]

bearSignalBoxBottom(offset) =>
    close[offset]

tablePosition(positionInput) =>
    switch positionInput
        "좌측 상단" => position.top_left
        "우측 상단" => position.top_right
        "좌측 하단" => position.bottom_left
        => position.bottom_right

tableTextSize(sizeInput) =>
    switch sizeInput
        "아주 작게" => size.tiny
        "보통" => size.normal
        => size.small

reportStateOff = 0
reportStateWatch = 1
reportStateReference = 2
reportStateCandidate = 3
reportStateSweep = 4

reportBoxTolerancePrice() =>
    reportBoxToleranceTicks * syminfo.mintick

boxExpired(boxRight) =>
    not na(boxRight) and bar_index > boxRight

boxContainsBar(boxTop, boxBottom, boxRight) =>
    tolerancePrice = reportBoxTolerancePrice()
    upperBound = boxTop + tolerancePrice
    lowerBound = boxBottom - tolerancePrice
    bodyTop = math.max(open, close)
    bodyBottom = math.min(open, close)
    not na(boxTop) and not na(boxBottom) and not na(boxRight) and bar_index <= boxRight and (reportBoxContainmentModeInput == "몸통만" ? bodyTop <= upperBound and bodyBottom >= lowerBound : reportBoxContainmentModeInput == "종가만" ? close <= upperBound and close >= lowerBound : high <= upperBound and low >= lowerBound)

reportWatchReason(startEvent, holdEvent, hintEvent, watchEvent, watchStrongEvent, fallbackReason) =>
    watchStrongEvent ? "ATR 강화" : watchEvent ? "ATR 배경" : hintEvent ? "다이버전스" : holdEvent ? "비정상 유지" : startEvent ? "비정상 시작" : fallbackReason

reportStateReason(state, triggerReason, fallbackReason) =>
    state == reportStateSweep ? (triggerReason == "" ? "스윕 박스" : triggerReason) : state == reportStateCandidate ? (triggerReason == "" ? "기준 박스" : triggerReason) : state == reportStateReference ? (triggerReason == "" ? "기준 봉" : triggerReason) : state == reportStateWatch ? (triggerReason == "" ? fallbackReason : triggerReason) : (triggerReason == "" ? "OFF" : triggerReason)

reportStatusText(signalCount) =>
    signalCount > 0 ? "ON(" + str.tostring(signalCount) + ")" : "OFF"

reportStatusColor(signalCount, activeColor, inactiveColor) =>
    signalCount > 0 ? activeColor : inactiveColor

strongBgPullbackBonus(streak) =>
    rampEndStreak = math.max(lsStrongBgPullbackMinStreak, lsStrongBgPullbackRampEndStreak)
    holdEndStreak = math.max(rampEndStreak, lsStrongBgPullbackHoldEndStreak)
    rampSteps = math.max(math.min(streak, rampEndStreak) - lsStrongBgPullbackMinStreak, 0)
    peakBonus = lsStrongBgPullbackBonusScore + rampSteps * lsStrongBgPullbackExtraStreakScore
    adjustedBonus = streak > holdEndStreak ? peakBonus - (streak - holdEndStreak) * lsStrongBgPullbackPenaltyScore : peakBonus
    math.max(math.min(adjustedBonus, lsStrongBgPullbackMaxBonusScore), 0)

reportPositionCode(trackingActive, referenceReady, candidateReady, sweepReady) =>
    if not trackingActive
        reportStateOff
    else if sweepReady
        reportStateSweep
    else if candidateReady
        reportStateCandidate
    else if referenceReady
        reportStateReference
    else
        reportStateWatch

reportPositionLabel(positionCode) =>
    positionCode == reportStateSweep ? "스윕" : positionCode == reportStateCandidate ? "후보" : positionCode == reportStateReference ? "기준" : positionCode == reportStateWatch ? "관찰" : "OFF"

reportPositionText(positionCode, score) =>
    positionLabel = reportPositionLabel(positionCode)
    if positionCode <= 0 or na(score)
        positionLabel
    else
        positionLabel + " (" + str.tostring(math.round(score)) + ")"

reportPositionDisplayScore(positionCode, score, lastCandidateScore, lastSweepScore) =>
    if positionCode == reportStateSweep and not na(lastSweepScore)
        na(score) ? lastSweepScore : math.max(score, lastSweepScore)
    else if (positionCode == reportStateReference or positionCode == reportStateCandidate) and not na(lastCandidateScore)
        na(score) ? lastCandidateScore : math.max(score, lastCandidateScore)
    else
        score

reportPositionColor(positionCode, activeColor, neutralColor) =>
    positionCode == reportStateSweep ? activeColor : positionCode == reportStateCandidate ? color.new(activeColor, 0) : positionCode == reportStateReference ? color.new(activeColor, 15) : positionCode == reportStateWatch ? color.new(activeColor, 35) : neutralColor

reportPositionScoreGuideText() =>
    weakEnd = math.max(lsMinScore - 4, 1)
    formingStart = weakEnd + 1
    formingEnd = math.max(lsMinScore - 1, formingStart)
    strongStart = math.max(lsStrongScore, lsMinScore)
    referenceStart = lsMinScore
    referenceEnd = math.max(strongStart - 1, referenceStart)
    referenceText = referenceStart == referenceEnd ? str.tostring(referenceStart) + "점 기준" : str.tostring(referenceStart) + "~" + str.tostring(referenceEnd) + "점 기준"
    "1~" + str.tostring(weakEnd) + "점 약 / " + str.tostring(formingStart) + "~" + str.tostring(formingEnd) + "점 형성 / " + referenceText + " / " + str.tostring(strongStart) + "점+ 강화"

effectiveKeepHistoricalBoxes = keepHistoricalBoxes and not useLightweightRendering
effectiveReferenceMaxObjects = useLightweightRendering ? math.min(referenceMaxObjects, lightweightMaxObjects) : referenceMaxObjects
effectiveDivergenceMaxObjects = useLightweightRendering ? math.min(divergenceMaxObjects, lightweightMaxObjects) : divergenceMaxObjects
effectiveReferenceExtendBars = useLightweightRendering ? math.min(referenceExtendBars, lightweightMaxExtendBars) : referenceExtendBars
effectiveDivergenceExtendBars = useLightweightRendering ? math.min(divergenceExtendBars, lightweightMaxExtendBars) : divergenceExtendBars

reportTimeText(signalTime) =>
    na(signalTime) ? "OFF" : str.format_time(signalTime, "yy-MM-dd HH:mm", reportTimeZoneInput == "" ? "Asia/Seoul" : reportTimeZoneInput)

reportEndTimeText(startTime, endTime, isTrackingActive) =>
    if na(startTime)
        "OFF"
    else if isTrackingActive
        "-"
    else
        na(endTime) ? "OFF" : reportTimeText(endTime)

var int bullReportStartCount = 0
var int bearReportStartCount = 0
var int bullReportHoldCount = 0
var int bearReportHoldCount = 0
var int bullReportHintCount = 0
var int bearReportHintCount = 0
var int bullReportWatchCount = 0
var int bearReportWatchCount = 0
var int bullReportWatchStrongCount = 0
var int bearReportWatchStrongCount = 0
var int bullReportCandidateCount = 0
var int bearReportCandidateCount = 0
var int bullReportConfirmCount = 0
var int bearReportConfirmCount = 0
var int bullConsumedPullbackBar = na
var int bearConsumedPullbackBar = na
var int bullReportFirstSignalTime = na
var int bearReportFirstSignalTime = na
var int bullReportEndTime = na
var int bearReportEndTime = na
var float bullReportDisplayScore = na
var float bearReportDisplayScore = na
var float bullReportLastCandidateScore = na
var float bearReportLastCandidateScore = na
var float bullReportLastSweepScore = na
var float bearReportLastSweepScore = na
var float bullReportCandidateBoxTop = na
var float bullReportCandidateBoxBottom = na
var int bullReportCandidateBoxRight = na
var float bearReportCandidateBoxTop = na
var float bearReportCandidateBoxBottom = na
var int bearReportCandidateBoxRight = na
var float bullReportSweepBoxTop = na
var float bullReportSweepBoxBottom = na
var int bullReportSweepBoxRight = na
var float bearReportSweepBoxTop = na
var float bearReportSweepBoxBottom = na
var int bearReportSweepBoxRight = na
var bool bullReportCandidateBoxWasInside = false
var bool bearReportCandidateBoxWasInside = false
var bool bullReportSweepBoxWasInside = false
var bool bearReportSweepBoxWasInside = false
var int bullReportState = reportStateOff
var int bearReportState = reportStateOff
var string bullReportStateReason = "OFF"
var string bearReportStateReason = "OFF"
var bool bullReportTrackingActive = false
var bool bearReportTrackingActive = false

var box[] referenceBoxes = array.new_box()
var box[] divergenceBoxes = array.new_box()
var float[] bullSweepZoneTops = array.new_float()
var float[] bullSweepZoneBottoms = array.new_float()
var int[] bullSweepZoneRights = array.new_int()
var float[] bearSweepZoneTops = array.new_float()
var float[] bearSweepZoneBottoms = array.new_float()
var int[] bearSweepZoneRights = array.new_int()

trimBullSweepZones() =>
    maxZones = effectiveKeepHistoricalBoxes ? 500 : effectiveReferenceMaxObjects + effectiveDivergenceMaxObjects
    while array.size(bullSweepZoneTops) > maxZones
        array.shift(bullSweepZoneTops)
        array.shift(bullSweepZoneBottoms)
        array.shift(bullSweepZoneRights)

trimBearSweepZones() =>
    maxZones = effectiveKeepHistoricalBoxes ? 500 : effectiveReferenceMaxObjects + effectiveDivergenceMaxObjects
    while array.size(bearSweepZoneTops) > maxZones
        array.shift(bearSweepZoneTops)
        array.shift(bearSweepZoneBottoms)
        array.shift(bearSweepZoneRights)

addBullSweepZone(top, bottom, right) =>
    array.push(bullSweepZoneTops, top)
    array.push(bullSweepZoneBottoms, bottom)
    array.push(bullSweepZoneRights, right)
    trimBullSweepZones()

addBearSweepZone(top, bottom, right) =>
    array.push(bearSweepZoneTops, top)
    array.push(bearSweepZoneBottoms, bottom)
    array.push(bearSweepZoneRights, right)
    trimBearSweepZones()

removeBullSweepZone(index) =>
    array.remove(bullSweepZoneTops, index)
    array.remove(bullSweepZoneBottoms, index)
    array.remove(bullSweepZoneRights, index)

removeBearSweepZone(index) =>
    array.remove(bearSweepZoneTops, index)
    array.remove(bearSweepZoneBottoms, index)
    array.remove(bearSweepZoneRights, index)

trimReferenceObjects() =>
    maxVisibleBoxes = effectiveKeepHistoricalBoxes ? math.max(1, 500 - array.size(divergenceBoxes)) : effectiveReferenceMaxObjects
    while array.size(referenceBoxes) > maxVisibleBoxes
        oldBox = array.shift(referenceBoxes)
        box.delete(oldBox)

trimDivergenceObjects() =>
    maxVisibleBoxes = effectiveKeepHistoricalBoxes ? math.max(1, 500 - array.size(referenceBoxes)) : effectiveDivergenceMaxObjects
    while array.size(divergenceBoxes) > maxVisibleBoxes
        oldBox = array.shift(divergenceBoxes)
        box.delete(oldBox)

// =========================
// cRSI Calculation
// =========================
cycleLen = math.max(1, int(domCycle / 2))
cyclicMemory = domCycle * 2
torque = 2.0 / (vibration + 1.0)
phasingLag = int((vibration - 1) / 2.0)

up = ta.rma(math.max(ta.change(close), 0), cycleLen)
down = ta.rma(-math.min(ta.change(close), 0), cycleLen)
rsi = down == 0 ? 100.0 : up == 0 ? 0.0 : 100.0 - 100.0 / (1.0 + up / down)

var float crsi = na
crsi := torque * (2.0 * rsi - nz(rsi[phasingLag])) + (1.0 - torque) * nz(crsi[1])

// =========================
// Dynamic Band Calculation
// =========================
float db = na
float ub = na
bandPercent = math.max(0.0, math.min(100.0, leveling))
inverseBandPercent = 100.0 - bandPercent

if useFastCRSIBands
    db := ta.percentile_nearest_rank(crsi, cyclicMemory, bandPercent)
    ub := ta.percentile_nearest_rank(crsi, cyclicMemory, inverseBandPercent)
else
    lmax = ta.highest(crsi, cyclicMemory)
    lmin = ta.lowest(crsi, cyclicMemory)
    mstep = (lmax - lmin) / 100.0
    aperc = leveling / 100.0

    if mstep == 0
        db := lmin
        ub := lmax
    else
        for steps = 0 to 100
            testValue = lmin + mstep * steps
            below = 0.0
            for m = 0 to cyclicMemory - 1
                below += crsi[m] < testValue ? 1 : 0
            ratio = below / cyclicMemory
            if ratio >= aperc
                db := testValue
                break

        for steps = 0 to 100
            testValue = lmax - mstep * steps
            above = 0.0
            for m = 0 to cyclicMemory - 1
                above += crsi[m] >= testValue ? 1 : 0
            ratio = above / cyclicMemory
            if ratio >= aperc
                ub := testValue
                break

// =========================
// Confirmed OB / OS
// =========================
isOverbought = crsi >= absoluteOB
isOversold = crsi <= absoluteOS

// =========================
// Abnormal Candle Calculation
// =========================
bbBasis = ta.sma(close, bbLength)
bbDev = ta.stdev(close, bbLength) * bbMultiplier
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev

candleBodyHigh = math.max(open, close)
candleBodyLow = math.min(open, close)
candleBodySpan = math.max(candleBodyHigh - candleBodyLow, syminfo.mintick)
candleRangeSpan = math.max(high - low, syminfo.mintick)

upperBodyOutside = math.max(candleBodyHigh - bbUpper, 0.0)
lowerBodyOutside = math.max(bbLower - candleBodyLow, 0.0)
upperBodyBreakRatio = upperBodyOutside / candleBodySpan
lowerBodyBreakRatio = lowerBodyOutside / candleBodySpan
upperVisualOutside = math.max(high - bbUpper, 0.0)
lowerVisualOutside = math.max(bbLower - low, 0.0)
upperVisualBreakRatio = upperVisualOutside / candleRangeSpan
lowerVisualBreakRatio = lowerVisualOutside / candleRangeSpan

isBearishBandExtended = upperBodyOutside > 0 and upperBodyBreakRatio >= bbBodyBreakRatio
isBullishBandExtended = lowerBodyOutside > 0 and lowerBodyBreakRatio >= bbBodyBreakRatio

// cRSI 과매수/과매도 상태 중에서 볼린저 밴드를 일정 비율 이상 몸통으로 초과한 캔들만 비정상 캔들로 승격합니다.
isBearishAbnormalCandleRaw = isOverbought and isBearishBandExtended
isBullishAbnormalCandleRaw = isOversold and isBullishBandExtended
isBearishAbnormalCandle = barstate.isconfirmed and isBearishAbnormalCandleRaw
isBullishAbnormalCandle = barstate.isconfirmed and isBullishAbnormalCandleRaw

// 시각 표시는 고가/저가가 밴드 밖으로 일정 비율 이상 나온 경우에만 색을 칠해, 밴드 안쪽 캔들은 기본 색으로 보이게 합니다.
isVisuallyBearishOutsideBand = upperVisualOutside > 0 and upperVisualBreakRatio >= bbVisualBreakRatio
isVisuallyBullishOutsideBand = lowerVisualOutside > 0 and lowerVisualBreakRatio >= bbVisualBreakRatio

barCol = isBearishAbnormalCandle and isVisuallyBearishOutsideBand ? overboughtColor : isBullishAbnormalCandle and isVisuallyBullishOutsideBand ? oversoldColor : na

// =========================
// Buy / Sell Volume
// =========================
rangeValue = high - low
buyVolume = rangeValue == 0 ? 0.0 : volume * (close - low) / rangeValue
sellVolume = rangeValue == 0 ? 0.0 : volume * (high - close) / rangeValue

avgBuyVolume = ta.sma(buyVolume, abnormalVolLookback)
avgSellVolume = ta.sma(sellVolume, abnormalVolLookback)

abnormalBuyVolume = buyVolume > avgBuyVolume * (1 + abnormalVolMultiplier)
abnormalSellVolume = sellVolume > avgSellVolume * (1 + abnormalVolMultiplier)

// =========================
// Smart Volume Conditions
// =========================
upperWick = high - math.max(open, close)
lowerWick = math.min(open, close) - low
bodySize = math.abs(close - open)

isBullPressureBar = close > open or lowerWick > bodySize
isBearPressureBar = close < open or upperWick > bodySize

crsiBullFilter = not useCRSIFilterForVolume or isOversold
crsiBearFilter = not useCRSIFilterForVolume or isOverbought

bullSmartVolumeSignal = enableSmartVolume and abnormalBuyVolume and isBullPressureBar and crsiBullFilter
bearSmartVolumeSignal = enableSmartVolume and abnormalSellVolume and isBearPressureBar and crsiBearFilter

// =========================
// RSI Divergence Calculation
// =========================
osc = ta.rsi(close, rsiDivLength)

plFound = not na(ta.pivotlow(osc, lbL, lbR))
phFound = not na(ta.pivothigh(osc, lbL, lbR))

_inRange(cond) =>
    bars = ta.barssince(cond == true)
    rangeLower <= bars and bars <= rangeUpper

inRangePl = _inRange(plFound[1])
inRangePh = _inRange(phFound[1])

oscHL = osc[lbR] > ta.valuewhen(plFound, osc[lbR], 1) and inRangePl
oscLH = osc[lbR] < ta.valuewhen(phFound, osc[lbR], 1) and inRangePh

priceLL = low[lbR] < ta.valuewhen(plFound, low[lbR], 1)
priceHH = high[lbR] > ta.valuewhen(phFound, high[lbR], 1)

bullDivRaw = showRSIDivergence and showRegularBullDiv and plFound and priceLL and oscHL
bearDivRaw = showRSIDivergence and showRegularBearDiv and phFound and priceHH and oscLH

regularBullDiv = barstate.isconfirmed and bullDivRaw
regularBearDiv = barstate.isconfirmed and bearDivRaw

// =========================
// Divergence Markers
// =========================
plotshape(regularBullDiv, offset=-lbR, title="일반 강세 다이버전스", style=shape.triangleup, location=location.belowbar, color=divergenceBullMarkerColor, size=size.tiny)
plotshape(regularBearDiv, offset=-lbR, title="일반 약세 다이버전스", style=shape.triangledown, location=location.abovebar, color=divergenceBearMarkerColor, size=size.tiny)

if barstate.isconfirmed and regularBullDiv and showDivergenceCandleZone
    bullDivReferenceIndex = bar_index - lbR
    bullDivReferenceTop = bullDivBoxTop(lbR)
    bullDivReferenceBottom = bullDivBoxBottom(lbR)
    bullDivReferenceRight = bullDivReferenceIndex + effectiveDivergenceExtendBars
    bullDivReferenceBox = box.new(bullDivReferenceIndex, bullDivReferenceTop, bullDivReferenceRight, bullDivReferenceBottom, xloc=xloc.bar_index, bgcolor=divergenceBullZoneColor, border_color=color.new(divergenceBullZoneColor, 0))
    array.push(divergenceBoxes, bullDivReferenceBox)
    trimDivergenceObjects()

if barstate.isconfirmed and regularBearDiv and showDivergenceCandleZone
    bearDivReferenceIndex = bar_index - lbR
    bearDivReferenceTop = bearDivBoxTop(lbR)
    bearDivReferenceBottom = bearDivBoxBottom(lbR)
    bearDivReferenceRight = bearDivReferenceIndex + effectiveDivergenceExtendBars
    bearDivReferenceBox = box.new(bearDivReferenceIndex, bearDivReferenceTop, bearDivReferenceRight, bearDivReferenceBottom, xloc=xloc.bar_index, bgcolor=divergenceBearZoneColor, border_color=color.new(divergenceBearZoneColor, 0))
    array.push(divergenceBoxes, bearDivReferenceBox)
    trimDivergenceObjects()

// =========================
// ATR
// =========================
atr = ta.atr(atrLength)
signalAtr = ta.atr(50)
signalAtrAvg = ta.rma(signalAtr, 50)
signalVolatilityRatio = signalAtrAvg > 0 ? signalAtr / signalAtrAvg : 1.0

// =========================
// Volume Pressure Tracker Composite Logic
// =========================
vpBar = bar_index
vpPriceVolume = hlc3 * volume

var float vpPh = na
var float vpPl = na
var int vpPhBar = 0
var int vpPlBar = 0
var float vpP = vpPriceVolume
var float vpVol = volume
var float vpVap = na

vpHighestBars = ta.highestbars(high, vpSwingPeriod)
vpLowestBars = ta.lowestbars(low, vpSwingPeriod)

vpPh := vpHighestBars == 0 ? high : vpPh
vpPl := vpLowestBars == 0 ? low : vpPl
vpPhBar := vpHighestBars == 0 ? vpBar : vpPhBar
vpPlBar := vpLowestBars == 0 ? vpBar : vpPlBar
vpDir = vpPhBar > vpPlBar ? 1 : -1

vpAptRaw = vpUseAdapt ? vpBaseAPT / math.pow(signalVolatilityRatio, vpVolBias) : vpBaseAPT
vpAptClamped = math.max(5.0, math.min(300.0, vpAptRaw))
vpAptSeries = math.round(vpAptClamped)

if vpDir != vpDir[1]
    vpAnchorBar = vpDir > 0 ? vpPlBar : vpPhBar
    vpAnchorPrice = vpDir > 0 ? vpPl : vpPh
    vpBarsback = vpBar - vpAnchorBar
    vpP := vpAnchorPrice * volume[vpBarsback]
    vpVol := volume[vpBarsback]
    vpVap := vpVol > 0 ? vpP / vpVol : na

    if vpUseAdapt
        for i = vpBarsback to 0 by 1
            alpha = alphaFromAPT(vpAptSeries[i])
            vpP := (1.0 - alpha) * vpP + alpha * vpPriceVolume[i]
            vpVol := (1.0 - alpha) * vpVol + alpha * volume[i]
            vappe = vpVol > 0 ? vpP / vpVol : na
            if i == 0
                vpVap := vappe
    else
        alpha = alphaFromAPT(vpAptSeries)
        alphaComplement = 1.0 - alpha
        for i = vpBarsback to 0 by 1
            vpP := alphaComplement * vpP + alpha * vpPriceVolume[i]
            vpVol := alphaComplement * vpVol + alpha * volume[i]
            vappe = vpVol > 0 ? vpP / vpVol : na
            if i == 0
                vpVap := vappe
else
    alpha = alphaFromAPT(vpAptSeries)
    alphaComplement = 1.0 - alpha
    vpP := alphaComplement * vpP + alpha * vpPriceVolume
    vpVol := alphaComplement * vpVol + alpha * volume
    vpVap := vpVol > 0 ? vpP / vpVol : na

vpBaseLine = donchian(vpBasePeriods)
vpMaValue = ta.sma(close, vpMaLength)
vpBullAlignment = not na(vpVap) and not na(vpBaseLine) and not na(vpMaValue) and vpMaValue > vpBaseLine and vpBaseLine > vpVap
vpBearAlignment = not na(vpVap) and not na(vpBaseLine) and not na(vpMaValue) and vpMaValue < vpBaseLine and vpBaseLine < vpVap
vpAvgVolume = ta.sma(volume, vpLength)
vpAbnormalVolume = volume > vpAvgVolume * (1 + vpMultiplier)
vpBullPressureSignal = vpBullAlignment and vpAbnormalVolume and buyVolume > sellVolume
vpBearPressureSignal = vpBearAlignment and vpAbnormalVolume and sellVolume > buyVolume

// =========================
// Helper Signal Composite Logic
// =========================
helperOverboughtLevel = 80.0
helperOversoldLevel = 20.0
helperMfi = ta.mfi(hlc3, helperMfiLength)

helperGap = math.abs(crsi - helperMfi)
helperBearishGapBg = crsi > helperMfi and helperGap >= helperGapThreshold
helperBullishGapBg = helperMfi > crsi and helperGap >= helperGapThreshold

helperVolAvg = ta.sma(volume, helperVolumeAvgLength)
helperVolumeOkay = volume > helperVolAvg * helperVolumeMultiplier
helperPriceEma = ta.ema(close, helperTrendLength)
helperPriceStretchPct = helperPriceEma != 0 ? (close - helperPriceEma) / helperPriceEma * 100.0 : 0.0
helperPriceExtendedUp = close > close[helperTrendLength] and helperPriceStretchPct >= helperPriceStretchThreshold
helperPriceExtendedDown = close < close[helperTrendLength] and helperPriceStretchPct <= -helperPriceStretchThreshold

helperBearishGap = crsi - helperMfi
helperBullishGap = helperMfi - crsi
helperBearishGapScore = helperBearishGap > helperStrongGapThreshold ? 2 : helperBearishGap > helperWeakGapThreshold ? 1 : 0
helperBullishGapScore = helperBullishGap > helperStrongGapThreshold ? 2 : helperBullishGap > helperWeakGapThreshold ? 1 : 0

helperBearishZonePass = crsi >= helperBearishZone or (not na(ub) and crsi >= ub)
helperBullishZonePass = crsi <= helperBullishZone or (not na(db) and crsi <= db)
helperBearishGapFade = helperBearishGap < helperBearishGap[helperGapFadeLookback]
helperBullishGapFade = helperBullishGap < helperBullishGap[helperGapFadeLookback]
helperCrsiTurningDown = crsi < crsi[1]
helperCrsiTurningUp = crsi > crsi[1]
helperMfiTurningDown = helperMfi < helperMfi[1]
helperMfiTurningUp = helperMfi > helperMfi[1]

helperBearishRiskScore = 0
helperBearishRiskScore += helperBearishGapBg ? 1 : 0
helperBearishRiskScore += helperBearishGapScore
helperBearishRiskScore += helperPriceExtendedUp ? 1 : 0
helperBearishRiskScore += helperVolumeOkay ? 1 : 0
helperBearishRiskScore += helperBearishZonePass ? 1 : 0
helperBearishRiskScore += ((helperUseGapFade and helperBearishGapFade) or (not helperUseGapFade and helperCrsiTurningDown)) ? 1 : 0
helperBearishRiskScore += (helperCrsiTurningDown or helperMfiTurningDown) ? 1 : 0

helperBullishRiskScore = 0
helperBullishRiskScore += helperBullishGapBg ? 1 : 0
helperBullishRiskScore += helperBullishGapScore
helperBullishRiskScore += helperPriceExtendedDown ? 1 : 0
helperBullishRiskScore += helperVolumeOkay ? 1 : 0
helperBullishRiskScore += helperBullishZonePass ? 1 : 0
helperBullishRiskScore += ((helperUseGapFade and helperBullishGapFade) or (not helperUseGapFade and helperCrsiTurningUp)) ? 1 : 0
helperBullishRiskScore += (helperCrsiTurningUp or helperMfiTurningUp) ? 1 : 0

helperBearishRiskStrength = helperBearishRiskScore >= 7 ? 3 : helperBearishRiskScore >= 5 ? 2 : helperBearishRiskScore >= 4 ? 1 : 0
helperBullishRiskStrength = helperBullishRiskScore >= 7 ? 3 : helperBullishRiskScore >= 5 ? 2 : helperBullishRiskScore >= 4 ? 1 : 0

helperBearishRiskRaw = helperBearishGapBg and helperBearishRiskStrength >= helperMinStrength and helperBullishRiskStrength == 0
helperBullishRiskRaw = helperBullishGapBg and helperBullishRiskStrength >= helperMinStrength and helperBearishRiskStrength == 0

helperBearishSignal = barstate.isconfirmed and helperBearishRiskRaw and helperMfi > helperOversoldLevel
helperBullishSignal = barstate.isconfirmed and helperBullishRiskRaw and helperMfi < helperOverboughtLevel

// =========================
// Background Trigger Signals
// =========================
bullDivTrigger = regularBullDiv
bearDivTrigger = regularBearDiv
bullCandleTrigger = isBullishAbnormalCandle
bearCandleTrigger = isBearishAbnormalCandle

var int bullDivTriggerBar = na
var int bearDivTriggerBar = na
var float bullDivRefClose = na
var float bullDivRefRsi = na
var float bullDivRefAtr = na
var float bearDivRefClose = na
var float bearDivRefRsi = na
var float bearDivRefAtr = na
var int bullCandleTriggerBar = na
var int bearCandleTriggerBar = na
var float bullCandleRefClose = na
var float bullCandleRefRsi = na
var float bullCandleRefAtr = na
var float bearCandleRefClose = na
var float bearCandleRefRsi = na
var float bearCandleRefAtr = na

if bullDivTrigger
    bullDivTriggerBar := bar_index
    bullDivRefClose := low[lbR]
    bullDivRefRsi := osc[lbR]
    bullDivRefAtr := atr[lbR]

if bearDivTrigger
    bearDivTriggerBar := bar_index
    bearDivRefClose := high[lbR]
    bearDivRefRsi := osc[lbR]
    bearDivRefAtr := atr[lbR]

if bullCandleTrigger
    bullCandleTriggerBar := bar_index
    bullCandleRefClose := candleBodyLow
    bullCandleRefRsi := osc
    bullCandleRefAtr := atr

if bearCandleTrigger
    bearCandleTriggerBar := bar_index
    bearCandleRefClose := candleBodyHigh
    bearCandleRefRsi := osc
    bearCandleRefAtr := atr

// =========================
// Divergence-based Background Logic
// =========================
bullDivBars = not na(bullDivTriggerBar) ? bar_index - bullDivTriggerBar : na
bearDivBars = not na(bearDivTriggerBar) ? bar_index - bearDivTriggerBar : na

hasBullDiv = bullDivBars >= 0 and bullDivBars <= setupLookbackBars
hasBearDiv = bearDivBars >= 0 and bearDivBars <= setupLookbackBars

bullDivPriceMove = hasBullDiv and not na(bullDivRefClose) ? bullDivRefClose - low : na
bullDivRsiMove = hasBullDiv and not na(bullDivRefRsi) ? bullDivRefRsi - osc : na
bullDivAtrNeed = hasBullDiv and not na(bullDivRefAtr) ? bullDivRefAtr * atrMultiplier : na

bearDivPriceMove = hasBearDiv and not na(bearDivRefClose) ? high - bearDivRefClose : na
bearDivRsiMove = hasBearDiv and not na(bearDivRefRsi) ? osc - bearDivRefRsi : na
bearDivAtrNeed = hasBearDiv and not na(bearDivRefAtr) ? bearDivRefAtr * atrMultiplier : na

bullBgFromDiv = hasBullDiv and bullDivBars > 0 and not na(bullDivPriceMove) and not na(bullDivRsiMove) and not na(bullDivAtrNeed) and bullDivPriceMove >= bullDivAtrNeed and bullDivRsiMove <= rsiMoveLimit
bearBgFromDiv = hasBearDiv and bearDivBars > 0 and not na(bearDivPriceMove) and not na(bearDivRsiMove) and not na(bearDivAtrNeed) and bearDivPriceMove >= bearDivAtrNeed and bearDivRsiMove <= rsiMoveLimit

// =========================
// Candle-based Background Logic
// =========================
bullCandleBars = not na(bullCandleTriggerBar) ? bar_index - bullCandleTriggerBar : na
bearCandleBars = not na(bearCandleTriggerBar) ? bar_index - bearCandleTriggerBar : na

hasBullCandle = bullCandleBars >= 0 and bullCandleBars <= candleSetupLookbackBars
hasBearCandle = bearCandleBars >= 0 and bearCandleBars <= candleSetupLookbackBars

bullCandlePriceMove = hasBullCandle and not na(bullCandleRefClose) ? bullCandleRefClose - low : na
bullCandleRsiMove = hasBullCandle and not na(bullCandleRefRsi) ? bullCandleRefRsi - osc : na
bullCandleAtrNeed = hasBullCandle and not na(bullCandleRefAtr) ? bullCandleRefAtr * candleAtrMultiplier : na

bearCandlePriceMove = hasBearCandle and not na(bearCandleRefClose) ? high - bearCandleRefClose : na
bearCandleRsiMove = hasBearCandle and not na(bearCandleRefRsi) ? osc - bearCandleRefRsi : na
bearCandleAtrNeed = hasBearCandle and not na(bearCandleRefAtr) ? bearCandleRefAtr * candleAtrMultiplier : na

bullBgFromCandle = hasBullCandle and bullCandleBars > 0 and not na(bullCandlePriceMove) and not na(bullCandleRsiMove) and not na(bullCandleAtrNeed) and bullCandlePriceMove >= bullCandleAtrNeed and bullCandleRsiMove <= rsiMoveLimit
bearBgFromCandle = hasBearCandle and bearCandleBars > 0 and not na(bearCandlePriceMove) and not na(bearCandleRsiMove) and not na(bearCandleAtrNeed) and bearCandlePriceMove >= bearCandleAtrNeed and bearCandleRsiMove <= rsiMoveLimit

// =========================
// Background Filters
// =========================
recentBullishAbnormalCandle = withinLookback(bullCandleTriggerBar, candleSetupLookbackBars)
recentBearishAbnormalCandle = withinLookback(bearCandleTriggerBar, candleSetupLookbackBars)
volumeSma20 = ta.sma(volume, 20)

bullBgCRSIFilter = not useCRSIFilterForBg or recentBullishAbnormalCandle or isOversold or (not na(db) and crsi <= db)
bearBgCRSIFilter = not useCRSIFilterForBg or recentBearishAbnormalCandle or isOverbought or (not na(ub) and crsi >= ub)

bullBgVolumeFilter = not useVolumeFilterForBg or abnormalBuyVolume or bullSmartVolumeSignal or volume > volumeSma20 * 1.05
bearBgVolumeFilter = not useVolumeFilterForBg or abnormalSellVolume or bearSmartVolumeSignal or volume > volumeSma20 * 1.05

bullBgFromDiv := bullBgFromDiv and bullBgCRSIFilter and bullBgVolumeFilter and useDivForBg and showBgZone
bearBgFromDiv := bearBgFromDiv and bearBgCRSIFilter and bearBgVolumeFilter and useDivForBg and showBgZone
bullBgFromCandle := bullBgFromCandle and bullBgCRSIFilter and bullBgVolumeFilter and useCandleForBg and showBgZone
bearBgFromCandle := bearBgFromCandle and bearBgCRSIFilter and bearBgVolumeFilter and useCandleForBg and showBgZone

// =========================
// Background Strength
// =========================
bullBgStrongByDiv = bullBgFromDiv and not na(bullDivPriceMove) and not na(bullDivRefAtr) and bullDivPriceMove >= bullDivRefAtr * strongBgAtrMultiplier
bullBgStrongByCandle = bullBgFromCandle and not na(bullCandlePriceMove) and not na(bullCandleRefAtr) and bullCandlePriceMove >= bullCandleRefAtr * candleStrongBgAtrMultiplier
bearBgStrongByDiv = bearBgFromDiv and not na(bearDivPriceMove) and not na(bearDivRefAtr) and bearDivPriceMove >= bearDivRefAtr * strongBgAtrMultiplier
bearBgStrongByCandle = bearBgFromCandle and not na(bearCandlePriceMove) and not na(bearCandleRefAtr) and bearCandlePriceMove >= bearCandleRefAtr * candleStrongBgAtrMultiplier

bullBgStrong = (bullBgFromDiv and bullBgFromCandle) or bullBgStrongByDiv or bullBgStrongByCandle
bearBgStrong = (bearBgFromDiv and bearBgFromCandle) or bearBgStrongByDiv or bearBgStrongByCandle

bullBgOn = bullBgFromDiv or bullBgFromCandle
bearBgOn = bearBgFromDiv or bearBgFromCandle

bullBgStrongSignal = barstate.isconfirmed and bullBgStrong
bearBgStrongSignal = barstate.isconfirmed and bearBgStrong
bullBgOnSignal = barstate.isconfirmed and bullBgOn
bearBgOnSignal = barstate.isconfirmed and bearBgOn
var int bullBgStrongStreak = 0
var int bearBgStrongStreak = 0
bullBgStrongStreak := bullBgStrongSignal ? nz(bullBgStrongStreak[1]) + 1 : 0
bearBgStrongStreak := bearBgStrongSignal ? nz(bearBgStrongStreak[1]) + 1 : 0

bullStrongBgPullbackDepth = ta.highest(high, lsStrongBgPullbackLookback) - low
bearStrongBgPullbackDepth = high - ta.lowest(low, lsStrongBgPullbackLookback)
bullStrongBgPullbackSignal = lsUseStrongBgPullbackBonus and bullBgStrongStreak >= lsStrongBgPullbackMinStreak and close < open and low < low[1] and bullStrongBgPullbackDepth >= atr * lsStrongBgPullbackAtrRatio
bearStrongBgPullbackSignal = lsUseStrongBgPullbackBonus and bearBgStrongStreak >= lsStrongBgPullbackMinStreak and close > open and high > high[1] and bearStrongBgPullbackDepth >= atr * lsStrongBgPullbackAtrRatio
bullStrongBgPullbackBonusRaw = bullStrongBgPullbackSignal ? strongBgPullbackBonus(bullBgStrongStreak) : 0
bearStrongBgPullbackBonusRaw = bearStrongBgPullbackSignal ? strongBgPullbackBonus(bearBgStrongStreak) : 0

bullBgColor = bullBgStrongSignal ? color.new(bullBgStrongColor, bgTransparency) : bullBgOnSignal ? color.new(bullBgBaseColor, bgTransparency) : na
bearBgColor = bearBgStrongSignal ? color.new(bearBgStrongColor, bgTransparency) : bearBgOnSignal ? color.new(bearBgBaseColor, bgTransparency) : na

finalBgColor = not na(bullBgColor) ? bullBgColor : not na(bearBgColor) ? bearBgColor : na
bgcolor(finalBgColor, title="강세/약세 배경 구간")

// =========================
// L/S Composite Signals
// =========================
var int helperBullishSignalBar = na
var int helperBearishSignalBar = na
var int bullBgOnSignalBar = na
var int bearBgOnSignalBar = na
var int bullBgStrongSignalBar = na
var int bearBgStrongSignalBar = na
var int bullLatestPullbackBar = na
var int bearLatestPullbackBar = na
var float bullLatestPullbackBonus = na
var float bearLatestPullbackBonus = na
var int bullAbnormalOrderVolumeBar = na
var int bearAbnormalOrderVolumeBar = na

if helperBullishSignal
    helperBullishSignalBar := bar_index

if helperBearishSignal
    helperBearishSignalBar := bar_index

if bullBgOnSignal
    bullBgOnSignalBar := bar_index

if bearBgOnSignal
    bearBgOnSignalBar := bar_index

if bullBgStrongSignal
    bullBgStrongSignalBar := bar_index

if bearBgStrongSignal
    bearBgStrongSignalBar := bar_index

recentBullDivSignal = withinLookback(bullDivTriggerBar, lsSetupLookback)
recentBearDivSignal = withinLookback(bearDivTriggerBar, lsSetupLookback)
recentHelperBullishSignal = withinLookback(helperBullishSignalBar, lsSetupLookback)
recentHelperBearishSignal = withinLookback(helperBearishSignalBar, lsSetupLookback)
recentBullStrongBgSignal = withinLookback(bullBgStrongSignalBar, lsStrongBgBonusLookback)
recentBearStrongBgSignal = withinLookback(bearBgStrongSignalBar, lsStrongBgBonusLookback)

if bullStrongBgPullbackSignal
    bullLatestPullbackBar := bar_index
    bullLatestPullbackBonus := bullStrongBgPullbackBonusRaw

if bearStrongBgPullbackSignal
    bearLatestPullbackBar := bar_index
    bearLatestPullbackBonus := bearStrongBgPullbackBonusRaw

bullLatestPullbackBarsAgo = not na(bullLatestPullbackBar) ? bar_index - bullLatestPullbackBar : na
bearLatestPullbackBarsAgo = not na(bearLatestPullbackBar) ? bar_index - bearLatestPullbackBar : na
bullPullbackBonusAvailable = not na(bullLatestPullbackBarsAgo) and bullLatestPullbackBarsAgo <= lsStrongBgPullbackLookback and (na(bullConsumedPullbackBar) or bullLatestPullbackBar > bullConsumedPullbackBar)
bearPullbackBonusAvailable = not na(bearLatestPullbackBarsAgo) and bearLatestPullbackBarsAgo <= lsStrongBgPullbackLookback and (na(bearConsumedPullbackBar) or bearLatestPullbackBar > bearConsumedPullbackBar)
recentBullStrongBgPullbackBonus = bullPullbackBonusAvailable ? int(nz(bullLatestPullbackBonus, 0)) : 0
recentBearStrongBgPullbackBonus = bearPullbackBonusAvailable ? int(nz(bearLatestPullbackBonus, 0)) : 0
totalVolumeAvg = ta.sma(volume, lsOrderVolumeAvgLength)
totalVolumeEnough = not lsRequireOrderVolumeAvg or (not na(totalVolumeAvg) and volume > totalVolumeAvg)
lsFilterAvgBuyVolume = ta.sma(buyVolume, lsFilterOrderVolumeLength)
lsFilterAvgSellVolume = ta.sma(sellVolume, lsFilterOrderVolumeLength)
lsFilterAbnormalBuyOrderVolume = buyVolume > lsFilterAvgBuyVolume * (1 + lsFilterOrderVolumeMultiplier)
lsFilterAbnormalSellOrderVolume = sellVolume > lsFilterAvgSellVolume * (1 + lsFilterOrderVolumeMultiplier)

if lsFilterAbnormalBuyOrderVolume and buyVolume > sellVolume
    bullAbnormalOrderVolumeBar := bar_index

if lsFilterAbnormalSellOrderVolume and sellVolume > buyVolume
    bearAbnormalOrderVolumeBar := bar_index

recentBullBgSignal = withinLookback(bullBgOnSignalBar, lsBgAbnormalVolumeLookback)
recentBearBgSignal = withinLookback(bearBgOnSignalBar, lsBgAbnormalVolumeLookback)
recentBullAbnormalOrderVolume = withinLookback(bullAbnormalOrderVolumeBar, lsBgAbnormalVolumeLookback)
recentBearAbnormalOrderVolume = withinLookback(bearAbnormalOrderVolumeBar, lsBgAbnormalVolumeLookback)
bullAbnormalOrderVolumeReady = recentBullAbnormalOrderVolume
bearAbnormalOrderVolumeReady = recentBearAbnormalOrderVolume
bullBgAbnormalVolumeBonusReady = recentBullBgSignal and recentBullAbnormalOrderVolume
bearBgAbnormalVolumeBonusReady = recentBearBgSignal and recentBearAbnormalOrderVolume

bullishVolumeConfirm = bullSmartVolumeSignal or vpBullPressureSignal or (lsFilterAbnormalBuyOrderVolume and buyVolume > sellVolume)
bearishVolumeConfirm = bearSmartVolumeSignal or vpBearPressureSignal or (lsFilterAbnormalSellOrderVolume and sellVolume > buyVolume)

bullSetupScore = 0
bullSetupScore += recentBullishAbnormalCandle ? 2 : 0
bullSetupScore += recentBullDivSignal ? 2 : 0
bullSetupScore += bullBgOnSignal ? 1 : 0
bullSetupScore += bullBgStrongSignal ? 1 : 0
bullSetupScore += recentBullStrongBgPullbackBonus
bullSetupScore += recentHelperBullishSignal ? 1 : 0
bullSetupScore += recentBullStrongBgSignal ? lsStrongBgBonusScore : 0
bullSetupScore += bullBgAbnormalVolumeBonusReady ? lsBgAbnormalVolumeBonusScore : 0

bearSetupScore = 0
bearSetupScore += recentBearishAbnormalCandle ? 2 : 0
bearSetupScore += recentBearDivSignal ? 2 : 0
bearSetupScore += bearBgOnSignal ? 1 : 0
bearSetupScore += bearBgStrongSignal ? 1 : 0
bearSetupScore += recentBearStrongBgPullbackBonus
bearSetupScore += recentHelperBearishSignal ? 1 : 0
bearSetupScore += recentBearStrongBgSignal ? lsStrongBgBonusScore : 0
bearSetupScore += bearBgAbnormalVolumeBonusReady ? lsBgAbnormalVolumeBonusScore : 0

bullConfirmScore = 0
bullConfirmScore += bullishVolumeConfirm ? 2 : 0
bullConfirmScore += close > open ? 1 : 0
bullConfirmScore += close > close[1] ? 1 : 0
bullConfirmScore += crsi > crsi[1] ? 1 : 0
bullConfirmScore += helperMfi > helperMfi[1] ? 1 : 0

bearConfirmScore = 0
bearConfirmScore += bearishVolumeConfirm ? 2 : 0
bearConfirmScore += close < open ? 1 : 0
bearConfirmScore += close < close[1] ? 1 : 0
bearConfirmScore += crsi < crsi[1] ? 1 : 0
bearConfirmScore += helperMfi < helperMfi[1] ? 1 : 0

bullUnifiedScore = bullSetupScore + bullConfirmScore
bearUnifiedScore = bearSetupScore + bearConfirmScore

bullSetupReady = bullSetupScore >= 3
bearSetupReady = bearSetupScore >= 3
bullConfirmReady = bullConfirmScore >= 4 and (not lsRequireVolumeConfirm or bullishVolumeConfirm)
bearConfirmReady = bearConfirmScore >= 4 and (not lsRequireVolumeConfirm or bearishVolumeConfirm)
bullTrendExtensionBlocked = lsUseTrendExtensionFilter and helperPriceExtendedUp and bullReportTrackingActive and bullReportCandidateCount > 0
bearTrendExtensionBlocked = lsUseTrendExtensionFilter and helperPriceExtendedDown and bearReportTrackingActive and bearReportCandidateCount > 0

// Block L/S candidates unless abnormal order flow has appeared near the setup window.
bullEntryCandidate = bullSetupReady and bullConfirmReady and totalVolumeEnough and (not lsRequireAbnormalOrderVolume or bullAbnormalOrderVolumeReady) and bullUnifiedScore >= lsMinScore and bullUnifiedScore > bearUnifiedScore and not bearBgStrongSignal and not bullTrendExtensionBlocked
bearEntryCandidate = bearSetupReady and bearConfirmReady and totalVolumeEnough and (not lsRequireAbnormalOrderVolume or bearAbnormalOrderVolumeReady) and bearUnifiedScore >= lsMinScore and bearUnifiedScore > bullUnifiedScore and not bullBgStrongSignal and not bearTrendExtensionBlocked

var int lastLongSignalBar = na
var int lastShortSignalBar = na
var bool bearBgSeenSinceLong = true
var bool bullBgSeenSinceShort = true

if bullBgOnSignal
    bullBgSeenSinceShort := true

if bearBgOnSignal
    bearBgSeenSinceLong := true

canLongSignal = na(lastLongSignalBar) or bar_index - lastLongSignalBar > lsCooldownBars
canShortSignal = na(lastShortSignalBar) or bar_index - lastShortSignalBar > lsCooldownBars
prevBullBgReady = not lsRequirePreviousBg or bullBgOnSignal[1]
prevBearBgReady = not lsRequirePreviousBg or bearBgOnSignal[1]
longDirectionResetReady = not lsRequireOppositeBgReset or na(lastShortSignalBar) or bullBgSeenSinceShort
shortDirectionResetReady = not lsRequireOppositeBgReset or na(lastLongSignalBar) or bearBgSeenSinceLong

signalBarReady = barstate.isconfirmed
bullSignalReady = canLongSignal and prevBullBgReady and longDirectionResetReady and bullEntryCandidate
bearSignalReady = canShortSignal and prevBearBgReady and shortDirectionResetReady and bearEntryCandidate
bullSignalReadyState = bullSignalReady ? 1 : 0
bearSignalReadyState = bearSignalReady ? 1 : 0
longSignal = signalBarReady and bullSignalReady and (nz(bullSignalReadyState[1], 0) == 0)
shortSignal = signalBarReady and bearSignalReady and (nz(bearSignalReadyState[1], 0) == 0)

if longSignal
    lastLongSignalBar := bar_index
    bearBgSeenSinceLong := false
    if bullPullbackBonusAvailable
        bullConsumedPullbackBar := bullLatestPullbackBar

if shortSignal
    lastShortSignalBar := bar_index
    bullBgSeenSinceShort := false
    if bearPullbackBonusAvailable
        bearConsumedPullbackBar := bearLatestPullbackBar

displayLongSignal = longSignal
displayShortSignal = shortSignal

strongLongSignalColor = strongLongSignalColorInput
strongShortSignalColor = strongShortSignalColorInput
bullSweepSignalColor = bullSweepSignalColorInput
bearSweepSignalColor = bearSweepSignalColorInput

plotshape(showStrongLSSignals and displayLongSignal, title="3단계 롱 기준 봉 (첫 기준 신호) - 종합 기준 통과", style=shape.circle, location=location.belowbar, color=strongLongSignalColor, size=size.tiny)
plotshape(showStrongLSSignals and displayShortSignal, title="3단계 숏 기준 봉 (첫 기준 신호) - 종합 기준 통과", style=shape.circle, location=location.abovebar, color=strongShortSignalColor, size=size.tiny)

confirmedLongSignal = barstate.isconfirmed and displayLongSignal
confirmedShortSignal = barstate.isconfirmed and displayShortSignal

if confirmedLongSignal and showReferenceCandleZone
    longReferenceTop = bullSignalBoxTop(0)
    longReferenceBottom = bullSignalBoxBottom(0)
    longReferenceRight = bar_index + effectiveReferenceExtendBars
    longReferenceBox = box.new(bar_index, longReferenceTop, longReferenceRight, longReferenceBottom, xloc=xloc.bar_index, bgcolor=referenceBullZoneColor, border_color=strongLongSignalColor)
    array.push(referenceBoxes, longReferenceBox)
    addBullSweepZone(longReferenceTop, longReferenceBottom, longReferenceRight)
    trimReferenceObjects()

if confirmedShortSignal and showReferenceCandleZone
    shortReferenceTop = bearSignalBoxTop(0)
    shortReferenceBottom = bearSignalBoxBottom(0)
    shortReferenceRight = bar_index + effectiveReferenceExtendBars
    shortReferenceBox = box.new(bar_index, shortReferenceTop, shortReferenceRight, shortReferenceBottom, xloc=xloc.bar_index, bgcolor=referenceBearZoneColor, border_color=strongShortSignalColor)
    array.push(referenceBoxes, shortReferenceBox)
    addBearSweepZone(shortReferenceTop, shortReferenceBottom, shortReferenceRight)
    trimReferenceObjects()

bullLiquiditySweep = false
bearLiquiditySweep = false
bullSweepReady = barstate.isconfirmed and close < open and vpAbnormalVolume and sellVolume > buyVolume
bearSweepReady = barstate.isconfirmed and close > open and vpAbnormalVolume and buyVolume > sellVolume

if barstate.isconfirmed and array.size(bullSweepZoneTops) > 0
    i = array.size(bullSweepZoneTops) - 1
    while i >= 0
        bullSweepRight = array.get(bullSweepZoneRights, i)
        bullSweepBottom = array.get(bullSweepZoneBottoms, i)
        if bar_index > bullSweepRight
            removeBullSweepZone(i)
        else if bullSweepReady and low < bullSweepBottom
            bullLiquiditySweep := true
            removeBullSweepZone(i)
        i -= 1

if barstate.isconfirmed and array.size(bearSweepZoneTops) > 0
    i = array.size(bearSweepZoneTops) - 1
    while i >= 0
        bearSweepRight = array.get(bearSweepZoneRights, i)
        bearSweepTop = array.get(bearSweepZoneTops, i)
        if bar_index > bearSweepRight
            removeBearSweepZone(i)
        else if bearSweepReady and high > bearSweepTop
            bearLiquiditySweep := true
            removeBearSweepZone(i)
        i -= 1

finalBarColor = showLiquiditySweepSignals and bullLiquiditySweep ? bullSweepSignalColor : showLiquiditySweepSignals and bearLiquiditySweep ? bearSweepSignalColor : paintBars ? barCol : na
barcolor(finalBarColor)

bullSweepFollowThroughVolumeReady = volume >= nz(volume[1]) * lsSweepConfirmVolumeRatio
bearSweepFollowThroughVolumeReady = volume >= nz(volume[1]) * lsSweepConfirmVolumeRatio
confirmedBullSweepFollowThrough = barstate.isconfirmed and bullLiquiditySweep[1] and close > open and buyVolume > sellVolume and bullSweepFollowThroughVolumeReady
confirmedBearSweepFollowThrough = barstate.isconfirmed and bearLiquiditySweep[1] and close < open and sellVolume > buyVolume and bearSweepFollowThroughVolumeReady

plotshape(showLiquiditySweepSignals and confirmedBullSweepFollowThrough, title="4단계 롱 확인 (하단 유동성 스윕) - 확인 봉", style=shape.diamond, location=location.belowbar, color=bullSweepSignalColor, size=size.tiny)
plotshape(showLiquiditySweepSignals and confirmedBearSweepFollowThrough, title="4단계 숏 확인 (상단 유동성 스윕) - 확인 봉", style=shape.diamond, location=location.abovebar, color=bearSweepSignalColor, size=size.tiny)

if showLiquiditySweepSignals and confirmedBullSweepFollowThrough and showReferenceCandleZone
    bullSweepReferenceIndex = bar_index
    bullSweepReferenceTop = bullSignalBoxTop(0)
    bullSweepReferenceBottom = bullSignalBoxBottom(0)
    bullSweepReferenceRight = bullSweepReferenceIndex + effectiveReferenceExtendBars
    bullSweepReferenceBox = box.new(bullSweepReferenceIndex, bullSweepReferenceTop, bullSweepReferenceRight, bullSweepReferenceBottom, xloc=xloc.bar_index, bgcolor=sweepBullZoneColor, border_color=bullSweepSignalColor)
    array.push(referenceBoxes, bullSweepReferenceBox)
    trimReferenceObjects()

if showLiquiditySweepSignals and confirmedBearSweepFollowThrough and showReferenceCandleZone
    bearSweepReferenceIndex = bar_index
    bearSweepReferenceTop = bearSignalBoxTop(0)
    bearSweepReferenceBottom = bearSignalBoxBottom(0)
    bearSweepReferenceRight = bearSweepReferenceIndex + effectiveReferenceExtendBars
    bearSweepReferenceBox = box.new(bearSweepReferenceIndex, bearSweepReferenceTop, bearSweepReferenceRight, bearSweepReferenceBottom, xloc=xloc.bar_index, bgcolor=sweepBearZoneColor, border_color=bearSweepSignalColor)
    array.push(referenceBoxes, bearSweepReferenceBox)
    trimReferenceObjects()

// =========================
// Entry Alerts
// =========================
overboughtEnter = isBearishAbnormalCandle and not (isBearishAbnormalCandle[1] == true)
oversoldEnter = isBullishAbnormalCandle and not (isBullishAbnormalCandle[1] == true)

repeatOverboughtAlert = enableRepeatingOBOSAlert and isBearishAbnormalCandle
repeatOversoldAlert = enableRepeatingOBOSAlert and isBullishAbnormalCandle

bullBgAlert = bullBgOnSignal
bearBgAlert = bearBgOnSignal

bullBgStrongAlert = bullBgStrongSignal
bearBgStrongAlert = bearBgStrongSignal

alertcondition(oversoldEnter, title="0단계 롱 자리 (과매도 시작) - 하단 이탈", message="0단계 롱 자리 (과매도 시작) - 하단 이탈")
alertcondition(overboughtEnter, title="0단계 숏 자리 (과매수 시작) - 상단 이탈", message="0단계 숏 자리 (과매수 시작) - 상단 이탈")

alertcondition(repeatOversoldAlert, title="0단계 롱 자리 유지 (과매도 계속) - 하단 유지", message="0단계 롱 자리 유지 (과매도 계속) - 하단 유지")
alertcondition(repeatOverboughtAlert, title="0단계 숏 자리 유지 (과매수 계속) - 상단 유지", message="0단계 숏 자리 유지 (과매수 계속) - 상단 유지")

alertcondition(regularBullDiv, title="1단계 롱 힌트 (하락 힘 약해짐) - 강세 다이버전스", message="1단계 롱 힌트 (하락 힘 약해짐) - 강세 다이버전스")
alertcondition(regularBearDiv, title="1단계 숏 힌트 (상승 힘 약해짐) - 약세 다이버전스", message="1단계 숏 힌트 (상승 힘 약해짐) - 약세 다이버전스")

alertcondition(bullBgAlert, title="2단계 롱 감시 (매수 배경 진입) - ATR 배경", message="2단계 롱 감시 (매수 배경 진입) - ATR 배경")
alertcondition(bearBgAlert, title="2단계 숏 감시 (매도 배경 진입) - ATR 배경", message="2단계 숏 감시 (매도 배경 진입) - ATR 배경")

alertcondition(bullBgStrongAlert, title="2단계 롱 감시 강화 (매수 배경 강화) - ATR 확장", message="2단계 롱 감시 강화 (매수 배경 강화) - ATR 확장")
alertcondition(bearBgStrongAlert, title="2단계 숏 감시 강화 (매도 배경 강화) - ATR 확장", message="2단계 숏 감시 강화 (매도 배경 강화) - ATR 확장")
alertcondition(longSignal, title="3단계 롱 기준 봉 (첫 기준 신호) - 종합 기준 통과", message="3단계 롱 기준 봉 (첫 기준 신호) - 종합 기준 통과")
alertcondition(shortSignal, title="3단계 숏 기준 봉 (첫 기준 신호) - 종합 기준 통과", message="3단계 숏 기준 봉 (첫 기준 신호) - 종합 기준 통과")
alertcondition(confirmedBullSweepFollowThrough, title="4단계 롱 확인 (하단 유동성 스윕) - 확인 봉", message="4단계 롱 확인 (하단 유동성 스윕) - 확인 봉")
alertcondition(confirmedBearSweepFollowThrough, title="4단계 숏 확인 (상단 유동성 스윕) - 확인 봉", message="4단계 숏 확인 (상단 유동성 스윕) - 확인 봉")

// =========================
// Report Table
// =========================
bullReportStartEvent = barstate.isconfirmed and oversoldEnter
bearReportStartEvent = barstate.isconfirmed and overboughtEnter
bullReportHoldEvent = barstate.isconfirmed and isBullishAbnormalCandle
bearReportHoldEvent = barstate.isconfirmed and isBearishAbnormalCandle
bullReportHintEvent = barstate.isconfirmed and regularBullDiv
bearReportHintEvent = barstate.isconfirmed and regularBearDiv
bullReportWatchEvent = barstate.isconfirmed and bullBgOn
bearReportWatchEvent = barstate.isconfirmed and bearBgOn
bullReportWatchStrongEvent = barstate.isconfirmed and bullBgStrong
bearReportWatchStrongEvent = barstate.isconfirmed and bearBgStrong
bullReportCandidateEvent = barstate.isconfirmed and longSignal
bearReportCandidateEvent = barstate.isconfirmed and shortSignal
bullReportConfirmEvent = barstate.isconfirmed and confirmedBullSweepFollowThrough
bearReportConfirmEvent = barstate.isconfirmed and confirmedBearSweepFollowThrough

bullReportAnyEvent = bullReportStartEvent or bullReportHoldEvent or bullReportHintEvent or bullReportWatchEvent or bullReportWatchStrongEvent or bullReportCandidateEvent or bullReportConfirmEvent
bearReportAnyEvent = bearReportStartEvent or bearReportHoldEvent or bearReportHintEvent or bearReportWatchEvent or bearReportWatchStrongEvent or bearReportCandidateEvent or bearReportConfirmEvent
bullReportEndEvent = barstate.isconfirmed and bearReportWatchStrongEvent
bearReportEndEvent = barstate.isconfirmed and bullReportWatchStrongEvent

if barstate.isconfirmed
    if bullReportEndEvent and bullReportTrackingActive
        bullReportEndTime := time_close
        bullReportLastCandidateScore := na
        bullReportLastSweepScore := na
        bullReportCandidateBoxTop := na
        bullReportCandidateBoxBottom := na
        bullReportCandidateBoxRight := na
        bullReportSweepBoxTop := na
        bullReportSweepBoxBottom := na
        bullReportSweepBoxRight := na
        bullReportCandidateBoxWasInside := false
        bullReportSweepBoxWasInside := false
        bullReportState := reportStateOff
        bullReportStateReason := "반대 ATR 강화"
        bullReportTrackingActive := false
    else
        if bullReportAnyEvent and not bullReportTrackingActive
            bullReportStartCount := 0
            bullReportHoldCount := 0
            bullReportHintCount := 0
            bullReportWatchCount := 0
            bullReportWatchStrongCount := 0
            bullReportCandidateCount := 0
            bullReportConfirmCount := 0
            bullReportFirstSignalTime := na
            bullReportEndTime := na
            bullReportFirstSignalTime := time_close
            bullReportDisplayScore := bullUnifiedScore
            bullReportLastCandidateScore := na
            bullReportLastSweepScore := na
            bullReportCandidateBoxTop := na
            bullReportCandidateBoxBottom := na
            bullReportCandidateBoxRight := na
            bullReportSweepBoxTop := na
            bullReportSweepBoxBottom := na
            bullReportSweepBoxRight := na
            bullReportCandidateBoxWasInside := false
            bullReportSweepBoxWasInside := false
            bullReportState := reportStateWatch
            bullReportStateReason := "관찰"
            bullReportTrackingActive := true

        if bullReportTrackingActive
            bullCandidateExpiredReason = ""
            bullCandidateWaitReason = ""
            bullSweepExpiredReason = ""
            bullSweepWaitReason = ""
            bullCandidateReentryEvent = false
            bullSweepReentryEvent = false
            bullCandidateBoxInside = false
            bullSweepBoxInside = false
            bullCandidateBoxExpired = false
            bullSweepBoxExpired = false
            bullFallbackReason = reportWatchReason(bullReportStartEvent, bullReportHoldEvent, bullReportHintEvent, bullReportWatchEvent, bullReportWatchStrongEvent, bullReportState == reportStateWatch ? bullReportStateReason : "관찰")
            bullReportStartCount += bullReportStartEvent ? 1 : 0
            bullReportHoldCount += bullReportHoldEvent ? 1 : 0
            bullReportHintCount += bullReportHintEvent ? 1 : 0
            bullReportWatchCount += bullReportWatchEvent ? 1 : 0
            bullReportWatchStrongCount += bullReportWatchStrongEvent ? 1 : 0
            bullReportCandidateCount += bullReportCandidateEvent ? 1 : 0
            bullReportConfirmCount += bullReportConfirmEvent ? 1 : 0
            bullReportDisplayScore := bullUnifiedScore
            if bullReportCandidateEvent
                bullReportLastCandidateScore := bullUnifiedScore
                bullReportCandidateBoxTop := bullSignalBoxTop(0)
                bullReportCandidateBoxBottom := bullSignalBoxBottom(0)
                bullReportCandidateBoxRight := bar_index + effectiveReferenceExtendBars
                bullReportCandidateBoxWasInside := true
            else if not na(bullReportCandidateBoxRight)
                bullCandidateBoxExpired := boxExpired(bullReportCandidateBoxRight)
                bullCandidateBoxInside := not bullCandidateBoxExpired and boxContainsBar(bullReportCandidateBoxTop, bullReportCandidateBoxBottom, bullReportCandidateBoxRight)
                if bullCandidateBoxExpired
                    bullCandidateExpiredReason := "기준 박스 만료"
                    bullReportCandidateBoxTop := na
                    bullReportCandidateBoxBottom := na
                    bullReportCandidateBoxRight := na
                    bullReportCandidateBoxWasInside := false
                else
                    bullCandidateReentryEvent := bullCandidateBoxInside and not bullReportCandidateBoxWasInside
                    bullCandidateWaitReason := bullCandidateBoxInside ? "" : "기준 박스 이탈"
                    bullReportCandidateBoxWasInside := bullCandidateBoxInside
            else
                bullReportCandidateBoxWasInside := false

            if bullReportConfirmEvent
                bullReportLastSweepScore := bullUnifiedScore
                bullReportSweepBoxTop := bullSignalBoxTop(0)
                bullReportSweepBoxBottom := bullSignalBoxBottom(0)
                bullReportSweepBoxRight := bar_index + effectiveReferenceExtendBars
                bullReportCandidateBoxTop := na
                bullReportCandidateBoxBottom := na
                bullReportCandidateBoxRight := na
                bullReportCandidateBoxWasInside := false
                bullReportSweepBoxWasInside := true
            else if not na(bullReportSweepBoxRight)
                bullSweepBoxExpired := boxExpired(bullReportSweepBoxRight)
                bullSweepBoxInside := not bullSweepBoxExpired and boxContainsBar(bullReportSweepBoxTop, bullReportSweepBoxBottom, bullReportSweepBoxRight)
                if bullSweepBoxExpired
                    bullSweepExpiredReason := "스윕 박스 만료"
                    bullReportSweepBoxTop := na
                    bullReportSweepBoxBottom := na
                    bullReportSweepBoxRight := na
                    bullReportSweepBoxWasInside := false
                else
                    bullSweepReentryEvent := bullSweepBoxInside and not bullReportSweepBoxWasInside
                    bullSweepWaitReason := bullSweepBoxInside ? "" : "스윕 박스 이탈"
                    bullReportSweepBoxWasInside := bullSweepBoxInside
            else
                bullReportSweepBoxWasInside := false

            bullReportReferenceReady = bullReportCandidateEvent
            bullReportCandidateReady = not bullReportCandidateEvent and bullCandidateBoxInside
            bullReportSweepBoxReady = not bullReportConfirmEvent and bullSweepBoxInside
            bullReportSweepReady = bullReportConfirmEvent or bullReportSweepBoxReady
            bullReportState := reportPositionCode(bullReportTrackingActive, bullReportReferenceReady, bullReportCandidateReady, bullReportSweepReady)
            bullTriggerReason = bullReportConfirmEvent ? "스윕 확인" : bullSweepReentryEvent ? "스윕 박스 재진입" : bullReportSweepBoxReady ? "스윕 박스" : bullSweepWaitReason != "" ? bullSweepWaitReason : bullSweepExpiredReason != "" ? bullSweepExpiredReason : bullReportCandidateEvent ? "기준 봉" : bullCandidateReentryEvent ? "기준 박스 재진입" : bullReportCandidateReady ? "기준 박스" : bullCandidateWaitReason != "" ? bullCandidateWaitReason : bullCandidateExpiredReason != "" ? bullCandidateExpiredReason : bullFallbackReason
            bullReportStateReason := reportStateReason(bullReportState, bullTriggerReason, bullFallbackReason)

    if bearReportEndEvent and bearReportTrackingActive
        bearReportEndTime := time_close
        bearReportLastCandidateScore := na
        bearReportLastSweepScore := na
        bearReportCandidateBoxTop := na
        bearReportCandidateBoxBottom := na
        bearReportCandidateBoxRight := na
        bearReportSweepBoxTop := na
        bearReportSweepBoxBottom := na
        bearReportSweepBoxRight := na
        bearReportCandidateBoxWasInside := false
        bearReportSweepBoxWasInside := false
        bearReportState := reportStateOff
        bearReportStateReason := "반대 ATR 강화"
        bearReportTrackingActive := false
    else
        if bearReportAnyEvent and not bearReportTrackingActive
            bearReportStartCount := 0
            bearReportHoldCount := 0
            bearReportHintCount := 0
            bearReportWatchCount := 0
            bearReportWatchStrongCount := 0
            bearReportCandidateCount := 0
            bearReportConfirmCount := 0
            bearReportFirstSignalTime := na
            bearReportEndTime := na
            bearReportFirstSignalTime := time_close
            bearReportDisplayScore := bearUnifiedScore
            bearReportLastCandidateScore := na
            bearReportLastSweepScore := na
            bearReportCandidateBoxTop := na
            bearReportCandidateBoxBottom := na
            bearReportCandidateBoxRight := na
            bearReportSweepBoxTop := na
            bearReportSweepBoxBottom := na
            bearReportSweepBoxRight := na
            bearReportCandidateBoxWasInside := false
            bearReportSweepBoxWasInside := false
            bearReportState := reportStateWatch
            bearReportStateReason := "관찰"
            bearReportTrackingActive := true

        if bearReportTrackingActive
            bearCandidateExpiredReason = ""
            bearCandidateWaitReason = ""
            bearSweepExpiredReason = ""
            bearSweepWaitReason = ""
            bearCandidateReentryEvent = false
            bearSweepReentryEvent = false
            bearCandidateBoxInside = false
            bearSweepBoxInside = false
            bearCandidateBoxExpired = false
            bearSweepBoxExpired = false
            bearFallbackReason = reportWatchReason(bearReportStartEvent, bearReportHoldEvent, bearReportHintEvent, bearReportWatchEvent, bearReportWatchStrongEvent, bearReportState == reportStateWatch ? bearReportStateReason : "관찰")
            bearReportStartCount += bearReportStartEvent ? 1 : 0
            bearReportHoldCount += bearReportHoldEvent ? 1 : 0
            bearReportHintCount += bearReportHintEvent ? 1 : 0
            bearReportWatchCount += bearReportWatchEvent ? 1 : 0
            bearReportWatchStrongCount += bearReportWatchStrongEvent ? 1 : 0
            bearReportCandidateCount += bearReportCandidateEvent ? 1 : 0
            bearReportConfirmCount += bearReportConfirmEvent ? 1 : 0
            bearReportDisplayScore := bearUnifiedScore
            if bearReportCandidateEvent
                bearReportLastCandidateScore := bearUnifiedScore
                bearReportCandidateBoxTop := bearSignalBoxTop(0)
                bearReportCandidateBoxBottom := bearSignalBoxBottom(0)
                bearReportCandidateBoxRight := bar_index + effectiveReferenceExtendBars
                bearReportCandidateBoxWasInside := true
            else if not na(bearReportCandidateBoxRight)
                bearCandidateBoxExpired := boxExpired(bearReportCandidateBoxRight)
                bearCandidateBoxInside := not bearCandidateBoxExpired and boxContainsBar(bearReportCandidateBoxTop, bearReportCandidateBoxBottom, bearReportCandidateBoxRight)
                if bearCandidateBoxExpired
                    bearCandidateExpiredReason := "기준 박스 만료"
                    bearReportCandidateBoxTop := na
                    bearReportCandidateBoxBottom := na
                    bearReportCandidateBoxRight := na
                    bearReportCandidateBoxWasInside := false
                else
                    bearCandidateReentryEvent := bearCandidateBoxInside and not bearReportCandidateBoxWasInside
                    bearCandidateWaitReason := bearCandidateBoxInside ? "" : "기준 박스 이탈"
                    bearReportCandidateBoxWasInside := bearCandidateBoxInside
            else
                bearReportCandidateBoxWasInside := false

            if bearReportConfirmEvent
                bearReportLastSweepScore := bearUnifiedScore
                bearReportSweepBoxTop := bearSignalBoxTop(0)
                bearReportSweepBoxBottom := bearSignalBoxBottom(0)
                bearReportSweepBoxRight := bar_index + effectiveReferenceExtendBars
                bearReportCandidateBoxTop := na
                bearReportCandidateBoxBottom := na
                bearReportCandidateBoxRight := na
                bearReportCandidateBoxWasInside := false
                bearReportSweepBoxWasInside := true
            else if not na(bearReportSweepBoxRight)
                bearSweepBoxExpired := boxExpired(bearReportSweepBoxRight)
                bearSweepBoxInside := not bearSweepBoxExpired and boxContainsBar(bearReportSweepBoxTop, bearReportSweepBoxBottom, bearReportSweepBoxRight)
                if bearSweepBoxExpired
                    bearSweepExpiredReason := "스윕 박스 만료"
                    bearReportSweepBoxTop := na
                    bearReportSweepBoxBottom := na
                    bearReportSweepBoxRight := na
                    bearReportSweepBoxWasInside := false
                else
                    bearSweepReentryEvent := bearSweepBoxInside and not bearReportSweepBoxWasInside
                    bearSweepWaitReason := bearSweepBoxInside ? "" : "스윕 박스 이탈"
                    bearReportSweepBoxWasInside := bearSweepBoxInside
            else
                bearReportSweepBoxWasInside := false

            bearReportReferenceReady = bearReportCandidateEvent
            bearReportCandidateReady = not bearReportCandidateEvent and bearCandidateBoxInside
            bearReportSweepBoxReady = not bearReportConfirmEvent and bearSweepBoxInside
            bearReportSweepReady = bearReportConfirmEvent or bearReportSweepBoxReady
            bearReportState := reportPositionCode(bearReportTrackingActive, bearReportReferenceReady, bearReportCandidateReady, bearReportSweepReady)
            bearTriggerReason = bearReportConfirmEvent ? "스윕 확인" : bearSweepReentryEvent ? "스윕 박스 재진입" : bearReportSweepBoxReady ? "스윕 박스" : bearSweepWaitReason != "" ? bearSweepWaitReason : bearSweepExpiredReason != "" ? bearSweepExpiredReason : bearReportCandidateEvent ? "기준 봉" : bearCandidateReentryEvent ? "기준 박스 재진입" : bearReportCandidateReady ? "기준 박스" : bearCandidateWaitReason != "" ? bearCandidateWaitReason : bearCandidateExpiredReason != "" ? bearCandidateExpiredReason : bearFallbackReason
            bearReportStateReason := reportStateReason(bearReportState, bearTriggerReason, bearFallbackReason)

bullReportPositionCode = bullReportState
bearReportPositionCode = bearReportState
bullReportPositionScore = reportPositionDisplayScore(bullReportPositionCode, bullReportDisplayScore, bullReportLastCandidateScore, bullReportLastSweepScore)
bearReportPositionScore = reportPositionDisplayScore(bearReportPositionCode, bearReportDisplayScore, bearReportLastCandidateScore, bearReportLastSweepScore)

reportBorderColor = color.new(reportNeutralColor, math.max(reportBackgroundTransparency - 70, 0))
reportFrameColor = color.new(reportNeutralColor, math.max(reportBackgroundTransparency - 78, 0))
var table tradeReportTable = table.new(tablePosition(reportPositionInput), 3, 14, border_width=0, border_color=reportBorderColor, frame_width=0, frame_color=reportFrameColor)
reportHeaderBgColor = color.new(reportHeaderColor, reportBackgroundTransparency)
reportLabelBgColorValue = color.new(reportLabelBgColor, math.max(reportBackgroundTransparency - 28, 0))
reportFieldBgColorValue = color.new(reportFieldBgColor, reportBackgroundTransparency)
reportBullHeaderBgColor = color.new(reportBullColor, math.max(reportBackgroundTransparency - 20, 0))
reportBearHeaderBgColor = color.new(reportBearColor, math.max(reportBackgroundTransparency - 20, 0))
reportTextSize = tableTextSize(reportTextSizeInput)
reportHeaderText = "시그널"
var bool reportTableStaticInitialized = false
reportTableRefresh = showTradeReport and barstate.islast and (barstate.isnew or barstate.isconfirmed or not reportTableStaticInitialized)

if showTradeReport
    if reportTableRefresh
        if not reportTableStaticInitialized
            table.cell(tradeReportTable, 0, 0, reportHeaderText, text_color=color.white, bgcolor=reportHeaderBgColor, text_size=reportTextSize)
            table.cell(tradeReportTable, 1, 0, "롱 반등 감시", text_color=color.white, bgcolor=reportBullHeaderBgColor, text_size=reportTextSize)
            table.cell(tradeReportTable, 2, 0, "숏 반등 감시", text_color=color.white, bgcolor=reportBearHeaderBgColor, text_size=reportTextSize)
            table.cell(tradeReportTable, 0, 1, "비정상 시작", text_color=color.white, text_halign=text.align_center, bgcolor=reportLabelBgColorValue, text_size=reportTextSize)
            table.cell(tradeReportTable, 0, 2, "비정상 유지", text_color=color.white, text_halign=text.align_center, bgcolor=reportLabelBgColorValue, text_size=reportTextSize)
            table.cell(tradeReportTable, 0, 3, "다이버전스", text_color=color.white, text_halign=text.align_center, bgcolor=reportLabelBgColorValue, text_size=reportTextSize)
            table.cell(tradeReportTable, 0, 4, "ATR 배경", text_color=color.white, text_halign=text.align_center, bgcolor=reportLabelBgColorValue, text_size=reportTextSize)
            table.cell(tradeReportTable, 0, 5, "ATR 강화", text_color=color.white, text_halign=text.align_center, bgcolor=reportLabelBgColorValue, text_size=reportTextSize)
            table.cell(tradeReportTable, 0, 6, "기준 발생", text_color=color.white, text_halign=text.align_center, bgcolor=reportLabelBgColorValue, text_size=reportTextSize)
            table.cell(tradeReportTable, 0, 7, "스윕 확인", text_color=color.white, text_halign=text.align_center, bgcolor=reportLabelBgColorValue, text_size=reportTextSize)
            table.cell(tradeReportTable, 0, 8, "시작 시간", text_color=color.white, text_halign=text.align_center, bgcolor=reportLabelBgColorValue, text_size=reportTextSize)
            table.cell(tradeReportTable, 0, 9, "종료 시간", text_color=color.white, text_halign=text.align_center, bgcolor=reportLabelBgColorValue, text_size=reportTextSize)
            table.cell(tradeReportTable, 0, 10, "포지션", text_color=color.white, text_halign=text.align_center, bgcolor=reportLabelBgColorValue, text_size=reportTextSize)
            table.cell(tradeReportTable, 0, 11, "포지션 이유", text_color=color.white, text_halign=text.align_center, bgcolor=reportLabelBgColorValue, text_size=reportTextSize)
            table.merge_cells(tradeReportTable, 0, 12, 2, 12)
            table.cell(tradeReportTable, 0, 12, "포지션 종류는 OFF / 관찰 / 기준 / 후보 / 스윕 입니다.", text_color=color.silver, text_halign=text.align_left, bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
            table.merge_cells(tradeReportTable, 0, 13, 2, 13)
            reportTableStaticInitialized := true
        bullReportPositionValue = reportPositionText(bullReportPositionCode, bullReportPositionScore)
        bearReportPositionValue = reportPositionText(bearReportPositionCode, bearReportPositionScore)
        bullReportPositionColor = reportPositionColor(bullReportPositionCode, reportBullColor, reportNeutralColor)
        bearReportPositionColor = reportPositionColor(bearReportPositionCode, reportBearColor, reportNeutralColor)
        reportPositionScoreGuideValue = reportPositionScoreGuideText()
        table.cell(tradeReportTable, 1, 1, reportStatusText(bullReportStartCount), text_color=reportStatusColor(bullReportStartCount, reportBullColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 2, 1, reportStatusText(bearReportStartCount), text_color=reportStatusColor(bearReportStartCount, reportBearColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 1, 2, reportStatusText(bullReportHoldCount), text_color=reportStatusColor(bullReportHoldCount, reportBullColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 2, 2, reportStatusText(bearReportHoldCount), text_color=reportStatusColor(bearReportHoldCount, reportBearColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 1, 3, reportStatusText(bullReportHintCount), text_color=reportStatusColor(bullReportHintCount, reportBullColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 2, 3, reportStatusText(bearReportHintCount), text_color=reportStatusColor(bearReportHintCount, reportBearColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 1, 4, reportStatusText(bullReportWatchCount), text_color=reportStatusColor(bullReportWatchCount, reportBullColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 2, 4, reportStatusText(bearReportWatchCount), text_color=reportStatusColor(bearReportWatchCount, reportBearColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 1, 5, reportStatusText(bullReportWatchStrongCount), text_color=reportStatusColor(bullReportWatchStrongCount, reportBullColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 2, 5, reportStatusText(bearReportWatchStrongCount), text_color=reportStatusColor(bearReportWatchStrongCount, reportBearColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 1, 6, reportStatusText(bullReportCandidateCount), text_color=reportStatusColor(bullReportCandidateCount, reportBullColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 2, 6, reportStatusText(bearReportCandidateCount), text_color=reportStatusColor(bearReportCandidateCount, reportBearColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 1, 7, reportStatusText(bullReportConfirmCount), text_color=reportStatusColor(bullReportConfirmCount, reportBullColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 2, 7, reportStatusText(bearReportConfirmCount), text_color=reportStatusColor(bearReportConfirmCount, reportBearColor, reportNeutralColor), bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 1, 8, reportTimeText(bullReportFirstSignalTime), text_color=color.white, bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 2, 8, reportTimeText(bearReportFirstSignalTime), text_color=color.white, bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 1, 9, reportEndTimeText(bullReportFirstSignalTime, bullReportEndTime, bullReportTrackingActive), text_color=color.white, bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 2, 9, reportEndTimeText(bearReportFirstSignalTime, bearReportEndTime, bearReportTrackingActive), text_color=color.white, bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 1, 10, bullReportPositionValue, text_color=bullReportPositionColor, bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 2, 10, bearReportPositionValue, text_color=bearReportPositionColor, bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 1, 11, bullReportStateReason, text_color=color.white, bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 2, 11, bearReportStateReason, text_color=color.white, bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
        table.cell(tradeReportTable, 0, 13, reportPositionScoreGuideValue, text_color=color.silver, text_halign=text.align_left, bgcolor=reportFieldBgColorValue, text_size=reportTextSize)
else if barstate.islast and reportTableStaticInitialized
    table.clear(tradeReportTable, 0, 0, 2, 13)
    reportTableStaticInitialized := false

// =========================
// Optional Plots
// =========================
plot(showCRSIPlots ? crsi : na, title="cRSI", color=color.fuchsia)
plot(showCRSIPlots ? ub : na, title="cRSI 상단 밴드", color=color.new(color.red, 0))
plot(showCRSIPlots ? db : na, title="cRSI 하단 밴드", color=color.new(color.aqua, 0))
plot(showBBPlots ? bbBasis : na, title="비정상 캔들 볼린저 기준선", color=color.new(color.gray, 40))
plot(showBBPlots ? bbUpper : na, title="비정상 캔들 볼린저 상단", color=color.new(overboughtColor, 35))
plot(showBBPlots ? bbLower : na, title="비정상 캔들 볼린저 하단", color=color.new(oversoldColor, 35))
plot(showVolumeMA ? avgBuyVolume : na, title="매수 거래량 평균선", color=buyVolumeMAColor)
plot(showVolumeMA ? avgSellVolume : na, title="매도 거래량 평균선", color=sellVolumeMAColor)
