//@version=6
indicator(title="Triple-Stochastic-Wave", shorttitle="Triple-Stoch-Wave", format=format.price, precision=2)

stoch_pair(length, smooth_k, smooth_d) =>
    highest_high = ta.highest(high, length)
    lowest_low = ta.lowest(low, length)
    price_range = math.max(highest_high - lowest_low, syminfo.mintick)
    raw_k = 100.0 * (close - lowest_low) / price_range
    k = ta.sma(raw_k, smooth_k)
    d = ta.sma(k, smooth_d)
    [k, d]

fast_length = input.int(5, "Fast Length", minval=1, group="Fast Stochastic (5/3/3)", inline="fast1")
fast_smooth_k = input.int(3, "Smooth K", minval=1, group="Fast Stochastic (5/3/3)", inline="fast1")
fast_smooth_d = input.int(3, "Smooth D", minval=1, group="Fast Stochastic (5/3/3)", inline="fast1")

mid_length = input.int(10, "Mid Length", minval=1, group="Mid Stochastic (10/6/6)", inline="mid1")
mid_smooth_k = input.int(6, "Smooth K", minval=1, group="Mid Stochastic (10/6/6)", inline="mid1")
mid_smooth_d = input.int(6, "Smooth D", minval=1, group="Mid Stochastic (10/6/6)", inline="mid1")

slow_length = input.int(20, "Slow Length", minval=1, group="Slow Stochastic (20/9/9)", inline="slow1")
slow_smooth_k = input.int(9, "Smooth K", minval=1, group="Slow Stochastic (20/9/9)", inline="slow1")
slow_smooth_d = input.int(9, "Smooth D", minval=1, group="Slow Stochastic (20/9/9)", inline="slow1")

oversold = input.int(20, "Oversold", minval=0, maxval=50, group="Wave Rules", inline="rule1")
overbought = input.int(80, "Overbought", minval=50, maxval=100, group="Wave Rules", inline="rule1")
trend_midline = input.int(50, "Trend Midline", minval=0, maxval=100, group="Wave Rules", inline="rule1")
slow_context_lookback = input.int(8, "Slow Context Lookback", minval=2, group="Wave Rules", inline="rule2")
mid_pullback_lookback = input.int(6, "Mid Pullback Lookback", minval=2, group="Wave Rules", inline="rule2")

[fast_k, fast_d] = stoch_pair(fast_length, fast_smooth_k, fast_smooth_d)
[mid_k, mid_d] = stoch_pair(mid_length, mid_smooth_k, mid_smooth_d)
[slow_k, slow_d] = stoch_pair(slow_length, slow_smooth_k, slow_smooth_d)

// Slow = context, mid = reset, fast = trigger.
slow_bull_trend = slow_k > slow_d and (slow_k >= trend_midline or ta.lowest(slow_k, slow_context_lookback) <= oversold)
slow_bear_trend = slow_k < slow_d and (slow_k <= trend_midline or ta.highest(slow_k, slow_context_lookback) >= overbought)

mid_bull_reset = mid_k > mid_d and ta.rising(mid_k, 2) and ta.lowest(mid_k, mid_pullback_lookback) <= trend_midline
mid_bear_reset = mid_k < mid_d and ta.falling(mid_k, 2) and ta.highest(mid_k, mid_pullback_lookback) >= trend_midline

fast_bull_trigger = ta.crossover(fast_k, fast_d) and fast_k <= oversold
fast_bear_trigger = ta.crossunder(fast_k, fast_d) and fast_k >= overbought

all_bull_aligned = slow_k > slow_d and mid_k > mid_d and fast_k > fast_d
all_bear_aligned = slow_k < slow_d and mid_k < mid_d and fast_k < fast_d

bull_wave_background = slow_bull_trend and mid_bull_reset
bear_wave_background = slow_bear_trend and mid_bear_reset

bgcolor(bull_wave_background ? color.new(#2E7D32, 80) : na, title="Bull Wave Background", editable=true)
bgcolor(bear_wave_background ? color.new(#C62828, 80) : na, title="Bear Wave Background", editable=true)

hline(overbought, "Overbought", color=color.new(color.gray, 0))
hline(trend_midline, "Trend Midline", color=color.new(color.gray, 65))
hline(oversold, "Oversold", color=color.new(color.gray, 0))

plot(slow_k, title="Slow %K (20/9/9)", color=color.new(#1565C0, 0), linewidth=3)
plot(slow_d, title="Slow %D (20/9/9)", color=color.new(#1565C0, 55), linewidth=2, display=display.pane + display.data_window)
plot(mid_k, title="Mid %K (10/6/6)", color=color.new(#00897B, 0), linewidth=2)
plot(mid_d, title="Mid %D (10/6/6)", color=color.new(#00897B, 55), linewidth=1, display=display.pane + display.data_window)
plot(fast_k, title="Fast %K (5/3/3)", color=color.new(#FB8C00, 45), linewidth=1)
plot(fast_d, title="Fast %D (5/3/3)", color=color.new(#FB8C00, 75), linewidth=1, display=display.pane + display.data_window)

plot(fast_bull_trigger ? fast_k : na, title="Fast Bull Cross", style=plot.style_circles, color=color.new(#7CB342, 0), linewidth=4, display=display.pane)
plot(fast_bear_trigger ? fast_k : na, title="Fast Bear Cross", style=plot.style_circles, color=color.new(#D81B60, 0), linewidth=4, display=display.pane)

alertcondition(all_bull_aligned, title="Triple Stochastic Bull Alignment", message="Triple Stochastic bullish alignment: fast, mid, slow are all above their signal lines")
alertcondition(all_bear_aligned, title="Triple Stochastic Bear Alignment", message="Triple Stochastic bearish alignment: fast, mid, slow are all below their signal lines")

// ============================================================================
// 우측 상단 상태 테이블 (저장소 공통 컨벤션 — 2열×3행, 확정봉 기준 판정)
// ============================================================================
// 색 팔레트 (저장소 시그니처): 강=선명(투명도0), 약/셋업=둔탁 녹 #6E8F72 · 적 #A57A7A
solidGreen = color.new(color.green, 0)
solidRed   = color.new(color.red, 0)
dullGreen  = color.new(#6E8F72, 0)
dullRed    = color.new(#A57A7A, 0)
neutralGray = color.new(color.gray, 40)

// --- 확정봉 기준 신호(미마감봉 크로스 점멸 방지) ---
// crossover/crossunder 및 정렬/셋업 판정을 직전 확정봉([1]) 값으로 읽는다.
c_all_bull_aligned = all_bull_aligned[1]
c_all_bear_aligned = all_bear_aligned[1]
c_slow_bull_trend  = slow_bull_trend[1]
c_slow_bear_trend  = slow_bear_trend[1]
c_bull_wave_bg     = bull_wave_background[1]
c_bear_wave_bg     = bear_wave_background[1]
c_fast_bull_trig   = fast_bull_trigger[1]
c_fast_bear_trig   = fast_bear_trigger[1]
c_slow_k = slow_k[1]

// --- 과매수/과매도 (과열·침체 국면, 확정봉 slow %K 기준) ---
c_overbought = c_slow_k >= overbought
c_oversold   = c_slow_k <= oversold

// --- 셀1(2행): 정렬/추세 ---
// 판정 텍스트/색과 함께, 1행 종합이 참조할 방향/강도 상태를 분류한다.
//   alignDir: 1=상승, -1=하락, 0=중립(엇갈림)   alignStrong: 3중 정렬(강추세) 여부
alignText = "엇갈림"
alignColor = neutralGray
alignDir = 0
alignStrong = false
if c_all_bull_aligned
    alignText  := "3중 상승 정렬"
    alignColor := solidGreen
    alignDir := 1
    alignStrong := true
else if c_all_bear_aligned
    alignText  := "3중 하락 정렬"
    alignColor := solidRed
    alignDir := -1
    alignStrong := true
else if c_slow_bull_trend
    alignText  := "상승 추세"
    alignColor := dullGreen
    alignDir := 1
else if c_slow_bear_trend
    alignText  := "하락 추세"
    alignColor := dullRed
    alignDir := -1

// --- 셀2(3행): 모멘텀 (band-walking 완화 반영) ---
// 강추세(3중 정렬) 중의 과매수/과매도는 밴드워킹일 수 있어 반전으로 읽지 않고
// "추세중"으로 회색 표기(강추세 구간 상태 서술).
// 판정 텍스트/색과 함께, 1행 종합이 참조할 방향/유형 상태를 분류한다.
//   setupDir: 1=상승, -1=하락, 0=없음/중립
//   setupKind: "reversal"(과매도·과매수 극단에서의 fast 크로스=추세 전환 초입) · "trigger"(웨이브+트리거·트리거) · "setup"(웨이브 셋업) · "exhaust"(과열/침체) · "none"
setupText = "-"
setupColor = neutralGray
setupDir = 0
setupKind = "none"
// 최우선: 과매도/과매수 극단에서 fast 트리거 발생 = 추세 전환 초입(반등/하락 임박)
// 위상(웨이브)만 보는 하위 분기보다 위에 두어, 위치(과매도·과매수)를 반영하지 못하는 오안내를 차단.
if c_oversold and c_fast_bull_trig
    setupText  := "상승 전환(반등 임박)"
    setupColor := solidGreen
    setupDir := 1
    setupKind := "reversal"
else if c_overbought and c_fast_bear_trig
    setupText  := "하락 전환(하락 임박)"
    setupColor := solidRed
    setupDir := -1
    setupKind := "reversal"
else if c_bull_wave_bg and c_fast_bull_trig
    setupText  := "상승 웨이브+트리거"
    setupColor := solidGreen
    setupDir := 1
    setupKind := "trigger"
else if c_bear_wave_bg and c_fast_bear_trig
    setupText  := "하락 웨이브+트리거"
    setupColor := solidRed
    setupDir := -1
    setupKind := "trigger"
else if c_bull_wave_bg
    setupText  := "상승 웨이브(셋업)"
    setupColor := dullGreen
    setupDir := 1
    setupKind := "setup"
else if c_bear_wave_bg
    setupText  := "하락 웨이브(셋업)"
    setupColor := dullRed
    setupDir := -1
    setupKind := "setup"
else if c_fast_bull_trig
    setupText  := "상승 트리거"
    setupColor := dullGreen
    setupDir := 1
    setupKind := "trigger"
else if c_fast_bear_trig
    setupText  := "하락 트리거"
    setupColor := dullRed
    setupDir := -1
    setupKind := "trigger"
else if c_overbought and c_all_bull_aligned
    setupText  := "과매수(추세중)"
    setupColor := neutralGray
    // band-walking 완화: 강추세 중 과열은 반전 아님 → 방향/유형 중립 취급(1행에 영향 없음)
else if c_oversold and c_all_bear_aligned
    setupText  := "과매도(추세중)"
    setupColor := neutralGray
    // band-walking 완화: 강추세 중 침체는 반전 아님 → 방향/유형 중립 취급(1행에 영향 없음)
else if c_overbought
    setupText  := "과매수(과열)"
    setupColor := dullRed
    setupKind := "exhaust"
    // 과열은 방향 확정 신호가 아님 → setupDir 0 유지(1행에서 '과열 주의' 수식으로만 반영)
else if c_oversold
    setupText  := "과매도(침체)"
    setupColor := dullGreen
    setupKind := "exhaust"
    // 침체는 방향 확정 신호가 아님 → setupDir 0 유지(1행에서 '침체 주의' 수식으로만 반영)

// --- 1행(종합): 2행·3행 상태의 조합 함수 = f(align*, setup*) ---
// 하위 두 행 결과만 입력으로 삼아 "포지션 관점" 종합 상태를 서술한다(매매 지시어 없음).
// 색: 상승=녹(강 선명/약 둔탁 #6E8F72), 하락=적(강 선명/약 둔탁 #A57A7A), 중립=회색.
verdictText  = "중립/관망"
verdictColor = neutralGray
// 최우선: 3행이 추세 전환(과매도/과매수 극단의 fast 크로스)이면 종합도 전환으로 확정.
// 엇갈림 중립화(아래)보다 위에 두어야 2행 정렬(예: 하락 추세)이 전환을 덮어쓰지 못한다.
// (예: 1행 "상승 전환" + 2행 "하락 추세" = 하락 추세 바닥에서의 반등 초입으로 읽히는 의도된 정보)
if setupKind == "reversal" and setupDir == 1
    verdictText  := "상승 전환"
    verdictColor := solidGreen
else if setupKind == "reversal" and setupDir == -1
    verdictText  := "하락 전환"
    verdictColor := solidRed
// 강한 방향: 2행이 3중 정렬(강추세)이고 3행이 같은 방향 트리거 → 최강 종합
else if alignStrong and setupDir == 1 and setupKind == "trigger"
    verdictText  := "강한 상승 우위"
    verdictColor := solidGreen
else if alignStrong and setupDir == -1 and setupKind == "trigger"
    verdictText  := "강한 하락 우위"
    verdictColor := solidRed
// 2·3행 방향 엇갈림 → 중립/관망(우선 차단)
else if alignDir != 0 and setupDir != 0 and alignDir != setupDir
    verdictText  := "중립/관망"
    verdictColor := neutralGray
// 상승 계열 종합
else if alignDir == 1 or setupDir == 1
    // 3행이 같은 방향 트리거면 우위 확정, 셋업이면 대기, 방향 없는 과열이면 과열 주의
    if setupDir == 1 and setupKind == "trigger"
        verdictText  := alignStrong ? "강한 상승 우위" : "상승 우위"
        verdictColor := alignStrong ? solidGreen : dullGreen
    else if setupDir == 1 and setupKind == "setup"
        verdictText  := "상승 우위(대기)"
        verdictColor := dullGreen
    else if alignStrong and setupKind == "exhaust"
        verdictText  := "상승 우위(과열 주의)"
        verdictColor := dullGreen
    else if alignStrong
        verdictText  := "상승 우위"
        verdictColor := solidGreen
    else
        verdictText  := "상승 우위(대기)"
        verdictColor := dullGreen
// 하락 계열 종합 (대칭)
else if alignDir == -1 or setupDir == -1
    if setupDir == -1 and setupKind == "trigger"
        verdictText  := alignStrong ? "강한 하락 우위" : "하락 우위"
        verdictColor := alignStrong ? solidRed : dullRed
    else if setupDir == -1 and setupKind == "setup"
        verdictText  := "하락 우위(대기)"
        verdictColor := dullRed
    else if alignStrong and setupKind == "exhaust"
        verdictText  := "하락 우위(침체 주의)"
        verdictColor := dullRed
    else if alignStrong
        verdictText  := "하락 우위"
        verdictColor := solidRed
    else
        verdictText  := "하락 우위(대기)"
        verdictColor := dullRed

var table stochStatus = table.new(position.top_right, 2, 3, border_width=1, border_color=color.new(color.gray, 50))
if barstate.islast
    table.cell(stochStatus, 0, 0, "삼중 Stoch", text_color=color.white, bgcolor=color.new(#1B2A4A, 0), text_size=size.small)
    table.cell(stochStatus, 1, 0, verdictText, text_color=color.white, bgcolor=verdictColor, text_size=size.small)
    table.cell(stochStatus, 0, 1, "정렬/추세", text_color=color.white, text_size=size.small)
    table.cell(stochStatus, 1, 1, alignText, text_color=color.white, bgcolor=alignColor, text_size=size.small)
    table.cell(stochStatus, 0, 2, "모멘텀", text_color=color.white, text_size=size.small)
    table.cell(stochStatus, 1, 2, setupText, text_color=color.white, bgcolor=setupColor, text_size=size.small)
