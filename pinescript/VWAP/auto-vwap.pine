//@version=6
indicator(title="Auto VWAP", shorttitle="Auto VWAP", overlay=true)

hideonDWM = input(false, title="Hide VWAP on 1D or Above", group="VWAP Settings", display=display.none)
anchorMode = input.string(defval="Recent Bars", title="Anchor Mode", options=["Session", "Recent Trading Days", "Recent Bars"], group="VWAP Settings")
recentTradingDays = input.int(defval=5, title="Recent Trading Days", minval=1, group="VWAP Settings", display=display.none, active=anchorMode == "Recent Trading Days")
// 기본 화면용 VWAP window 길이(=Recent Bars 모드일 때의 rolling length). CEO 지시: 기본 화면 VWAP 기본값 50.
//  변곡 지점용 VWAP는 "변곡 지점" 그룹에서 독립 length(기본 20)로 분리 계산한다.
recentBars = input.int(defval=50, title="Recent Bars (기본 화면 VWAP)", minval=1, group="VWAP Settings", display=display.none, active=anchorMode == "Recent Bars")
src = input(title="Source", defval=hlc3, group="VWAP Settings", display=display.none)
offset = input.int(0, title="Offset", group="VWAP Settings", display=display.none)
enableDynamicLineColor = input.bool(false, title="Enable Dynamic Line Color", group="VWAP Settings", display=display.none)
// VWAP 중앙선 지지/저항 색 규칙(CEO 개정 7규칙 — 전면 재작성). 화면 기본 VWAP 선(vwapValue)의 색을 봉 단위로 판정한다.
//  판정 축: (1) 시가(open) 출발 구간 + (2) 고가/저가(high/low)의 VWAP 돌파 여부 + (3) 종가(close) 마감 위치. (개정판은 high/low를 다시 쓴다.)
//  "근처 범위"는 **밴드1 기준 ±p%**로 정의(p는 규칙3 동적값, 기본 10~30%):
//   상단 근처 상한 nearUpper = vwap + p×(upperBand1 − vwap),  하단 근처 하한 nearLower = vwap − p×(vwap − lowerBand1).
//   [규칙3] p = 밴드폭 반비례 동적 %. r=(upperBand1−lowerBand1)/vwap 를 rLow~rHigh 사이 정규화 → 저변동성(좁은밴드)→max%(30)·고변동성(넓은밴드)→min%(10) 반비례 보간·clamp.
//  시가 구간(실수 전체 커버·상호배타): open<nearLower / nearLower≤open<vwap / open==vwap(중립) / vwap<open≤nearUpper / open>nearUpper.
//  ▸ 저항 계열(시가가 VWAP 아래쪽 출발):
//     [A] open<nearLower : close>nearUpper→저항실패(녹,#2) / close<nearLower&high≥nearLower→저항(빨강,규칙1 X-A확정 되밀림) / high≤vwap&nearLower≤close≤vwap→저항(빨강,#4) / vwap<close≤nearUpper→중립(#3) / nearLower≤close≤vwap&high>vwap위꼬리→중립(구멍X-A잔여) / close<nearLower&high<nearLower→중립(미진입).
//     [B] nearLower≤open<vwap : close>nearUpper→저항실패(녹,#5) / close≤vwap→저항(빨강,통합B,high무관·#6+B+ 흡수) / 그외(vwap<close≤nearUpper)→중립.
//  ▸ 지지 계열(시가가 VWAP 위쪽 출발, 위 저항의 정확한 상하 대칭 — 고↔저·상↔하·돌파↔이탈):
//     [C] open>nearUpper : close<nearLower→지지실패(빨강) / close>nearUpper&low≤nearUpper→지지(녹,규칙2 X-C확정 되밀림) / low≥vwap&vwap≤close≤nearUpper→지지(녹,#4거울) / nearLower≤close<vwap→중립 / vwap≤close≤nearUpper&low<vwap아래꼬리→중립(구멍X-C잔여) / close>nearUpper&low>nearUpper→중립(미진입).
//     [D] vwap<open≤nearUpper : close<nearLower→지지실패(빨강) / close≥vwap→지지(녹,통합D,low무관·#6+D+ 흡수) / 그외(nearLower≤close<vwap)→중립.
//  색 규약: 지지=녹 / 지지실패=빨강 / 저항=빨강 / 저항실패=녹 / 그 외 전부 중립(흰).
//  ★ 구멍: [A]/[C] 위/아래꼬리 되밀림 중 규칙1/2(X-A/X-C 확정, close가 근처 반대편 돌파 마감이면서 near 닿음)는 이제 저항/지지 확정. 나머지 잔여(nearLower≤close≤vwap 위꼬리 등)만 중립. [B]/[D]의 X-B/X-D는 규칙 B+/D+가 흡수. → 모든 (시가,고저,종가) 조합이 한 색으로 결정.
//  enableDynamicLineColor(밴드2 이탈 녹/빨강)와 독립한 별도 VWAP 선 전용 색이다.
enableVwapSRColor = input.bool(true, title="VWAP 선 지지/저항 색(시가 구간·종가 돌파)", group="VWAP Settings", tooltip="켜면 화면 VWAP 중앙선의 색을 봉 단위로 지지=녹/지지실패=빨강/저항=빨강/저항실패=녹/중립=흰색으로 칠합니다(CEO 개정 7규칙). 판정은 시가가 VWAP 기준 어느 구간(하단근처 아래/안·상단근처 안/위)에서 출발했는지 + 고가/저가가 VWAP을 넘었는지 + 종가 마감 위치로 결정합니다. 위/아래꼬리로 찔렀다 되밀린 봉이나 VWAP은 넘었으나 근처엔 못 미친 봉은 중립(흰)으로 처리합니다. '근처 범위'는 VWAP↔밴드1 거리의 일정 % 이내(아래 근처 % 입력)로 정의합니다. 이 옵션은 아래 Enable Dynamic Line Color(밴드2 이탈 색)와 별개이며, 켜져 있으면 VWAP 선 색을 이 규칙이 담당합니다(밴드1·밴드2 등 다른 선 색은 기존대로).")
// VWAP 중앙선 "근처 범위" 폭(밴드1 기준 %). CEO 새 정의: VWAP를 0%, 밴드1을 100%로 볼 때 이 %까지를 '근처'로 본다.
//  상단 근처 상한 = vwap + (p/100)×(upperBand1 − vwap),  하단 근처 하한 = vwap − (p/100)×(vwap − lowerBand1).  p = 동적 근처 %(아래 규칙 3).
//  ⚠️ 과거 규칙과 달리 밴드2가 아니라 밴드1 기준이다. 밴드1이 na(워밍업)·편차 0(도지)면 판정 불가로 흰색 폴백.
// [규칙 3 — 근처 % 동적화(밴드폭 반비례)] 고정 10% 대신 밴드폭에 반비례하는 값을 쓴다.
//  ▸ 밴드폭 측정: bandWidth1 = upperBand1 − lowerBand1 (밴드1 폭 = 2×stdev×bandMult_1). 근처가 밴드1 기준이므로 밴드1 폭을 사용.
//  ▸ 정규화(종목·가격 무관): r = bandWidth1 / vwap (가격 대비 밴드폭 비율). 절대값이 아니라 비율이라 종목·가격대 무관.
//  ▸ 매핑(반비례): r≤rLow(저변동성)→최대%(30), r≥rHigh(고변동성)→최소%(10), 사이는 선형보간. clamp로 [min,max] 보장.
//      t = clamp((r − rLow)/(rHigh − rLow), 0, 1);  근처% = maxPct − t×(maxPct − minPct).
//  ▸ 기본값 근거: 세션 VWAP 밴드1(≈1σ×배수)은 통상 가격의 0.5~2% 폭 → rLow=0.005(0.5%), rHigh=0.02(2.0%) 라운드넘버. min 10·max 30은 CEO 지정.
//  ▸ 리페인팅 없음: upperBand1/lowerBand1/vwap 모두 확정봉 세트값(computeVwapSet, ta.cum 기반) → 미래참조 없음.
vwapNearMinPct = input.float(10.0, title="VWAP 근처 범위 최소 %(고변동성)", minval=0.0, maxval=100.0, step=1.0, group="VWAP Settings", active=enableVwapSRColor, display=display.none, tooltip="밴드폭이 넓을 때(고변동성) 적용할 근처 범위 최소 %. 밴드폭/VWAP 비율이 '고변동성 임계' 이상이면 이 값으로 수렴합니다. 기본 10.")
vwapNearMaxPct = input.float(30.0, title="VWAP 근처 범위 최대 %(저변동성)", minval=0.0, maxval=100.0, step=1.0, group="VWAP Settings", active=enableVwapSRColor, display=display.none, tooltip="밴드폭이 좁을 때(저변동성) 적용할 근처 범위 최대 %. 밴드폭/VWAP 비율이 '저변동성 임계' 이하이면 이 값으로 수렴합니다. 기본 30. 근처 %는 이 값과 최소 % 사이에서 밴드폭에 반비례로 결정됩니다.")
vwapNearRLowPct = input.float(0.5, title="근처 % 저변동성 임계(밴드폭/VWAP, %)", minval=0.0, step=0.1, group="VWAP Settings", active=enableVwapSRColor, display=display.none, tooltip="밴드1 폭 ÷ VWAP 비율(%)이 이 값 이하이면 저변동성으로 보고 근처 %를 최대(기본 30)로 씁니다. 기본 0.5%(=밴드1 폭이 가격의 0.5% 이하일 때 저변동성). 세션 VWAP 밴드1(≈1σ×배수) 통상 하단.")
vwapNearRHighPct = input.float(2.0, title="근처 % 고변동성 임계(밴드폭/VWAP, %)", minval=0.0, step=0.1, group="VWAP Settings", active=enableVwapSRColor, display=display.none, tooltip="밴드1 폭 ÷ VWAP 비율(%)이 이 값 이상이면 고변동성으로 보고 근처 %를 최소(기본 10)로 씁니다. 기본 2.0%. 저변동성 임계와 이 값 사이는 선형보간합니다(반비례). 저변동성 임계보다 커야 합니다.")
showBandPctLabels = input.bool(true, title="VWAP·밴드 간격 % 라벨 표시", group="VWAP Settings")

BANDS_GROUP = "Bands Settings"
CALC_MODE_TOOLTIP = "Determines how band distance is calculated. Log Standard Deviation uses volume-weighted log-price volatility, and Absolute Standard Deviation uses price units."
calcModeInput = input.string("Log Standard Deviation", "Bands Calculation Mode", options=["Log Standard Deviation", "Absolute Standard Deviation"], group=BANDS_GROUP, tooltip=CALC_MODE_TOOLTIP, display=display.none)
showBand_1 = input(true, title="", group=BANDS_GROUP, inline="band_1", display=display.none)
bandMult_1 = input.float(1.0, title="Bands Multiplier #1", group=BANDS_GROUP, inline="band_1", step=0.5, minval=0, display=display.none, active=showBand_1)
showBand_2 = input(true, title="", group=BANDS_GROUP, inline="band_2", display=display.none)
bandMult_2 = input.float(2.0, title="Bands Multiplier #2", group=BANDS_GROUP, inline="band_2", step=0.5, minval=0, display=display.none, active=showBand_2)

DEFAULT_LINE_COLOR = #FFFFFF
LOWER_BREAK_LINE_COLOR = #00FF00
UPPER_BREAK_LINE_COLOR = #FF0000

formatPercentGap(float bandValue, float baseValue) =>
    if na(bandValue) or na(baseValue) or baseValue == 0
        ""
    else
        percentGap = (bandValue / baseValue - 1.0) * 100.0
        (percentGap > 0 ? "+" : "") + str.tostring(percentGap, "0.00") + "%"

updateLineEndLabel(label existingLineEndLabel, int xPos, float yPrice, string labelText, color lineColor, bool shouldShow) =>
    label updatedLabel = existingLineEndLabel
    if shouldShow
        if na(updatedLabel)
            updatedLabel := label.new(x=xPos, y=yPrice, text=labelText, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(lineColor, 100), textcolor=lineColor, size=size.small)
        else
            label.set_xy(updatedLabel, xPos, yPrice)
            label.set_text(updatedLabel, labelText)
            label.set_textcolor(updatedLabel, lineColor)
            label.set_color(updatedLabel, color.new(lineColor, 100))
            label.set_style(updatedLabel, label.style_label_left)
    else if not na(updatedLabel)
        label.delete(updatedLabel)
        updatedLabel := na
    updatedLabel

cumVolume = ta.cum(volume)
if barstate.islast and cumVolume == 0
    runtime.error("No volume is provided by the data vendor.")

isNewSession = barstate.isfirst or timeframe.change("D")
sessionTime = time("D")
sessionCloseTime = time_close("D")
isLatestSession = sessionTime <= last_bar_time and sessionCloseTime > last_bar_time

var label upperBand1LineEndLabel = na
var label lowerBand1LineEndLabel = na
var label upperBand2LineEndLabel = na
var label lowerBand2LineEndLabel = na

// VWAP·밴드·밴드2 계산 헬퍼 — window 길이(barsLen)와 **소스(srcArg)**를 파라미터로 받아
//  "기본 화면용(length=50, src)"·"변곡(length=ipRecentBars, ipSrc)" 세트를 독립 계산한다(CEO 지시: VWAP 완전 분리 + 소스 독립).
//  ⚠️ 소스별로 서로 다른 누적이 필요하므로 누적(cumulative*)·세션 앵커 배열을 **함수-로컬 var로 내부화**한다.
//   Pine v6에서 함수 내부 var/var array는 그 호출부(instance)마다 독립 상태를 가지므로, 두 번 호출하면 두 개의 독립 누적이 유지된다.
//   소스가 동일하면(기본값 hlc3) 각 인스턴스가 같은 누적 궤적을 재현하므로 기존(전역 단일 누적) 대비 값이 동일하다(거동 불변).
//  세션 앵커 배열 push는 소스와 무관한 "시점 스냅샷"이라, 각 인스턴스가 자기 소스 누적을 그 시점에 스냅샷하는 것이 산식상 올바르다.
//  산식 자체(anchored VWAP + 로그/절대 표준편차 밴드)는 원본과 100% 동일. 확정봉 기준 누적이라 소스가 series여도 신규 리페인팅 없음.
//  반환: [vwapValue, upperBand1, lowerBand1, upperBand2, lowerBand2, shouldPlot].
computeVwapSet(int barsLen, float srcArg) =>
    var array<float> sessionStartPV = array.new_float()
    var array<float> sessionStartVolume = array.new_float()
    var array<float> sessionStartP2V = array.new_float()
    var array<float> sessionStartLogPV = array.new_float()
    var array<float> sessionStartLog2V = array.new_float()
    var array<float> sessionStartInvalidLogVolume = array.new_float()

    var float cumulativePV = 0.0
    var float cumulativeVolume = 0.0
    var float cumulativeP2V = 0.0
    var float cumulativeLogPV = 0.0
    var float cumulativeLog2V = 0.0
    var float cumulativeInvalidLogVolume = 0.0

    if isNewSession
        array.push(sessionStartPV, cumulativePV)
        array.push(sessionStartVolume, cumulativeVolume)
        array.push(sessionStartP2V, cumulativeP2V)
        array.push(sessionStartLogPV, cumulativeLogPV)
        array.push(sessionStartLog2V, cumulativeLog2V)
        array.push(sessionStartInvalidLogVolume, cumulativeInvalidLogVolume)

    barPV = srcArg * volume
    barP2V = srcArg * srcArg * volume
    logSrc = srcArg > 0 ? math.log(srcArg) : na
    barLogPV = na(logSrc) ? 0.0 : logSrc * volume
    barLog2V = na(logSrc) ? 0.0 : logSrc * logSrc * volume
    barInvalidLogVolume = na(logSrc) ? volume : 0.0
    cumulativePV += barPV
    cumulativeVolume += volume
    cumulativeP2V += barP2V
    cumulativeLogPV += barLogPV
    cumulativeLog2V += barLog2V
    cumulativeInvalidLogVolume += barInvalidLogVolume

    sessionCount = array.size(sessionStartPV)
    anchorSessionIndex = anchorMode == "Session" ? sessionCount - 1 : math.max(sessionCount - recentTradingDays, 0)

    anchorPV = anchorMode == "Recent Bars" ? nz(cumulativePV[barsLen], 0.0) : array.get(sessionStartPV, anchorSessionIndex)
    anchorVolume = anchorMode == "Recent Bars" ? nz(cumulativeVolume[barsLen], 0.0) : array.get(sessionStartVolume, anchorSessionIndex)
    anchorP2V = anchorMode == "Recent Bars" ? nz(cumulativeP2V[barsLen], 0.0) : array.get(sessionStartP2V, anchorSessionIndex)
    anchorLogPV = anchorMode == "Recent Bars" ? nz(cumulativeLogPV[barsLen], 0.0) : array.get(sessionStartLogPV, anchorSessionIndex)
    anchorLog2V = anchorMode == "Recent Bars" ? nz(cumulativeLog2V[barsLen], 0.0) : array.get(sessionStartLog2V, anchorSessionIndex)
    anchorInvalidLogVolume = anchorMode == "Recent Bars" ? nz(cumulativeInvalidLogVolume[barsLen], 0.0) : array.get(sessionStartInvalidLogVolume, anchorSessionIndex)

    windowPV = cumulativePV - anchorPV
    windowVolume = cumulativeVolume - anchorVolume
    windowP2V = cumulativeP2V - anchorP2V
    windowLogPV = cumulativeLogPV - anchorLogPV
    windowLog2V = cumulativeLog2V - anchorLog2V
    windowInvalidLogVolume = cumulativeInvalidLogVolume - anchorInvalidLogVolume

    float vwapLocal = na
    float upperBand1Local = na
    float lowerBand1Local = na
    float upperBand2Local = na
    float lowerBand2Local = na

    shouldPlotLocal = not (hideonDWM and timeframe.isdwm) and windowVolume > 0 and (anchorMode != "Session" or isLatestSession)

    if shouldPlotLocal
        vwapLocal := windowPV / windowVolume
        weightedVariance = math.max(windowP2V / windowVolume - math.pow(vwapLocal, 2), 0)
        stdevAbs = math.sqrt(weightedVariance)
        weightedLogVariance = math.max(windowLog2V / windowVolume - math.pow(windowLogPV / windowVolume, 2), 0)
        stdevLog = math.sqrt(weightedLogVariance)
        canUseLogBands = windowInvalidLogVolume == 0 and vwapLocal > 0

        if calcModeInput == "Absolute Standard Deviation"
            upperBand1Local := vwapLocal + stdevAbs * bandMult_1
            lowerBand1Local := vwapLocal - stdevAbs * bandMult_1
            upperBand2Local := vwapLocal + stdevAbs * bandMult_2
            lowerBand2Local := vwapLocal - stdevAbs * bandMult_2
        else if canUseLogBands
            upperBand1Local := vwapLocal * math.exp(stdevLog * bandMult_1)
            lowerBand1Local := vwapLocal * math.exp(-stdevLog * bandMult_1)
            upperBand2Local := vwapLocal * math.exp(stdevLog * bandMult_2)
            lowerBand2Local := vwapLocal * math.exp(-stdevLog * bandMult_2)
    [vwapLocal, upperBand1Local, lowerBand1Local, upperBand2Local, lowerBand2Local, shouldPlotLocal]

// =========================
// 변곡 지점(Inflection Point) 설정 — 변곡용 밴드2 상/하단 선이 "기본 청산선"(shortClear/longClear, 3모드 OR) 안으로
//  들어오는 순간을 마커로 표시하기 위한 표시 옵션이다. CEO 지시 #4: 변곡 전용 청산선 파라미터 세트는 **삭제**했다.
//  변곡용 VWAP window(ipRecentBars=22)만 기본 화면 세트와 독립으로 유지하고, 청산선 판정은 "스윕/청산" 그룹(기본 청산 설정)을 쓴다.
//  ⚠️ 이 그룹은 판정·마커 표시 전용이며, 화면에 청산선(직선)을 그리지 않는다(마커만 그린다).
//  ⚠️ 매매 전략(진입·청산·임계값)과 무관한 표시 옵션이다.
// =========================
IP_GROUP = "변곡 지점"
ipShowMarkers = input.bool(true, title="변곡 지점 마커 표시", group=IP_GROUP, tooltip="변곡용 밴드2 상/하단 선이 기본 청산선(가격 모드 기본·거래량 가중·최근봉 가중 3가지 중 1개 이상) 안으로 들어오는 순간을 밴드2 값 위치에 마커로 표시합니다(색=기본 청산선 색). 청산선 수평 필터·3봉 평균 게이트·방향성 밴드워킹 억제와 AND로 결합합니다.")
// 변곡 지점 판정용 VWAP window 길이 — 기본 화면 VWAP(recentBars=50)와 **완전 독립**. CEO 지시: 변곡용 기본 10.
//  이 length로 별도 window(±σ 밴드·밴드2 포함)를 산출하고, 변곡 지점 마커 판정은 이 변곡용 밴드2/VWAP 기준으로 계산한다.
//  (anchored 특성: Recent Bars 앵커 모드에서만 유효. Session/Recent Trading Days 모드에선 기본 세트와 동일 앵커를 공유.)
ipRecentBars = input.int(defval=10, title="[변곡] Recent Bars (변곡 VWAP)", minval=1, group=IP_GROUP, display=display.none, active=anchorMode == "Recent Bars", tooltip="변곡 지점 판정용 VWAP의 window 길이(N선). 기본 화면 VWAP와 독립. 기본 10. Recent Bars 앵커 모드에서만 유효합니다.")
// 변곡 VWAP 소스 선택(CEO 지시) — 기본값 = hlc3(현재 거동과 동일. 화면 VWAP src와 같은 hlc3로 누적하던 것을 그대로 유지).
//  input.source 방식(화면 VWAP의 src와 동일 톤): close/hlc3/hl2/ohlc4/open 등 어떤 series든 선택 가능한 소스 드롭다운.
//  ⚠️ 소스별로 **독립 누적**이 되도록 computeVwapSet가 소스를 인자로 받는다(전역 단일 누적으로는 소스 분리 불가). 확정봉 기준 누적이라 신규 리페인팅 없음.
ipSrc  = input(title="[변곡] Source (변곡 VWAP)", defval=hlc3, group=IP_GROUP, display=display.none, tooltip="변곡 VWAP(변곡 Recent Bars)의 VWAP 소스. 기본 hlc3(고저종÷3)로, 현재 동작과 동일합니다. close(종가)·hl2·ohlc4 등으로 바꿀 수 있습니다.")
// 마커 모양 옵션(기본값=십자가). 리터럴 style plotshape로 분기하므로 컴파일 안전(입력→series 강등 이슈 없음).
ipMarkerStyle = input.string("원", title="변곡 지점 마커 모양", options=["십자가", "원", "삼각형", "다이아몬드", "네모"], group=IP_GROUP, active=ipShowMarkers, tooltip="변곡 지점 마커의 모양입니다. 기본값은 원(circle)입니다.")
// CEO 재지시: "기본 vwap이 청산선 안으로 들어오고, 마커가 생길 때"만 기본 화면 밴드2 선을 마커색으로 강조(표시 전용, 판정·계산 불변).
//  상단 밴드2(upperBandValue2)는 숏 마커(upper2Marker)이면서 화면 상단 밴드2가 숏 청산선 안(upperBandValue2 < shortClear)일 때 숏 마커색(shortClearLineColor)으로,
//  하단 밴드2(lowerBandValue2)는 롱 마커(lower2Marker)이면서 화면 하단 밴드2가 롱 청산선 안(lowerBandValue2 > longClear)일 때 롱 마커색(longClearLineColor)으로 강조한다.
//  OFF·조건 미충족이면 기본색(activeLineColor)으로 원복. 봉 단위 색 지정이라 조건 봉만 강조되고 나머지는 기본색.
ipBand2MarkerColor = input.bool(true, title="변곡 마커 봉 밴드2 강조 색", group=IP_GROUP, active=ipShowMarkers, tooltip="켜면 변곡 마커가 뜨면서 해당 방향 기본 화면 밴드2가 실제로 청산선 안으로 들어온 봉에서만 그 밴드2 선을 마커와 같은 색으로 강조합니다(상단=숏 마커색, 하단=롱 마커색). 그 봉에서만 색이 바뀌고 나머지 봉은 기본색을 유지합니다. 밴드2 위치·계산·마커 판정은 바뀌지 않는 표시 전용 옵션입니다.")
// ⚠️ 변곡 전용 청산선 파라미터(ipCe*/ipSweep*)·변곡 전용 청산선 색(ipLong/ipShortClearLineColor)은 제거되었다(CEO 지시 #4).
//  변곡 마커 판정은 이제 아래 "스윕/청산" 그룹(기본 청산 설정)을 그대로 쓴다. 마커 색도 기본 청산선 색(short/longClearLineColor)을 쓴다.
// 요구사항 4: 밴드워킹 억제 필터 — 변곡 시점 청산선의 기울기가 "근사 수평"일 때만 마커를 표시한다.
//  청산선이 추세로 기울어(위/아래 워킹 중) 있으면 변곡 조건이 성립해도 마커를 억제한다.
//  판정: 최근 N봉 사이 청산선 값 변화량(|line - line[N]|)을 ATR로 정규화한 비율(=ATR 대비 배수)이 임계 이내면 수평.
//   → 절대 가격차가 아니라 ATR 정규화 비율이라 종목·타임프레임 무관하게 동작한다.
//  변곡 전용 청산선이 제거됐으므로(CEO 지시 #4), flat 판정은 **후보 3모드(기본·거래량 가중·최근봉 가중) 청산선** 기준으로 한다.
//  ⚠️ 화면 페인팅용(ceMode) 청산선 shortClear/longClear는 flat 판정에 쓰지 않는다 — 스윕 모드 선택이 마커에 관여하면 안 되기 때문(사양 1). 후보에 기여한 모드의 청산선 flat만 본다.
//  ⚠️ 청산선 계산·전략 로직과 무관한 표시 전용 필터다(마커 억제만).
ipFlatFilter = input.bool(true, title="변곡 시 청산선 수평 필터(밴드워킹 억제)", group=IP_GROUP, active=ipShowMarkers, tooltip="켜면 변곡 시점 청산선 기울기가 근사 수평일 때만 마커를 표시합니다. 판정은 후보에 기여한 모드(기본·거래량 가중·최근봉 가중 중 밴드2가 들어온 모드)의 청산선 기울기로 하며, 스윕 가격 모드(ceMode) 선택과는 무관합니다. 청산선이 추세로 기울어(밴드워킹 중) 있으면 변곡이어도 억제합니다.")
ipFlatLookback = input.int(3, title="[변곡] 수평 판정 lookback 봉수", minval=1, group=IP_GROUP, active=ipShowMarkers and ipFlatFilter, display=display.none, tooltip="청산선 기울기를 측정할 과거 봉 수(N). 최근 N봉 사이 청산선 값 변화량으로 기울기를 판정합니다. 기본 3.")
ipFlatSlopeMax = input.float(0.15, title="[변곡] 수평 허용 기울기(ATR 대비 배수)", minval=0.0, step=0.01, group=IP_GROUP, active=ipShowMarkers and ipFlatFilter, display=display.none, tooltip="N봉 사이 청산선 변화량 ÷ ATR 이 이 값 이하이면 '수평'으로 간주합니다. 기본 0.15(=ATR의 15%). 값을 키우면 더 기울어도 표시, 줄이면 더 엄격히 수평만 표시.")
// 방향성 밴드워킹 억제 — 이치모쿠 메인 지표 "VWAP 상태"의 밴드워킹 판정 알고리즘을 이식(포팅)한다.
//  목적: 추세(밴드워킹) 방향과 반대되는 변곡 마커를 억제한다(역추세 진입 억제).
//   - 아래(하락) 밴드워킹 중 → 롱 변곡 마커(녹색·하단, lower2Marker) 억제.
//   - 위(상승) 밴드워킹 중 → 숏 변곡 마커(빨강·상단, upper2Marker) 억제.
//  ⚠️ 이 밴드워킹은 "화면상 추세 국면" 성격이므로 **밴드워킹 판정 전용 VWAP 세트**(length=bwRecentBars 기본 50, 소스=src, bwVwapValue/밴드1/밴드2/bwShouldPlot) 기준으로 판정한다.
//   (변곡 마커의 발동 판정은 변곡용 세트(length=20)이지만, 방향 억제는 넓은 추세 국면을 봐야 하므로 이치모쿠와 동일하게 넓은 세트를 쓴다.)
//   ⚠️ 화면 세트(recentBars, src)와 분리했다(CEO 판단 A) — recentBars(화면 표시 전용)를 바꿔도 밴드워킹→마커 표시 여부가 흔들리지 않는다. 기본값 50·동일 소스라 거동 불변.
//  ⚠️ 표시 억제 전용 필터다 — 매매 전략(진입·청산·임계·산식)과 무관하다.
ipBwSuppress = input.bool(true, title="추세(밴드워킹) 방향 반대 마커 억제", group=IP_GROUP, active=ipShowMarkers, tooltip="켜면 밴드워킹(추세) 방향과 반대되는 변곡 마커를 숨깁니다. 하락 밴드워킹 중이면 롱(녹색·하단) 마커를, 상승 밴드워킹 중이면 숏(빨강·상단) 마커를 억제합니다. 이치모쿠 메인 지표의 'VWAP 상태' 밴드워킹 판정 알고리즘을 이식한 것으로, 밴드워킹 판정 전용 VWAP 세트([밴드워킹] Recent Bars, 화면 VWAP와 독립)를 기준으로 판정합니다.")
// 밴드워킹 판정 파라미터 — 이치모쿠 원본 기본값과 동일(vwSlopeLen=5, vwWalkSlopeLen=3, 평탄 임계=밴드폭의 3%).
ipBwSlopeLen = input.int(5, title="[밴드워킹] VWAP 기울기 lookback 봉수", minval=1, group=IP_GROUP, active=ipShowMarkers and ipBwSuppress, display=display.none, tooltip="VWAP 기울기·밴드폭 확장/수축을 측정할 과거 봉 수. 이치모쿠 원본 기본 5.")
ipBwWalkSlopeLen = input.int(3, title="[밴드워킹] 밴드2 레일 기울기 lookback 봉수", minval=1, group=IP_GROUP, active=ipShowMarkers and ipBwSuppress, display=display.none, tooltip="밴드워킹 종료(레일 반전) 판정용 밴드2 상/하단선 기울기 측정 봉 수. 이치모쿠 원본 기본 3.")
ipBwFlatPct = input.float(0.03, title="[밴드워킹] VWAP 평탄 임계(밴드폭 대비 비율)", minval=0.0, step=0.01, group=IP_GROUP, active=ipShowMarkers and ipBwSuppress, display=display.none, tooltip="VWAP 기울기가 밴드2 총폭의 이 비율보다 작으면 '평탄'으로 봅니다. 이치모쿠 원본 기본 0.03(=밴드폭의 3%).")
// 밴드워킹 판정 전용 VWAP window 길이 — 화면 세트(recentBars)·변곡 세트(ipRecentBars)와 **모두 독립**. CEO 지시(판단 A).
//  버그 교정: 이전엔 밴드워킹 블록이 화면 세트(computeVwapSet(recentBars, src)) 값을 참조해, recentBars(화면 표시 전용)를 바꾸면 변곡 마커 표시 여부가 흔들렸다(오염).
//   → 전용 window(bwRecentBars)로 별도 세트를 계산해 밴드워킹 판정을 화면 세트에서 분리한다. 소스는 기존 밴드워킹이 화면 세트를 참조했으므로 **화면과 동일한 src**를 그대로 쓴다(변곡 소스 ipSrc 아님).
//  ⚠️ 기본값 50 = 기존 recentBars 기본값 50 + 동일 소스 src → 기본 상태에서 밴드워킹 판정이 수정 전과 비트 단위로 동일(거동 100% 보존).
//  ipBwSlopeLen/ipBwWalkSlopeLen(기울기 lookback)은 그대로 유지(이미 별도 파라미터).
bwRecentBars = input.int(defval=50, title="[밴드워킹] Recent Bars (판정 전용 VWAP)", minval=1, group=IP_GROUP, active=ipShowMarkers and ipBwSuppress and anchorMode == "Recent Bars", display=display.none, tooltip="밴드워킹 억제 판정 전용 window. 화면 VWAP의 Recent Bars와 독립.")

// =========================
// OBV DI 게이트 설정 — 변곡 마커 표시 게이트(3봉 hlc3 평균 게이트를 대체). CEO 지시.
//  OBV-ADX 보조지표(obv-adx-extreme-background.pine)의 DI+/DI-(OBV 기반 커스텀 산식)를 이식한다.
//  숏 변곡 마커는 DI- 우위(diMinus > diPlus), 롱 변곡 마커는 DI+ 우위(diPlus > diMinus)일 때만 표시한다.
//  ⚠️ input 기본값은 OBV-ADX 원본(20)보다 짧게 잡는다(DI Length=5, ADX Smoothing=5) — DI 우위 반응을 빠르게 하기 위함. 표시 게이트 전용 — 매매 전략(진입·청산·임계)과 무관.
// =========================
DI_GROUP = "OBV DI 게이트"
// DI Length — DI+/DI- 계산의 유일한 실제 파라미터(EMA·표준편차 길이). OBV-ADX 원본 len(20)보다 짧은 5가 기본 — DI 우위 반응이 빨라진다.
obvDiLen = input.int(5, minval=1, title="DI Length", group=DI_GROUP, active=ipShowMarkers, tooltip="OBV 기반 DI+/DI- 계산에 쓰는 길이(EMA·표준편차 window). 기본 5(OBV-ADX 원본 20보다 짧아 DI 우위 반응이 빠릅니다).")
// ADX Smoothing — OBV-ADX 원본 lensig(20)에 대응하는 옵션이며 기본 5로 짧게 잡는다. auto-vwap 마커 게이트는 DI 우위만 보므로 ADX 자체는 쓰지 않지만,
//  OBV-ADX와 input 정합(동일 옵션 구성)을 위해 유지한다(계산부에서 값은 산출하되 게이트엔 미사용).
obvAdxSmooth = input.int(5, minval=1, maxval=50, title="ADX Smoothing", group=DI_GROUP, active=ipShowMarkers, display=display.none, tooltip="OBV-ADX 원본 lensig(20)에 대응하는 옵션(기본 5). 변곡 마커 게이트는 DI 우위(DI+/DI-)만 사용하므로 ADX 값은 게이트에 쓰이지 않습니다.")
// OBV 에너지 평균 길이 — 변곡 마커 색 채도(강/약) 판정용. auto-vwap 마커용으로 기본 5(짧게)로 잡는다(반응 빠름). obvDiLen(기본 5)과 결이 맞음.
//  에너지 강/약 = OBV 방향 격차 |diPlus−diMinus|(=obv-adx의 |diDiff|)가 그 평균 이상/이하인가 + 3봉 전 대비 감소 여부.
//  ⚠️ 산식 구조는 obv-adx-extreme-background.pine 상태판(L79-82)의 energyFading과 동일(평균 대비 OR 3봉 전 모멘텀). 평균 창만 obvEnergyLen(auto-vwap 기본 5, obv-adx 기본 14)로 다르게 두고, 3봉 전 [3] 룩백은 obv-adx와 동일한 고정 상수. 표시 전용(마커 색 채도만) — 판정·표시 여부와 무관.
obvEnergyLen = input.int(5, minval=1, title="OBV 에너지 평균 길이", group=DI_GROUP, active=ipShowMarkers, display=display.none, tooltip="변곡 마커 색 채도(강/약) 판정용. OBV 방향 격차 |DI+−DI-|가 이 길이의 평균 이상이고 3봉 전보다 줄지 않았으면 '강(선명)', 아니면 '약(둔탁)'으로 마커 채도를 나눕니다. 평균만 obvEnergyLen(기본 5)로 짧게, 3봉 전 대비 모멘텀은 obv-adx 상태판과 동일한 고정 [3] 룩백입니다. 마커 표시 여부·판정은 바뀌지 않는 표시 전용 옵션입니다.")

// 기본 화면용 VWAP 세트(length=50, 소스=src) — 화면 plot·밴드·라벨의 기준. 소스는 기존 화면 VWAP src(기본 hlc3) 유지 → 거동 불변.
[vwapValue, upperBandValue1, lowerBandValue1, upperBandValue2, lowerBandValue2, shouldPlot] = computeVwapSet(recentBars, src)
// 변곡 지점 판정용 VWAP 세트(length=ipRecentBars, 소스=ipSrc) — 변곡 지점 마커 판정에만 쓰는 독립 window·소스·밴드2/VWAP. ipSrc 기본 hlc3 → 거동 불변.
[ipVwapValue, ipUpperBandValue1, ipLowerBandValue1, ipUpperBandValue2, ipLowerBandValue2, ipShouldPlot] = computeVwapSet(ipRecentBars, ipSrc)
// 밴드워킹 판정 전용 VWAP 세트(length=bwRecentBars, 소스=src) — 화면 세트와 독립(CEO 지시 판단 A). 소스는 화면과 동일 src → 기본값(50, src)에서 화면 세트와 동일 궤적.
//  ⚠️ 튜플 변수는 bw* 접두어로 명명해 화면 세트(vwapValue/…)·변곡 세트(ipVwapValue/…)와 이름 충돌 없음. 아래 밴드워킹 블록이 이 세트를 참조한다.
[bwVwapValue, bwUpperBandValue1, bwLowerBandValue1, bwUpperBandValue2, bwLowerBandValue2, bwShouldPlot] = computeVwapSet(bwRecentBars, src)

// =========================
// 밴드워킹(추세 국면) 판정 — 이치모쿠 advanced-ichimoku.pine "VWAP 상태" 알고리즘(원본 vwUpperWalk/vwLowerWalk)의 이식(포팅).
//  ⚠️ 기준 세트: 밴드워킹 판정 전용 VWAP 세트(length=bwRecentBars, 소스=src) — bwVwapValue/bwUpperBandValue1·2/bwLowerBandValue1·2/bwShouldPlot.
//   원본 이치모쿠는 자체 VWAP(recentBars=50, hlc3) 한 세트로만 밴드워킹을 판정하므로, auto-vwap에서도 "화면상 추세 국면"을
//   대변하는 세트(기본 length=50)에 매핑하는 것이 원본 의미(넓은 추세 판정)와 정합. 변곡용 세트(length=20)는 단기 발동용이라 부적합.
//  ⚠️ 버그 교정(CEO 판단 A): 이전엔 화면 세트(recentBars, src)를 참조했다 → recentBars(화면 표시 전용)를 바꾸면 밴드워킹→마커 표시 여부가 오염됐다.
//   전용 window(bwRecentBars)로 분리. 기본값 50 + 동일 소스 src라 기본 상태에서 화면 세트와 동일 궤적 → 밴드워킹 판정 거동 불변.
//  대응 매핑(이치모쿠 원본 → auto-vwap):
//   vwapValue→bwVwapValue · vwUpper1/vwLower1→bwUpperBandValue1/bwLowerBandValue1 · vwUpper2/vwLower2→bwUpperBandValue2/bwLowerBandValue2 · vwHasVwap→bwHasVwap.
//  파라미터: vwSlopeLen→ipBwSlopeLen(5) · vwWalkSlopeLen→ipBwWalkSlopeLen(3) · 평탄 임계 3%→ipBwFlatPct(0.03). 원본과 동일.
//  ⚠️ 확정 성격 값(과거참조 [n])만 참조 → 신규 리페인팅 없음. 표시 억제 전용(전략 로직 불변).
// =========================
bwHasVwap = bwShouldPlot and not na(bwVwapValue)
bwNearLower = bwHasVwap and not na(bwLowerBandValue1) and close < bwLowerBandValue1
bwNearUpper = bwHasVwap and not na(bwUpperBandValue1) and close > bwUpperBandValue1
bwBw2 = bwHasVwap and not na(bwUpperBandValue2) and not na(bwLowerBandValue2) ? bwUpperBandValue2 - bwLowerBandValue2 : na
bwSlope = bwHasVwap and not na(bwVwapValue[ipBwSlopeLen]) ? bwVwapValue - bwVwapValue[ipBwSlopeLen] : na
// 평탄 판정 임계 = 밴드폭의 ipBwFlatPct(기본 3%). 기울기가 이보다 작으면 평탄.
bwFlatThresh = not na(bwBw2) ? bwBw2 * ipBwFlatPct : na
bwSlopeUp = not na(bwSlope) and not na(bwFlatThresh) and bwSlope > bwFlatThresh
bwSlopeDown = not na(bwSlope) and not na(bwFlatThresh) and bwSlope < -bwFlatThresh
bwSlopeFlat = bwHasVwap and not bwSlopeUp and not bwSlopeDown
bwExpanding = bwHasVwap and not na(bwBw2[ipBwSlopeLen]) and bwBw2 > bwBw2[ipBwSlopeLen]
bwContracting = bwHasVwap and not na(bwBw2[ipBwSlopeLen]) and bwBw2 < bwBw2[ipBwSlopeLen]
bwPreWalk = bwContracting or bwSlopeFlat or bwContracting[1] or bwContracting[2]
bwUpBreakout = bwPreWalk and close > open and not na(bwUpperBandValue2) and close > bwUpperBandValue2
bwDownBreakout = bwPreWalk and close < open and not na(bwLowerBandValue2) and close < bwLowerBandValue2
bwLowerRising = bwHasVwap and not na(bwLowerBandValue2[ipBwWalkSlopeLen]) and bwLowerBandValue2 > bwLowerBandValue2[ipBwWalkSlopeLen]
bwUpperFalling = bwHasVwap and not na(bwUpperBandValue2[ipBwWalkSlopeLen]) and bwUpperBandValue2 < bwUpperBandValue2[ipBwWalkSlopeLen]
var int bwWalk = 0
if bwWalk == 1 and (not bwHasVwap or bwUpperFalling)
    bwWalk := 0
if bwWalk == -1 and (not bwHasVwap or bwLowerRising)
    bwWalk := 0
if bwUpBreakout
    bwWalk := 1
if bwDownBreakout
    bwWalk := -1
// 위(상승) 밴드워킹 / 아래(하락) 밴드워킹 — 이치모쿠 원본 vwUpperWalk/vwLowerWalk 동일 산식(추가 게이트 없음).
isUpBandWalking = bwWalk == 1 or (bwExpanding and bwSlopeUp and bwNearUpper)
isDownBandWalking = bwWalk == -1 or (bwExpanding and bwSlopeDown and bwNearLower)

isLowerBand2Break = shouldPlot and showBand_2 and not na(lowerBandValue2) and low < lowerBandValue2
isUpperBand2Break = shouldPlot and showBand_2 and not na(upperBandValue2) and high > upperBandValue2
// Rare wide-range candles can sweep both sides; bias the highlight toward the close vs VWAP.
color breakHighlightLineColor = DEFAULT_LINE_COLOR
if isLowerBand2Break and not isUpperBand2Break
    breakHighlightLineColor := LOWER_BREAK_LINE_COLOR
else if isUpperBand2Break and not isLowerBand2Break
    breakHighlightLineColor := UPPER_BREAK_LINE_COLOR
else if isLowerBand2Break and isUpperBand2Break
    breakHighlightLineColor := close <= vwapValue ? LOWER_BREAK_LINE_COLOR : UPPER_BREAK_LINE_COLOR

color activeLineColor = enableDynamicLineColor ? breakHighlightLineColor : DEFAULT_LINE_COLOR
color activeFillColor = color.new(activeLineColor, 92)

// =========================
// VWAP 중앙선 지지/저항 색 판정(CEO 개정 7규칙 — 전면 재작성). 화면 기본 VWAP 선(vwapValue) 전용.
//  판정에 쓰는 open/high/low/close·vwapValue·밴드1은 모두 현재봉의 확정 성격 값이다(과거 봉은 이미 확정, 형성 중 현재봉만 실시간).
//   → 과거 봉 색은 재계산돼도 값이 불변이라 리페인팅(과거 변조) 없음. 형성 중 현재봉은 고저·종가 확정 전 색이 바뀔 수 있으나(정상적 인트라바 갱신), 봉 마감 시 확정된다.
//  근처 범위(밴드1 기준, p=규칙3 동적값 vwapNearMinPct~vwapNearMaxPct/100, 기본 0.10~0.30):
//   nearUpper = vwapValue + p×(upperBandValue1 − vwapValue),  nearLower = vwapValue − p×(vwapValue − lowerBandValue1).
//   [규칙3] p 산출: bandWidth1=upperBandValue1−lowerBandValue1; r=bandWidth1/vwapValue; t=clamp((r−rLow)/(rHigh−rLow),0,1); nearPct=maxPct−t×(maxPct−minPct); p=clamp(nearPct,0,100)/100.
//    rLow=vwapNearRLowPct/100(저변동성 임계·기본 0.5%), rHigh=vwapNearRHighPct/100(고변동성 임계·기본 2.0%). r 작을수록(밴드 좁을수록) p 큼(넓은 근처), r 클수록 p 작음(좁은 근처) — 반비례.
//  시가 구간(실수 전체 커버·상호배타): open<nearLower / nearLower≤open<vwap / open==vwap(중립) / vwap<open≤nearUpper / open>nearUpper.
//  ▸ 저항 계열(시가 VWAP 아래쪽 출발, 위로 시도):
//     [A] open<nearLower :
//         close>nearUpper                        → 저항실패(녹, CEO #2)
//         close<nearLower AND high≥nearLower     → 저항(빨강, CEO 규칙1). 되밀림 저항 확정: 종가는 하단근처 아래로 마감했으나 고가가 하단근처 이상 닿았다 되밀림(구멍 X-A 확정분).
//         high≤vwap AND nearLower≤close≤vwap     → 저항(빨강, CEO #4). 종가가 하단근처 범위(nearLower~vwap)까지 올라온 저항만 인정.
//         vwap<close≤nearUpper                   → 중립(흰, CEO #3)
//         close<nearLower AND high<nearLower     → 중립(흰, CEO 추가규칙·미진입) ← 하단근처 근처조차 못 닿고 아래로 마감 → 지지/저항 아님. (규칙1로 세분: high≥nearLower면 저항, 미만이면 흰)
//         nearLower≤close≤vwap AND high>vwap     → 중립(흰, 구멍 X-A 잔여) ← 위꼬리로 VWAP 위 찔렀다 근처 범위로 되밀림, CEO 미정의 → (i) 중립 유지
//     [B] nearLower≤open<vwap :
//         close>nearUpper                        → 저항실패(녹, CEO #5)
//         close≤vwap                             → 저항(빨강, CEO 통합규칙 B) ← 하단근처 안 출발 후 종가가 VWAP 이하면 high 무관 저항. 하단근처 위치(nearLower≤close≤vwap, 구 #6)와 하단근처 아래 이탈(close<nearLower, 구 B+) 모두 흡수. (기존 high≤vwap 위꼬리 가드 제거 → 위꼬리로 고가가 VWAP 넘어도 저항 유지)
//         나머지(vwap<close≤nearUpper)           → 중립(흰) ← 종가가 VWAP 위·상단근처 이하 되밀림
//  ▸ 지지 계열(시가 VWAP 위쪽 출발, 아래로 시도 — 저항의 정확한 거울상: 고↔저, 상↔하, 돌파↔이탈, 녹↔빨강 규약만 지지=녹/지지실패=빨강):
//     [C] open>nearUpper :
//         close<nearLower                        → 지지실패(빨강, #2 거울)
//         close>nearUpper AND low≤nearUpper      → 지지(녹, CEO 규칙2·규칙1 거울). 되밀림 지지 확정: 종가는 상단근처 위로 마감했으나 저가가 상단근처 이하 닿았다 되밀림(구멍 X-C 확정분).
//         low≥vwap AND vwap≤close≤nearUpper      → 지지(녹, #4 거울). 종가가 상단근처 범위(vwap~nearUpper)까지 내려온 지지만 인정.
//         nearLower≤close<vwap                   → 중립(흰, #3 거울)
//         close>nearUpper AND low>nearUpper      → 중립(흰, CEO 추가규칙·미진입) ← 상단근처 근처조차 못 닿고 위로 마감 → 지지/저항 아님. (규칙2로 세분: low≤nearUpper면 지지, 초과면 흰)
//         vwap≤close≤nearUpper AND low<vwap      → 중립(흰, 구멍 X-C 잔여, 아래꼬리 되밀림) → (i) 중립 유지
//     [D] vwap<open≤nearUpper :
//         close<nearLower                        → 지지실패(빨강, #5 거울)
//         close≥vwap                             → 지지(녹, CEO 통합규칙 D) ← 상단근처 안 출발 후 종가가 VWAP 이상이면 low 무관 지지. 상단근처 위치(vwap≤close≤nearUpper, 구 #6 거울)와 상단근처 위 이탈(close>nearUpper, 구 D+) 모두 흡수. (기존 low≥vwap 아래꼬리 가드 제거 → 아래꼬리로 저가가 VWAP 밑으로 내려가도 지지 유지)
//         나머지(nearLower≤close<vwap)           → 중립(흰) ← 종가가 VWAP 아래·하단근처 이상 되밀림
//  색 규약: 지지=녹 / 지지실패=빨강 / 저항=빨강 / 저항실패=녹 / 그 외 전부 중립(흰).
//  ★ 구멍 처리: [A]/[C]의 위/아래꼬리 되밀림 중 규칙1/2(close가 하단근처 아래/상단근처 위로 마감 AND high≥nearLower/low≤nearUpper 로 근처 닿음)는 저항/지지 확정(구멍 X-A/X-C 확정분). 잔여(nearLower≤close≤vwap 위꼬리·vwap≤close≤nearUpper 아래꼬리)만 (i) 중립. [B]/[D]는 통합규칙 B/D(close≤vwap·close≥vwap)가 고저 무관으로 전부 흡수(X-B/X-D 및 위/아래꼬리 되밀림 포함).
//  ★ CEO 규칙1/2(되밀림 저항/지지 세분): [A] open<nearLower AND close<nearLower 를 high로 세분 → high≥nearLower(고가가 하단근처 닿음)면 저항(빨강), high<nearLower(못 닿음)면 중립(흰·미진입). [C] open>nearUpper AND close>nearUpper 를 low로 세분 → low≤nearUpper(저가가 상단근처 닿음)면 지지(녹), low>nearUpper(못 닿음)면 중립(흰·미진입).
//     취지: 근처 아래/위로 마감했어도 고가/저가가 근처에 닿았다 되밀렸으면 되밀림 저항/지지로 인정. 근처 근처조차 못 닿았으면 미진입 중립. (기존 close<nearLower→일괄 흰 / close>nearUpper→일괄 흰 을 high/low 기준으로 세분)
//  ★ CEO 통합규칙 B/D(근처 안 출발 → 종가 VWAP 기준·고저 무관 저항/지지 확정): [B] nearLower≤open<vwap AND close≤vwap → 저항(빨강, high 무관). [D] vwap<open≤nearUpper AND close≥vwap → 지지(녹, low 무관).
//     취지: 근처 안에서 출발해 종가가 VWAP를 넘지 못하면([B]) / 넘어서면([D]) 위/아래꼬리 되밀림과 무관하게 저항/지지로 확정. 구 #6(근처 위치)와 구 B+/D+(근처 반대편 이탈)를 하나로 통합, 기존 high≤vwap/low≥vwap 위·아래꼬리 가드 제거(위꼬리로 고가가 VWAP 넘어도 [B] 저항 유지·아래꼬리로 저가가 VWAP 밑이어도 [D] 지지 유지). → [B]는 close≤vwap 단일 분기, [D]는 close≥vwap 단일 분기.
//   → 모든 (시가,고가,저가,종가) 조합이 정확히 한 색으로 결정(상호배타·구멍 없음). strict/등호는 아래 부등호대로 엄밀히 적용.
//  엣지케이스: (a) open==vwap(경계) → 어느 계열도 아님 → 흰색. (b) 밴드1/vwap na(워밍업) → 흰색. (c) 밴드1 편차 0(도지) → bandWidth1=0 → r=0(≤rLow)이라 규칙3은 최대 % 반환하나 nearUpper==vwap·nearLower==vwap로 근처 구간이 소멸, strict 부등호가 자연 차단 → 흰색.
//  [규칙3 폴백] rHigh≤rLow(임계 뒤집힘)나 vwap==0(r na)이면 보간 불가 → nearPct=최대 %(넓은 근처, 판정 보수화). 최종 p는 clamp[0,100]로 범위 보장.
//  enableDynamicLineColor(밴드2 이탈 녹/빨강)와 독립한 별도 VWAP 선 전용 색이다.
// =========================
color vwapSRColor = DEFAULT_LINE_COLOR
if enableVwapSRColor and shouldPlot and not na(vwapValue) and not na(upperBandValue1) and not na(lowerBandValue1)
    // [규칙 3] 근처 % 동적화(밴드폭 반비례). 밴드폭/VWAP 비율 r을 rLow~rHigh 사이에서 정규화 → maxPct~minPct로 반비례 매핑.
    //  r≤rLow(저변동성)→maxPct(넓은 근처), r≥rHigh(고변동성)→minPct(좁은 근처). clamp로 범위 보장. 모두 확정봉 세트값 → 리페인팅 없음.
    float bandWidth1 = upperBandValue1 - lowerBandValue1          // 밴드1 폭(= 2×stdev×bandMult_1)
    float rNear = vwapValue != 0 ? bandWidth1 / vwapValue : na    // 가격 대비 밴드폭 비율(종목·가격 무관 정규화)
    float rLow  = vwapNearRLowPct / 100.0                         // 저변동성 임계(입력 %→비율)
    float rHigh = vwapNearRHighPct / 100.0                        // 고변동성 임계(입력 %→비율)
    // 임계가 뒤집혔거나 같으면(rHigh<=rLow) 보간 불가 → 최대 %로 폴백(넓은 근처, 판정 보수화). rNear na면(vwap 0) 최대 %.
    float tNear = (na(rNear) or rHigh <= rLow) ? 0.0 : math.min(math.max((rNear - rLow) / (rHigh - rLow), 0.0), 1.0)
    float nearPct = vwapNearMaxPct - tNear * (vwapNearMaxPct - vwapNearMinPct)  // 반비례: t=0(저변동)→max, t=1(고변동)→min
    float p = math.min(math.max(nearPct, 0.0), 100.0) / 100.0     // 최종 clamp [0,100] 후 비율화
    // 근처 범위 경계(밴드1 기준). 도지(편차 0)면 nearUpper==vwap / nearLower==vwap로 수렴 → 아래 strict 부등호가 자연 차단.
    float nearUpper = vwapValue + p * (upperBandValue1 - vwapValue)
    float nearLower = vwapValue - p * (vwapValue - lowerBandValue1)
    // 시가 출발 구간(상호배타·전체 커버). open==vwap은 어디에도 안 들어감(중립).
    bool openBelowNear = open < nearLower                        // [A] 하단 근처 범위 아래
    bool openInLower   = open >= nearLower and open < vwapValue  // [B] 하단 근처 범위 안(경계 nearLower 포함 ~ vwap 미만)
    bool openInUpper   = open > vwapValue and open <= nearUpper  // [D] 상단 근처 범위 안(vwap 초과 ~ nearUpper 포함)
    bool openAboveNear = open > nearUpper                        // [C] 상단 근처 범위 위
    // 저항 계열(시가 VWAP 아래쪽). [B] 저항실패(녹)=close>nearUpper, 저항(빨강)=close≤vwap(고저 무관·통합규칙 B), 그 외(vwap<close≤nearUpper) 중립(흰).
    if openBelowNear                                             // [A] CEO #2·#3·#4 + 규칙1(X-A 확정) + 구멍 잔여 + 추가규칙(하단근처 미진입)
        if close > nearUpper
            vwapSRColor := LOWER_BREAK_LINE_COLOR   // 저항실패(녹) — CEO #2
        else if close < nearLower and high >= nearLower
            vwapSRColor := UPPER_BREAK_LINE_COLOR   // 저항(빨강) — CEO 규칙1. open<nearLower→종가도 nearLower 아래(close<nearLower)로 마감했지만 고가가 하단근처 이상(high≥nearLower) 닿았다 되밀림 → 되밀림 저항 확정.
        else if high <= vwapValue and close <= vwapValue and close >= nearLower
            vwapSRColor := UPPER_BREAK_LINE_COLOR   // 저항(빨강) — CEO #4. 단 종가가 nearLower~vwap(하단근처 범위)까지 올라온 저항만.
        // else: CEO #3(vwap<close≤nearUpper) 또는 구멍 X-A(nearLower≤close≤vwap AND high>vwap 위꼬리 되밀림) 또는 규칙1 잔여(close<nearLower AND high<nearLower: 하단근처 근처조차 못 닿음 → 미진입 흰색) → 흰색(중립)
    else if openInLower                                          // [B] CEO #5·#6 + B+ + 미정의 구간
        if close > nearUpper
            vwapSRColor := LOWER_BREAK_LINE_COLOR   // 저항실패(녹) — CEO #5
        else if close <= vwapValue
            vwapSRColor := UPPER_BREAK_LINE_COLOR   // 저항(빨강) — CEO 통합규칙 B. 하단근처 안 출발 후 close≤vwap이면(하단근처 위치 #6 + 하단근처 아래 이탈 B+ 모두) high 무관 저항. (기존 high≤vwap 가드 제거·구멍 X-B 흡수)
        // else: vwap<close≤nearUpper(종가가 VWAP 위·상단근처 이하 되밀림) → 흰색(중립)
    // 지지 계열(시가 VWAP 위쪽) — 저항 계열의 정확한 거울상(고↔저·상↔하·돌파↔이탈).
    else if openAboveNear                                        // [C] #2·#3·#4 거울 + 규칙2(X-C 확정, 규칙1 거울) + 구멍 잔여 + 추가규칙(상단근처 미진입)
        if close < nearLower
            vwapSRColor := UPPER_BREAK_LINE_COLOR   // 지지실패(빨강) — #2 거울
        else if close > nearUpper and low <= nearUpper
            vwapSRColor := LOWER_BREAK_LINE_COLOR   // 지지(녹) — CEO 규칙2(규칙1 거울). open>nearUpper→종가도 nearUpper 위(close>nearUpper)로 마감했지만 저가가 상단근처 이하(low≤nearUpper) 닿았다 되밀림 → 되밀림 지지 확정.
        else if low >= vwapValue and close >= vwapValue and close <= nearUpper
            vwapSRColor := LOWER_BREAK_LINE_COLOR   // 지지(녹) — #4 거울. 단 종가가 vwap~nearUpper(상단근처 범위)까지 내려온 지지만.
        // else: (#3 거울: nearLower≤close<vwap) 또는 구멍 X-C(vwap≤close≤nearUpper AND low<vwap 아래꼬리 되밀림) 또는 규칙2 잔여(close>nearUpper AND low>nearUpper: 상단근처 근처조차 못 닿음 → 미진입 흰색) → 흰색(중립)
    else if openInUpper                                          // [D] #5·#6 거울 + D+ + 미정의 구간
        if close < nearLower
            vwapSRColor := UPPER_BREAK_LINE_COLOR   // 지지실패(빨강) — #5 거울
        else if close >= vwapValue
            vwapSRColor := LOWER_BREAK_LINE_COLOR   // 지지(녹) — CEO 통합규칙 D. 상단근처 안 출발 후 close≥vwap이면(상단근처 위치 #6 + 상단근처 위 이탈 D+ 모두) low 무관 지지. (기존 low≥vwap 가드 제거·구멍 X-D 흡수)
        // else: nearLower≤close<vwap(종가가 VWAP 아래·하단근처 이상 되밀림) → 흰색(중립)
    // 그 외(open==vwap 경계 등) → 흰색 유지(중립).
// 최종 VWAP 선 색: 지지/저항 규칙 ON이면 그 색(중립이면 흰색), OFF면 기존 activeLineColor(동적색 옵션 거동 보존).
color vwapLineColor = enableVwapSRColor ? vwapSRColor : activeLineColor

// =========================
// 샹들리에 청산선(스윕/청산) — 이치모쿠 advanced-ichimoku.pine 의 로직을 그대로 이식(값 계산 전용).
//  - longCE  : 가격 아래쪽 스윕(샹들리에, ta.highest - ATR, 상향 트레일). longClear = 그 너머(더 아래).
//  - shortCE : 가격 위쪽 스윕(샹들리에, ta.lowest + ATR, 하향 트레일). shortClear = 그 너머(더 위).
//  - 산식·파라미터 기본값(기간 22, ATR 배수 3.0, 버퍼 0.4, 피벗 5, 최대간격 1.0)은 이치모쿠와 동일.
//  - 스윕 가격 모드(ceMode)도 이치모쿠와 동일: 기본 / 거래량 가중(VWMA) / 최근봉 가중(WMA) / 거래량+최근봉(f_volRecencyMa).
//    기본값은 이치모쿠와 동일하게 "기본". 가중 모드 선택 시 청산선(longCE/shortCE→longClear/shortClear)이 그 가중 앵커 기준으로 계산됨.
//  - 확정 성격 값(ta.*)·과거참조([1] 트레일)만 사용 → 이치모쿠와 동일하게 신규 리페인팅 없음.
//    가중 모드도 앵커를 직전 봉([1]) 기준으로 잡아(형성 중 현재봉 제외) 이치모쿠와 동일한 확정 성격 유지.
//  - 청산선(longClear/shortClear)은 computeClearLines 헬퍼로 계산한다. 파라미터 세트는 "스윕/청산" 그룹(기본 청산 설정) 하나뿐이다(CEO 지시 #4: 변곡 전용 세트 삭제).
//    · 화면 페인팅: mode=ceMode 세트를 plot 으로 전 히스토리 봉에 직접 그린다(이치모쿠에서 이동).
//    · 변곡 마커 후보 판정: 같은 파라미터로 mode만 "기본"·"거래량 가중"·"최근봉 가중" 3가지로 각각 계산해 OR로 확인한다(#1·#2).
//    스윕라인(longCE/shortCE)은 여기로 옮기지 않는다(그리지 않음).
// =========================
ceLength = input.int(14, title="스윕 룩백 길이", minval=1, group="스윕/청산")
ceAtrLen = input.int(14, title="스윕 ATR 길이", minval=1, group="스윕/청산")
ceMult = input.float(3.0, title="스윕 ATR 배수", minval=0.0, step=0.01, group="스윕/청산")
// 스윕 가격 모드(샹들리에 기반):
//  - 기본: 표준 샹들리에(룩백 고가/저가 − ATR)
//  - 거래량 가중: 거래량 큰 봉(VWMA)에 가중 → 거래 몰린 봉에서 스윕가를 끌어올림
//  - 최근봉 가중: 최근봉(WMA)에 가중 → 휩쏘 급등/급락 봉에서 스윕가를 빠르게·높게
//  - 거래량+최근봉: 두 가중을 함께(거래량 × 선형 최근봉)
ceMode = input.string("최근봉 가중", title="스윕 가격 모드", options=["기본", "거래량 가중", "최근봉 가중", "거래량+최근봉"], group="스윕/청산")
ceWeightLen = input.int(14, title="가중 트레일 길이", minval=1, group="스윕/청산")
ceWeightMult = input.float(3.0, title="가중 트레일 ATR 배수", minval=0.0, step=0.01, group="스윕/청산")
sweepBufferMult = input.float(1.0, title="청산 버퍼 ATR 배수(스윕 너머)", minval=0.0, step=0.1, group="스윕/청산")
useSweepPivot = input.bool(true, title="청산에 스윙 풀(피벗) 반영", group="스윕/청산")
sweepPivotLen = input.int(5, minval=1, title="스윙 풀 좌우 봉수", group="스윕/청산")
sweepMaxGapMult = input.float(1.0, title="청산-스윕 최대 간격 ATR 배수", minval=0.1, step=0.1, group="스윕/청산")
// 청산선(직선=손절 기준선) 차트 페인팅 옵션 — 이치모쿠에서 이 지표로 이동(CEO 지시).
//  청산선(longClear/shortClear)만 전 히스토리 봉에 plot으로 그린다(스윕라인 longCE/shortCE는 여기로 옮기지 않음).
//  ⚠️ 이 "스윕/청산" 그룹의 청산선은 화면 plot 전용이다. 변곡 지점(밴드2 마커) 판정은 "변곡 지점" 그룹의 독립 청산선 세트를 쓴다(CEO 지시: 세트 완전 독립).
showClearLines = input.bool(true, title="청산선 표시(전 히스토리 봉)", group="스윕/청산", tooltip="롱/숏 청산선(직선=손절 기준선)을 차트 전 구간 봉마다 plot으로 그립니다. 스윕라인(점선)은 이 지표에 없습니다(이치모쿠 전략 전용).")
clearLineWidth = input.int(1, title="청산 선 두께", minval=1, group="스윕/청산", active=showClearLines)
longClearLineColor = input.color(#00C853, title="롱 청산선 색", group="스윕/청산", active=showClearLines, tooltip="청산선(직선=손절 기준선)의 롱 색. 값 계산·밴드2 색 판정에는 영향 없는 표시 옵션입니다.")
shortClearLineColor = input.color(#FF1744, title="숏 청산선 색", group="스윕/청산", active=showClearLines, tooltip="청산선(직선=손절 기준선)의 숏 색. 값 계산·밴드2 색 판정에는 영향 없는 표시 옵션입니다.")

// 거래량 × 최근봉(선형) 가중 평균
f_volRecencyMa(src, len) =>
    float num = 0.0
    float den = 0.0
    for i = 0 to len - 1
        float w = volume[i] * (len - i)
        num += src[i] * w
        den += w
    den != 0 ? num / den : src

// 청산선(longClear/shortClear) 계산 헬퍼 — 이치모쿠에서 이식한 산식을 그대로 함수화(값 불변).
//  각 호출은 독립 var/ta 상태를 가지므로 화면 페인팅용(mode=ceMode)과 후보 판정용 3모드(기본/거래량/최근봉) 세트를 안전히 병렬 계산할 수 있다.
//  반환: [longClear, shortClear]. 확정 성격 값(ta.*·과거참조 [1] 트레일)만 사용 → 신규 리페인팅 없음.
computeClearLines(int ceLen, int atrLen, float mult, string mode, int wLen, float wMult, float bufMult, bool usePivot, int pivotLen, float maxGapMult) =>
    atrCe = ta.atr(atrLen)   // 한 번만 계산해 ceAtrVal·weightAtr·sweepAtr에서 재사용(중복 ta.atr 제거)
    ceAtrVal = mult * atrCe
    // 모드별 앵커 — 활성 모드에 필요한 것만 계산(기본 모드에선 VWMA/WMA/가중루프 모두 생략 → 속도↑).
    // 가중 모드(거래량/최근봉/거래량+최근봉)는 형성 중인 현재봉을 제외하고 **직전 봉 기준**([1])으로 앵커를 잡는다.
    longAnchorWNow = mode == "거래량 가중" ? ta.vwma(high, wLen) : mode == "최근봉 가중" ? ta.wma(high, wLen) : mode == "거래량+최근봉" ? f_volRecencyMa(high, wLen) : na
    shortAnchorWNow = mode == "거래량 가중" ? ta.vwma(low, wLen) : mode == "최근봉 가중" ? ta.wma(low, wLen) : mode == "거래량+최근봉" ? f_volRecencyMa(low, wLen) : na
    longAnchorW = longAnchorWNow[1]
    shortAnchorW = shortAnchorWNow[1]
    weightAtr = wMult * atrCe
    longCERaw = mode == "기본" ? ta.highest(high, ceLen) - ceAtrVal : longAnchorW - weightAtr
    shortCERaw = mode == "기본" ? ta.lowest(low, ceLen) + ceAtrVal : shortAnchorW + weightAtr
    var float longCE = na
    longCEPrev = nz(longCE[1], longCERaw)
    longCE := close[1] > longCEPrev ? math.max(longCERaw, longCEPrev) : longCERaw
    var float shortCE = na
    shortCEPrev = nz(shortCE[1], shortCERaw)
    shortCE := close[1] < shortCEPrev ? math.min(shortCERaw, shortCEPrev) : shortCERaw

    sweepAtr = atrCe
    sweepPLow = ta.pivotlow(pivotLen, pivotLen)
    sweepPHigh = ta.pivothigh(pivotLen, pivotLen)
    var float lastSweepPLow = na
    var float lastSweepPHigh = na
    lastSweepPLow := not na(sweepPLow) ? sweepPLow : lastSweepPLow
    lastSweepPHigh := not na(sweepPHigh) ? sweepPHigh : lastSweepPHigh
    float longClearLocal = longCE - bufMult * sweepAtr
    longClearLocal := usePivot and not na(lastSweepPLow) ? math.min(longClearLocal, lastSweepPLow - syminfo.mintick) : longClearLocal
    longClearLocal := math.max(longClearLocal, longCE - maxGapMult * sweepAtr)
    float shortClearLocal = shortCE + bufMult * sweepAtr
    shortClearLocal := usePivot and not na(lastSweepPHigh) ? math.max(shortClearLocal, lastSweepPHigh + syminfo.mintick) : shortClearLocal
    shortClearLocal := math.min(shortClearLocal, shortCE + maxGapMult * sweepAtr)
    [longClearLocal, shortClearLocal]

// (a) 기본 청산선 세트(화면 페인팅용) — mode=ceMode. 화면에 plot으로 그려진다(전 히스토리 봉).
//  ⚠️ 이 세트(ceMode)는 화면 plot·손익비 등 표시 전용이다. 변곡 마커 판정(후보·수평필터·표시) 어디에도 쓰지 않는다(사양 1: ceMode는 페인팅 전용).
[longClear, shortClear] = computeClearLines(ceLength, ceAtrLen, ceMult, ceMode, ceWeightLen, ceWeightMult, sweepBufferMult, useSweepPivot, sweepPivotLen, sweepMaxGapMult)
// (b) 후보 판정용 3모드 청산선 세트(CEO 지시 #1·#2) — mode만 "기본"·"거래량 가중"·"최근봉 가중"으로 바꿔 각각 계산한다.
//  mode 외 파라미터(길이·ATR·배수·가중·버퍼·피벗·최대간격)는 모두 "스윕/청산" 그룹(기본 청산 설정) 공통값을 쓴다.
//  각 호출은 computeClearLines 내부 var/ta 상태가 독립이라 3세트를 안전히 병렬 계산할 수 있다.
// 변수명은 ASCII(_base=기본 / _vol=거래량 가중 / _recent=최근봉 가중)로 둔다(기존 파일 변수명 규약 유지: 한글 변수명 전례 없음).
[longClear_base, shortClear_base] = computeClearLines(ceLength, ceAtrLen, ceMult, "기본", ceWeightLen, ceWeightMult, sweepBufferMult, useSweepPivot, sweepPivotLen, sweepMaxGapMult)
[longClear_vol, shortClear_vol] = computeClearLines(ceLength, ceAtrLen, ceMult, "거래량 가중", ceWeightLen, ceWeightMult, sweepBufferMult, useSweepPivot, sweepPivotLen, sweepMaxGapMult)
[longClear_recent, shortClear_recent] = computeClearLines(ceLength, ceAtrLen, ceMult, "최근봉 가중", ceWeightLen, ceWeightMult, sweepBufferMult, useSweepPivot, sweepPivotLen, sweepMaxGapMult)
// 수평 필터용 ATR — 후보/수평 판정이 3모드 청산선(shortClear_*/longClear_*) 기준이므로 기본 스윕 ATR 길이(ceAtrLen)에 맞춘다.
//  ⚠️ ATR은 mode 무관 공통값이라 ceMode에 의존하지 않는다(모드 독립 보장의 일부).
ipFlatAtr = ta.atr(ceAtrLen)

// =========================
// 변곡 지점(Inflection Point) 판정 — 변곡용 밴드2 상/하단 선이 "기본 청산선"(3모드 OR) 안으로 들어오는지 판정한다.
//  밴드2 선 색은 기본색 고정, 변곡 순간은 마커로만 표시한다.
//  - 화면 밴드(upperBandValue2/lowerBandValue2) 위치·색은 절대 변경하지 않는다(언제나 원값 위치 + 기본 activeLineColor).
//  - 후보 판정(CEO 지시 #1·#2): 청산 설정의 가격 모드를 "기본"·"거래량 가중"·"최근봉 가중" 3가지로 각각 계산한 청산선 중
//    **1개 이상**을 밴드2가 뚫고 들어오면 후보. (숏=ipUpperBandValue2 < shortClear_m, 롱=ipLowerBandValue2 > longClear_m, m∈{기본,거래량,최근봉})
//  - 상/하단 각각 독립 판정.
// =========================
// 변곡 판정은 **변곡용 VWAP 세트(length=22)의 밴드2**(ipUpperBandValue2/ipLowerBandValue2)와 **기본 청산선 3모드**(shortClear_*/longClear_*) 기준이다.
//  마커만 판정에 쓰므로 화면 밴드 위치·색은 불변.
// 요구사항 4: 청산선 "수평(flat)" 판정 헬퍼 — 최근 lb봉 사이 변화량을 ATR로 정규화한 비율이 임계 이내이면 true.
//  atr<=0(초기·데이터 부족)일 때는 정규화가 불가능하므로 필터를 통과시키지 않는다(false).
//  na 값(과거참조 부족)일 때도 판정 불가로 false 처리.
isClearLineFlat(float lineVal, int lb, float atrVal, float maxRatio) =>
    float prevVal = lineVal[lb]
    na(lineVal) or na(prevVal) or na(atrVal) or atrVal <= 0 ? false : (math.abs(lineVal - prevVal) / atrVal) <= maxRatio
// 후보 판정(CEO 지시 #1·#2) — 3모드 OR. na 가드는 각 항에 포함. 각 모드별 "밴드2 진입" 성립 여부를 개별 bool로 둔다.
//  숏 진입_m = (ipUpperBandValue2 < shortClear_m),  롱 진입_m = (ipLowerBandValue2 > longClear_m).  m∈{기본(base),거래량(vol),최근봉(recent)}.
//  ⚠️ 3모드는 모두 computeClearLines를 mode 리터럴("기본"/"거래량 가중"/"최근봉 가중")로 고정 호출한 세트라 ceMode 선택과 무관하다.
ipUpperBand2Valid = ipShouldPlot and not na(ipUpperBandValue2)
ipLowerBand2Valid = ipShouldPlot and not na(ipLowerBandValue2)
shortEnter_base   = ipUpperBand2Valid and not na(shortClear_base)   and ipUpperBandValue2 < shortClear_base
shortEnter_vol    = ipUpperBand2Valid and not na(shortClear_vol)    and ipUpperBandValue2 < shortClear_vol
shortEnter_recent = ipUpperBand2Valid and not na(shortClear_recent) and ipUpperBandValue2 < shortClear_recent
longEnter_base    = ipLowerBand2Valid and not na(longClear_base)    and ipLowerBandValue2 > longClear_base
longEnter_vol     = ipLowerBand2Valid and not na(longClear_vol)     and ipLowerBandValue2 > longClear_vol
longEnter_recent  = ipLowerBand2Valid and not na(longClear_recent)  and ipLowerBandValue2 > longClear_recent
// 숏 후보 = OR_m ( 진입_m ),  롱 후보 = OR_m ( 진입_m ).
shortCand = shortEnter_base or shortEnter_vol or shortEnter_recent
longCand  = longEnter_base or longEnter_vol or longEnter_recent

// ── 수평 필터(밴드워킹 억제) — 모드 독립 교정(CEO 지시: ceMode가 마커에 관여 금지) ──
//  버그(교정 전): flat 판정 대상이 화면 페인팅용 shortClear/longClear(=ceMode 세트)였다 → 스윕 모드를 바꾸면 마커 발동이 바뀜(사양 1 위반).
//  교정(후보 논리와 정합): 후보에 기여한(밴드2가 들어온) 모드의 청산선이 flat일 때만 그 방향 flat 통과로 본다.
//   → 숏 flatOk = OR_m ( 진입_m AND flat(shortClear_m) ),  롱 flatOk = OR_m ( 진입_m AND flat(longClear_m) ).
//   3모드 청산선은 mode 리터럴 고정 호출이므로 ceMode 선택과 완전 무관하다. 필터 OFF면 항상 통과(기존 동작 유지).
ipUpperFlatOk = not ipFlatFilter or ((shortEnter_base and isClearLineFlat(shortClear_base, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)) or (shortEnter_vol and isClearLineFlat(shortClear_vol, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)) or (shortEnter_recent and isClearLineFlat(shortClear_recent, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)))
ipLowerFlatOk = not ipFlatFilter or ((longEnter_base and isClearLineFlat(longClear_base, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)) or (longEnter_vol and isClearLineFlat(longClear_vol, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)) or (longEnter_recent and isClearLineFlat(longClear_recent, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)))

// 표시 게이트(CEO 지시) — OBV 기반 DI+/DI- 우위. 3봉 hlc3 평균 게이트를 대체한다.
//  OBV-ADX 보조지표(obv-adx-extreme-background.pine)의 DI+/DI- 산식을 그대로 이식(값 동일, v6 정합).
//   obvValue = OBV 누적. up/down = OBV 변화량. plusDM/minusDM = 방향성 이동. trur = OBV 표준편차의 RMA(=정규화 기준).
//   diPlus = 100 * EMA(plusDM,len)/trur,  diMinus = 100 * EMA(minusDM,len)/trur.  (fixnan으로 trur==0/na 보정)
//  숏 변곡: DI- 우위(diMinus > diPlus).  롱 변곡: DI+ 우위(diPlus > diMinus).  na면 억제(둘 다 미표시).
//  ⚠️ 확정 성격 값(ta.cum/change/rma/stdev/ema)만 사용 → 신규 리페인팅 없음. 표시 게이트 전용(전략 로직 불변).
obvValue = ta.cum(math.sign(ta.change(close)) * volume)
obvUp = ta.change(obvValue)
obvDown = -ta.change(obvValue)
obvPlusDM = na(obvUp) ? na : obvUp > obvDown and obvUp > 0 ? obvUp : 0
obvMinusDM = na(obvDown) ? na : obvDown > obvUp and obvDown > 0 ? obvDown : 0
obvTrur = ta.rma(ta.stdev(obvValue, obvDiLen), obvDiLen)
diPlus = fixnan(obvTrur == 0 ? 0 : 100 * ta.ema(obvPlusDM, obvDiLen) / obvTrur)
diMinus = fixnan(obvTrur == 0 ? 0 : 100 * ta.ema(obvMinusDM, obvDiLen) / obvTrur)
// OBV 방향 격차 |diPlus−diMinus|(=obv-adx의 |diDiff|) — ADX·에너지 채도 공용. 원본 obv-adx가 diDiff를 재사용하듯 여기서도 한 번만 계산(중복 제거).
diEnergy = math.abs(diPlus - diMinus)
// ADX(OBV-ADX 원본 lensig 사용) — input 정합용으로 계산만 유지. 변곡 마커 게이트엔 미사용.
obvDiSum = diPlus + diMinus
obvAdx = 100 * ta.ema(diEnergy / (obvDiSum == 0 ? 1 : obvDiSum), obvAdxSmooth)
// DI 우위 게이트(na 가드 포함) — DI 값이 na면 해당 방향 억제.
shortDiGate = not na(diMinus) and not na(diPlus) and diMinus > diPlus
longDiGate = not na(diPlus) and not na(diMinus) and diPlus > diMinus
// ── OBV 에너지 강/약 판정(변곡 마커 색 채도 전용) — OBV-ADX 상태판 energyFading 산식 이식 ──
//  obv-adx-extreme-background.pine(L80-82): diEnergy=|diDiff|=|plus-minus|, diEnergyAvg=sma(diEnergy,obvEnergyLen),
//   energyFading = diEnergy < diEnergyAvg or diEnergy < diEnergy[3]. diEnergy는 위(obvAdx 앞)에서 이미 계산해 재사용(중복 없음).
//  평균 창은 obvEnergyLen(기본 5), 3봉 전 모멘텀 [3]은 평균과 무관한 독립 룩백(obv-adx와 동일한 고정 상수) → 평균이 짧아져도 시간축 부정합 없음.
//  energyStrong = not energyFading → '강(선명색)', energyFading → '약(둔탁색)'. na면 약으로 취급(보수적: 둔탁).
//  ⚠️ 확정 성격 값(ema/sma/과거참조[3])만 사용 → 신규 리페인팅 없음. 마커 색 채도만 바꿈(판정·표시 여부·y좌표 불변).
diEnergyAvg = ta.sma(diEnergy, obvEnergyLen)
energyFading = na(diEnergy) or na(diEnergyAvg) or diEnergy < diEnergyAvg or diEnergy < diEnergy[3]
energyStrong = not energyFading
// 채도 색 상수 — 선명색은 마커 기존 색(short/longClearLineColor), 둔탁색은 저장소 시그니처 팔레트(둔탁 녹/빨강, obv-adx 상태판과 동일).
color DULL_LONG_COLOR  = #6E8F72   // 둔탁 녹(롱 약)
color DULL_SHORT_COLOR = #A57A7A   // 둔탁 빨강(숏 약)
// 마커 색(채도 반영): 롱=강→선명 녹(longClearLineColor)/약→둔탁 녹, 숏=강→선명 빨강(shortClearLineColor)/약→둔탁 빨강.
//  ⚠️ 채도는 색만 바꾸며 마커 발동(upper2Marker/lower2Marker)에는 관여하지 않는다.
color lowerMarkerColor = energyStrong ? longClearLineColor : DULL_LONG_COLOR
color upperMarkerColor = energyStrong ? shortClearLineColor : DULL_SHORT_COLOR

// 방향성 밴드워킹 억제(ipBwSuppress) AND 결합 — 후보·수평필터·DI 우위 게이트 위에 방향 억제만 얹는다.
//  숏(빨강·상단) = 후보(3모드OR) AND 수평필터(숏) AND (DI- 우위) AND (not 상승 밴드워킹).
//  롱(녹색·하단) = 후보(3모드OR) AND 수평필터(롱) AND (DI+ 우위) AND (not 하락 밴드워킹).
//  토글 OFF면 억제 항이 항상 참 → 기존 동작 그대로.
upperBwOk = not ipBwSuppress or not isUpBandWalking
lowerBwOk = not ipBwSuppress or not isDownBandWalking
// ── VWAP 선색 AND 게이트(CEO 지시 A) — 최종 선색(vwapSRColor, 새 시가구간·종가돌파 규칙 결과) 기준 ──
//  롱(하단) 마커: 선색이 흰색 또는 녹색일 때만 표시(빨강이면 억제). 숏(상단) 마커: 선색이 흰색 또는 빨강일 때만 표시(녹색이면 억제).
//  구현: 최종 vwapSRColor를 색 상수와 비교한다(녹=LOWER_BREAK_LINE_COLOR, 빨강=UPPER_BREAK_LINE_COLOR, 흰=DEFAULT_LINE_COLOR).
//  ⚠️ 선 지지/저항 색 옵션(enableVwapSRColor) OFF이면 선색 판정 자체가 없으므로 게이트를 적용하지 않는다(기존 마커 거동 유지). ON일 때만 억제 게이트 발동.
//  선색은 확정 성격 값(open/close·vwap·밴드1) 기반이라 신규 리페인팅 없음(현재봉 실시간 변동 성격은 기존 선색과 동일).
bool srcGateLong  = not enableVwapSRColor or vwapSRColor != UPPER_BREAK_LINE_COLOR  // 롱: 빨강만 억제(흰/녹 허용)
bool srcGateShort = not enableVwapSRColor or vwapSRColor != LOWER_BREAK_LINE_COLOR  // 숏: 녹색만 억제(흰/빨강 허용)
upper2Marker = shortCand and ipUpperFlatOk and shortDiGate and upperBwOk and srcGateShort
lower2Marker = longCand and ipLowerFlatOk and longDiGate and lowerBwOk and srcGateLong
// 요구사항 1: 밴드2 상/하단 선 색은 청산선 진입에 따른 색 변경을 제거하고 기본색(activeLineColor)으로 되돌린다.
// CEO 재지시(강조 옵션 보정): "기본 vwap이 청산선 안으로 들어오고, 마커가 생길 때" 해당 밴드2를 마커색으로 강조.
//  ⚠️ 후보/마커 판정은 변곡용 밴드2(ipUpperBandValue2/ipLowerBandValue2, window=ipRecentBars 기본 10)를 3모드 청산선과 비교한다(L405-410).
//     따라서 마커(upper2Marker/lower2Marker)만으로는 "화면에 그려지는 기본 밴드2"가 청산선 안이라는 보장이 없다.
//     → 화면 세트 밴드2(upperBandValue2/lowerBandValue2)가 실제로 청산선 안인지를 별도 게이트로 명시한다.
//  기본(화면) 밴드2 "청산선 안" 판정 — 후보 판정과 동일 부등호, 화면에 그려지는 청산선(shortClear/longClear, ceMode 결과선 L372) 기준.
//   상단(숏 맥락): upperBandValue2 < shortClear  (후보 shortEnter_m = ipUpperBandValue2 < shortClear_m 와 동일 부등호).
//   하단(롱 맥락): lowerBandValue2 > longClear   (후보 longEnter_m  = ipLowerBandValue2 > longClear_m  와 동일 부등호).
//   화면에 그려지는 선(shortClear/longClear)을 기준으로 삼아 "그 vwap의 밴드2가 화면 청산선 안"이라는 CEO 취지와 정렬한다.
//   na 가드: 화면 밴드2·청산선이 유효할 때만 판정(shouldPlot·not na). 어느 한쪽이라도 na면 강조 안 함.
baseUpperBand2InClear = shouldPlot and not na(upperBandValue2) and not na(shortClear) and upperBandValue2 < shortClear
baseLowerBand2InClear = shouldPlot and not na(lowerBandValue2) and not na(longClear)  and lowerBandValue2 > longClear
//  강조 = 옵션 ON AND 마커 발동 AND 화면 밴드2가 청산선 안. 셋 다 충족해야 마커색, 아니면 기본색(activeLineColor)으로 원복.
//  마커 plotshape와 동일 색 변수(upper/lowerMarkerColor)를 재사용해 강조색·마커색 불일치를 원천 차단.
//   ⚠️ 마커색이 OBV 에너지 채도(강 선명/약 둔탁)로 나뉘므로 밴드2 강조색도 동일 채도를 따른다(같은 봉에서 마커=둔탁·밴드2=선명 불일치 방지 — 일관성).
//  봉 단위 series color 지정이므로 리페인팅 없음(마커 조건·밴드2·청산선 모두 확정 성격 값 기반).
color upperBand2LineColor = ipBand2MarkerColor and upper2Marker and baseUpperBand2InClear ? upperMarkerColor : activeLineColor
color lowerBand2LineColor = ipBand2MarkerColor and lower2Marker and baseLowerBand2InClear ? lowerMarkerColor : activeLineColor

// 사양 2(CEO 지시 변경): 마커 y좌표를 기본 화면 밴드2가 아니라 **화면에 실제 그려지는 청산선**(shortClear/longClear, ceMode 선택 결과선)에 얹는다.
//  - 숏 변곡 마커(upper2Marker) y = shortClear(숏 청산선).  롱 변곡 마커(lower2Marker) y = longClear(롱 청산선).
//  - shortClear/longClear 는 computeClearLines(ceMode 반영, 위 L367)의 확정 성격 값(ta.*·과거참조 [1] 트레일) → 신규 리페인팅 없음.
//  ⚠️ na 가드: 청산선이 na인 봉에서는 y를 na로 두어 그 봉의 마커를 **미표시**한다(밴드2 등 다른 선으로 폴백하지 않음).
//   폴백 미채택 이유: 지시 취지가 "마커를 청산선 위에 정렬"이므로 청산선이 없는데 다른 값에 얹으면 정렬이 깨진다.
//   마커 발동 조건(upper2Marker/lower2Marker)은 불변 — 위치 y좌표만 청산선으로 이동하고 na일 때만 미표시.
float upper2MarkerY = shortClear
float lower2MarkerY = longClear

// VWAP 중앙선: 두께 2px(CEO 지시 — 지지/저항 색 규칙) + 가격축 라벨은 이 선만 표시(display 기본=all). 밴드는 라벨 제외.
//  색 = vwapLineColor(지지/저항 규칙 ON이면 녹/빨강/흰색, OFF면 기존 activeLineColor).
plot(vwapValue, title="브이왑", color=vwapLineColor, offset=offset, linewidth=2, editable=true, linestyle=plot.linestyle_solid)

displayBand1 = showBand_1 ? display.all - display.price_scale : display.none
upperBand_1 = plot(upperBandValue1, title="Upper Band #1", color=activeLineColor, offset=offset, display=displayBand1, editable=true, linestyle=plot.linestyle_dotted)
lowerBand_1 = plot(lowerBandValue1, title="Lower Band #1", color=activeLineColor, offset=offset, display=displayBand1, editable=true, linestyle=plot.linestyle_dotted)
fill(upperBand_1, lowerBand_1, title="Bands Fill #1", color=activeFillColor, display=display.none, editable=true)

// 최외곽 상/하단 선(Band #2): 위치·색 모두 항상 원값/기본색(고정). 요구사항 1: 청산선 진입 색 변경 제거 + 두께 1px.
displayBand2 = showBand_2 ? display.all - display.price_scale : display.none
upperBand_2 = plot(upperBandValue2, title="Upper Band #2", color=upperBand2LineColor, offset=offset, display=displayBand2, editable=true, linewidth=1, linestyle=plot.linestyle_dashed)
lowerBand_2 = plot(lowerBandValue2, title="Lower Band #2", color=lowerBand2LineColor, offset=offset, display=displayBand2, editable=true, linewidth=1, linestyle=plot.linestyle_dashed)
// fill(±2σ 채움)은 밴드2 원값 선(upperBand_2/lowerBand_2)에 직접 붙인다. clamp 폐기로 선 자체가 항상 원값이라 별도 fill ref plot 불필요. 현재 display=none.
fill(upperBand_2, lowerBand_2, title="Bands Fill #2", color=activeFillColor, display=display.none, editable=true)

// =========================
// 변곡 지점(Inflection Point) 마커 — 요구사항 1·2·3.
//  상단(빨강): 변곡용 밴드2 상단선이 기본 청산선(3모드 OR) 안 진입 => 화면 숏 청산선(shortClear) 값 위치에 숏 청산선 색 마커.
//  하단(녹색): 변곡용 밴드2 하단선이 기본 청산선(3모드 OR) 안 진입 => 화면 롱 청산선(longClear) 값 위치에 롱 청산선 색 마커.
//  마커 색 = 기본 청산선 색(shortClearLineColor/longClearLineColor)과 동일. 모양은 옵션(기본=원). 화면 밴드2 선 위치·색은 불변(마커만 추가).
// =========================
// ⚠️ location=location.absolute + size.tiny 로 series 값 좌표에 정확히 그린다(직전 커밋 유지).
//    판정(발동 조건)은 변곡용 밴드2(ipUpperBandValue2/ipLowerBandValue2, length=22) vs 기본 청산선 3모드(shortClear_*/longClear_*)로 그대로 유지.
//    다만 y위치(그려지는 좌표)는 화면에 페인트되는 청산선(upper2MarkerY=shortClear, lower2MarkerY=longClear)에 놓아 마커가 실제 화면 청산선 위에 얹힌다(na면 미표시).
//    location.top/bottom 은 첫 인자(값)가 무시되어 창 최상/최하단에 고정되므로 쓰지 않는다.
// ⚠️ plotshape의 style은 const string만 받으므로, 모양 삼항을 style 인자에 **직접 인라인**한다(변수 저장 시 컴파일 에러).
//    각 분기가 shape.* 리터럴이라 컴파일 타임 상수로 평가된다. 기본값(원)은 첫 분기(shape.circle).
//    ⚠️ 마커 색은 OBV 에너지 강/약 채도 반영: 숏=upperMarkerColor(강→선명 빨강/약→둔탁 빨강), 롱=lowerMarkerColor(강→선명 녹/약→둔탁 녹). 색만 채도로 나뉘고 발동·모양·y좌표는 불변.
plotshape(ipShowMarkers and upper2Marker ? upper2MarkerY : na, title="변곡 지점(상단)", style=ipMarkerStyle == "원" ? shape.circle : ipMarkerStyle == "삼각형" ? shape.triangleup : ipMarkerStyle == "다이아몬드" ? shape.diamond : ipMarkerStyle == "네모" ? shape.square : shape.cross, location=location.absolute, color=upperMarkerColor, size=size.tiny, offset=offset, editable=true)
plotshape(ipShowMarkers and lower2Marker ? lower2MarkerY : na, title="변곡 지점(하단)", style=ipMarkerStyle == "원" ? shape.circle : ipMarkerStyle == "삼각형" ? shape.triangleup : ipMarkerStyle == "다이아몬드" ? shape.diamond : ipMarkerStyle == "네모" ? shape.square : shape.cross, location=location.absolute, color=lowerMarkerColor, size=size.tiny, offset=offset, editable=true)

// =========================
// 샹들리에 청산선(직선=손절 기준선) 차트 페인팅 — 이치모쿠에서 이동(CEO 지시).
//  ⚠️ "봉 전체 다 나올 수 있게"(CEO): 최근 몇 봉만 그리는 line.new 방식이 아니라 plot으로 전 히스토리 봉에 그린다.
//  longClear/shortClear 는 위 computeClearLines(기본 화면 세트)에서 매 봉 계산된 확정 성격 값(ta.*·과거참조 [1] 트레일)이라
//   plot 으로 전 구간에 그려도 신규 리페인팅이 없다(그리기 전환 시에도 값 자체는 불변).
//  스윕라인(longCE/shortCE)은 여기로 옮기지 않는다(CEO: "청산선 스윕라인은 옮기지 않음") → plot 하지 않는다.
plot(showClearLines ? longClear : na, title="롱 청산선", color=longClearLineColor, linewidth=clearLineWidth, offset=offset, editable=true, linestyle=plot.linestyle_solid)
plot(showClearLines ? shortClear : na, title="숏 청산선", color=shortClearLineColor, linewidth=clearLineWidth, offset=offset, editable=true, linestyle=plot.linestyle_solid)

if barstate.islast
    lineEndX = bar_index + offset
    upperBand1LineEndLabel := updateLineEndLabel(upperBand1LineEndLabel, lineEndX, upperBandValue1, formatPercentGap(upperBandValue1, vwapValue), activeLineColor, showBandPctLabels and shouldPlot and showBand_1 and not na(upperBandValue1))
    lowerBand1LineEndLabel := updateLineEndLabel(lowerBand1LineEndLabel, lineEndX, lowerBandValue1, formatPercentGap(lowerBandValue1, vwapValue), activeLineColor, showBandPctLabels and shouldPlot and showBand_1 and not na(lowerBandValue1))
    upperBand2LineEndLabel := updateLineEndLabel(upperBand2LineEndLabel, lineEndX, upperBandValue2, formatPercentGap(upperBandValue2, vwapValue), activeLineColor, showBandPctLabels and shouldPlot and showBand_2 and not na(upperBandValue2))
    lowerBand2LineEndLabel := updateLineEndLabel(lowerBand2LineEndLabel, lineEndX, lowerBandValue2, formatPercentGap(lowerBandValue2, vwapValue), activeLineColor, showBandPctLabels and shouldPlot and showBand_2 and not na(lowerBandValue2))
