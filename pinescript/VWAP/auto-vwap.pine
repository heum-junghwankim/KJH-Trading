//@version=6
indicator(title="Auto VWAP", shorttitle="Auto VWAP", overlay=true)

hideonDWM = input(false, title="Hide VWAP on 1D or Above", group="VWAP Settings", display=display.none)
anchorMode = input.string(defval="Recent Bars", title="Anchor Mode", options=["Session", "Recent Trading Days", "Recent Bars"], group="VWAP Settings")
recentTradingDays = input.int(defval=5, title="Recent Trading Days", minval=1, group="VWAP Settings", display=display.none, active=anchorMode == "Recent Trading Days")
// 기본 화면용 VWAP window 길이(=Recent Bars 모드일 때의 rolling length). CEO 지시: 기본 화면 VWAP 기본값 50.
//  변곡 지점용 VWAP는 "변곡 지점" 그룹에서 독립 length(기본 14)로 분리 계산한다.
recentBars = input.int(defval=50, title="Recent Bars (기본 화면 VWAP)", minval=1, group="VWAP Settings", display=display.none, active=anchorMode == "Recent Bars")
src = input(title="Source", defval=hlc3, group="VWAP Settings", display=display.none)
offset = input.int(0, title="Offset", group="VWAP Settings", display=display.none)
enableDynamicLineColor = input.bool(false, title="Enable Dynamic Line Color", group="VWAP Settings", display=display.none)
// VWAP 중앙선 지지/저항 색 규칙(CEO 확정 — near 구간 종가 + 꼬리 걸침 이탈). 화면 기본 VWAP 선(vwapValue)의 색을 봉 단위로 판정한다.
//  "near 구간" = VWAP와 밴드1 사이의 **동적 %(pct) 범위**(밴드1 전체가 아님). 하단 near=[lowerNear, vwap], 상단 near=[vwap, upperNear].
//   ▸ upperNear = vwap + pct×(upperBand1 − vwap),  lowerNear = vwap − pct×(vwap − lowerBand1). 하단 near 최저=lowerNear, 상단 near 최고=upperNear.
//   ▸ pct = 밴드폭 반비례 동적(좁을 때 최대 0.60, 넓을 때 최소 0.20). r=(upperBand1−lowerBand1)/vwap 를 rLow~rHigh 사이 정규화 후 max~min 반비례 보간·clamp. (계산부는 vwapSRColor 블록 참조)
//  ▸ 저항(빨강, UPPER_BREAK_LINE_COLOR) = ① lowerNear ≤ close ≤ vwap  OR  ② close < lowerNear AND high > lowerNear(종가 하단 near 이탈+고가 꼬리 걸침).
//  ▸ 지지(녹, LOWER_BREAK_LINE_COLOR)   = ③ vwap ≤ close ≤ upperNear  OR  ④ close > upperNear AND low < upperNear(종가 상단 near 이탈+저가 꼬리 걸침).
//  ▸ 그 외(완전 이탈: close 가 near 구간 밖 + 꼬리도 near 미접촉 / na 워밍업) → 중립(흰, DEFAULT_LINE_COLOR).
//  ★ close==vwap은 ①③ 양쪽에 걸리므로 저항을 먼저 평가 → 저항(빨강)으로 확정. 부동소수라 실제 동일값은 드묾.
//  na/밴드1 유효성 가드(shouldPlot·not na(vwap/upperBand1/lowerBand1))가 워밍업·도지 방어. 모두 확정봉 세트값(close/high/low/vwap/밴드1·near) → 리페인팅 없음.
//  enableDynamicLineColor(밴드2 이탈 녹/빨강)와 독립한 별도 VWAP 선 전용 색이다.
enableVwapSRColor = input.bool(true, title="VWAP 선 지지/저항 색(구간 종가·꼬리 걸침 이탈)", group="VWAP Settings", tooltip="켜면 화면 VWAP 중앙선의 색을 봉 단위로 칠합니다(CEO 확정 규칙). 구간=VWAP와 밴드1 사이의 동적 near 범위(아래 '근처 구간 %' 참고). 하단 near 최저=lowerNear, 상단 near 최고=upperNear. 저항(빨강)=lowerNear≤종가≤VWAP(①), 또는 종가가 lowerNear 아래로 이탈했지만 고가가 lowerNear 위(② 꼬리 걸침). 지지(녹색)=VWAP≤종가≤upperNear(③), 또는 종가가 upperNear 위로 이탈했지만 저가가 upperNear 아래(④ 꼬리 걸침). 종가가 near 구간 밖이고 꼬리도 near에 안 걸치거나 워밍업(밴드1/VWAP na)이면 중립(흰색). 종가=VWAP 경계는 저항으로 처리합니다. 이 옵션은 아래 Enable Dynamic Line Color(밴드2 이탈 색)와 별개이며, 켜져 있으면 VWAP 선 색을 이 규칙이 담당합니다(밴드1·밴드2 등 다른 선 색은 기존대로).")
// VWAP 선색 "근처(near) 구간" 동적 % — 저항/지지 판정 구간을 밴드1 전체가 아니라 VWAP~밴드1의 일부(pct)로 좁힌다(CEO 지시).
//  상단 구간 최고 = upperNear = vwap + pct×(upperBand1 − vwap), 하단 구간 최저 = lowerNear = vwap − pct×(vwap − lowerBand1). 저항(하단)·지지(상단) 동일 pct 대칭.
//  ▸ pct = 밴드폭 반비례 동적 %: 밴드폭 좁음(저변동성)→최대 %(기본 60), 밴드폭 넓음(고변동성)→최소 %(기본 20).
//  ▸ 정규화: r = (upperBand1 − lowerBand1) / vwap (가격 대비 밴드1 폭 비율, 종목·가격 무관). r을 rLow~rHigh 사이에서 정규화 후 max~min으로 반비례 선형보간·clamp.
//  ▸ 임계 기본값: rLow=0.5%(저변동성 하단)·rHigh=2.0%(고변동성 상단) — 세션 VWAP 밴드1(≈1σ×배수) 통상 폭. 과최적화 경계상 라운드넘버.
vwapNearMinPct = input.float(20.0, title="VWAP 근처 구간 최소 %(넓을 때)", minval=0.0, maxval=100.0, step=1.0, group="VWAP Settings", active=enableVwapSRColor, display=display.none, tooltip="밴드폭이 넓을 때(고변동성) 적용할 근처 구간 비율의 최소 %. 밴드1폭/VWAP 비율이 '고변동성 임계' 이상이면 이 값으로 수렴합니다. 근처 구간이 VWAP 바로 옆으로 좁아집니다. 기본 20.")
vwapNearMaxPct = input.float(60.0, title="VWAP 근처 구간 최대 %(좁을 때)", minval=0.0, maxval=100.0, step=1.0, group="VWAP Settings", active=enableVwapSRColor, display=display.none, tooltip="밴드폭이 좁을 때(저변동성) 적용할 근처 구간 비율의 최대 %. 밴드1폭/VWAP 비율이 '저변동성 임계' 이하이면 이 값으로 수렴합니다. 기본 60. 근처 %는 이 값과 최소 % 사이에서 밴드폭에 반비례로 결정됩니다.")
vwapNearRLowPct = input.float(0.5, title="근처 % 저변동성 임계(밴드1폭/VWAP, %)", minval=0.0, step=0.1, group="VWAP Settings", active=enableVwapSRColor, display=display.none, tooltip="밴드1 폭 ÷ VWAP 비율(%)이 이 값 이하이면 저변동성으로 보고 근처 %를 최대(기본 60)로 씁니다. 기본 0.5%(=밴드1 폭이 가격의 0.5% 이하일 때 저변동성). 세션 VWAP 밴드1(≈1σ×배수) 통상 하단.")
vwapNearRHighPct = input.float(2.0, title="근처 % 고변동성 임계(밴드1폭/VWAP, %)", minval=0.0, step=0.1, group="VWAP Settings", active=enableVwapSRColor, display=display.none, tooltip="밴드1 폭 ÷ VWAP 비율(%)이 이 값 이상이면 고변동성으로 보고 근처 %를 최소(기본 20)로 씁니다. 기본 2.0%. 저변동성 임계와 이 값 사이는 선형보간합니다(반비례). 저변동성 임계보다 커야 합니다.")
showBandPctLabels = input.bool(true, title="VWAP·밴드 간격 % 라벨 표시", group="VWAP Settings")

BANDS_GROUP = "Bands Settings"
CALC_MODE_TOOLTIP = "Determines how band distance is calculated. Log Standard Deviation uses volume-weighted log-price volatility, and Absolute Standard Deviation uses price units."
calcModeInput = input.string("Log Standard Deviation", "Bands Calculation Mode", options=["Log Standard Deviation", "Absolute Standard Deviation"], group=BANDS_GROUP, tooltip=CALC_MODE_TOOLTIP, display=display.none)
showBand_1 = input(true, title="", group=BANDS_GROUP, inline="band_1", display=display.none)
bandMult_1 = input.float(1.0, title="Bands Multiplier #1", group=BANDS_GROUP, inline="band_1", step=0.5, minval=0, display=display.none, active=showBand_1)
showBand_2 = input(true, title="", group=BANDS_GROUP, inline="band_2", display=display.none)
bandMult_2 = input.float(2.0, title="Bands Multiplier #2", group=BANDS_GROUP, inline="band_2", step=0.5, minval=0, display=display.none, active=showBand_2)

// =========================
// 횡보 압축(리본) — SUPER-ICHIMOKU 메인 지표(advanced-ichimoku.pine)의 리본 "수축/확장(압축·분출)" 판정을 이식(포팅).
//  ⚠️ 자기완결 이식: 이치모쿠 원본 리본은 A(이평 리본)·B(구름 두께)·A and B 3모드였으나, auto-vwap엔 구름(선행스팬 A/B)이 없으므로
//   구름 의존 B모드를 제거하고 **A모드(이평 리본) 단독으로 고정** 이식한다. A모드는 구름과 무관하게 이평 리본 폭만 쓰므로 압축·분출 의미가 보존된다.
//   원본 A모드는 이치모쿠 input(전환선 길이 conversionPeriods=8, 리딩B 길이 leadingSpanBPeriods=44)에 리본 길이를 맞췄는데,
//   auto-vwap엔 그 input이 없으므로 **리본 전용 input(ribbonConvPeriods=8, ribbonSpanBPeriods=44)** 로 동일 기본값을 자기완결 선언한다.
//  ⚠️ 실시간 반영(CEO 지시): 원본은 ribbonConfirmOnClose 옵션(끄면 실시간)이었으나, 본 이식은 지시대로 **확정봉 게이트 없이 매 봉(형성 중 현재봉 포함)**
//   상태를 갱신한다 → 현재봉에서 압축 즉시 회색·분출 즉시 해제. 미마감봉 켜짐/꺼짐·과거봉 재계산(리페인팅) 허용. 나머지 파라미터(이평 종류·ATR 기준·수축 배수·확장 봉수)는 원본과 동일 명칭/기본값.
//  ⚠️ 표시 전용 — 변곡 마커·게이트·밴드·청산선 로직과 무관하다.
// =========================
CHOP_GROUP = "횡보 압축"
showChopBg = input.bool(true, title="횡보 압축 배경(밴드2 회색) 표시", group=CHOP_GROUP, tooltip="켜면 리본(이평) 폭이 ATR 대비 좁아져 '횡보 압축'이 발생한 봉부터, 다음 상승/하락 분출이 나오기 전까지 화면 VWAP 밴드2(상단2~하단2) 사이 영역을 반투명 회색으로 채웁니다. 매 봉(형성 중 현재봉 포함) 실시간 반영되어, 현재봉에서 압축 시 즉시 회색이 켜지고 분출 시 즉시 꺼집니다(미마감봉 켜짐/꺼짐·과거봉 재계산 등 리페인팅 허용). 표시 전용 옵션이며 변곡 마커·게이트·밴드·청산선 판정과 무관합니다.")
chopBgBaseColor = input.color(color.gray, title="횡보 압축 배경색", group=CHOP_GROUP, active=showChopBg, tooltip="횡보 압축 배경으로 밴드2(상단2~하단2) 사이 영역을 채우는 바탕색. 기본 회색. 밴드2 선(plot) 색과는 무관하며, 여기 지정한 색은 아래 '배경 투명도'와 합쳐져 반투명으로 칠해집니다.")
chopBgTransp = input.int(78, title="횡보 압축 배경 투명도", minval=0, maxval=100, group=CHOP_GROUP, active=showChopBg, tooltip="횡보 압축 배경색의 투명도(0=불투명, 100=완전 투명). 기본 78(불투명 약 22%)로, 밴드2 자체 fill(투명도 92)보다 진하게 잡아 압축 구간이 배경으로 뚜렷이 보이게 합니다. 너무 크면(옅으면) 선처럼 오인될 수 있습니다.")
ribbonMaType = input.string("SMA", title="리본 이동평균 종류", options=["SMA", "EMA", "WMA", "VWMA"], group=CHOP_GROUP, active=showChopBg, tooltip="압축/분출 판정용 이평 리본의 이동평균 종류. 이치모쿠 원본과 동일(기본 SMA).")
ribbonConvPeriods = input.int(8, minval=1, title="리본 빠른 길이(전환선 대응)", group=CHOP_GROUP, active=showChopBg, display=display.none, tooltip="이평 리본에서 가장 짧은(빠른) 이평 길이. 이치모쿠 전환선 길이에 대응(기본 8). 리본은 이 길이~리본 느린 길이 사이 7개 이평으로 구성됩니다.")
ribbonSpanBPeriods = input.int(44, minval=1, title="리본 느린 길이(리딩B 대응)", group=CHOP_GROUP, active=showChopBg, display=display.none, tooltip="이평 리본에서 가장 긴(느린) 이평 길이. 이치모쿠 리딩 스팬 B 길이에 대응(기본 44).")
ribbonAtrLength = input.int(14, minval=1, title="폭 ATR 기준", group=CHOP_GROUP, active=showChopBg, display=display.none, tooltip="리본 폭을 정규화할 ATR 길이. 이치모쿠 원본과 동일(기본 14).")
ribbonCompressAtrMult = input.float(0.8, minval=0.1, step=0.1, title="수축 판정 ATR 배수", group=CHOP_GROUP, active=showChopBg, display=display.none, tooltip="리본 폭이 ATR×이 배수보다 좁으면 '압축'으로 봅니다. 이치모쿠 원본과 동일(기본 0.8).")
ribbonExpandBars = input.int(1, minval=1, title="확장 판정 폭 증가 봉수(작을수록 빠름)", group=CHOP_GROUP, active=showChopBg, display=display.none, tooltip="리본 폭이 N봉 전보다 커지면 '확장(분출)'으로 봅니다. 작을수록 빠르게 반응. 이치모쿠 원본과 동일(기본 1).")

DEFAULT_LINE_COLOR = #FFFFFF
LOWER_BREAK_LINE_COLOR = #00FF00
UPPER_BREAK_LINE_COLOR = #FF0000
// 횡보 압축 배경(밴드2 영역 한정 fill용) — 배경색·투명도 옵션(횡보 압축 그룹)을 합쳐 반투명 색으로 산정. 기본 회색/투명도 78.
//  ⚠️ 이 색은 밴드2 두 선(upperBand_2/lowerBand_2) '사이 영역의 바탕(fill)'에만 칠한다. 밴드2 선(plot) color는 절대 변경하지 않는다(선색 불변).
//  기본 투명도 78(불투명 약 22%): 밴드2 자체 fill(투명도 92)보다 진하게 잡아 압축 구간이 배경으로 뚜렷이 보이게 한다. 너무 옅으면 선처럼 오인되므로 하한선 성격.
chopBgColor = color.new(chopBgBaseColor, chopBgTransp)

formatPercentGap(float bandValue, float baseValue) =>
    if na(bandValue) or na(baseValue) or baseValue == 0
        ""
    else
        percentGap = (bandValue / baseValue - 1.0) * 100.0
        (percentGap > 0 ? "+" : "") + str.tostring(percentGap, "0.00") + "%"

updateLineEndLabel(label existingLineEndLabel, int xPos, float yPrice, string labelText, color lineColor, bool shouldShow) =>
    label updatedLabel = existingLineEndLabel
    if shouldShow
        if na(updatedLabel)
            updatedLabel := label.new(x=xPos, y=yPrice, text=labelText, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(lineColor, 100), textcolor=lineColor, size=size.small)
        else
            label.set_xy(updatedLabel, xPos, yPrice)
            label.set_text(updatedLabel, labelText)
            label.set_textcolor(updatedLabel, lineColor)
            label.set_color(updatedLabel, color.new(lineColor, 100))
            label.set_style(updatedLabel, label.style_label_left)
    else if not na(updatedLabel)
        label.delete(updatedLabel)
        updatedLabel := na
    updatedLabel

cumVolume = ta.cum(volume)
if barstate.islast and cumVolume == 0
    runtime.error("No volume is provided by the data vendor.")

isNewSession = barstate.isfirst or timeframe.change("D")
sessionTime = time("D")
sessionCloseTime = time_close("D")
isLatestSession = sessionTime <= last_bar_time and sessionCloseTime > last_bar_time

var label upperBand1LineEndLabel = na
var label lowerBand1LineEndLabel = na
var label upperBand2LineEndLabel = na
var label lowerBand2LineEndLabel = na

// VWAP·밴드·밴드2 계산 헬퍼 — window 길이(barsLen)와 **소스(srcArg)**를 파라미터로 받아
//  "기본 화면용(length=50, src)"·"숏 변곡(length=ipRecentBars, ipSrcShort=low)"·"롱 변곡(length=ipRecentBars, ipSrcLong=high)" 세트를 독립 계산한다(CEO 지시: VWAP 완전 분리 + 소스 독립 + 변곡 숏/롱 분리).
//  ⚠️ 소스별로 서로 다른 누적이 필요하므로 누적(cumulative*)·세션 앵커 배열을 **함수-로컬 var로 내부화**한다.
//   Pine v6에서 함수 내부 var/var array는 그 호출부(instance)마다 독립 상태를 가지므로, 두 번 호출하면 두 개의 독립 누적이 유지된다.
//   소스가 동일하면(기본값 hlc3) 각 인스턴스가 같은 누적 궤적을 재현하므로 기존(전역 단일 누적) 대비 값이 동일하다(거동 불변).
//  세션 앵커 배열 push는 소스와 무관한 "시점 스냅샷"이라, 각 인스턴스가 자기 소스 누적을 그 시점에 스냅샷하는 것이 산식상 올바르다.
//  산식 자체(anchored VWAP + 로그/절대 표준편차 밴드)는 원본과 100% 동일. 확정봉 기준 누적이라 소스가 series여도 신규 리페인팅 없음.
//  반환: [vwapValue, upperBand1, lowerBand1, upperBand2, lowerBand2, shouldPlot].
computeVwapSet(int barsLen, float srcArg) =>
    var array<float> sessionStartPV = array.new_float()
    var array<float> sessionStartVolume = array.new_float()
    var array<float> sessionStartP2V = array.new_float()
    var array<float> sessionStartLogPV = array.new_float()
    var array<float> sessionStartLog2V = array.new_float()
    var array<float> sessionStartInvalidLogVolume = array.new_float()

    var float cumulativePV = 0.0
    var float cumulativeVolume = 0.0
    var float cumulativeP2V = 0.0
    var float cumulativeLogPV = 0.0
    var float cumulativeLog2V = 0.0
    var float cumulativeInvalidLogVolume = 0.0

    if isNewSession
        array.push(sessionStartPV, cumulativePV)
        array.push(sessionStartVolume, cumulativeVolume)
        array.push(sessionStartP2V, cumulativeP2V)
        array.push(sessionStartLogPV, cumulativeLogPV)
        array.push(sessionStartLog2V, cumulativeLog2V)
        array.push(sessionStartInvalidLogVolume, cumulativeInvalidLogVolume)

    barPV = srcArg * volume
    barP2V = srcArg * srcArg * volume
    logSrc = srcArg > 0 ? math.log(srcArg) : na
    barLogPV = na(logSrc) ? 0.0 : logSrc * volume
    barLog2V = na(logSrc) ? 0.0 : logSrc * logSrc * volume
    barInvalidLogVolume = na(logSrc) ? volume : 0.0
    cumulativePV += barPV
    cumulativeVolume += volume
    cumulativeP2V += barP2V
    cumulativeLogPV += barLogPV
    cumulativeLog2V += barLog2V
    cumulativeInvalidLogVolume += barInvalidLogVolume

    sessionCount = array.size(sessionStartPV)
    anchorSessionIndex = anchorMode == "Session" ? sessionCount - 1 : math.max(sessionCount - recentTradingDays, 0)

    anchorPV = anchorMode == "Recent Bars" ? nz(cumulativePV[barsLen], 0.0) : array.get(sessionStartPV, anchorSessionIndex)
    anchorVolume = anchorMode == "Recent Bars" ? nz(cumulativeVolume[barsLen], 0.0) : array.get(sessionStartVolume, anchorSessionIndex)
    anchorP2V = anchorMode == "Recent Bars" ? nz(cumulativeP2V[barsLen], 0.0) : array.get(sessionStartP2V, anchorSessionIndex)
    anchorLogPV = anchorMode == "Recent Bars" ? nz(cumulativeLogPV[barsLen], 0.0) : array.get(sessionStartLogPV, anchorSessionIndex)
    anchorLog2V = anchorMode == "Recent Bars" ? nz(cumulativeLog2V[barsLen], 0.0) : array.get(sessionStartLog2V, anchorSessionIndex)
    anchorInvalidLogVolume = anchorMode == "Recent Bars" ? nz(cumulativeInvalidLogVolume[barsLen], 0.0) : array.get(sessionStartInvalidLogVolume, anchorSessionIndex)

    windowPV = cumulativePV - anchorPV
    windowVolume = cumulativeVolume - anchorVolume
    windowP2V = cumulativeP2V - anchorP2V
    windowLogPV = cumulativeLogPV - anchorLogPV
    windowLog2V = cumulativeLog2V - anchorLog2V
    windowInvalidLogVolume = cumulativeInvalidLogVolume - anchorInvalidLogVolume

    float vwapLocal = na
    float upperBand1Local = na
    float lowerBand1Local = na
    float upperBand2Local = na
    float lowerBand2Local = na

    shouldPlotLocal = not (hideonDWM and timeframe.isdwm) and windowVolume > 0 and (anchorMode != "Session" or isLatestSession)

    if shouldPlotLocal
        vwapLocal := windowPV / windowVolume
        weightedVariance = math.max(windowP2V / windowVolume - math.pow(vwapLocal, 2), 0)
        stdevAbs = math.sqrt(weightedVariance)
        weightedLogVariance = math.max(windowLog2V / windowVolume - math.pow(windowLogPV / windowVolume, 2), 0)
        stdevLog = math.sqrt(weightedLogVariance)
        canUseLogBands = windowInvalidLogVolume == 0 and vwapLocal > 0

        if calcModeInput == "Absolute Standard Deviation"
            upperBand1Local := vwapLocal + stdevAbs * bandMult_1
            lowerBand1Local := vwapLocal - stdevAbs * bandMult_1
            upperBand2Local := vwapLocal + stdevAbs * bandMult_2
            lowerBand2Local := vwapLocal - stdevAbs * bandMult_2
        else if canUseLogBands
            upperBand1Local := vwapLocal * math.exp(stdevLog * bandMult_1)
            lowerBand1Local := vwapLocal * math.exp(-stdevLog * bandMult_1)
            upperBand2Local := vwapLocal * math.exp(stdevLog * bandMult_2)
            lowerBand2Local := vwapLocal * math.exp(-stdevLog * bandMult_2)
    [vwapLocal, upperBand1Local, lowerBand1Local, upperBand2Local, lowerBand2Local, shouldPlotLocal]

// =========================
// 변곡 지점(Inflection Point) 설정 — 변곡용 밴드2 상/하단 선이 "기본 청산선"(shortClear/longClear, 3모드 OR) 안으로
//  들어오는 순간을 마커로 표시하기 위한 표시 옵션이다. CEO 지시 #4: 변곡 전용 청산선 파라미터 세트는 **삭제**했다.
//  변곡용 VWAP window(ipRecentBars=7)만 기본 화면 세트와 독립으로 유지하고, 청산선 판정은 "스윕/청산" 그룹(기본 청산 설정)을 쓴다.
//  ⚠️ 이 그룹은 판정·마커 표시 전용이며, 화면에 청산선(직선)을 그리지 않는다(마커만 그린다).
//  ⚠️ 매매 전략(진입·청산·임계값)과 무관한 표시 옵션이다.
// =========================
IP_GROUP = "변곡 지점"
ipShowMarkers = input.bool(true, title="변곡 지점 마커 표시", group=IP_GROUP, tooltip="변곡용 밴드2 상/하단 선이 기본 청산선(가격 모드 기본·거래량 가중·최근봉 가중 3가지 중 1개 이상) 안으로 들어오는 순간을 밴드2 값 위치에 마커로 표시합니다(색=기본 청산선 색). 청산선 수평 필터·3봉 평균 게이트·방향성 밴드워킹 억제와 AND로 결합합니다.")
// 변곡 지점 판정용 VWAP window 길이 — 기본 화면 VWAP(recentBars=50)와 **완전 독립**. CEO 지시: 변곡용 기본 14.
//  이 length로 별도 window(±σ 밴드·밴드2 포함)를 산출하고, 변곡 지점 마커 판정은 이 변곡용 밴드2/VWAP 기준으로 계산한다.
//  ⚠️ 이 length는 숏 변곡 세트(소스=low)·롱 변곡 세트(소스=high) 두 세트가 **공유**한다(CEO 지시: length 등 나머지 기본값 동일, 소스만 분리).
//  (anchored 특성: Recent Bars 앵커 모드에서만 유효. Session/Recent Trading Days 모드에선 기본 세트와 동일 앵커를 공유.)
ipRecentBars = input.int(defval=14, title="[변곡] Recent Bars (변곡 VWAP)", minval=1, group=IP_GROUP, display=display.none, active=anchorMode == "Recent Bars", tooltip="변곡 지점 판정용 VWAP의 window 길이(N선). 숏·롱 변곡 VWAP 두 세트가 공유합니다. 기본 화면 VWAP와 독립. 기본 14. Recent Bars 앵커 모드에서만 유효합니다.")
// 변곡 VWAP 소스 선택(CEO 지시) — 변곡 VWAP을 **숏 변곡용·롱 변곡용 2세트로 분리**한다.
//  숏 변곡 VWAP 소스 = 저가(low) 기본, 롱 변곡 VWAP 소스 = 고가(high) 기본. 유연성을 위해 소스를 각각 입력으로 둔다(기존 변곡 소스가 input이었으므로 입력 방식 유지).
//  input.source 방식(화면 VWAP의 src와 동일 톤): close/hlc3/hl2/ohlc4/open/high/low 등 어떤 series든 선택 가능한 소스 드롭다운.
//  ⚠️ 소스별로 **독립 누적**이 되도록 computeVwapSet가 소스를 인자로 받는다(전역 단일 누적으로는 소스 분리 불가). 확정봉 기준 누적이라 신규 리페인팅 없음.
//  ⚠️ length·표준편차 배수 등 나머지 파라미터는 두 세트 모두 기존 변곡 세트와 동일(ipRecentBars·bandMult_*·calcModeInput 공유). 소스만 저가/고가로 다르다.
ipSrcShort = input(title="[변곡] 숏 Source (숏 변곡 VWAP)", defval=low,  group=IP_GROUP, display=display.none, tooltip="숏 변곡 VWAP의 소스. 기본 low(저가). 숏 변곡 마커(상단, 빨강) 판정용 밴드2 계산에 쓰입니다. length·밴드 배수 등 나머지 파라미터는 롱 변곡 VWAP과 동일합니다.")
ipSrcLong  = input(title="[변곡] 롱 Source (롱 변곡 VWAP)", defval=high, group=IP_GROUP, display=display.none, tooltip="롱 변곡 VWAP의 소스. 기본 high(고가). 롱 변곡 마커(하단, 녹색) 판정용 밴드2 계산에 쓰입니다. length·밴드 배수 등 나머지 파라미터는 숏 변곡 VWAP과 동일합니다.")
// 마커 모양 옵션(기본값=십자가). 리터럴 style plotshape로 분기하므로 컴파일 안전(입력→series 강등 이슈 없음).
ipMarkerStyle = input.string("원", title="변곡 지점 마커 모양", options=["십자가", "원", "삼각형", "다이아몬드", "네모"], group=IP_GROUP, active=ipShowMarkers, tooltip="변곡 지점 마커의 모양입니다. 기본값은 원(circle)입니다.")
// CEO 재지시: "기본 vwap이 청산선 안으로 들어오고, 마커가 생길 때"만 기본 화면 밴드2 선을 마커색으로 강조(표시 전용, 판정·계산 불변).
//  상단 밴드2(upperBandValue2)는 숏 마커(upper2Marker)이면서 화면 상단 밴드2가 숏 청산선 안(upperBandValue2 < shortClear)일 때 숏 마커색(shortClearLineColor)으로,
//  하단 밴드2(lowerBandValue2)는 롱 마커(lower2Marker)이면서 화면 하단 밴드2가 롱 청산선 안(lowerBandValue2 > longClear)일 때 롱 마커색(longClearLineColor)으로 강조한다.
//  OFF·조건 미충족이면 기본색(activeLineColor)으로 원복. 봉 단위 색 지정이라 조건 봉만 강조되고 나머지는 기본색.
ipBand2MarkerColor = input.bool(true, title="변곡 마커 봉 밴드2 강조 색", group=IP_GROUP, active=ipShowMarkers, tooltip="켜면 변곡 마커가 뜨면서 해당 방향 기본 화면 밴드2가 실제로 청산선 안으로 들어온 봉에서만 그 밴드2 선을 마커와 같은 색으로 강조합니다(상단=숏 마커색, 하단=롱 마커색). 그 봉에서만 색이 바뀌고 나머지 봉은 기본색을 유지합니다. 밴드2 위치·계산·마커 판정은 바뀌지 않는 표시 전용 옵션입니다.")
// 변곡 마커 봉 캔들 색(CEO 지시, 기본 ON) — 마커가 표시된 봉의 캔들을 그 마커 색으로 칠한다(표시 전용).
//  롱 마커 봉 → 캔들=롱 마커색(longMarkerColorFinal), 숏 마커 봉 → 캔들=숏 마커색(shortMarkerColorFinal). 마커 미표시 봉은 캔들 색 원복(na).
ipMarkerCandleColor = input.bool(true, title="변곡 마커 캔들 색", group=IP_GROUP, active=ipShowMarkers, tooltip="켜면 변곡 마커가 표시된 봉의 캔들 색을 그 마커 색과 동일하게 칠합니다(롱=녹 계열, 숏=빨강 계열, OBV 에너지 채도 반영). 원 변곡·연장 마커 봉 모두 적용됩니다. 마커가 없는 봉은 원래 캔들 색을 유지합니다. 마커 판정·위치·색은 바뀌지 않는 표시 전용 옵션입니다.")
// ⚠️ 변곡 전용 청산선 파라미터(ipCe*/ipSweep*)·변곡 전용 청산선 색(ipLong/ipShortClearLineColor)은 제거되었다(CEO 지시 #4).
//  변곡 마커 판정은 이제 아래 "스윕/청산" 그룹(기본 청산 설정)을 그대로 쓴다. 마커 색도 기본 청산선 색(short/longClearLineColor)을 쓴다.
// 요구사항 4: 밴드워킹 억제 필터 — 변곡 시점 청산선의 기울기가 "근사 수평"일 때만 마커를 표시한다.
//  청산선이 추세로 기울어(위/아래 워킹 중) 있으면 변곡 조건이 성립해도 마커를 억제한다.
//  판정: 최근 N봉 사이 청산선 값 변화량(|line - line[N]|)을 ATR로 정규화한 비율(=ATR 대비 배수)이 임계 이내면 수평.
//   → 절대 가격차가 아니라 ATR 정규화 비율이라 종목·타임프레임 무관하게 동작한다.
//  변곡 전용 청산선이 제거됐으므로(CEO 지시 #4), flat 판정은 **후보 3모드(기본·거래량 가중·최근봉 가중) 청산선** 기준으로 한다.
//  ⚠️ 화면 페인팅용(ceMode) 청산선 shortClear/longClear는 flat 판정에 쓰지 않는다 — 스윕 모드 선택이 마커에 관여하면 안 되기 때문(사양 1). 후보에 기여한 모드의 청산선 flat만 본다.
//  ⚠️ 청산선 계산·전략 로직과 무관한 표시 전용 필터다(마커 억제만).
ipFlatFilter = input.bool(true, title="변곡 시 청산선 수평 필터(밴드워킹 억제)", group=IP_GROUP, active=ipShowMarkers, tooltip="켜면 변곡 시점 청산선 기울기가 근사 수평일 때만 마커를 표시합니다. 판정은 후보에 기여한 모드(기본·거래량 가중·최근봉 가중 중 밴드2가 들어온 모드)의 청산선 기울기로 하며, 스윕 가격 모드(ceMode) 선택과는 무관합니다. 청산선이 추세로 기울어(밴드워킹 중) 있으면 변곡이어도 억제합니다.")
ipFlatLookback = input.int(3, title="[변곡] 수평 판정 lookback 봉수", minval=1, group=IP_GROUP, active=ipShowMarkers and ipFlatFilter, display=display.none, tooltip="청산선 기울기를 측정할 과거 봉 수(N). 최근 N봉 사이 청산선 값 변화량으로 기울기를 판정합니다. 기본 3.")
ipFlatSlopeMax = input.float(0.15, title="[변곡] 수평 허용 기울기(ATR 대비 배수)", minval=0.0, step=0.01, group=IP_GROUP, active=ipShowMarkers and ipFlatFilter, display=display.none, tooltip="N봉 사이 청산선 변화량 ÷ ATR 이 이 값 이하이면 '수평'으로 간주합니다. 기본 0.15(=ATR의 15%). 값을 키우면 더 기울어도 표시, 줄이면 더 엄격히 수평만 표시.")
// 방향성 밴드워킹 억제 — 이치모쿠 메인 지표 "VWAP 상태"의 밴드워킹 판정 알고리즘을 이식(포팅)한다.
//  목적: 추세(밴드워킹) 방향과 반대되는 변곡 마커를 억제한다(역추세 진입 억제).
//   - 아래(하락) 밴드워킹 중 → 롱 변곡 마커(녹색·하단, lower2Marker) 억제.
//   - 위(상승) 밴드워킹 중 → 숏 변곡 마커(빨강·상단, upper2Marker) 억제.
//  ⚠️ 이 밴드워킹은 "화면상 추세 국면" 성격이므로 **밴드워킹 판정 전용 VWAP 세트**(length=bwRecentBars 기본 14, 소스=src, bwVwapValue/밴드1/밴드2/bwShouldPlot) 기준으로 판정한다.
//   (변곡 마커의 발동 판정은 변곡용 세트(length=ipRecentBars; 숏=ipSrcShort/low, 롱=ipSrcLong/high)를 쓰고, 방향 억제는 이 밴드워킹 전용 세트(length=bwRecentBars, 소스=src)를 별도로 쓴다.)
//   ⚠️ 화면 세트(recentBars, src)와 분리했다(CEO 판단 A) — recentBars(화면 표시 전용)를 바꿔도 밴드워킹→마커 표시 여부가 흔들리지 않는다. 기본 14봉으로 화면 세트(recentBars=50)와 독립이며, 소스만 화면과 동일한 src를 쓴다.
//  ⚠️ 표시 억제 전용 필터다 — 매매 전략(진입·청산·임계·산식)과 무관하다.
ipBwSuppress = input.bool(false, title="추세(밴드워킹) 방향 반대 마커 억제", group=IP_GROUP, active=ipShowMarkers, tooltip="켜면 밴드워킹(추세) 방향과 반대되는 변곡 마커를 숨깁니다. 하락 밴드워킹 중이면 롱(녹색·하단) 마커를, 상승 밴드워킹 중이면 숏(빨강·상단) 마커를 억제합니다. 이치모쿠 메인 지표의 'VWAP 상태' 밴드워킹 판정 알고리즘을 이식한 것으로, 밴드워킹 판정 전용 VWAP 세트([밴드워킹] Recent Bars, 화면 VWAP와 독립)를 기준으로 판정합니다.")
// 밴드워킹 판정 파라미터 — 이치모쿠 원본 기본값과 동일(vwSlopeLen=5, vwWalkSlopeLen=3, 평탄 임계=밴드폭의 3%).
ipBwSlopeLen = input.int(5, title="[밴드워킹] VWAP 기울기 lookback 봉수", minval=1, group=IP_GROUP, active=ipShowMarkers and ipBwSuppress, display=display.none, tooltip="VWAP 기울기·밴드폭 확장/수축을 측정할 과거 봉 수. 이치모쿠 원본 기본 5.")
ipBwWalkSlopeLen = input.int(3, title="[밴드워킹] 밴드2 레일 기울기 lookback 봉수", minval=1, group=IP_GROUP, active=ipShowMarkers and ipBwSuppress, display=display.none, tooltip="밴드워킹 종료(레일 반전) 판정용 밴드2 상/하단선 기울기 측정 봉 수. 이치모쿠 원본 기본 3.")
ipBwFlatPct = input.float(0.03, title="[밴드워킹] VWAP 평탄 임계(밴드폭 대비 비율)", minval=0.0, step=0.01, group=IP_GROUP, active=ipShowMarkers and ipBwSuppress, display=display.none, tooltip="VWAP 기울기가 밴드2 총폭의 이 비율보다 작으면 '평탄'으로 봅니다. 이치모쿠 원본 기본 0.03(=밴드폭의 3%).")
// 밴드워킹 판정 전용 VWAP window 길이 — 화면 세트(recentBars)·변곡 세트(ipRecentBars)와 **모두 독립**. CEO 지시(판단 A).
//  버그 교정: 이전엔 밴드워킹 블록이 화면 세트(computeVwapSet(recentBars, src)) 값을 참조해, recentBars(화면 표시 전용)를 바꾸면 변곡 마커 표시 여부가 흔들렸다(오염).
//   → 전용 window(bwRecentBars)로 별도 세트를 계산해 밴드워킹 판정을 화면 세트에서 분리한다. 소스는 기존 밴드워킹이 화면 세트를 참조했으므로 **화면과 동일한 src**를 그대로 쓴다(변곡 소스 ipSrcShort/ipSrcLong 아님).
//  ⚠️ 기본값 14 — 화면 세트(recentBars 기본 50)와 독립인 별도 window다. 소스만 화면과 동일한 src를 그대로 쓴다.
//  ipBwSlopeLen/ipBwWalkSlopeLen(기울기 lookback)은 그대로 유지(이미 별도 파라미터).
bwRecentBars = input.int(defval=14, title="[밴드워킹] Recent Bars (판정 전용 VWAP)", minval=1, group=IP_GROUP, active=ipShowMarkers and ipBwSuppress and anchorMode == "Recent Bars", display=display.none, tooltip="밴드워킹 억제 판정 전용 window. 화면 VWAP의 Recent Bars와 독립.")
// 캔들 형태 게이트(옵션) — 원 변곡 마커(upper2Marker/lower2Marker)에만 AND 결합. 기본 OFF(방향·형태 무관 발동).
//  ⚠️ flat/선색 게이트와 동일 패턴: OFF면 게이트가 항상 통과(방향·형태 무관), ON이면 숏=음봉·롱=양봉 + 반전형 제외.
ipShapeFilter = input.bool(false, title="캔들 형태 게이트", group=IP_GROUP, active=ipShowMarkers, tooltip="숏=음봉·롱=양봉 + 반전형 제외. OFF면 방향·형태 무관")

// =========================
// OBV DI 게이트 설정 — 변곡 마커 표시 게이트(3봉 hlc3 평균 게이트를 대체). CEO 지시.
//  OBV-ADX 보조지표(obv-adx-extreme-background.pine)의 DI+/DI-(OBV 기반 커스텀 산식)를 이식한다.
//  숏 변곡 마커는 DI- 우위(diMinus > diPlus), 롱 변곡 마커는 DI+ 우위(diPlus > diMinus)일 때만 표시한다.
//  ⚠️ input 기본값은 OBV-ADX 원본(20)보다 짧게 잡는다(DI Length=5, ADX Smoothing=5) — DI 우위 반응을 빠르게 하기 위함. 표시 게이트 전용 — 매매 전략(진입·청산·임계)과 무관.
// =========================
DI_GROUP = "OBV DI 게이트"
// DI Length — DI+/DI- 계산의 유일한 실제 파라미터(EMA·표준편차 길이). OBV-ADX 원본 len(20)보다 짧은 5가 기본 — DI 우위 반응이 빨라진다.
obvDiLen = input.int(5, minval=1, title="DI Length", group=DI_GROUP, active=ipShowMarkers, tooltip="OBV 기반 DI+/DI- 계산에 쓰는 길이(EMA·표준편차 window). 기본 5(OBV-ADX 원본 20보다 짧아 DI 우위 반응이 빠릅니다).")
// ADX Smoothing — OBV-ADX 원본 lensig(20)에 대응하는 옵션이며 기본 5로 짧게 잡는다. auto-vwap 마커 게이트는 DI 우위만 보므로 ADX 자체는 쓰지 않지만,
//  OBV-ADX와 input 정합(동일 옵션 구성)을 위해 유지한다(계산부에서 값은 산출하되 게이트엔 미사용).
obvAdxSmooth = input.int(5, minval=1, maxval=50, title="ADX Smoothing", group=DI_GROUP, active=ipShowMarkers, display=display.none, tooltip="OBV-ADX 원본 lensig(20)에 대응하는 옵션(기본 5). 변곡 마커 게이트는 DI 우위(DI+/DI-)만 사용하므로 ADX 값은 게이트에 쓰이지 않습니다.")
// OBV 에너지 평균 길이 — 변곡 마커 색 채도(강/약) 판정용. auto-vwap 마커용으로 기본 5(짧게)로 잡는다(반응 빠름). obvDiLen(기본 5)과 결이 맞음.
//  에너지 강/약 = OBV 방향 격차 |diPlus−diMinus|(=obv-adx의 |diDiff|)가 그 평균 이상/이하인가 + 3봉 전 대비 감소 여부.
//  ⚠️ 산식 구조는 obv-adx-extreme-background.pine 상태판(L79-82)의 energyFading과 동일(평균 대비 OR 3봉 전 모멘텀). 평균 창만 obvEnergyLen(auto-vwap 기본 5, obv-adx 기본 14)로 다르게 두고, 3봉 전 [3] 룩백은 obv-adx와 동일한 고정 상수. 표시 전용(마커 색 채도만) — 판정·표시 여부와 무관.
obvEnergyLen = input.int(5, minval=1, title="OBV 에너지 평균 길이", group=DI_GROUP, active=ipShowMarkers, display=display.none, tooltip="변곡 마커 색 채도(강/약) 판정용. OBV 방향 격차 |DI+−DI-|가 이 길이의 평균 이상이고 3봉 전보다 줄지 않았으면 '강(선명)', 아니면 '약(둔탁)'으로 마커 채도를 나눕니다. 평균만 obvEnergyLen(기본 5)로 짧게, 3봉 전 대비 모멘텀은 obv-adx 상태판과 동일한 고정 [3] 룩백입니다. 마커 표시 여부·판정은 바뀌지 않는 표시 전용 옵션입니다.")

// =========================
// 비정상 매수/매도 — SUPER-ICHIMOKU 메인 지표(advanced-ichimoku.pine)의 "비정상 캔들"(비정상 매수/매도) 판정을 이식(포팅).
//  판정: cRSI 과매수/과매도(도미넌트 사이클) + 볼린저 밴드 이탈(고가/저가 기준). 두 조건이 동시 성립하면 비정상.
//   ▸ 비정상 매수(과매수 구간, abnCandleState==-1) = cRSI 과매수(abnIsOB) AND 고가가 볼린저 상단 밴드를 초과(초과폭÷캔들범위 ≥ 비율). → 빨강 배경.
//   ▸ 비정상 매도(과매도 구간, abnCandleState== 1) = cRSI 과매도(abnIsOS) AND 저가가 볼린저 하단 밴드를 이탈(이탈폭÷캔들범위 ≥ 비율). → 파랑 배경.
//   ⚠️ 이치모쿠 원본과 매핑: "비정상 매수 = 과매수(cRSI≥OB + 상단밴드 돌파)"·"비정상 매도 = 과매도(cRSI≤OS + 하단밴드 이탈)". 지시 매핑(비정상매수=과매수·비정상매도=과매도)과 정확히 일치.
//  ⚠️ 자기완결 포팅(이치모쿠 의존 제거):
//   (1) 원본은 기준 길이를 베이스 라인(basePeriods)에 연동(abnLen=basePeriods)했으나, auto-vwap엔 이치모쿠 input이 없으므로 **전용 input(abnBaseLen)** 로 동일 기본값(22)을 자기완결 선언한다.
//       원본 basePeriods 기본값이 22이므로 abnBaseLen 기본 22 → cRSI 사이클 길이(basePeriods/2)·볼린저·ATR·RSI·추적 lookback이 모두 원본과 동일한 값으로 재현된다.
//   (2) 원본은 래치 리셋 트리거로 '이격도 중립 복귀'(abnDisparityNeutral = overCount==0 and underCount==0)를 썼으나, auto-vwap엔 이격도 블록이 없으므로 **이치모쿠 이격도(Disparity) 계산을 그대로 자기완결 이식**한다.
//       이격도 = 종가 ÷ 선택 이평 × 100, 고정 임계(±%)+적응형(σ 배수)로 되돌림 판정. overCount/underCount==0(중립)이면 abnDisparityNeutral=true. input(이격도 MA 종류·길이·임계·통계 구간·σ 배수)도 원본 명칭/기본값/툴팁 그대로 이식.
//       ⚠️ 이 이격도는 오직 비정상 상태 래치 리셋(원본과 동일한 종료 조건)에만 쓰이며, 테이블·다른 표시를 새로 만들지 않는다(표시 전용 최소 이식).
//  ⚠️ 배경(bgcolor)은 확정 성격 래치(abnCandleState) 기반 — cRSI/볼린저는 현재봉 close/high/low를 쓰므로 형성 중 현재봉은 실시간 변동(원본과 동일 거동), 과거봉은 확정. 원본과 동일한 리페인팅 특성(신규 리페인팅 추가 없음).
//  ⚠️ 표시 전용(배경색 + 아래 과매수/과매도 수평선) — 변곡 마커·게이트·밴드·청산선·횡보 압축 로직과 무관. 매매 전략(진입·청산·임계)과 무관.
// =========================
ABN_GROUP = "비정상 매수/매도"
// 기준 길이 — 원본은 basePeriods(베이스 라인, 기본 22)에 연동. auto-vwap엔 이치모쿠 input이 없어 전용 input으로 동일 기본값 자기완결 선언.
abnBaseLen = input.int(22, minval=1, title="비정상 기준 길이(베이스 라인 대응)", group=ABN_GROUP, tooltip="비정상 매수/매도 판정 기준 길이. 이치모쿠 메인 지표는 베이스 라인 길이(기본 22)에 연동했으나, auto-vwap엔 그 input이 없어 전용 입력으로 동일 기본값(22)을 둡니다. cRSI 사이클 길이(이 값÷2)·볼린저·ATR·RSI·추적 lookback이 모두 이 값에 연동됩니다. 전략성 파라미터(수학자 리뷰 대상).")
abnVibration = input.int(10, minval=1, title="비정상 캔들 cRSI Vibration", group=ABN_GROUP)
abnOB = input.float(70.0, title="비정상 절대 과매수", group=ABN_GROUP)
abnOS = input.float(30.0, title="비정상 절대 과매도", group=ABN_GROUP)
abnBbMult = input.float(2.0, minval=0.1, step=0.1, title="비정상 볼린저 배수", group=ABN_GROUP)
abnBodyRatio = input.float(0.3, minval=0.0, step=0.05, title="비정상 밴드 초과 비율(고저 기준)", group=ABN_GROUP)
abnShowBg = input.bool(true, title="비정상 매수/매도 배경 표시", group=ABN_GROUP, tooltip="비정상 매도=파랑, 비정상 매수=빨강 배경으로 세로 스트립을 칠합니다. (반등 감시 배경은 CEO 지시로 제거됨)")
// 비정상 매수/매도 세로 배경색(CEO 명시: 매도=파랑, 매수=빨강 — 방향 직관과 반대지만 지시대로)
abnSellBgColor = input.color(color.blue, title="비정상 매도 배경 색(파랑)", group=ABN_GROUP)
abnBuyBgColor = input.color(color.red, title="비정상 매수 배경 색(빨강)", group=ABN_GROUP)
abnBgTransp = input.int(82, minval=0, maxval=100, title="비정상 배경 투명도", group=ABN_GROUP)
// 과매수/과매도 수평선(신규, CEO 지시) — 가장 최근 비정상 이벤트 방향에 따라 항상 1개만 표시.
abnShowLevelLines = input.bool(true, title="과매수/과매도 수평선 표시", group=ABN_GROUP, tooltip="가장 최근 비정상 이벤트 방향에 따라 수평선을 항상 1개만 표시합니다(2개 동시 표시 안 함). 최근이 비정상 매수(과매수)면 그 구간의 최고가에 빨강(수평선 매수 색) 수평선 1개, 최근이 비정상 매도(과매도)면 그 구간의 최저가에 파랑(수평선 매도 색) 수평선 1개를 그립니다. 화면 전체 가로이며(굵기·점선/실선은 아래 옵션), 새 구간이 나오거나 방향이 바뀌면 그 방향의 극값·색으로 갱신합니다. 확정봉 구간 추적이라 리페인팅이 없습니다. 표시 전용 옵션입니다.")
// 과매수/과매도 수평선 전용 색(CEO 지시: 옵션화) — 배경색(abnBuyBgColor/abnSellBgColor)과 독립으로 바꿀 수 있게 별도 input을 둔다.
//  기본값은 배경색과 동일(매수=빨강 color.red / 매도=파랑 color.blue) → 기존 동작 그대로. 사용자가 배경색과 다르게 지정하려면 이 값을 조정한다.
abnLevelBuyColor = input.color(color.red, title="과매수 수평선 색(매수)", group=ABN_GROUP, active=abnShowLevelLines, tooltip="가장 최근 비정상 매수(과매수) 방향일 때 그리는 수평선 색. 기본 빨강(비정상 매수 배경색과 동일). 비정상 배경색과 독립적으로 조정할 수 있습니다.")
abnLevelSellColor = input.color(color.blue, title="과매도 수평선 색(매도)", group=ABN_GROUP, active=abnShowLevelLines, tooltip="가장 최근 비정상 매도(과매도) 방향일 때 그리는 수평선 색. 기본 파랑(비정상 매도 배경색과 동일). 비정상 배경색과 독립적으로 조정할 수 있습니다.")
// 수평선 굵기(옵션) — 기본 1(현재 동작). 점선/실선은 abnLevelDashed로 선택(기본 점선=현재 동작).
abnLevelWidth = input.int(1, minval=1, maxval=5, title="과매수/과매도 수평선 굵기", group=ABN_GROUP, active=abnShowLevelLines, display=display.none, tooltip="수평선 두께(px). 기본 1(현재 동작). 굵게 하면 더 눈에 띄지만 차트를 가릴 수 있습니다.")
abnLevelDashed = input.bool(true, title="과매수/과매도 수평선 점선", group=ABN_GROUP, active=abnShowLevelLines, display=display.none, tooltip="켜면 점선(기본, 현재 동작), 끄면 실선으로 수평선을 그립니다.")

// 이격도(Disparity) 자기완결 이식 — 비정상 상태 래치 리셋(원본 abnDisparityNeutral)에만 사용. 이치모쿠 원본 산식·input 그대로.
DISP_GROUP = "이격도"
disparityMaType = input.string("SMA", title="이격도 MA 종류", options=["SMA", "EMA", "WMA", "VWMA"], group=DISP_GROUP)
disparityMaLen = input.int(20, minval=1, title="이격도 MA 길이", group=DISP_GROUP)
disparityThreshold = input.float(10.0, minval=0.1, step=0.1, title="이격도 임계(±%, 고정)", group=DISP_GROUP)
disparityStatLen = input.int(50, minval=5, title="이격도 통계 구간(적응형)", group=DISP_GROUP)
disparityStatMult = input.float(1.5, minval=0.1, step=0.1, title="이격도 통계 시그마 배수", group=DISP_GROUP)

// 기본 화면용 VWAP 세트(length=50, 소스=src) — 화면 plot·밴드·라벨의 기준. 소스는 기존 화면 VWAP src(기본 hlc3) 유지 → 거동 불변.
[vwapValue, upperBandValue1, lowerBandValue1, upperBandValue2, lowerBandValue2, shouldPlot] = computeVwapSet(recentBars, src)
// 변곡 지점 판정용 VWAP 세트 — 숏/롱 2세트로 분리(CEO 지시). window(length=ipRecentBars)·밴드 배수·calcMode는 공통, 소스만 다르다.
//  ▸ 숏 변곡 세트(소스=ipSrcShort 기본 low): 숏 변곡 마커(상단) 판정용. 상단 밴드2(ipUpperBandValue2)만 판정에 쓴다.
//  ▸ 롱 변곡 세트(소스=ipSrcLong 기본 high): 롱 변곡 마커(하단) 판정용. 하단 밴드2(ipLowerBandValue2)만 판정에 쓴다.
//  ⚠️ computeVwapSet 내부 var 누적이 호출부(instance)별 독립이므로 두 호출이 각자 자기 소스(low/high)로 독립 누적한다. 확정봉 기준 → 신규 리페인팅 없음.
//  ⚠️ 숏 세트에서 상단 밴드2만, 롱 세트에서 하단 밴드2만 실제 사용하지만, 세트 대칭·가독성을 위해 6튜플을 그대로 받는다(미사용값은 컴파일러가 최적화).
[ipVwapValueShort, ipUpperBandValue1Short, ipLowerBandValue1Short, ipUpperBandValue2, ipLowerBandValue2Short, ipShouldPlotShort] = computeVwapSet(ipRecentBars, ipSrcShort)
[ipVwapValueLong,  ipUpperBandValue1Long,  ipLowerBandValue1Long,  ipUpperBandValue2Long,  ipLowerBandValue2, ipShouldPlotLong]  = computeVwapSet(ipRecentBars, ipSrcLong)
// 밴드워킹 판정 전용 VWAP 세트(length=bwRecentBars, 소스=src) — 화면 세트와 독립(CEO 지시 판단 A). window는 기본 14봉(화면 세트 recentBars=50과 독립), 소스만 화면과 동일 src.
//  ⚠️ 튜플 변수는 bw* 접두어로 명명해 화면 세트(vwapValue/…)·변곡 세트(ipVwapValueShort/Long/…)와 이름 충돌 없음. 아래 밴드워킹 블록이 이 세트를 참조한다.
[bwVwapValue, bwUpperBandValue1, bwLowerBandValue1, bwUpperBandValue2, bwLowerBandValue2, bwShouldPlot] = computeVwapSet(bwRecentBars, src)

// =========================
// 비정상 매수/매도 판정 — advanced-ichimoku.pine "비정상 캔들" 블록의 이식(포팅). 산식·기본값 동일.
//  원본 abnLen/abnLookback=basePeriods → auto-vwap은 abnBaseLen(전용 input, 기본 22)로 자기완결. cRSI/볼린저/ATR/RSI 산식은 100% 동일.
//  원본 abnDisparityNeutral(이격도 중립 복귀)은 아래 이격도 자기완결 이식으로 재현 → 래치 리셋 트리거로만 사용.
// =========================
// 이격도(Disparity) — 종가 ÷ 이평 × 100. 고정 임계(±%) + 적응형(σ 배수)로 되돌림 판정. 원본과 동일 산식(중립 여부만 사용).
disparityMa = switch disparityMaType
    "SMA" => ta.sma(close, disparityMaLen)
    "EMA" => ta.ema(close, disparityMaLen)
    "WMA" => ta.wma(close, disparityMaLen)
    "VWMA" => ta.vwma(close, disparityMaLen)
disparity = not na(disparityMa) and disparityMa != 0 ? close / disparityMa * 100 : na
disparityStd = ta.stdev(disparity, disparityStatLen)
disparityStatOk = not na(disparity) and not na(disparityStd) and disparityStd > 0
overFixed  = not na(disparity) and disparity - 100 >= disparityThreshold
overStat   = disparityStatOk and disparity - 100 >= disparityStatMult * disparityStd
underFixed = not na(disparity) and 100 - disparity >= disparityThreshold
underStat  = disparityStatOk and 100 - disparity >= disparityStatMult * disparityStd
overCount  = (overFixed ? 1 : 0) + (overStat ? 1 : 0)
underCount = (underFixed ? 1 : 0) + (underStat ? 1 : 0)

// 기준 길이 = abnBaseLen(원본 basePeriods 대응) — 비정상 캔들 신호 최적화
abnLen = abnBaseLen
abnLookback = abnBaseLen
// cRSI (도미넌트 사이클 = 베이스 라인) → 절대 과매수/과매도
abnCycleLen = math.max(1, int(abnBaseLen / 2))
abnTorque = 2.0 / (abnVibration + 1.0)
abnPhasingLag = int((abnVibration - 1) / 2.0)
abnUp = ta.rma(math.max(ta.change(close), 0), abnCycleLen)
abnDown = ta.rma(-math.min(ta.change(close), 0), abnCycleLen)
abnRsiRaw = abnDown == 0 ? 100.0 : abnUp == 0 ? 0.0 : 100.0 - 100.0 / (1.0 + abnUp / abnDown)
var float abnCrsi = na
abnCrsi := abnTorque * (2.0 * abnRsiRaw - nz(abnRsiRaw[abnPhasingLag])) + (1.0 - abnTorque) * nz(abnCrsi[1])
abnIsOB = abnCrsi >= abnOB
abnIsOS = abnCrsi <= abnOS

// 볼린저 밴드 이탈 = 비정상 캔들. 고가/저가 기준(원본과 동일). 비정상 매수=고가가 상단 초과, 비정상 매도=저가가 하단 이탈.
abnBbBasis = ta.sma(close, abnLen)
abnBbDev = ta.stdev(close, abnLen) * abnBbMult
abnBbUpper = abnBbBasis + abnBbDev
abnBbLower = abnBbBasis - abnBbDev
abnRangeSpan = math.max(high - low, syminfo.mintick)
abnUpperOut = math.max(high - abnBbUpper, 0.0)
abnLowerOut = math.max(abnBbLower - low, 0.0)
abnBearExt = abnUpperOut > 0 and abnUpperOut / abnRangeSpan >= abnBodyRatio
abnBullExt = abnLowerOut > 0 and abnLowerOut / abnRangeSpan >= abnBodyRatio
abnBearCandle = abnIsOB and abnBearExt   // 비정상 매수(과매수): cRSI 과매수 + 상단밴드 돌파
abnBullCandle = abnIsOS and abnBullExt   // 비정상 매도(과매도): cRSI 과매도 + 하단밴드 이탈

// 상태 래치: 이격도 중립 복귀 시 리셋. (원본 advanced-ichimoku.pine 동일 — 반등 감시 abnWatch는 auto-vwap 미이식, 배경이 안 쓰므로 생략)
abnDisparityNeutral = overCount == 0 and underCount == 0
var int abnCandleState = 0   // 1=비정상 매도(과매도), -1=비정상 매수(과매수), 0=없음
if abnDisparityNeutral
    abnCandleState := 0
if abnBullCandle
    abnCandleState := 1
if abnBearCandle
    abnCandleState := -1

// 세로 배경색(원본 동일): 비정상 매도(abnCandleState==1)=파랑, 비정상 매수(abnCandleState==-1)=빨강.
abnBg = abnCandleState == 1 ? color.new(abnSellBgColor, abnBgTransp) : abnCandleState == -1 ? color.new(abnBuyBgColor, abnBgTransp) : na

// =========================
// 과매수/과매도 수평선(CEO 지시) — 항상 var line 1개만 유지·갱신(2개 동시 표시 금지).
//  가장 최근 비정상 이벤트 방향(lastAbnDir)에 따라 그 방향의 극값·색으로 라인 1개의 y·color를 스위칭한다.
//   ▸ 최근이 비정상 매수(lastAbnDir==-1) → y=가장 최근 과매수 구간 high 최댓값, color=비정상 매수 배경색(abnBuyBgColor, 빨강). 파랑선 미표시.
//   ▸ 최근이 비정상 매도(lastAbnDir== 1) → y=가장 최근 과매도 구간 low 최솟값, color=비정상 매도 배경색(abnSellBgColor, 파랑). 빨강선 미표시.
//  ▸ 방향 래치(lastAbnDir): 비정상 매수/매도가 뜬 봉에서 그 방향으로 갱신되고, 이후 이격도 중립 복귀(abnCandleState==0)가 와도 "가장 최근 방향"으로 유지된다.
//    → 라인은 항상 최근 이벤트 방향 1개만 그린다(어느 쪽도 없었던 초기(0)에는 미표시).
//  구간 추적(유지): 비정상 매수/매도가 연속되는 봉을 한 "구간"으로 본다. 상태가 그 방향으로 새로 진입하는 봉(진입 엣지)에서 누적 극값을 그 봉 값으로 초기화하고,
//   같은 방향이 지속되는 동안 high 최댓값/low 최솟값을 누적한다. 매 진행 봉마다 라인 y를 갱신 → "진행 중 구간도 최신 극값으로 갱신"(CEO: 진행 중 갱신).
//  ▸ 라인 오브젝트는 1개(var line). 최초 1회만 line.new, 이후 line.set_xy1/2 + line.set_color로 갱신 → 오브젝트 누적 없음(항상 1개, max_lines_count 무관).
//  ▸ extend=extend.both + xloc.bar_index로 화면 전체 가로. 점선(line.style_dotted)·width=1(얇게)은 유지.
//  ⚠️ abnCandleState/lastAbnDir는 확정 성격 래치(진입 엣지 판정)라 신규 리페인팅 없음(원본 배경과 동일 특성). 형성 중 현재봉의 high/low 갱신은 원본 배경 실시간성과 동일.
// =========================
// 진입 엣지: 이번 봉이 그 방향 비정상인데 직전 봉은 그 방향이 아니었으면 = 새 구간 시작.
abnBuyEnter = abnCandleState == -1 and (na(abnCandleState[1]) or abnCandleState[1] != -1)   // 과매수 구간 진입
abnSellEnter = abnCandleState == 1 and (na(abnCandleState[1]) or abnCandleState[1] != 1)     // 과매도 구간 진입
var float abnBuyRunHigh = na    // 현재(가장 최근) 과매수 구간의 누적 최고가
var float abnSellRunLow = na    // 현재(가장 최근) 과매도 구간의 누적 최저가
if abnBuyEnter
    abnBuyRunHigh := high
else if abnCandleState == -1
    abnBuyRunHigh := math.max(nz(abnBuyRunHigh, high), high)
if abnSellEnter
    abnSellRunLow := low
else if abnCandleState == 1
    abnSellRunLow := math.min(nz(abnSellRunLow, low), low)
// 가장 최근 비정상 이벤트 방향 래치 — 매수(-1)/매도(1)가 뜬 봉에서 갱신, 중립 복귀(0)에도 유지.
var int lastAbnDir = 0   // -1=최근 비정상 매수(과매수), 1=최근 비정상 매도(과매도), 0=아직 없음
if abnCandleState == -1
    lastAbnDir := -1
else if abnCandleState == 1
    lastAbnDir := 1
// 최근 방향에 따라 라인 1개의 y·color를 선택(2개 동시 금지). na 가드.
//  ▸ 색은 수평선 전용 옵션(abnLevelBuyColor/abnLevelSellColor)을 쓴다(기본값=배경색과 동일 → 거동 불변). 스타일=abnLevelDashed(기본 점선), 굵기=abnLevelWidth(기본 1).
abnLevelY = lastAbnDir == -1 ? abnBuyRunHigh : lastAbnDir == 1 ? abnSellRunLow : na
abnLevelColor = lastAbnDir == -1 ? abnLevelBuyColor : abnLevelSellColor
abnLevelStyle = abnLevelDashed ? line.style_dotted : line.style_solid
var line abnLevelLine = na    // 과매수/과매도 수평선(항상 1개만 유지)
if abnShowLevelLines and lastAbnDir != 0 and not na(abnLevelY)
    if na(abnLevelLine)
        abnLevelLine := line.new(bar_index, abnLevelY, bar_index + 1, abnLevelY, xloc=xloc.bar_index, extend=extend.both, color=abnLevelColor, style=abnLevelStyle, width=abnLevelWidth)
    else
        line.set_xy1(abnLevelLine, bar_index, abnLevelY)
        line.set_xy2(abnLevelLine, bar_index + 1, abnLevelY)
        line.set_color(abnLevelLine, abnLevelColor)
        line.set_style(abnLevelLine, abnLevelStyle)
        line.set_width(abnLevelLine, abnLevelWidth)
else if not na(abnLevelLine)
    // 표시 OFF(또는 방향 미확정으로 회귀) 시 이미 생성된 라인이 남지 않도록 삭제하고 na로 되돌린다.
    line.delete(abnLevelLine)
    abnLevelLine := na
// 과매수/과매도 수평선 값(abnLevelY)을 우측 가격축 라벨로만 표기(CEO 지시). display.price_scale 전용 plot이라 차트엔 선을 그리지 않는다
//  → 차트 수평선은 위 abnLevelLine(line 오브젝트)이 이미 그리므로 중복 선 없음. 표시 토글 OFF·방향 미확정·워밍업(abnLevelY na)이면 라벨도 없음.
//  라벨 색은 최근 이벤트 색(abnLevelColor: 매수=빨강/매도=파랑)과 일치. 확정 성격 값(abnLevelY)이라 신규 리페인팅 없음.
plot(abnShowLevelLines ? abnLevelY : na, title="과매수/과매도선", color=abnLevelColor, display=display.price_scale, editable=true)

// =========================
// 밴드워킹(추세 국면) 판정 — 이치모쿠 advanced-ichimoku.pine "VWAP 상태" 알고리즘(원본 vwUpperWalk/vwLowerWalk)의 이식(포팅).
//  ⚠️ 기준 세트: 밴드워킹 판정 전용 VWAP 세트(length=bwRecentBars, 소스=src) — bwVwapValue/bwUpperBandValue1·2/bwLowerBandValue1·2/bwShouldPlot.
//   원본 이치모쿠는 자체 VWAP(recentBars=50, hlc3) 한 세트로만 밴드워킹을 판정하므로, auto-vwap에서도 "화면상 추세 국면"을
//   대변하는 전용 세트(bwRecentBars, 기본 14봉·화면 세트 recentBars=50과 독립)에 매핑한다. 변곡용 세트(length=14)와는 소스가 달라(src vs ipSrcShort/ipSrcLong) 별도 세트로 둔다.
//  ⚠️ 버그 교정(CEO 판단 A): 이전엔 화면 세트(recentBars, src)를 참조했다 → recentBars(화면 표시 전용)를 바꾸면 밴드워킹→마커 표시 여부가 오염됐다.
//   전용 window(bwRecentBars)로 분리. 기본 14봉으로 화면 세트(recentBars=50)와 독립이며, 소스만 화면과 동일한 src를 쓴다.
//  대응 매핑(이치모쿠 원본 → auto-vwap):
//   vwapValue→bwVwapValue · vwUpper1/vwLower1→bwUpperBandValue1/bwLowerBandValue1 · vwUpper2/vwLower2→bwUpperBandValue2/bwLowerBandValue2 · vwHasVwap→bwHasVwap.
//  파라미터: vwSlopeLen→ipBwSlopeLen(5) · vwWalkSlopeLen→ipBwWalkSlopeLen(3) · 평탄 임계 3%→ipBwFlatPct(0.03). 원본과 동일.
//  ⚠️ 확정 성격 값(과거참조 [n])만 참조 → 신규 리페인팅 없음. 표시 억제 전용(전략 로직 불변).
// =========================
bwHasVwap = bwShouldPlot and not na(bwVwapValue)
bwNearLower = bwHasVwap and not na(bwLowerBandValue1) and close < bwLowerBandValue1
bwNearUpper = bwHasVwap and not na(bwUpperBandValue1) and close > bwUpperBandValue1
bwBw2 = bwHasVwap and not na(bwUpperBandValue2) and not na(bwLowerBandValue2) ? bwUpperBandValue2 - bwLowerBandValue2 : na
bwSlope = bwHasVwap and not na(bwVwapValue[ipBwSlopeLen]) ? bwVwapValue - bwVwapValue[ipBwSlopeLen] : na
// 평탄 판정 임계 = 밴드폭의 ipBwFlatPct(기본 3%). 기울기가 이보다 작으면 평탄.
bwFlatThresh = not na(bwBw2) ? bwBw2 * ipBwFlatPct : na
bwSlopeUp = not na(bwSlope) and not na(bwFlatThresh) and bwSlope > bwFlatThresh
bwSlopeDown = not na(bwSlope) and not na(bwFlatThresh) and bwSlope < -bwFlatThresh
bwSlopeFlat = bwHasVwap and not bwSlopeUp and not bwSlopeDown
bwExpanding = bwHasVwap and not na(bwBw2[ipBwSlopeLen]) and bwBw2 > bwBw2[ipBwSlopeLen]
bwContracting = bwHasVwap and not na(bwBw2[ipBwSlopeLen]) and bwBw2 < bwBw2[ipBwSlopeLen]
bwPreWalk = bwContracting or bwSlopeFlat or bwContracting[1] or bwContracting[2]
bwUpBreakout = bwPreWalk and close > open and not na(bwUpperBandValue2) and close > bwUpperBandValue2
bwDownBreakout = bwPreWalk and close < open and not na(bwLowerBandValue2) and close < bwLowerBandValue2
bwLowerRising = bwHasVwap and not na(bwLowerBandValue2[ipBwWalkSlopeLen]) and bwLowerBandValue2 > bwLowerBandValue2[ipBwWalkSlopeLen]
bwUpperFalling = bwHasVwap and not na(bwUpperBandValue2[ipBwWalkSlopeLen]) and bwUpperBandValue2 < bwUpperBandValue2[ipBwWalkSlopeLen]
var int bwWalk = 0
if bwWalk == 1 and (not bwHasVwap or bwUpperFalling)
    bwWalk := 0
if bwWalk == -1 and (not bwHasVwap or bwLowerRising)
    bwWalk := 0
if bwUpBreakout
    bwWalk := 1
if bwDownBreakout
    bwWalk := -1
// 위(상승) 밴드워킹 / 아래(하락) 밴드워킹 — 이치모쿠 원본 vwUpperWalk/vwLowerWalk 동일 산식(추가 게이트 없음).
isUpBandWalking = bwWalk == 1 or (bwExpanding and bwSlopeUp and bwNearUpper)
isDownBandWalking = bwWalk == -1 or (bwExpanding and bwSlopeDown and bwNearLower)

// =========================
// 횡보 압축(리본) 판정 — advanced-ichimoku.pine 리본 A모드(이평 리본) 이식(자기완결·B모드 제거).
//  원본 매핑: ribbonMa/rAtr/aStep/aMa*/aTop/aBottom/aHeight/aCompressed/aExpanding/aBull 동일 산식.
//   원본 conversionPeriods→ribbonConvPeriods, leadingSpanBPeriods→ribbonSpanBPeriods(리본 전용 input). 소스 close 동일.
//  원본 모드 결합(compNow/expNow/bullNow/bearNow)에서 B·A and B 항을 제거하고 A모드값으로 고정.
//  ⚠️ 실시간 반영(CEO 지시): 확정봉(barstate.isconfirmed) 게이트 제거 → 상태 래치를 매 봉(형성 중 현재봉 포함) 갱신.
//   현재봉에서 압축 진입 시 즉시 회색 ON, 분출 시 즉시 OFF. 미마감봉 켜짐/꺼짐·과거봉 재계산(리페인팅)은 허용(CEO 명시).
//  ⚠️ 표시 전용(회색 배경 래치)만 산출. 변곡/게이트/밴드/청산선 로직과 무관.
// =========================
ribbonMa(length) =>
    switch ribbonMaType
        "SMA" => ta.sma(close, length)
        "EMA" => ta.ema(close, length)
        "WMA" => ta.wma(close, length)
        "VWMA" => ta.vwma(close, length)
rAtr = ta.atr(ribbonAtrLength)
// A 모드: 리본 전용 길이(빠른~느린)에 맞춘 7개 이평 리본
aStep = (ribbonSpanBPeriods - ribbonConvPeriods) / 6.0
aMaFast = ribbonMa(math.max(1, ribbonConvPeriods))
aMa1 = ribbonMa(math.max(1, int(math.round(ribbonConvPeriods + aStep))))
aMa2 = ribbonMa(math.max(1, int(math.round(ribbonConvPeriods + aStep * 2))))
aMa3 = ribbonMa(math.max(1, int(math.round(ribbonConvPeriods + aStep * 3))))
aMa4 = ribbonMa(math.max(1, int(math.round(ribbonConvPeriods + aStep * 4))))
aMa5 = ribbonMa(math.max(1, int(math.round(ribbonConvPeriods + aStep * 5))))
aMaSlow = ribbonMa(math.max(1, ribbonSpanBPeriods))
aTop = math.max(aMaFast, math.max(aMa1, math.max(aMa2, math.max(aMa3, math.max(aMa4, math.max(aMa5, aMaSlow))))))
aBottom = math.min(aMaFast, math.min(aMa1, math.min(aMa2, math.min(aMa3, math.min(aMa4, math.min(aMa5, aMaSlow))))))
aHeight = math.max(aTop - aBottom, syminfo.mintick)
aCompressed = not na(rAtr) and aHeight < rAtr * ribbonCompressAtrMult
aExpanding = not na(aHeight[ribbonExpandBars]) and aHeight > aHeight[ribbonExpandBars]
aBull = aMaFast >= aMaSlow
// A모드 고정 결합(원본 compNow/bullNow/bearNow에서 B항 제거). 폭 확장은 aExpanding을 직접 참조한다.
compNow = aCompressed
bullNow = aBull
bearNow = not aBull
// 회색 배경 유지 래치(정합 재작성 — ON/OFF를 동일한 chopBgOn/compNow 레벨 위에서 판정).
//  ⚠️ 버그 수정: 이전(엣지 기반 rArmed 상태머신) 방식은 ON은 compNow(레벨)로 켜는데 OFF는
//   진입 엣지(compNow and not compNow[1])로만 무장되는 var rArmed에 의존 → 무장/분출 타이밍이
//   ON 기준과 어긋나 분출이 영영 안 잡히면 회색이 분출 후에도 무한 유지되는 결함이 있었다.
//   (압축이 여러 봉 유지되는 동안 aExpanding이 한 번이라도 참이면 rArmed가 소진되어, 실제 분출 봉에서
//    rArmed=false·같은 방향이면 분출 판정이 성립하지 않았다.)
//  ✅ 정합 원칙: "회색이 켜져 있다(chopBgOn)"는 사실 자체를 무장 상태로 사용한다. 별도 var 상태머신을 두지 않는다.
//   - ON:  압축 상태(compNow)가 성립한 봉에 즉시 ON(1봉 지연 없음).
//   - OFF: 회색이 켜진 뒤(chopBgOn) 압축이 풀리고(not compNow) 밴드 폭이 다시 확장(aExpanding)되며
//          방향(bullNow/bearNow)이 잡히면 = 분출 → 즉시 OFF. aExpanding은 압축이 풀린 뒤 평가되므로
//          압축 도중 무장이 소진되는 문제가 원천 제거된다.
//   - 그 외(압축 아님 + 분출도 아님)는 chopBgOn 유지 → 깜빡임 없음. 압축이 계속 참이면 유지.
//  ⚠️ 실시간 반영(CEO 지시): 확정봉(barstate.isconfirmed) 게이트 없이 매 봉(형성 중 현재봉 포함) 갱신.
//   미마감봉에서 켜짐/꺼짐·과거봉 재계산되는 리페인팅은 허용(CEO 명시). 표시 전용 래치이며 신호 로직과 무관.
//   rBullExpansion/rBearExpansion은 방향 표기용(회색 배경 전용) — 다른 로직에서 참조하지 않는다.
var bool chopBgOn = false
bool rBullExpansion = chopBgOn and not compNow and aExpanding and bullNow
bool rBearExpansion = chopBgOn and not compNow and aExpanding and bearNow
if compNow
    chopBgOn := true            // 압축 봉에 즉시 ON(지연 없음)
else if rBullExpansion or rBearExpansion
    chopBgOn := false           // 압축 종료 후 분출(폭 재확장 + 방향) 시 OFF

isLowerBand2Break = shouldPlot and showBand_2 and not na(lowerBandValue2) and low < lowerBandValue2
isUpperBand2Break = shouldPlot and showBand_2 and not na(upperBandValue2) and high > upperBandValue2
// Rare wide-range candles can sweep both sides; bias the highlight toward the close vs VWAP.
color breakHighlightLineColor = DEFAULT_LINE_COLOR
if isLowerBand2Break and not isUpperBand2Break
    breakHighlightLineColor := LOWER_BREAK_LINE_COLOR
else if isUpperBand2Break and not isLowerBand2Break
    breakHighlightLineColor := UPPER_BREAK_LINE_COLOR
else if isLowerBand2Break and isUpperBand2Break
    breakHighlightLineColor := close <= vwapValue ? LOWER_BREAK_LINE_COLOR : UPPER_BREAK_LINE_COLOR

color activeLineColor = enableDynamicLineColor ? breakHighlightLineColor : DEFAULT_LINE_COLOR
color activeFillColor = color.new(activeLineColor, 92)

// =========================
// VWAP 중앙선 지지/저항 색 판정(CEO 확정 — near 구간 종가 + 꼬리 걸침 이탈). 화면 기본 VWAP 선(vwapValue) 전용.
//  판정에 쓰는 close·high·low·vwapValue·밴드1(upperBandValue1/lowerBandValue1)은 모두 현재봉의 확정 성격 세트값이다.
//   → 과거 봉 색은 재계산돼도 값이 불변이라 리페인팅(과거 변조) 없음. 형성 중 현재봉만 종가/고저 확정 전 색이 바뀔 수 있으나(정상적 인트라바 갱신) 봉 마감 시 확정된다.
//  "near 구간" = VWAP와 밴드1 사이의 **동적 %(pct) 범위**. 하단 near=[lowerNear, vwap], 상단 near=[vwap, upperNear]. 하단 near 최저=lowerNear, 상단 near 최고=upperNear.
//   ▸ upperNear = vwap + pct×(upperBand1 − vwap),  lowerNear = vwap − pct×(vwap − lowerBand1). 저항(하단)·지지(상단) 동일 pct 대칭.
//  [pct 동적 산출 — 밴드폭 반비례, 범위 [0.20, 0.60]]
//   ▸ 밴드폭 측정: bandWidth1 = upperBand1 − lowerBand1 (밴드1 폭 = 2×stdev×bandMult_1). near 가 밴드1 기준이므로 밴드1 폭 사용.
//   ▸ 정규화(종목·가격 무관): r = bandWidth1 / vwap (가격 대비 밴드폭 비율). 절대값이 아닌 비율.
//   ▸ 매핑(반비례): r≤rLow(저변동성·좁은밴드)→최대%(0.60), r≥rHigh(고변동성·넓은밴드)→최소%(0.20), 사이는 선형보간·clamp.
//       t = clamp((r − rLow)/(rHigh − rLow), 0, 1);  nearPct = maxPct − t×(maxPct − minPct);  pct = clamp(nearPct, 0, 100)/100.
//   ▸ rLow=vwapNearRLowPct/100(기본 0.5%), rHigh=vwapNearRHighPct/100(기본 2.0%). rHigh≤rLow(임계 뒤집힘)·vwap==0(r na)이면 t=0 → 최대%(넓은 near, 판정 보수화) 폴백.
//  ▸ 저항(빨강, UPPER_BREAK_LINE_COLOR) =
//     ① lowerNear ≤ close ≤ vwap                (하단 near 안에 종가 마감 → VWAP이 저항)  OR
//     ② close < lowerNear AND high > lowerNear   (종가는 하단 near 아래로 이탈했으나 고가가 하단 near 최저 위 = 꼬리 걸침)
//  ▸ 지지(녹, LOWER_BREAK_LINE_COLOR) =
//     ③ vwap ≤ close ≤ upperNear                (상단 near 안에 종가 마감 → VWAP이 지지)  OR
//     ④ close > upperNear AND low < upperNear    (종가는 상단 near 위로 이탈했으나 저가가 상단 near 최고 아래 = 꼬리 걸침)
//  ▸ 그 외(완전 이탈: close가 near 구간 밖 + 꼬리도 near에 안 걸침 / na 워밍업) → 중립(흰, DEFAULT_LINE_COLOR).
//  ★ close==vwap 경계: ①은 close≤vwap, ③은 close≥vwap이라 close==vwap이 양쪽에 걸린다. **저항을 먼저 평가**(if 저항 → else if 지지)해
//    close==vwap이면 저항(빨강)으로 확정한다. 부동소수라 실제 동일값은 드묾.
//  ★ 상호배타·구멍 없음 검증:
//    · 저항 계열(close≤vwap[①] or close<lowerNear[②])과 지지 계열(close≥vwap[③] or close>upperNear[④])은 close==vwap 외엔 배타(위 우선순위로 close==vwap도 저항 단일 확정).
//    · ②(close<lowerNear)와 ①(close≥lowerNear) 배타, ④(close>upperNear)와 ③(close≤upperNear) 배타.
//    · lowerNear ≤ vwap ≤ upperNear(pct≥0·밴드 구조상 항상 성립)이므로 ②(close<lowerNear)와 ④(close>upperNear)도 동시 성립 불가.
//  엣지케이스: (a) close==vwap → 저항(빨강, 위 우선순위). (b) 밴드1/vwap na(워밍업) → 진입 가드에서 걸러져 흰.
//   (c) 밴드1 편차 0(도지) lowerBand1==upperBand1==vwap → bandWidth1=0 → r=0(≤rLow)이라 pct=최대나, upperNear==vwap·lowerNear==vwap로 near 구간 소멸.
//       close==vwap이면 ① 해당(저항), close≠vwap이면 ②(high>vwap==lowerNear)/④(low<vwap==upperNear)의 꼬리 걸침으로 판정. 확정봉 세트값이라 리페인팅 없음.
//  enableDynamicLineColor(밴드2 이탈 녹/빨강)와 독립한 별도 VWAP 선 전용 색이다.
// =========================
// ★ CEO 지시(무조건 억제): 지지/저항 "상태"는 옵션(enableVwapSRColor)과 무관하게 항상 판정한다.
//   - 판정 산식(pct/near/저항·지지)은 옵션이 담당하던 선색 규칙과 동일하되, if 게이트에서 enableVwapSRColor를 뺐다.
//   - 결과 boolean(vwapResistance/vwapSupport)을 최상위 스코프로 노출해 표시 최종단(showLong/ShortMarker)의 무조건 억제에 쓴다.
//   - 색 적용(vwapSRColor 칠하기)만 여전히 옵션에 종속시킨다(선색 표시 거동 보존). 즉 "상태 판정은 항상 / 색칠은 옵션 ON일 때만".
//   - shouldPlot·밴드1/vwap na 가드는 유지 → 워밍업엔 둘 다 false(중립)라 억제 없음(CEO "중립 무영향" 충족).
bool vwapResistance = false
bool vwapSupport = false
color vwapSRColor = DEFAULT_LINE_COLOR
if shouldPlot and not na(vwapValue) and not na(upperBandValue1) and not na(lowerBandValue1)
    // [pct 동적 산출] 밴드폭 반비례. 밴드폭/VWAP 비율 r을 rLow~rHigh 사이 정규화 → maxPct~minPct 반비례 매핑. 확정봉 세트값 → 리페인팅 없음.
    float bandWidth1 = upperBandValue1 - lowerBandValue1          // 밴드1 폭(= 2×stdev×bandMult_1)
    float rNear = vwapValue != 0 ? bandWidth1 / vwapValue : na    // 가격 대비 밴드폭 비율(종목·가격 무관 정규화)
    float rLow  = vwapNearRLowPct / 100.0                         // 저변동성 임계(입력 %→비율)
    float rHigh = vwapNearRHighPct / 100.0                        // 고변동성 임계(입력 %→비율)
    // 임계 뒤집힘(rHigh<=rLow)·rNear na(vwap 0)면 보간 불가 → t=0 → 최대%(넓은 near, 판정 보수화) 폴백.
    float tNear = (na(rNear) or rHigh <= rLow) ? 0.0 : math.min(math.max((rNear - rLow) / (rHigh - rLow), 0.0), 1.0)
    float nearPct = vwapNearMaxPct - tNear * (vwapNearMaxPct - vwapNearMinPct)  // 반비례: t=0(저변동·좁음)→max(0.60), t=1(고변동·넓음)→min(0.20)
    float pct = math.min(math.max(nearPct, 0.0), 100.0) / 100.0   // 최종 clamp [0,100] 후 비율화
    // near 구간 경계(밴드1 기준). 도지(편차 0)면 upperNear==vwap / lowerNear==vwap로 수렴 → strict 부등호가 꼬리 판정으로 자연 처리.
    float upperNear = vwapValue + pct * (upperBandValue1 - vwapValue)
    float lowerNear = vwapValue - pct * (vwapValue - lowerBandValue1)
    // 저항 = ①(하단 near 안 종가) OR ②(종가 하단 near 아래 이탈 + 고가 꼬리 걸침). ② high>lowerNear로 꼬리가 하단 near 최저 위에 닿았는지 판정.
    bool isResistance = (close >= lowerNear and close <= vwapValue) or (close < lowerNear and high > lowerNear)
    // 지지 = ③(상단 near 안 종가) OR ④(종가 상단 near 위 이탈 + 저가 꼬리 걸침). ④ low<upperNear로 꼬리가 상단 near 최고 아래에 닿았는지 판정.
    bool isSupport = (close >= vwapValue and close <= upperNear) or (close > upperNear and low < upperNear)
    // ★ close==vwap 우선순위: 저항을 먼저 확정(지지보다 먼저). 상태 boolean도 동일 우선순위로 상호배타 도출.
    if isResistance
        vwapResistance := true                  // 저항 상태(빨강). close==vwap은 여기서 우선 확정(지지보다 먼저).
    else if isSupport
        vwapSupport := true                     // 지지 상태(녹).
    // 색칠은 옵션 ON일 때만(선색 표시 거동 보존). 상태 판정과 독립.
    if enableVwapSRColor
        vwapSRColor := vwapResistance ? UPPER_BREAK_LINE_COLOR : vwapSupport ? LOWER_BREAK_LINE_COLOR : DEFAULT_LINE_COLOR
// 최종 VWAP 선 색: 지지/저항 규칙 ON이면 그 색(중립이면 흰색), OFF면 기존 activeLineColor(동적색 옵션 거동 보존).
color vwapLineColor = enableVwapSRColor ? vwapSRColor : activeLineColor

// =========================
// 샹들리에 청산선(스윕/청산) — 이치모쿠 advanced-ichimoku.pine 의 로직을 그대로 이식(값 계산 전용).
//  - longCE  : 가격 아래쪽 스윕(샹들리에, ta.highest - ATR, 상향 트레일). longClear = 그 너머(더 아래).
//  - shortCE : 가격 위쪽 스윕(샹들리에, ta.lowest + ATR, 하향 트레일). shortClear = 그 너머(더 위).
//  - 산식·파라미터 기본값(기간 22, ATR 배수 3.0, 버퍼 0.4, 피벗 5, 최대간격 1.0)은 이치모쿠와 동일.
//  - 스윕 가격 모드(ceMode)도 이치모쿠와 동일: 기본 / 거래량 가중(VWMA) / 최근봉 가중(WMA) / 거래량+최근봉(f_volRecencyMa).
//    기본값은 이치모쿠와 동일하게 "기본". 가중 모드 선택 시 청산선(longCE/shortCE→longClear/shortClear)이 그 가중 앵커 기준으로 계산됨.
//  - 확정 성격 값(ta.*)·과거참조([1] 트레일)만 사용 → 이치모쿠와 동일하게 신규 리페인팅 없음.
//    가중 모드도 앵커를 직전 봉([1]) 기준으로 잡아(형성 중 현재봉 제외) 이치모쿠와 동일한 확정 성격 유지.
//  - 청산선(longClear/shortClear)은 computeClearLines 헬퍼로 계산한다. 파라미터 세트는 "스윕/청산" 그룹(기본 청산 설정) 하나뿐이다(CEO 지시 #4: 변곡 전용 세트 삭제).
//    · 화면 페인팅: mode=ceMode 세트를 plot 으로 전 히스토리 봉에 직접 그린다(이치모쿠에서 이동).
//    · 변곡 마커 후보 판정: 같은 파라미터로 mode만 "기본"·"거래량 가중"·"최근봉 가중" 3가지로 각각 계산해 OR로 확인한다(#1·#2).
//    스윕라인(longCE/shortCE)은 여기로 옮기지 않는다(그리지 않음).
// =========================
ceLength = input.int(14, title="스윕 룩백 길이", minval=1, group="스윕/청산")
ceAtrLen = input.int(14, title="스윕 ATR 길이", minval=1, group="스윕/청산")
ceMult = input.float(3.0, title="스윕 ATR 배수", minval=0.0, step=0.01, group="스윕/청산")
// 스윕 가격 모드(샹들리에 기반):
//  - 기본: 표준 샹들리에(룩백 고가/저가 − ATR)
//  - 거래량 가중: 거래량 큰 봉(VWMA)에 가중 → 거래 몰린 봉에서 스윕가를 끌어올림
//  - 최근봉 가중: 최근봉(WMA)에 가중 → 휩쏘 급등/급락 봉에서 스윕가를 빠르게·높게
//  - 거래량+최근봉: 두 가중을 함께(거래량 × 선형 최근봉)
ceMode = input.string("최근봉 가중", title="스윕 가격 모드", options=["기본", "거래량 가중", "최근봉 가중", "거래량+최근봉"], group="스윕/청산")
ceWeightLen = input.int(14, title="가중 트레일 길이", minval=1, group="스윕/청산")
ceWeightMult = input.float(3.0, title="가중 트레일 ATR 배수", minval=0.0, step=0.01, group="스윕/청산")
sweepBufferMult = input.float(1.0, title="청산 버퍼 ATR 배수(스윕 너머)", minval=0.0, step=0.1, group="스윕/청산")
useSweepPivot = input.bool(true, title="청산에 스윙 풀(피벗) 반영", group="스윕/청산")
sweepPivotLen = input.int(5, minval=1, title="스윙 풀 좌우 봉수", group="스윕/청산")
sweepMaxGapMult = input.float(1.0, title="청산-스윕 최대 간격 ATR 배수", minval=0.1, step=0.1, group="스윕/청산")
// 청산선(직선=손절 기준선) 차트 페인팅 옵션 — 이치모쿠에서 이 지표로 이동(CEO 지시).
//  청산선(longClear/shortClear)만 전 히스토리 봉에 plot으로 그린다(스윕라인 longCE/shortCE는 여기로 옮기지 않음).
//  ⚠️ 이 "스윕/청산" 그룹의 청산선은 화면 plot 전용이다. 변곡 지점(밴드2 마커) 판정은 "변곡 지점" 그룹의 독립 청산선 세트를 쓴다(CEO 지시: 세트 완전 독립).
showClearLines = input.bool(true, title="청산선 표시(전 히스토리 봉)", group="스윕/청산", tooltip="롱/숏 청산선(직선=손절 기준선)을 차트 전 구간 봉마다 plot으로 그립니다. 스윕라인(점선)은 이 지표에 없습니다(이치모쿠 전략 전용).")
clearLineWidth = input.int(1, title="청산 선 두께", minval=1, group="스윕/청산", active=showClearLines)
longClearLineColor = input.color(#00C853, title="롱 청산선 색", group="스윕/청산", active=showClearLines, tooltip="청산선(직선=손절 기준선)의 롱 색. 값 계산·밴드2 색 판정에는 영향 없는 표시 옵션입니다.")
shortClearLineColor = input.color(#FF1744, title="숏 청산선 색", group="스윕/청산", active=showClearLines, tooltip="청산선(직선=손절 기준선)의 숏 색. 값 계산·밴드2 색 판정에는 영향 없는 표시 옵션입니다.")

// 거래량 × 최근봉(선형) 가중 평균
f_volRecencyMa(src, len) =>
    float num = 0.0
    float den = 0.0
    for i = 0 to len - 1
        float w = volume[i] * (len - i)
        num += src[i] * w
        den += w
    den != 0 ? num / den : src

// 청산선(longClear/shortClear) 계산 헬퍼 — 이치모쿠에서 이식한 산식을 그대로 함수화(값 불변).
//  각 호출은 독립 var/ta 상태를 가지므로 화면 페인팅용(mode=ceMode)과 후보 판정용 3모드(기본/거래량/최근봉) 세트를 안전히 병렬 계산할 수 있다.
//  반환: [longClear, shortClear]. 확정 성격 값(ta.*·과거참조 [1] 트레일)만 사용 → 신규 리페인팅 없음.
computeClearLines(int ceLen, int atrLen, float mult, string mode, int wLen, float wMult, float bufMult, bool usePivot, int pivotLen, float maxGapMult) =>
    atrCe = ta.atr(atrLen)   // 한 번만 계산해 ceAtrVal·weightAtr·sweepAtr에서 재사용(중복 ta.atr 제거)
    ceAtrVal = mult * atrCe
    // 모드별 앵커 — 활성 모드에 필요한 것만 계산(기본 모드에선 VWMA/WMA/가중루프 모두 생략 → 속도↑).
    // 가중 모드(거래량/최근봉/거래량+최근봉)는 형성 중인 현재봉을 제외하고 **직전 봉 기준**([1])으로 앵커를 잡는다.
    longAnchorWNow = mode == "거래량 가중" ? ta.vwma(high, wLen) : mode == "최근봉 가중" ? ta.wma(high, wLen) : mode == "거래량+최근봉" ? f_volRecencyMa(high, wLen) : na
    shortAnchorWNow = mode == "거래량 가중" ? ta.vwma(low, wLen) : mode == "최근봉 가중" ? ta.wma(low, wLen) : mode == "거래량+최근봉" ? f_volRecencyMa(low, wLen) : na
    longAnchorW = longAnchorWNow[1]
    shortAnchorW = shortAnchorWNow[1]
    weightAtr = wMult * atrCe
    longCERaw = mode == "기본" ? ta.highest(high, ceLen) - ceAtrVal : longAnchorW - weightAtr
    shortCERaw = mode == "기본" ? ta.lowest(low, ceLen) + ceAtrVal : shortAnchorW + weightAtr
    var float longCE = na
    longCEPrev = nz(longCE[1], longCERaw)
    longCE := close[1] > longCEPrev ? math.max(longCERaw, longCEPrev) : longCERaw
    var float shortCE = na
    shortCEPrev = nz(shortCE[1], shortCERaw)
    shortCE := close[1] < shortCEPrev ? math.min(shortCERaw, shortCEPrev) : shortCERaw

    sweepAtr = atrCe
    sweepPLow = ta.pivotlow(pivotLen, pivotLen)
    sweepPHigh = ta.pivothigh(pivotLen, pivotLen)
    var float lastSweepPLow = na
    var float lastSweepPHigh = na
    lastSweepPLow := not na(sweepPLow) ? sweepPLow : lastSweepPLow
    lastSweepPHigh := not na(sweepPHigh) ? sweepPHigh : lastSweepPHigh
    float longClearLocal = longCE - bufMult * sweepAtr
    longClearLocal := usePivot and not na(lastSweepPLow) ? math.min(longClearLocal, lastSweepPLow - syminfo.mintick) : longClearLocal
    longClearLocal := math.max(longClearLocal, longCE - maxGapMult * sweepAtr)
    float shortClearLocal = shortCE + bufMult * sweepAtr
    shortClearLocal := usePivot and not na(lastSweepPHigh) ? math.max(shortClearLocal, lastSweepPHigh + syminfo.mintick) : shortClearLocal
    shortClearLocal := math.min(shortClearLocal, shortCE + maxGapMult * sweepAtr)
    [longClearLocal, shortClearLocal]

// (a) 기본 청산선 세트(화면 페인팅용) — mode=ceMode. 화면에 plot으로 그려진다(전 히스토리 봉).
//  ⚠️ 이 세트(ceMode)는 화면 plot·손익비 등 표시 전용이다. 변곡 마커 판정(후보·수평필터·표시) 어디에도 쓰지 않는다(사양 1: ceMode는 페인팅 전용).
[longClear, shortClear] = computeClearLines(ceLength, ceAtrLen, ceMult, ceMode, ceWeightLen, ceWeightMult, sweepBufferMult, useSweepPivot, sweepPivotLen, sweepMaxGapMult)
// (b) 후보 판정용 3모드 청산선 세트(CEO 지시 #1·#2) — mode만 "기본"·"거래량 가중"·"최근봉 가중"으로 바꿔 각각 계산한다.
//  mode 외 파라미터(길이·ATR·배수·가중·버퍼·피벗·최대간격)는 모두 "스윕/청산" 그룹(기본 청산 설정) 공통값을 쓴다.
//  각 호출은 computeClearLines 내부 var/ta 상태가 독립이라 3세트를 안전히 병렬 계산할 수 있다.
// 변수명은 ASCII(_base=기본 / _vol=거래량 가중 / _recent=최근봉 가중)로 둔다(기존 파일 변수명 규약 유지: 한글 변수명 전례 없음).
[longClear_base, shortClear_base] = computeClearLines(ceLength, ceAtrLen, ceMult, "기본", ceWeightLen, ceWeightMult, sweepBufferMult, useSweepPivot, sweepPivotLen, sweepMaxGapMult)
[longClear_vol, shortClear_vol] = computeClearLines(ceLength, ceAtrLen, ceMult, "거래량 가중", ceWeightLen, ceWeightMult, sweepBufferMult, useSweepPivot, sweepPivotLen, sweepMaxGapMult)
[longClear_recent, shortClear_recent] = computeClearLines(ceLength, ceAtrLen, ceMult, "최근봉 가중", ceWeightLen, ceWeightMult, sweepBufferMult, useSweepPivot, sweepPivotLen, sweepMaxGapMult)
// 수평 필터용 ATR — 후보/수평 판정이 3모드 청산선(shortClear_*/longClear_*) 기준이므로 기본 스윕 ATR 길이(ceAtrLen)에 맞춘다.
//  ⚠️ ATR은 mode 무관 공통값이라 ceMode에 의존하지 않는다(모드 독립 보장의 일부).
ipFlatAtr = ta.atr(ceAtrLen)

// =========================
// 변곡 지점(Inflection Point) 판정 — 변곡용 밴드2 상/하단 선이 "기본 청산선"(3모드 OR) 안으로 들어오는지 판정한다.
//  밴드2 선 색은 기본색 고정, 변곡 순간은 마커로만 표시한다.
//  - 화면 밴드(upperBandValue2/lowerBandValue2) 위치·색은 절대 변경하지 않는다(언제나 원값 위치 + 기본 activeLineColor).
//  - 후보 판정(CEO 지시 #1·#2): 청산 설정의 가격 모드를 "기본"·"거래량 가중"·"최근봉 가중" 3가지로 각각 계산한 청산선 중
//    **1개 이상**을 밴드2가 뚫고 들어오면 후보. (숏=ipUpperBandValue2 < shortClear_m, 롱=ipLowerBandValue2 > longClear_m, m∈{기본,거래량,최근봉})
//  - 상/하단 각각 독립 판정.
// =========================
// 변곡 판정은 **변곡용 VWAP 세트(length=14)의 밴드2**(ipUpperBandValue2/ipLowerBandValue2)와 **기본 청산선 3모드**(shortClear_*/longClear_*) 기준이다.
//  마커만 판정에 쓰므로 화면 밴드 위치·색은 불변.
// 요구사항 4: 청산선 "수평(flat)" 판정 헬퍼 — 최근 lb봉 사이 변화량을 ATR로 정규화한 비율이 임계 이내이면 true.
//  atr<=0(초기·데이터 부족)일 때는 정규화가 불가능하므로 필터를 통과시키지 않는다(false).
//  na 값(과거참조 부족)일 때도 판정 불가로 false 처리.
isClearLineFlat(float lineVal, int lb, float atrVal, float maxRatio) =>
    float prevVal = lineVal[lb]
    na(lineVal) or na(prevVal) or na(atrVal) or atrVal <= 0 ? false : (math.abs(lineVal - prevVal) / atrVal) <= maxRatio
// 후보 판정(CEO 지시 #1·#2) — 3모드 OR. na 가드는 각 항에 포함. 각 모드별 "밴드2 진입" 성립 여부를 개별 bool로 둔다.
//  숏 진입_m = (ipUpperBandValue2 < shortClear_m),  롱 진입_m = (ipLowerBandValue2 > longClear_m).  m∈{기본(base),거래량(vol),최근봉(recent)}.
//  ⚠️ 3모드는 모두 computeClearLines를 mode 리터럴("기본"/"거래량 가중"/"최근봉 가중")로 고정 호출한 세트라 ceMode 선택과 무관하다.
// 숏 경로는 숏 변곡 세트(소스=low)의 shouldPlot·상단 밴드2를, 롱 경로는 롱 변곡 세트(소스=high)의 shouldPlot·하단 밴드2를 쓴다(세트 1:1 매핑).
ipUpperBand2Valid = ipShouldPlotShort and not na(ipUpperBandValue2)
ipLowerBand2Valid = ipShouldPlotLong  and not na(ipLowerBandValue2)
shortEnter_base   = ipUpperBand2Valid and not na(shortClear_base)   and ipUpperBandValue2 < shortClear_base
shortEnter_vol    = ipUpperBand2Valid and not na(shortClear_vol)    and ipUpperBandValue2 < shortClear_vol
shortEnter_recent = ipUpperBand2Valid and not na(shortClear_recent) and ipUpperBandValue2 < shortClear_recent
longEnter_base    = ipLowerBand2Valid and not na(longClear_base)    and ipLowerBandValue2 > longClear_base
longEnter_vol     = ipLowerBand2Valid and not na(longClear_vol)     and ipLowerBandValue2 > longClear_vol
longEnter_recent  = ipLowerBand2Valid and not na(longClear_recent)  and ipLowerBandValue2 > longClear_recent
// 숏 후보 = OR_m ( 진입_m ),  롱 후보 = OR_m ( 진입_m ).
shortCand = shortEnter_base or shortEnter_vol or shortEnter_recent
longCand  = longEnter_base or longEnter_vol or longEnter_recent

// ── 수평 필터(밴드워킹 억제) — 모드 독립 교정(CEO 지시: ceMode가 마커에 관여 금지) ──
//  버그(교정 전): flat 판정 대상이 화면 페인팅용 shortClear/longClear(=ceMode 세트)였다 → 스윕 모드를 바꾸면 마커 발동이 바뀜(사양 1 위반).
//  교정(후보 논리와 정합): 후보에 기여한(밴드2가 들어온) 모드의 청산선이 flat일 때만 그 방향 flat 통과로 본다.
//   → 숏 flatOk = OR_m ( 진입_m AND flat(shortClear_m) ),  롱 flatOk = OR_m ( 진입_m AND flat(longClear_m) ).
//   3모드 청산선은 mode 리터럴 고정 호출이므로 ceMode 선택과 완전 무관하다. 필터 OFF면 항상 통과(기존 동작 유지).
ipUpperFlatOk = not ipFlatFilter or ((shortEnter_base and isClearLineFlat(shortClear_base, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)) or (shortEnter_vol and isClearLineFlat(shortClear_vol, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)) or (shortEnter_recent and isClearLineFlat(shortClear_recent, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)))
ipLowerFlatOk = not ipFlatFilter or ((longEnter_base and isClearLineFlat(longClear_base, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)) or (longEnter_vol and isClearLineFlat(longClear_vol, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)) or (longEnter_recent and isClearLineFlat(longClear_recent, ipFlatLookback, ipFlatAtr, ipFlatSlopeMax)))

// 표시 게이트(CEO 지시) — OBV 기반 DI+/DI- 우위. 3봉 hlc3 평균 게이트를 대체한다.
//  OBV-ADX 보조지표(obv-adx-extreme-background.pine)의 DI+/DI- 산식을 그대로 이식(값 동일, v6 정합).
//   obvValue = OBV 누적. up/down = OBV 변화량. plusDM/minusDM = 방향성 이동. trur = OBV 표준편차의 RMA(=정규화 기준).
//   diPlus = 100 * EMA(plusDM,len)/trur,  diMinus = 100 * EMA(minusDM,len)/trur.  (fixnan으로 trur==0/na 보정)
//  숏 변곡: DI- 우위(diMinus > diPlus).  롱 변곡: DI+ 우위(diPlus > diMinus).  na면 억제(둘 다 미표시).
//  ⚠️ 확정 성격 값(ta.cum/change/rma/stdev/ema)만 사용 → 신규 리페인팅 없음. 표시 게이트 전용(전략 로직 불변).
obvValue = ta.cum(math.sign(ta.change(close)) * volume)
obvUp = ta.change(obvValue)
obvDown = -ta.change(obvValue)
obvPlusDM = na(obvUp) ? na : obvUp > obvDown and obvUp > 0 ? obvUp : 0
obvMinusDM = na(obvDown) ? na : obvDown > obvUp and obvDown > 0 ? obvDown : 0
obvTrur = ta.rma(ta.stdev(obvValue, obvDiLen), obvDiLen)
diPlus = fixnan(obvTrur == 0 ? 0 : 100 * ta.ema(obvPlusDM, obvDiLen) / obvTrur)
diMinus = fixnan(obvTrur == 0 ? 0 : 100 * ta.ema(obvMinusDM, obvDiLen) / obvTrur)
// OBV 방향 격차 |diPlus−diMinus|(=obv-adx의 |diDiff|) — ADX·에너지 채도 공용. 원본 obv-adx가 diDiff를 재사용하듯 여기서도 한 번만 계산(중복 제거).
diEnergy = math.abs(diPlus - diMinus)
// ADX(OBV-ADX 원본 lensig 사용) — input 정합용으로 계산만 유지. 변곡 마커 게이트엔 미사용.
obvDiSum = diPlus + diMinus
obvAdx = 100 * ta.ema(diEnergy / (obvDiSum == 0 ? 1 : obvDiSum), obvAdxSmooth)
// DI 우위 게이트(na 가드 포함) — DI 값이 na면 해당 방향 억제.
shortDiGate = not na(diMinus) and not na(diPlus) and diMinus > diPlus
longDiGate = not na(diPlus) and not na(diMinus) and diPlus > diMinus
// ── OBV 에너지 강/약 판정(변곡 마커 색 채도 전용) — OBV-ADX 상태판 energyFading 산식 이식 ──
//  obv-adx-extreme-background.pine(L80-82): diEnergy=|diDiff|=|plus-minus|, diEnergyAvg=sma(diEnergy,obvEnergyLen),
//   energyFading = diEnergy < diEnergyAvg or diEnergy < diEnergy[3]. diEnergy는 위(obvAdx 앞)에서 이미 계산해 재사용(중복 없음).
//  평균 창은 obvEnergyLen(기본 5), 3봉 전 모멘텀 [3]은 평균과 무관한 독립 룩백(obv-adx와 동일한 고정 상수) → 평균이 짧아져도 시간축 부정합 없음.
//  energyStrong = not energyFading → '강(선명색)', energyFading → '약(둔탁색)'. na면 약으로 취급(보수적: 둔탁).
//  ⚠️ 확정 성격 값(ema/sma/과거참조[3])만 사용 → 신규 리페인팅 없음. 마커 색 채도만 바꿈(판정·표시 여부·y좌표 불변).
diEnergyAvg = ta.sma(diEnergy, obvEnergyLen)
energyFading = na(diEnergy) or na(diEnergyAvg) or diEnergy < diEnergyAvg or diEnergy < diEnergy[3]
energyStrong = not energyFading
// 채도 색 상수 — 선명색은 마커 기존 색(short/longClearLineColor), 둔탁색은 저장소 시그니처 팔레트(둔탁 녹/빨강, obv-adx 상태판과 동일).
color DULL_LONG_COLOR  = #6E8F72   // 둔탁 녹(롱 약)
color DULL_SHORT_COLOR = #A57A7A   // 둔탁 빨강(숏 약)
// 마커 색(채도 반영): 롱=강→선명 녹(longClearLineColor)/약→둔탁 녹, 숏=강→선명 빨강(shortClearLineColor)/약→둔탁 빨강.
//  ⚠️ 채도는 색만 바꾸며 마커 발동(upper2Marker/lower2Marker)에는 관여하지 않는다.
color lowerMarkerColor = energyStrong ? longClearLineColor : DULL_LONG_COLOR
color upperMarkerColor = energyStrong ? shortClearLineColor : DULL_SHORT_COLOR

// 방향성 밴드워킹 억제(ipBwSuppress) AND 결합 — 후보·수평필터·DI 우위 게이트 위에 방향 억제만 얹는다.
//  숏(빨강·상단) = 후보(3모드OR) AND 수평필터(숏) AND (DI- 우위) AND (not 상승 밴드워킹).
//  롱(녹색·하단) = 후보(3모드OR) AND 수평필터(롱) AND (DI+ 우위) AND (not 하락 밴드워킹).
//  토글 OFF면 억제 항이 항상 참 → 기존 동작 그대로.
upperBwOk = not ipBwSuppress or not isUpBandWalking
lowerBwOk = not ipBwSuppress or not isDownBandWalking
// ── VWAP 선색 AND 게이트(CEO 지시 A, 기존 #6) — 최종 선색(vwapSRColor) 기준, 원 변곡 단계 결합 ──
//  롱(하단) 마커: 선색이 흰색 또는 녹색일 때만 표시(빨강이면 억제). 숏(상단) 마커: 선색이 흰색 또는 빨강일 때만 표시(녹색이면 억제).
//  구현: 최종 vwapSRColor를 색 상수와 비교한다(녹=LOWER_BREAK_LINE_COLOR, 빨강=UPPER_BREAK_LINE_COLOR, 흰=DEFAULT_LINE_COLOR).
//  ⚠️ 선 지지/저항 색 옵션(enableVwapSRColor) OFF이면 선색 판정 자체가 없으므로 게이트를 적용하지 않는다(기존 마커 거동 유지). ON일 때만 억제 게이트 발동.
//  ⚠️ [무조건 억제와의 관계 — CEO 신규 지시] 표시 최종단(showLong/ShortMarker)에 옵션과 무관한 무조건 억제(not vwapResistance / not vwapSupport)를 별도로 얹었다.
//     · #6은 방향 매핑이 무조건 억제와 동일하다(지지=녹→숏 억제, 저항=빨강→롱 억제). 단 #6은 (a)옵션 ON에서만·(b)원 변곡 단계에만 걸린다.
//     · 무조건 억제는 옵션과 무관·표시 최종단(원 변곡+연장 합류)에 걸리는 상위집합이라, enableVwapSRColor ON에서는 #6이 억제하는 봉을 최종단이 항상 함께 억제한다(중복이나 무해 — 결과 동일, 더 억제하지 않음).
//     · 따라서 #6은 유지한다(임의 제거 지양). ON 상태에서 #6 제거해도 결과는 같지만, OFF 상태 원 변곡 거동을 보존하고 이력 최소 침습을 위해 그대로 둔다.
//  선색은 확정 성격 값(close·high·low·vwap·밴드1) 기반이라 신규 리페인팅 없음(현재봉 실시간 변동 성격은 기존 선색과 동일).
bool srcGateLong  = not enableVwapSRColor or vwapSRColor != UPPER_BREAK_LINE_COLOR  // 롱: 빨강만 억제(흰/녹 허용)
bool srcGateShort = not enableVwapSRColor or vwapSRColor != LOWER_BREAK_LINE_COLOR  // 숏: 녹색만 억제(흰/빨강 허용)
// ── 캔들 형태 게이트(옵션 ipShapeFilter, 기본 OFF) — 원 변곡 마커(upper2Marker/lower2Marker)에만 AND 결합 ──
//  ON이면 방향(양봉/음봉)을 기본으로, 여기에 몸통↔꼬리 형태 제외 조건을 추가한다. OFF면 게이트가 항상 통과(방향·형태 무관). 모두 확정봉 OHLC 기반 → 신규 리페인팅 없음.
bool  ipBull      = close > open                        // 양봉
bool  ipBear      = close < open                        // 음봉  (도지: close==open → 둘 다 false)
//  몸통·꼬리 변수(형태 제외용) — 게이트 참조보다 앞에서 선언. abs·max·min은 모두 확정봉 OHLC 기반.
float body      = math.abs(close - open)                // 몸통 크기(절대값)
float upperWick = high - math.max(close, open)          // 위꼬리
float lowerWick = math.min(close, open) - low           // 아래꼬리
//  ▸ [공통 형태 반전 필터] — 원 변곡·연장 override 양쪽에 일관 적용하기 위해 boolean으로 추출한다(CEO 지시: 반전형은 방향/경로 무관 제외).
//     shortRejectShape = 하방 반전형(위꼬리가 몸통의 25% 미만이고 아래꼬리가 몸통보다 긴 봉 = 긴 아래꼬리·위꼬리 거의 없음) → 숏 마커 금지.
//     longRejectShape  = 상방 반전형(아래꼬리가 몸통의 25% 미만이고 위꼬리가 몸통보다 긴 봉 = 긴 위꼬리·아래꼬리 거의 없음) → 롱 마커 금지.
//     도지(body=0)면 body*0.25=0 → upperWick<0/lowerWick<0 불성립 → 제외조건 자연 미성립(안전).
bool  shortRejectShape = upperWick < body * 0.25 and lowerWick > body
bool  longRejectShape  = lowerWick < body * 0.25 and upperWick > body
//  ▸ 옵션(ipShapeFilter, 기본 OFF): OFF면 게이트가 항상 통과 → 원 변곡이 방향·형태 무관하게 발동(도지 포함). ON이면 아래 기존 동작 그대로.
//  ▸ 숏 변곡 유효 = 음봉.  제외 = "양봉 OR 도지".
//     도지(close==open)는 음봉이 아니므로 자동 제외(방향성 미확정 → 오탐 방지·자본 보존).
//  ▸ [개선 1] 음봉 숏 변곡 형태 제외: 하방 반전형(shortRejectShape)은 숏에서 제외.
bool  shortShapeOk = not ipShapeFilter or (ipBear and not shortRejectShape)
//  ▸ 롱 변곡 유효 = 양봉.  제외 = "음봉 OR 도지".
//     도지는 양봉이 아니므로 자동 제외.
//  ▸ [개선 2] 양봉 롱 변곡 형태 제외: 상방 반전형(longRejectShape)은 롱에서 제외.
bool  longShapeOk  = not ipShapeFilter or (ipBull and not longRejectShape)
//  ⚠️ 형태 방향 게이트(음봉/양봉)+형태 반전 필터(shortRejectShape/longRejectShape)는 원 변곡(upper2Marker/lower2Marker)에만 AND 결합한다. 연장(shortExt/longExt)에는 별도의 단독 꼬리 조건(반대 꼬리 ≤ 몸통)을 결합한다(아래 L582 인근).
upper2Marker = shortCand and ipUpperFlatOk and shortDiGate and upperBwOk and srcGateShort and shortShapeOk
lower2Marker = longCand and ipLowerFlatOk and longDiGate and lowerBwOk and srcGateLong and longShapeOk

// =========================
// 변곡 마커 연장(follow-through / override) — CEO 신규 규칙. 원 변곡 마커가 뜬 다음 봉에서 고·저점이 함께 이동하면(추세 지속) 동일 색 마커를 이어 표시한다.
//  ▸ [개선 3] 롱 연장(longExt): 이전봉에 롱 변곡 마커(lower2Marker[1])가 있었고 현재봉 저점>이전저점(low > low[1]) **그리고** 고점>이전고점(high > high[1])이면 롱 마커를 연장.
//       → 현재봉이 음봉이든 숏 변곡 자리든 **무관**하게 롱을 넣는다(CEO: "숏 변곡 자리든 롱 넣는다"). 기존 현재봉 방향 게이트(ipBull) 제거·고점 상승 조건 추가.
//  ▸ [개선 4] 숏 연장(shortExt): 이전봉에 숏 변곡 마커(upper2Marker[1])가 있었고 현재봉 고점<이전고점(high < high[1]) **그리고** 저점<이전저점(low < low[1])이면 숏 마커를 연장.
//       → 현재봉이 양봉이든 롱 변곡 자리든 **무관**하게 숏을 넣는다. 기존 현재봉 방향 게이트(ipBear) 제거·저점 하락 조건 추가.
//  ⚠️ 연장 기준은 **원 변곡 마커([1])만** 본다(연쇄 연장 불허) — 연장 마커는 다음 봉 연장의 "이전봉 변곡"으로 카운트하지 않는다.
//     근거: CEO 문언이 "이전봉에 (원) 변곡 마커"를 명시했고, 연장까지 트리거로 삼으면 게이트(DI·수평·밴드워킹)가 모두 꺼진 뒤에도 고점/저점만 이동하면 무한 연쇄되어
//     추세 소멸 후에도 마커가 붙는다(자본 보존·오탐 방지). 따라서 연장은 원 변곡 직후 1봉만 이어진다.
//  ⚠️ 표시 전용 — 마커 발동 판정(shortCand/longCand·게이트·채도)·청산선·계산은 불변. low/high·마커[1]은 확정봉 값 → 신규 리페인팅 없음(현재봉 실시간 low/high 변동 성격은 기존 마커와 동일).
//  ⚠️ 방향(양봉/음봉)은 무관 override — 연장은 고·저점 **둘 다** 이동(롱=둘 다 상승, 숏=둘 다 하락)을 요구하므로 방향 게이트 없이도 추세 지속을 판별한다.
//     이는 원 변곡의 방향 게이트(ipBull/ipBear)와 독립적이며, longExt/shortExt는 이전봉이 롱/숏 원 마커 중 하나에서 파생 → 상호 배타(동시 성립 없음, 아래 표시식 참조).
//  ⚠️ 단, 연장에는 **단독 꼬리 필터**를 AND 결합한다(CEO 지시): 숏 연장은 아래꼬리가 몸통보다 길면(lowerWick > body) 금지, 롱 연장은 위꼬리가 몸통보다 길면(upperWick > body) 금지.
//     코드로는 통과 판정을 `lowerWick <= body`(숏)·`upperWick <= body`(롱)로 쓴다(strict "더 길면 금지" = 같으면 표시).
//     원 변곡이 쓰는 shortRejectShape/longRejectShape(위꼬리 25% 미만 조건 포함)와 달리, 연장은 **위꼬리 25% 조건 없이 반대 꼬리 vs 몸통 단독 비교**만 본다(CEO 지시: 연장 override는 반대 꼬리가 몸통보다 길 때만 억제).
//     도지(body=0): 숏 연장은 아래꼬리>0이면 lowerWick<=0 불성립 → 억제. 롱 연장은 위꼬리>0이면 upperWick<=0 불성립 → 억제(아래꼬리·위꼬리 모두 0인 4-price 도지만 통과, 극히 드묾).
longExt  = lower2Marker[1] and low  > low[1]  and high > high[1] and upperWick <= body
shortExt = upper2Marker[1] and high < high[1] and low  < low[1] and lowerWick <= body
// 우선순위(숨김) — 연장(override)은 방향 유지 신호이므로 같은 봉의 반대 원 변곡보다 우선한다(CEO: "숏 변곡 자리든 롱 넣는다").
//  ▸ longExt 성립 봉: 숏 표시 억제(롱 override 우선). 그 봉에 upper2Marker(음봉 숏 원 변곡)가 동시에 떠도 `and not longExt`로 숏이 사라지고 롱만 그려진다.
//  ▸ shortExt 성립 봉: 롱 표시 억제(숏 override 우선). 그 봉에 lower2Marker(양봉 롱 원 변곡)가 동시에 떠도 `and not shortExt`로 롱이 사라지고 숏만 그려진다.
//  ▸ longExt·shortExt 동시 성립은 불가: longExt는 고·저점 둘 다 상승, shortExt는 둘 다 하락을 요구 → 상호 배타(같은 봉에서 동시 참 불가). 우선순위 충돌 없음.
// ── 방향-역행 억제 게이트(CEO 지시) — 표시식 최종단에 결합 ──
//  ▸ 숏 억제: 현재봉 고점·저점이 이전봉보다 각각 상승(high > high[1] AND low > low[1])하면 상승 추세 봉 → 숏 마커 미표시.
//  ▸ 롱 억제: 현재봉 고점·저점이 이전봉보다 각각 하락(low < low[1] AND high < high[1])하면 하락 추세 봉 → 롱 마커 미표시.
//  ⚠️ strict 비교(>, <): 고점 또는 저점이 이전봉과 같으면 "둘 다 상승/하락"이 아니므로 억제하지 않는다(경계는 통과).
//  ⚠️ 원 변곡 게이트(shortShapeOk/longShapeOk)가 아니라 **표시식 최종단**에 결합한다 — 화면에 그려지는 숏/롱 마커(원 변곡+연장) 전반에 일관 작동시키기 위함.
//     연장과의 무충돌: shortExt는 이미 high<high[1] and low<low[1]을 요구 → shortUpMove(high>high[1])와 상호 배타 → 연장 숏은 이 게이트에 걸리지 않는다.
//     longExt도 low>low[1] and high>high[1]을 요구 → longDownMove(low<low[1])와 상호 배타 → 연장 롱도 걸리지 않는다. 즉 실질 영향은 원 변곡 마커에만 미친다(override 3·4 취지 보존).
//  ⚠️ 확정봉 OHLC·[1] 참조 → 신규 리페인팅 없음(현재봉 실시간 high/low 변동 성격은 기존 마커와 동일).
bool shortUpMove   = high > high[1] and low  > low[1]   // 고·저점 둘 다 상승 → 숏 억제
bool longDownMove  = low  < low[1]  and high < high[1]  // 고·저점 둘 다 하락 → 롱 억제
// ── VWAP 선 지지/저항 "무조건" 억제(CEO 지시) — 표시식 최종단에 결합 ──
//  ▸ 규칙 #1: VWAP 선이 지지 상태(vwapSupport)이면 숏 마커 무조건 미표시.
//  ▸ 규칙 #2: VWAP 선이 저항 상태(vwapResistance)이면 롱 마커 무조건 미표시.
//  ⚠️ "무조건"의 근거: vwapSupport/vwapResistance는 enableVwapSRColor(선색 옵션)와 무관하게 항상 판정된다(위 판정 블록 참조).
//     또한 이 게이트를 표시 최종단(원 변곡+연장 합류 지점)에 얹으므로 원 변곡·연장(shortExt/longExt)·캔들색·밴드2 강조까지 일괄 억제된다.
//     (기존 옵션 종속 게이트 #6 srcGateShort/srcGateLong은 원 변곡 단계에만 걸렸고 OFF 시 무력화됐다 — 이 최종단 무조건 억제가 그 한계를 덮는다.)
//  ⚠️ 중립(vwapSupport==false and vwapResistance==false: 완전 이탈·워밍업 na)이면 두 항 모두 참 → 억제 없음(CEO "중립 무영향").
//  ⚠️ 상호배타: vwapSupport/vwapResistance는 위 판정에서 close==vwap 우선순위로 동시 참 불가 → 방향별 억제 충돌 없음.
//  ⚠️ 지지↔롱·저항↔숏은 억제 대상이 아니므로 무영향(지지 상태에서 롱은 그대로, 저항 상태에서 숏은 그대로).
//  ⚠️ vwapSupport/vwapResistance는 확정봉 close/high/low·vwap·밴드1 기반 → 신규 리페인팅 없음(현재봉 실시간 변동 성격은 기존 선색과 동일).
showLongMarker  = (lower2Marker or longExt)  and not shortExt and not longDownMove and not vwapResistance
showShortMarker = (upper2Marker or shortExt) and not longExt and not shortUpMove  and not vwapSupport
// 연장 마커 색 = "이전봉과 동일한 색"(CEO 문언) — 이전봉 마커색(lowerMarkerColor[1]/upperMarkerColor[1])을 그대로 상속한다(채도까지 이전봉 확정값).
//  현재봉 재계산(lower/upperMarkerColor)이 아니라 [1] 참조라야 이전봉과 색(OBV 에너지 채도 포함)이 정확히 일치한다.
//  원 변곡 마커 봉(lower2Marker/upper2Marker true, 연장 아님)은 기존대로 현재봉 색을 쓴다.
color longMarkerColorFinal  = longExt  and not lower2Marker ? lowerMarkerColor[1] : lowerMarkerColor
color shortMarkerColorFinal = shortExt and not upper2Marker ? upperMarkerColor[1] : upperMarkerColor
// 요구사항 1: 밴드2 상/하단 선 색은 청산선 진입에 따른 색 변경을 제거하고 기본색(activeLineColor)으로 되돌린다.
// CEO 재지시(강조 옵션 보정): "기본 vwap이 청산선 안으로 들어오고, 마커가 생길 때" 해당 밴드2를 마커색으로 강조.
//  ⚠️ 후보/마커 판정은 변곡용 밴드2(ipUpperBandValue2/ipLowerBandValue2, window=ipRecentBars 기본 14)를 3모드 청산선과 비교한다(L405-410).
//     따라서 마커(upper2Marker/lower2Marker)만으로는 "화면에 그려지는 기본 밴드2"가 청산선 안이라는 보장이 없다.
//     → 화면 세트 밴드2(upperBandValue2/lowerBandValue2)가 실제로 청산선 안인지를 별도 게이트로 명시한다.
//  기본(화면) 밴드2 "청산선 안" 판정 — 후보 판정과 동일 부등호, 화면에 그려지는 청산선(shortClear/longClear, ceMode 결과선 L372) 기준.
//   상단(숏 맥락): upperBandValue2 < shortClear  (후보 shortEnter_m = ipUpperBandValue2 < shortClear_m 와 동일 부등호).
//   하단(롱 맥락): lowerBandValue2 > longClear   (후보 longEnter_m  = ipLowerBandValue2 > longClear_m  와 동일 부등호).
//   화면에 그려지는 선(shortClear/longClear)을 기준으로 삼아 "그 vwap의 밴드2가 화면 청산선 안"이라는 CEO 취지와 정렬한다.
//   na 가드: 화면 밴드2·청산선이 유효할 때만 판정(shouldPlot·not na). 어느 한쪽이라도 na면 강조 안 함.
baseUpperBand2InClear = shouldPlot and not na(upperBandValue2) and not na(shortClear) and upperBandValue2 < shortClear
baseLowerBand2InClear = shouldPlot and not na(lowerBandValue2) and not na(longClear)  and lowerBandValue2 > longClear
//  강조 = 옵션 ON AND 마커 발동 AND 화면 밴드2가 청산선 안. 셋 다 충족해야 마커색, 아니면 기본색(activeLineColor)으로 원복.
//  마커 plotshape와 동일 색 변수(upper/lowerMarkerColor)를 재사용해 강조색·마커색 불일치를 원천 차단.
//   ⚠️ 마커색이 OBV 에너지 채도(강 선명/약 둔탁)로 나뉘므로 밴드2 강조색도 동일 채도를 따른다(같은 봉에서 마커=둔탁·밴드2=선명 불일치 방지 — 일관성).
//  봉 단위 series color 지정이므로 리페인팅 없음(마커 조건·밴드2·청산선 모두 확정 성격 값 기반).
//  ⚠️ VWAP 선 무조건 억제(CEO 지시) 정합: 지지 상태(vwapSupport)면 숏 밴드2 강조도 억제, 저항 상태(vwapResistance)면 롱 밴드2 강조도 억제한다.
//     마커가 억제된 봉에서 밴드2만 그 방향 색으로 강조되면 "화면에 그려지는 해당 방향 표현 억제"(CEO "무조건") 취지와 어긋나므로 여기서도 함께 억제한다.
color upperBand2LineColor = ipBand2MarkerColor and upper2Marker and baseUpperBand2InClear and not vwapSupport ? upperMarkerColor : activeLineColor
color lowerBand2LineColor = ipBand2MarkerColor and lower2Marker and baseLowerBand2InClear and not vwapResistance ? lowerMarkerColor : activeLineColor

// 사양 2(CEO 지시 변경): 마커 y좌표를 기본 화면 밴드2가 아니라 **화면에 실제 그려지는 청산선**(shortClear/longClear, ceMode 선택 결과선)에 얹는다.
//  - 숏 변곡 마커(upper2Marker) y = shortClear(숏 청산선).  롱 변곡 마커(lower2Marker) y = longClear(롱 청산선).
//  - shortClear/longClear 는 computeClearLines(ceMode 반영, 위 L367)의 확정 성격 값(ta.*·과거참조 [1] 트레일) → 신규 리페인팅 없음.
//  ⚠️ na 가드: 청산선이 na인 봉에서는 y를 na로 두어 그 봉의 마커를 **미표시**한다(밴드2 등 다른 선으로 폴백하지 않음).
//   폴백 미채택 이유: 지시 취지가 "마커를 청산선 위에 정렬"이므로 청산선이 없는데 다른 값에 얹으면 정렬이 깨진다.
//   마커 발동 조건(upper2Marker/lower2Marker)은 불변 — 위치 y좌표만 청산선으로 이동하고 na일 때만 미표시.
float upper2MarkerY = shortClear
float lower2MarkerY = longClear

// VWAP 중앙선: 두께 2px(CEO 지시 — 지지/저항 색 규칙). 선은 동적 색, 우측 가격축 라벨은 흰색 고정(CEO 지시).
//  색 = vwapLineColor(지지/저항 규칙 ON이면 녹/빨강/흰색, OFF면 기존 activeLineColor).
//  ▸ 동적 색 선: 가격축(price_scale)만 제외해 pane·상태줄·데이터윈도우에만 표시(밴드와 동일 패턴). 가격축 라벨이 선색을 따라가지 않게 함.
//  ▸ 흰색 가격축 라벨: 같은 값을 흰색으로 price_scale에만 그려 라벨만 흰색으로 고정(선은 pane에 그리지 않음 → 중복선 없음). 선색 판정·계산 불변.
plot(vwapValue, title="브이왑", color=vwapLineColor, offset=offset, linewidth=2, display=display.all - display.price_scale, editable=true, linestyle=plot.linestyle_solid)
plot(vwapValue, title="VWAP 가격축 라벨", color=color.white, offset=offset, display=display.price_scale, editable=true)

displayBand1 = showBand_1 ? display.all - display.price_scale : display.none
upperBand_1 = plot(upperBandValue1, title="Upper Band #1", color=activeLineColor, offset=offset, display=displayBand1, editable=true, linestyle=plot.linestyle_dotted)
lowerBand_1 = plot(lowerBandValue1, title="Lower Band #1", color=activeLineColor, offset=offset, display=displayBand1, editable=true, linestyle=plot.linestyle_dotted)
fill(upperBand_1, lowerBand_1, title="Bands Fill #1", color=activeFillColor, display=display.none, editable=true)

// 최외곽 상/하단 선(Band #2): 위치·색 모두 항상 원값/기본색(고정). 요구사항 1: 청산선 진입 색 변경 제거 + 두께 1px.
displayBand2 = showBand_2 ? display.all - display.price_scale : display.none
upperBand_2 = plot(upperBandValue2, title="Upper Band #2", color=upperBand2LineColor, offset=offset, display=displayBand2, editable=true, linewidth=1, linestyle=plot.linestyle_dashed)
lowerBand_2 = plot(lowerBandValue2, title="Lower Band #2", color=lowerBand2LineColor, offset=offset, display=displayBand2, editable=true, linewidth=1, linestyle=plot.linestyle_dashed)
// fill(±2σ 채움)은 밴드2 원값 선(upperBand_2/lowerBand_2)에 직접 붙인다. clamp 폐기로 선 자체가 항상 원값이라 별도 fill ref plot 불필요. 현재 display=none.
fill(upperBand_2, lowerBand_2, title="Bands Fill #2", color=activeFillColor, display=display.none, editable=true)
// 횡보 압축 배경(밴드2 회색) — 압축 유지 래치(chopBgOn)가 ON인 봉에 밴드2 상단2~하단2 영역을 반투명 회색으로 채운다.
//  chopBgOn은 압축 상태(compNow) 성립 봉에 즉시 set(1봉 지연 없음)되고, 압축 종료 후 폭 재확장 분출 봉에서 즉시 OFF된다.
//   압축이 잠깐 풀려도(compNow=false, 분출 아님) 래치를 유지 → 회색 깜빡임 없음. 상승/하락 분출 봉에서 즉시 OFF(무한 유지 없음).
//  ⚠️ 밴드2 영역 한정(전체 화면 bgcolor 아님). chopBgOn=false 봉·밴드2 미표시(showBand_2 off)·밴드2 na 봉은 na로 두어 미채움.
//   매 봉(형성 중 현재봉 포함) 실시간 판정되므로 압축 봉 즉시 회색·분출 봉 즉시 꺼짐. 미마감봉 켜짐/꺼짐·과거봉 재계산(리페인팅) 허용(CEO 명시).
fill(upperBand_2, lowerBand_2, color=(showChopBg and chopBgOn and showBand_2 and not na(upperBandValue2) and not na(lowerBandValue2)) ? chopBgColor : na, title="횡보 압축 배경(밴드2)", display=display.all, editable=true)

// =========================
// 변곡 지점(Inflection Point) 마커 — 요구사항 1·2·3.
//  상단(빨강): 변곡용 밴드2 상단선이 기본 청산선(3모드 OR) 안 진입 => 화면 숏 청산선(shortClear) 값 위치에 숏 청산선 색 마커.
//  하단(녹색): 변곡용 밴드2 하단선이 기본 청산선(3모드 OR) 안 진입 => 화면 롱 청산선(longClear) 값 위치에 롱 청산선 색 마커.
//  마커 색 = 기본 청산선 색(shortClearLineColor/longClearLineColor)과 동일. 모양은 옵션(기본=원). 화면 밴드2 선 위치·색은 불변(마커만 추가).
// =========================
// ⚠️ location=location.absolute + size.tiny 로 series 값 좌표에 정확히 그린다(직전 커밋 유지).
//    판정(발동 조건)은 변곡용 밴드2(ipUpperBandValue2/ipLowerBandValue2, length=14) vs 기본 청산선 3모드(shortClear_*/longClear_*)로 그대로 유지.
//    다만 y위치(그려지는 좌표)는 화면에 페인트되는 청산선(upper2MarkerY=shortClear, lower2MarkerY=longClear)에 놓아 마커가 실제 화면 청산선 위에 얹힌다(na면 미표시).
//    location.top/bottom 은 첫 인자(값)가 무시되어 창 최상/최하단에 고정되므로 쓰지 않는다.
// ⚠️ plotshape의 style은 const string만 받으므로, 모양 삼항을 style 인자에 **직접 인라인**한다(변수 저장 시 컴파일 에러).
//    각 분기가 shape.* 리터럴이라 컴파일 타임 상수로 평가된다. 기본값(원)은 첫 분기(shape.circle).
//    ⚠️ 마커 색은 OBV 에너지 강/약 채도 반영: 숏=upperMarkerColor(강→선명 빨강/약→둔탁 빨강), 롱=lowerMarkerColor(강→선명 녹/약→둔탁 녹). 색만 채도로 나뉘고 발동·모양·y좌표는 불변.
//    ⚠️ 표시 조건은 연장 포함(showShortMarker/showLongMarker) — 원 변곡(upper2Marker/lower2Marker) OR 연장(shortExt/longExt), 반대 방향 연장 우선 억제 반영. 색은 연장 봉이면 이전봉 색(shortMarkerColorFinal/longMarkerColorFinal) 상속.
plotshape(ipShowMarkers and showShortMarker ? upper2MarkerY : na, title="변곡 지점(상단)", style=ipMarkerStyle == "원" ? shape.circle : ipMarkerStyle == "삼각형" ? shape.triangleup : ipMarkerStyle == "다이아몬드" ? shape.diamond : ipMarkerStyle == "네모" ? shape.square : shape.cross, location=location.absolute, color=shortMarkerColorFinal, size=size.tiny, offset=offset, editable=true)
plotshape(ipShowMarkers and showLongMarker ? lower2MarkerY : na, title="변곡 지점(하단)", style=ipMarkerStyle == "원" ? shape.circle : ipMarkerStyle == "삼각형" ? shape.triangleup : ipMarkerStyle == "다이아몬드" ? shape.diamond : ipMarkerStyle == "네모" ? shape.square : shape.cross, location=location.absolute, color=longMarkerColorFinal, size=size.tiny, offset=offset, editable=true)

// 변곡 마커 봉 캔들 색(CEO 지시, ipMarkerCandleColor 기본 ON) — 표시된 마커 봉의 캔들을 마커색으로 칠한다.
//  ▸ 조건·색 모두 plotshape 마커와 동일 변수 재사용: 롱=showLongMarker→longMarkerColorFinal, 숏=showShortMarker→shortMarkerColorFinal.
//    (연장 봉은 상속색까지 마커와 정확히 일치. 마커 y·판정·채도·다른 로직 불변.)
//  ▸ plotshape 표시 정합: plotshape은 y좌표(upper2MarkerY=shortClear/lower2MarkerY=longClear)가 na면 그 봉 마커를 미표시한다.
//    barcolor는 y좌표를 안 쓰므로, "실제로 마커가 그려진 봉"에만 칠하도록 청산선 not na 가드를 AND로 얹어 plotshape 표시 조건과 일치시킨다(청산선 na 봉에서 캔들만 칠해지는 불일치 방지).
//  ▸ 롱·숏 동시 표시는 우선순위 억제(showLong/ShortMarker의 not shortExt/not longExt)로 이미 상호배타지만,
//    barcolor 단일 인자이므로 방어적으로 롱을 먼저 평가한다(규칙 #1 롱 우선과 방향 일치). 미표시 봉은 na → 캔들 원색 유지.
//  ▸ auto-vwap에 기존 barcolor 없음 → 신규 도입(중복·충돌 없음). 확정봉 마커 조건 기반이라 신규 리페인팅 없음.
barcolor(ipShowMarkers and ipMarkerCandleColor and showLongMarker and not na(lower2MarkerY) ? longMarkerColorFinal : ipShowMarkers and ipMarkerCandleColor and showShortMarker and not na(upper2MarkerY) ? shortMarkerColorFinal : na, title="변곡 마커 캔들 색", editable=true)

// =========================
// 샹들리에 청산선(직선=손절 기준선) 차트 페인팅 — 이치모쿠에서 이동(CEO 지시).
//  ⚠️ "봉 전체 다 나올 수 있게"(CEO): 최근 몇 봉만 그리는 line.new 방식이 아니라 plot으로 전 히스토리 봉에 그린다.
//  longClear/shortClear 는 위 computeClearLines(기본 화면 세트)에서 매 봉 계산된 확정 성격 값(ta.*·과거참조 [1] 트레일)이라
//   plot 으로 전 구간에 그려도 신규 리페인팅이 없다(그리기 전환 시에도 값 자체는 불변).
//  스윕라인(longCE/shortCE)은 여기로 옮기지 않는다(CEO: "청산선 스윕라인은 옮기지 않음") → plot 하지 않는다.
//  ⚠️ 가격축 라벨 제거(CEO 지시): 차트 선은 유지하되 우측 가격축의 숫자 라벨만 끈다(display.all - display.price_scale). 선·색·굵기·스타일 불변.
plot(showClearLines ? longClear : na, title="롱 청산선", color=longClearLineColor, linewidth=clearLineWidth, offset=offset, editable=true, linestyle=plot.linestyle_solid, display=display.all - display.price_scale)
plot(showClearLines ? shortClear : na, title="숏 청산선", color=shortClearLineColor, linewidth=clearLineWidth, offset=offset, editable=true, linestyle=plot.linestyle_solid, display=display.all - display.price_scale)

// 비정상 매수/매도 세로 배경(bgcolor) — 이치모쿠 이식. 매도=파랑, 매수=빨강. 표시 전용.
//  ⚠️ 횡보 압축 배경(밴드2 영역 한정 fill, 투명도 78)과 시각 충돌 확인: 비정상 배경은 화면 전체 세로 스트립(bgcolor)이고 반투명(기본 투명도 82로 더 옅음)이라
//   밴드2 회색 fill과 겹쳐도 각자 반투명으로 합성될 뿐 서로 덮어쓰지 않는다(원본 이치모쿠도 bgcolor+fill 공존). 색도 회색 vs 파랑/빨강으로 구분된다.
bgcolor(abnShowBg ? abnBg : na, title="비정상 매수/매도 배경")

if barstate.islast
    lineEndX = bar_index + offset
    upperBand1LineEndLabel := updateLineEndLabel(upperBand1LineEndLabel, lineEndX, upperBandValue1, formatPercentGap(upperBandValue1, vwapValue), activeLineColor, showBandPctLabels and shouldPlot and showBand_1 and not na(upperBandValue1))
    lowerBand1LineEndLabel := updateLineEndLabel(lowerBand1LineEndLabel, lineEndX, lowerBandValue1, formatPercentGap(lowerBandValue1, vwapValue), activeLineColor, showBandPctLabels and shouldPlot and showBand_1 and not na(lowerBandValue1))
    upperBand2LineEndLabel := updateLineEndLabel(upperBand2LineEndLabel, lineEndX, upperBandValue2, formatPercentGap(upperBandValue2, vwapValue), activeLineColor, showBandPctLabels and shouldPlot and showBand_2 and not na(upperBandValue2))
    lowerBand2LineEndLabel := updateLineEndLabel(lowerBand2LineEndLabel, lineEndX, lowerBandValue2, formatPercentGap(lowerBandValue2, vwapValue), activeLineColor, showBandPctLabels and shouldPlot and showBand_2 and not na(lowerBandValue2))
