//@version=6
indicator(title="Auto VWAP", shorttitle="Auto VWAP", overlay=true)

hideonDWM = input(false, title="Hide VWAP on 1D or Above", group="VWAP Settings", display=display.none)
anchorMode = input.string(defval="Recent Bars", title="Anchor Mode", options=["Session", "Recent Trading Days", "Recent Bars"], group="VWAP Settings")
recentTradingDays = input.int(defval=5, title="Recent Trading Days", minval=1, group="VWAP Settings", display=display.none, active=anchorMode == "Recent Trading Days")
recentBars = input.int(defval=50, title="Recent Bars", minval=1, group="VWAP Settings", display=display.none, active=anchorMode == "Recent Bars")
src = input(title="Source", defval=hlc3, group="VWAP Settings", display=display.none)
offset = input.int(0, title="Offset", group="VWAP Settings", display=display.none)
enableDynamicLineColor = input.bool(true, title="Enable Dynamic Line Color", group="VWAP Settings", display=display.none)

BANDS_GROUP = "Bands Settings"
CALC_MODE_TOOLTIP = "Determines the units used to calculate the distance of the bands. When 'Percentage' is selected, a multiplier of 1 means 1%."
calcModeInput = input.string("Standard Deviation", "Bands Calculation Mode", options=["Standard Deviation", "Percentage"], group=BANDS_GROUP, tooltip=CALC_MODE_TOOLTIP, display=display.none)
showBand_1 = input(true, title="", group=BANDS_GROUP, inline="band_1", display=display.none)
bandMult_1 = input.float(1.0, title="Bands Multiplier #1", group=BANDS_GROUP, inline="band_1", step=0.5, minval=0, display=display.none, active=showBand_1)
showBand_2 = input(true, title="", group=BANDS_GROUP, inline="band_2", display=display.none)
bandMult_2 = input.float(2.0, title="Bands Multiplier #2", group=BANDS_GROUP, inline="band_2", step=0.5, minval=0, display=display.none, active=showBand_2)

DEFAULT_LINE_COLOR = #FFFFFF
LOWER_BREAK_LINE_COLOR = #00FF00
UPPER_BREAK_LINE_COLOR = #FF0000

formatPercentGap(float bandValue, float baseValue) =>
    if na(bandValue) or na(baseValue) or baseValue == 0
        ""
    else
        percentGap = (bandValue / baseValue - 1.0) * 100.0
        (percentGap > 0 ? "+" : "") + str.tostring(percentGap, "0.00") + "%"

updateLineEndLabel(label existingLineEndLabel, int xPos, float yPrice, string labelText, color lineColor, bool shouldShow) =>
    label updatedLabel = existingLineEndLabel
    if shouldShow
        if na(updatedLabel)
            updatedLabel := label.new(x=xPos, y=yPrice, text=labelText, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(lineColor, 100), textcolor=lineColor, size=size.small)
        else
            label.set_xy(updatedLabel, xPos, yPrice)
            label.set_text(updatedLabel, labelText)
            label.set_textcolor(updatedLabel, lineColor)
            label.set_color(updatedLabel, color.new(lineColor, 100))
            label.set_style(updatedLabel, label.style_label_left)
    else if not na(updatedLabel)
        label.delete(updatedLabel)
        updatedLabel := na
    updatedLabel

cumVolume = ta.cum(volume)
if barstate.islast and cumVolume == 0
    runtime.error("No volume is provided by the data vendor.")

isNewSession = barstate.isfirst or timeframe.change("D")
sessionTime = time("D")
sessionCloseTime = time_close("D")
isLatestSession = sessionTime <= last_bar_time and sessionCloseTime > last_bar_time

var array<float> sessionStartPV = array.new_float()
var array<float> sessionStartVolume = array.new_float()
var array<float> sessionStartP2V = array.new_float()

var float cumulativePV = 0.0
var float cumulativeVolume = 0.0
var float cumulativeP2V = 0.0
var label vwapLineEndLabel = na
var label upperBand1LineEndLabel = na
var label lowerBand1LineEndLabel = na
var label upperBand2LineEndLabel = na
var label lowerBand2LineEndLabel = na

if isNewSession
    array.push(sessionStartPV, cumulativePV)
    array.push(sessionStartVolume, cumulativeVolume)
    array.push(sessionStartP2V, cumulativeP2V)

barPV = src * volume
barP2V = src * src * volume
cumulativePV += barPV
cumulativeVolume += volume
cumulativeP2V += barP2V

sessionCount = array.size(sessionStartPV)
anchorSessionIndex = anchorMode == "Session" ? sessionCount - 1 : math.max(sessionCount - recentTradingDays, 0)
anchorPV = anchorMode == "Recent Bars" ? nz(cumulativePV[recentBars], 0.0) : array.get(sessionStartPV, anchorSessionIndex)
anchorVolume = anchorMode == "Recent Bars" ? nz(cumulativeVolume[recentBars], 0.0) : array.get(sessionStartVolume, anchorSessionIndex)
anchorP2V = anchorMode == "Recent Bars" ? nz(cumulativeP2V[recentBars], 0.0) : array.get(sessionStartP2V, anchorSessionIndex)

windowPV = cumulativePV - anchorPV
windowVolume = cumulativeVolume - anchorVolume
windowP2V = cumulativeP2V - anchorP2V

float vwapValue = na
float upperBandValue1 = na
float lowerBandValue1 = na
float upperBandValue2 = na
float lowerBandValue2 = na

shouldPlot = not (hideonDWM and timeframe.isdwm) and windowVolume > 0 and (anchorMode != "Session" or isLatestSession)

if shouldPlot
    vwapValue := windowPV / windowVolume
    weightedVariance = math.max(windowP2V / windowVolume - math.pow(vwapValue, 2), 0)
    stdevAbs = math.sqrt(weightedVariance)
    bandBasis = calcModeInput == "Standard Deviation" ? stdevAbs : vwapValue * 0.01
    upperBandValue1 := vwapValue + bandBasis * bandMult_1
    lowerBandValue1 := vwapValue - bandBasis * bandMult_1
    upperBandValue2 := vwapValue + bandBasis * bandMult_2
    lowerBandValue2 := vwapValue - bandBasis * bandMult_2

isLowerBand2Break = shouldPlot and showBand_2 and not na(lowerBandValue2) and low < lowerBandValue2
isUpperBand2Break = shouldPlot and showBand_2 and not na(upperBandValue2) and high > upperBandValue2
// Rare wide-range candles can sweep both sides; bias the highlight toward the close vs VWAP.
color breakHighlightLineColor = DEFAULT_LINE_COLOR
if isLowerBand2Break and not isUpperBand2Break
    breakHighlightLineColor := LOWER_BREAK_LINE_COLOR
else if isUpperBand2Break and not isLowerBand2Break
    breakHighlightLineColor := UPPER_BREAK_LINE_COLOR
else if isLowerBand2Break and isUpperBand2Break
    breakHighlightLineColor := close <= vwapValue ? LOWER_BREAK_LINE_COLOR : UPPER_BREAK_LINE_COLOR

color activeLineColor = enableDynamicLineColor ? breakHighlightLineColor : DEFAULT_LINE_COLOR
color activeFillColor = color.new(activeLineColor, 92)

plot(vwapValue, title="브이왑", color=activeLineColor, offset=offset, editable=true, linestyle=plot.linestyle_solid)

displayBand1 = showBand_1 ? display.all : display.none
upperBand_1 = plot(upperBandValue1, title="Upper Band #1", color=activeLineColor, offset=offset, display=displayBand1, editable=true, linestyle=plot.linestyle_dotted)
lowerBand_1 = plot(lowerBandValue1, title="Lower Band #1", color=activeLineColor, offset=offset, display=displayBand1, editable=true, linestyle=plot.linestyle_dotted)
fill(upperBand_1, lowerBand_1, title="Bands Fill #1", color=activeFillColor, display=display.none, editable=true)

displayBand2 = showBand_2 ? display.all : display.none
upperBand_2 = plot(upperBandValue2, title="Upper Band #2", color=activeLineColor, offset=offset, display=displayBand2, editable=true, linestyle=plot.linestyle_dashed)
lowerBand_2 = plot(lowerBandValue2, title="Lower Band #2", color=activeLineColor, offset=offset, display=displayBand2, editable=true, linestyle=plot.linestyle_dashed)
fill(upperBand_2, lowerBand_2, title="Bands Fill #2", color=activeFillColor, display=display.none, editable=true)

if barstate.islast
    lineEndX = bar_index + offset
    vwapLineEndLabel := updateLineEndLabel(vwapLineEndLabel, lineEndX, vwapValue, "0", activeLineColor, shouldPlot and not na(vwapValue))
    upperBand1LineEndLabel := updateLineEndLabel(upperBand1LineEndLabel, lineEndX, upperBandValue1, formatPercentGap(upperBandValue1, vwapValue), activeLineColor, shouldPlot and showBand_1 and not na(upperBandValue1))
    lowerBand1LineEndLabel := updateLineEndLabel(lowerBand1LineEndLabel, lineEndX, lowerBandValue1, formatPercentGap(lowerBandValue1, vwapValue), activeLineColor, shouldPlot and showBand_1 and not na(lowerBandValue1))
    upperBand2LineEndLabel := updateLineEndLabel(upperBand2LineEndLabel, lineEndX, upperBandValue2, formatPercentGap(upperBandValue2, vwapValue), activeLineColor, shouldPlot and showBand_2 and not na(upperBandValue2))
    lowerBand2LineEndLabel := updateLineEndLabel(lowerBand2LineEndLabel, lineEndX, lowerBandValue2, formatPercentGap(lowerBandValue2, vwapValue), activeLineColor, shouldPlot and showBand_2 and not na(lowerBandValue2))

// =========================
// 우측 상단 상태판 (이치모쿠 신호 위치 / 과확장 확인)
// =========================
hasVwap   = shouldPlot and not na(vwapValue)
aboveVwap = hasVwap and close > vwapValue
gapPct    = hasVwap and vwapValue != 0 ? (close / vwapValue - 1.0) * 100.0 : na
posText   = not hasVwap ? "-" : aboveVwap ? "VWAP 위" : "VWAP 아래"
nearLower = hasVwap and not na(lowerBandValue1) and close < lowerBandValue1
nearUpper = hasVwap and not na(upperBandValue1) and close > upperBandValue1

// 밴드폭 변화(확장/수축)와 VWAP 기울기(각도)
slopeLen      = 5
bw2           = hasVwap and not na(upperBandValue2) and not na(lowerBandValue2) ? upperBandValue2 - lowerBandValue2 : na
vwapSlope     = hasVwap and not na(vwapValue[slopeLen]) ? vwapValue - vwapValue[slopeLen] : na
flatThresh    = not na(bw2) ? bw2 * 0.25 : na
slopeUp       = not na(vwapSlope) and not na(flatThresh) and vwapSlope > flatThresh
slopeDown     = not na(vwapSlope) and not na(flatThresh) and vwapSlope < -flatThresh
slopeFlat     = hasVwap and not slopeUp and not slopeDown
bwExpanding   = hasVwap and not na(bw2[slopeLen]) and bw2 > bw2[slopeLen]
bwContracting = hasVwap and not na(bw2[slopeLen]) and bw2 < bw2[slopeLen]

// 수축/저변동 구간에서 양봉이 상단 돌파 / 음봉이 하단 돌파 = 밴드워킹 진입(추세 시작)
bullCandle    = close > open
bearCandle    = close < open
preWalkRegime = bwContracting or slopeFlat or bwContracting[1] or bwContracting[2]
upBreakout    = preWalkRegime and bullCandle and not na(upperBandValue2) and close > upperBandValue2
downBreakout  = preWalkRegime and bearCandle and not na(lowerBandValue2) and close < lowerBandValue2
// 밴드선 각도가 반대로 꺾이면(=수축) 밴드워킹 종료
//  하단워킹: 최하단선(Lower Band #2)이 위로 꺾이면 중지 / 상단워킹: 최상단선이 아래로 꺾이면 중지
bandWalkSlopeLen = 3
lowerBandRising  = hasVwap and not na(lowerBandValue2[bandWalkSlopeLen]) and lowerBandValue2 > lowerBandValue2[bandWalkSlopeLen]
upperBandFalling = hasVwap and not na(upperBandValue2[bandWalkSlopeLen]) and upperBandValue2 < upperBandValue2[bandWalkSlopeLen]
var int vwapWalk = 0
if vwapWalk == 1 and (not hasVwap or upperBandFalling)
    vwapWalk := 0
if vwapWalk == -1 and (not hasVwap or lowerBandRising)
    vwapWalk := 0
// 돌파 진입(상태 유지)
if upBreakout
    vwapWalk := 1
if downBreakout
    vwapWalk := -1

// 밴드워킹(추세) = 돌파 진입 상태 유지 또는 (밴드 확장 + VWAP 기울기 방향 + 밴드 터치)
upperWalk = vwapWalk == 1 or (bwExpanding and slopeUp and nearUpper)
lowerWalk = vwapWalk == -1 or (bwExpanding and slopeDown and nearLower)
// 지지/저항(되돌림): 워킹이 아니고, 밴드 수축 또는 VWAP 평탄(중심) + 가격이 밴드 끝
support    = not upperWalk and not lowerWalk and (bwContracting or slopeFlat) and nearLower
resistance = not upperWalk and not lowerWalk and (bwContracting or slopeFlat) and nearUpper

slopeText  = not hasVwap ? "-" : slopeUp ? "상승" : slopeDown ? "하락" : "평탄(중심)"
bwStateText = not hasVwap ? "-" : bwExpanding ? "확장" : bwContracting ? "수축" : "유지"
bandState  = lowerWalk ? "하단 밴드워킹" : upperWalk ? "상단 밴드워킹" : support ? "하단 지지" : resistance ? "상단 저항" : "중앙(공방)"
bandColor  = lowerWalk or upperWalk ? color.new(color.orange, 0) : support or resistance ? color.new(color.gray, 30) : color.new(color.gray, 50)
posVerdict = lowerWalk ? "숏 유리(하단 밴드워킹)" : upperWalk ? "롱 유리(상단 밴드워킹)" : support ? "롱 유리(하단 지지)" : resistance ? "숏 유리(상단 저항)" : "중립"
posColor   = lowerWalk ? color.new(color.red, 0) : upperWalk ? color.new(color.green, 0) : support ? color.new(color.green, 0) : resistance ? color.new(color.red, 0) : color.new(color.gray, 40)

var table vwapStatus = table.new(position.top_right, 2, 5, border_width=1, border_color=color.new(color.gray, 50))
if barstate.islast
    table.cell(vwapStatus, 0, 0, "Auto VWAP", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.small)
    table.cell(vwapStatus, 1, 0, posVerdict, text_color=color.white, bgcolor=posColor, text_size=size.small)
    table.cell(vwapStatus, 0, 1, "위치", text_color=color.white, text_size=size.small)
    table.cell(vwapStatus, 1, 1, posText + (na(gapPct) ? "" : " " + (gapPct > 0 ? "+" : "") + str.tostring(gapPct, "0.0") + "%"), text_color=color.white, bgcolor=not hasVwap ? color.new(color.gray, 50) : aboveVwap ? color.new(color.green, 30) : color.new(color.red, 30), text_size=size.small)
    table.cell(vwapStatus, 0, 2, "VWAP 기울기", text_color=color.white, text_size=size.small)
    table.cell(vwapStatus, 1, 2, slopeText, text_color=color.white, bgcolor=slopeUp ? color.new(color.green, 30) : slopeDown ? color.new(color.red, 30) : color.new(color.gray, 50), text_size=size.small)
    table.cell(vwapStatus, 0, 3, "밴드폭", text_color=color.white, text_size=size.small)
    table.cell(vwapStatus, 1, 3, bwStateText, text_color=color.white, bgcolor=bwExpanding ? color.new(color.orange, 20) : color.new(color.gray, 50), text_size=size.small)
    table.cell(vwapStatus, 0, 4, "밴드 상태", text_color=color.white, text_size=size.small)
    table.cell(vwapStatus, 1, 4, bandState, text_color=color.white, bgcolor=bandColor, text_size=size.small)
