//@version=6
indicator(title="Advanced Ichimoku", shorttitle="Adv Ichimoku", overlay=true)

donchian(len) =>
    math.avg(ta.lowest(len), ta.highest(len))

conversionPeriods = input.int(8, minval=1, title="컨버전 라인 길이", group="기본 설정")
basePeriods = input.int(22, minval=1, title="베이스 라인 길이", group="기본 설정")
leadingSpanBPeriods = input.int(44, minval=1, title="리딩 스팬 B 길이", group="기본 설정")
displacement = input.int(22, minval=1, title="레깅 스팬 길이", group="기본 설정")

showConversionLine = input.bool(true, title="컨버전 라인 표시", group="표시")
showBaseLine = input.bool(true, title="베이스 라인 표시", group="표시")
showLaggingSpan = input.bool(true, title="레깅 스팬 표시", group="표시")
showLeadingSpanA = input.bool(false, title="리딩 스팬 A 표시", group="표시")
showLeadingSpanB = input.bool(false, title="리딩 스팬 B 표시", group="표시")
showKumoUpper = input.bool(false, title="Kumo Cloud Upper Line 표시", group="표시")
showKumoLower = input.bool(false, title="Kumo Cloud Lower Line 표시", group="표시")
showCloudFill = input.bool(true, title="Cloud Fill 표시", group="표시")

showBuySignal = input.bool(true, title="매수 신호 표시", group="매수 신호")
showSellSignal = input.bool(true, title="매도 신호 표시", group="매도 신호")

lineWidth = 1
conversionLineColor = input.color(#FFEB3B, "컨버전 라인 색", group="색상")
baseLineColor = input.color(#00FF00, "베이스 라인 색", group="색상")
laggingSpanColor = input.color(#FF9800, "레깅 스팬 색", group="색상")
leadingSpanAColor = input.color(#7B9077, "리딩 스팬 A 색", group="색상")
leadingSpanBColor = input.color(#9A7272, "리딩 스팬 B 색", group="색상")
kumoBoundaryColor = input.color(#3F5AA9, "Kumo 경계선 색", group="색상")
bullCloudColor = input.color(#0B5D4F, "양운(상승 구름) 색", group="색상")
bearCloudColor = input.color(#6B1E28, "음운(하락 구름) 색", group="색상")
cloudTransp = input.int(45, "구름 투명도", minval=0, maxval=100, group="색상")
bullishCloudColor = color.new(bullCloudColor, cloudTransp)
bearishCloudColor = color.new(bearCloudColor, cloudTransp)
defaultSellColor = #FF5FA2
defaultBuyColor = #00ACC1

conversionLine = donchian(conversionPeriods)
baseLine = donchian(basePeriods)
leadingSpanA = math.avg(conversionLine, baseLine)
leadingSpanB = donchian(leadingSpanBPeriods)
kumoUpper = math.max(leadingSpanA, leadingSpanB)
kumoLower = math.min(leadingSpanA, leadingSpanB)

// 신호 모드: 확정(원래 로직) / 예측(다음 봉 가정으로 1봉 빨리 포착). 기본 = 확정.
signalMode = input.string("확정 모드", title="신호 모드", options=["확정 모드", "예측 모드"], group="신호 모드")
isPredict = signalMode == "예측 모드"
showVwSignals = input.bool(false, title="거래량 가중 신호 표시", group="거래량 가중 신호")
vwTransp = input.int(50, minval=0, maxval=100, title="거래량 가중 투명도", group="거래량 가중 신호")

// =========================
// 멀티스케일 신호 — 래깅 설정값의 0.5× / 1× / 2× 스케일로 동일 로직 계산
// 한 함수가 일반(도న키언) 신호 + 거래량 가중(VWMA) 신호를 함께 반환한다. (후보 제거)
// 차트엔 1× 라인/구름만 그리고, 0.5×·2×는 신호 계산용으로만 쓴다.
// =========================
f_scale(p, mult) => math.max(1, int(math.round(p * mult)))

f_scaleSignals(float conv, float base, int convP, int baseP, int dispP) =>
    lagOff = math.max(dispP - 1, 0)
    lagBaseRef = base[lagOff]
    lagBull = not na(lagBaseRef) and (ta.crossover(close, lagBaseRef) or close > lagBaseRef)
    lagBear = not na(lagBaseRef) and (ta.crossunder(close, lagBaseRef) or close < lagBaseRef)
    convBull = ta.crossover(conv, base) or conv > base
    convBear = ta.crossunder(conv, base) or conv < base
    pBuy = (close + high) / 2
    pSell = (close + low) / 2
    pLagRef = base[math.max(lagOff - 1, 0)]
    pRawBuy = pBuy > pLagRef and convBull and low > low[1]
    pRawSell = pSell < pLagRef and convBear and high < high[1]
    rbEff = isPredict ? pRawBuy : (lagBull and convBull)
    rsEff = isPredict ? pRawSell : (lagBear and convBear)
    var int lastDir = 0
    bSig = rbEff and lastDir != 1
    sSig = rsEff and lastDir != -1
    if bSig
        lastDir := 1
    else if sSig
        lastDir := -1
    vConv = ta.vwma(close, convP)
    vBase = ta.vwma(close, baseP)
    vLagRef = vBase[lagOff]
    vLagBull = not na(vLagRef) and (ta.crossover(close, vLagRef) or close > vLagRef)
    vLagBear = not na(vLagRef) and (ta.crossunder(close, vLagRef) or close < vLagRef)
    vConvBull = ta.crossover(vConv, vBase) or vConv > vBase
    vConvBear = ta.crossunder(vConv, vBase) or vConv < vBase
    cN = math.max(1, convP - 1)
    bN = math.max(1, baseP - 1)
    pvConv = math.sum(close * volume, cN)
    vsConv = math.sum(volume, cN)
    pvBase = math.sum(close * volume, bN)
    vsBase = math.sum(volume, bN)
    vConvBuyN = (pvConv + pBuy * volume) / (vsConv + volume)
    vBaseBuyN = (pvBase + pBuy * volume) / (vsBase + volume)
    vConvSellN = (pvConv + pSell * volume) / (vsConv + volume)
    vBaseSellN = (pvBase + pSell * volume) / (vsBase + volume)
    vLagRefN = vBase[math.max(lagOff - 1, 0)]
    pvBuy = pBuy > vLagRefN and vConvBuyN > vBaseBuyN and low > low[1]
    pvSell = pSell < vLagRefN and vConvSellN < vBaseSellN and high < high[1]
    vRbEff = isPredict ? pvBuy : (vLagBull and vConvBull)
    vRsEff = isPredict ? pvSell : (vLagBear and vConvBear)
    var int vLastDir = 0
    vbSig = vRbEff and vLastDir != 1
    vsSig = vRsEff and vLastDir != -1
    if vbSig
        vLastDir := 1
    else if vsSig
        vLastDir := -1
    [bSig, sSig, vbSig, vsSig]

// 스케일 기간·donchian — 정상 0.25/0.5/1/2× (1×=전역 재사용). 모멘텀 모드는 표시 스케일을 한 단계 빠른 기간으로 시프트.
c025 = f_scale(conversionPeriods, 0.25)
b025 = f_scale(basePeriods, 0.25)
d025 = f_scale(displacement, 0.25)
c05 = f_scale(conversionPeriods, 0.5)
b05 = f_scale(basePeriods, 0.5)
d05 = f_scale(displacement, 0.5)
c20 = f_scale(conversionPeriods, 2.0)
b20 = f_scale(basePeriods, 2.0)
d20 = f_scale(displacement, 2.0)
donC025 = donchian(c025)
donB025 = donchian(b025)
donC05 = donchian(c05)
donB05 = donchian(b05)
donC20 = donchian(c20)
donB20 = donchian(b20)
// 원시 신호 세트(정상 로직): A=0.25× B=0.5× C=1× D=2×
[bA, sA, vbA, vsA] = f_scaleSignals(donC025, donB025, c025, b025, d025)
[bB, sB, vbB, vsB] = f_scaleSignals(donC05, donB05, c05, b05, d05)
[bC, sC, vbC, vsC] = f_scaleSignals(conversionLine, baseLine, conversionPeriods, basePeriods, displacement)
[bD, sD, vbD, vsD] = f_scaleSignals(donC20, donB20, c20, b20, d20)

// =========================
// 이격도 (Disparity) — 종가가 선택한 이평선에서 몇 %인지. 기준선 100, 임계 ±N%면 되돌림 주의.
//  (모멘텀 모드 즉시 반영을 위해 멀티스케일 신호 앞에서 계산)
// =========================
disparityMaType = input.string("SMA", title="이격도 MA 종류", options=["SMA", "EMA", "WMA", "VWMA"], group="이격도")
disparityMaLen = input.int(20, minval=1, title="이격도 MA 길이", group="이격도")
disparityThreshold = input.float(10.0, minval=0.1, step=0.1, title="이격도 임계(±%, 고정)", group="이격도")
disparityStatLen = input.int(50, minval=5, title="이격도 통계 구간(적응형)", group="이격도")
disparityStatMult = input.float(1.5, minval=0.1, step=0.1, title="이격도 통계 시그마 배수", group="이격도")
disparityMa = switch disparityMaType
    "SMA" => ta.sma(close, disparityMaLen)
    "EMA" => ta.ema(close, disparityMaLen)
    "WMA" => ta.wma(close, disparityMaLen)
    "VWMA" => ta.vwma(close, disparityMaLen)
disparity = not na(disparityMa) and disparityMa != 0 ? close / disparityMa * 100 : na
// 되돌림 판정 = 고정 임계(±%) + 적응형(자기 표준편차 시그마), 방향별로 두 기준 충족 개수를 센다.
//  1개 충족 → '되돌림 주의'(둔탁색), 2개 모두 → '되돌림 확실'(선명색), 0개 → '중립'(회색).
disparityStd = ta.stdev(disparity, disparityStatLen)
disparityStatOk = not na(disparity) and not na(disparityStd) and disparityStd > 0
overFixed  = not na(disparity) and disparity - 100 >= disparityThreshold
overStat   = disparityStatOk and disparity - 100 >= disparityStatMult * disparityStd
underFixed = not na(disparity) and 100 - disparity >= disparityThreshold
underStat  = disparityStatOk and 100 - disparity >= disparityStatMult * disparityStd
overCount  = (overFixed ? 1 : 0) + (overStat ? 1 : 0)
underCount = (underFixed ? 1 : 0) + (underStat ? 1 : 0)
disparityState = (overCount == 2 or underCount == 2) ? "되돌림 확실" : (overCount >= 1 or underCount >= 1) ? "되돌림 주의" : "중립"
disparityCellText = na(disparity) ? "-" : str.tostring(disparity, "0.0") + " (" + disparityState + ")"
// 과열(위)=빨강계 / 과매도(아래)=초록계, 확실=선명(투명도 0) / 주의=둔탁(채도 낮은 톤)
disparityCellColor = overCount == 2 ? color.new(color.red, 0) : underCount == 2 ? color.new(color.green, 0) : overCount >= 1 ? color.new(#A57A7A, 0) : underCount >= 1 ? color.new(#6E8F72, 0) : color.new(color.gray, 40)
// 되돌림 가격 = 이격도가 '중립'으로 복귀하는 가격 band. 중립 경계 = MA × (1 ± 중립폭%/100).
// 중립폭 = min(고정 임계, 통계 σ) — 둘 중 더 빨리 발동하는(좁은) 쪽이 중립 경계라서.
disparityNeutralPct = disparityStatOk ? math.min(disparityThreshold, disparityStatMult * disparityStd) : disparityThreshold
disparityLowerEdge = not na(disparityMa) ? disparityMa * (1 - disparityNeutralPct / 100) : na
disparityUpperEdge = not na(disparityMa) ? disparityMa * (1 + disparityNeutralPct / 100) : na
// 단일 되돌림 가격: 과열(상승 중 하락 반등)이면 중립 상단(최대값), 과매도(하락 중 상승 반등)이면 중립 하단(최소값). 중립이면 없음.
disparityPullbackPrice = overCount >= 1 ? disparityUpperEdge : underCount >= 1 ? disparityLowerEdge : na

// =========================
// 비정상 캔들 — cRSI 과매수/과매도 + 볼린저 몸통 이탈 캔들, 이후 ATR 추종 배경.
//  기준 길이(cRSI 사이클·볼린저·ATR·RSI·추적 봉수)는 베이스 라인(basePeriods)에 연동해 최적화.
//  차트: 비정상 캔들 바색 + 배경(bgcolor). 테이블: 비정상 캔들/감시 상태.
//  (모멘텀 모드 즉시 반영을 위해 멀티스케일 신호 앞에서 계산)
// =========================
abnVibration = input.int(10, minval=1, title="비정상 캔들 cRSI Vibration", group="비정상 캔들")
abnOB = input.float(70.0, title="비정상 절대 과매수", group="비정상 캔들")
abnOS = input.float(30.0, title="비정상 절대 과매도", group="비정상 캔들")
abnBbMult = input.float(2.0, minval=0.1, step=0.1, title="비정상 볼린저 배수", group="비정상 캔들")
abnBodyRatio = input.float(0.3, minval=0.0, step=0.05, title="비정상 밴드 초과 비율(고저 기준)", group="비정상 캔들")
abnVisualRatio = input.float(0.15, minval=0.0, step=0.05, title="비정상 바색 밴드 초과 비율(고저 기준)", group="비정상 캔들")
abnAtrMult = input.float(1.2, minval=0.1, step=0.1, title="비정상 배경 ATR 배수", group="비정상 캔들")
abnStrongAtrMult = input.float(1.8, minval=1.0, step=0.1, title="비정상 강한 배경 ATR 배수", group="비정상 캔들")
abnRsiMoveLimit = input.float(15.0, minval=0.1, step=0.1, title="비정상 RSI 이동 제한", group="비정상 캔들")
abnShowBg = input.bool(true, title="비정상 배경 표시", group="비정상 캔들")
abnShowBars = input.bool(true, title="비정상 캔들 바색 표시", group="비정상 캔들")
abnOverboughtColor = input.color(color.red, title="비정상 매수 캔들 색", group="비정상 캔들")
abnOversoldColor = input.color(color.aqua, title="비정상 매도 캔들 색", group="비정상 캔들")
abnBullBaseColor = input.color(color.green, title="매수 배경 색", group="비정상 캔들")
abnBullStrongColor = input.color(color.blue, title="강한 매수 배경 색", group="비정상 캔들")
abnBearBaseColor = input.color(#E65100, title="매도 배경 색(어두운 주황)", group="비정상 캔들")
abnBearStrongColor = input.color(color.red, title="강한 매도 배경 색", group="비정상 캔들")
abnBgTransp = input.int(82, minval=0, maxval=100, title="비정상 배경 투명도", group="비정상 캔들")

// 기준 길이 = 베이스 라인(basePeriods)에 연동 — 비정상 캔들 신호 최적화
abnLen = basePeriods
abnLookback = basePeriods
// cRSI (도미넌트 사이클 = 베이스 라인) → 절대 과매수/과매도
abnCycleLen = math.max(1, int(basePeriods / 2))
abnTorque = 2.0 / (abnVibration + 1.0)
abnPhasingLag = int((abnVibration - 1) / 2.0)
abnUp = ta.rma(math.max(ta.change(close), 0), abnCycleLen)
abnDown = ta.rma(-math.min(ta.change(close), 0), abnCycleLen)
abnRsiRaw = abnDown == 0 ? 100.0 : abnUp == 0 ? 0.0 : 100.0 - 100.0 / (1.0 + abnUp / abnDown)
var float abnCrsi = na
abnCrsi := abnTorque * (2.0 * abnRsiRaw - nz(abnRsiRaw[abnPhasingLag])) + (1.0 - abnTorque) * nz(abnCrsi[1])
abnIsOB = abnCrsi >= abnOB
abnIsOS = abnCrsi <= abnOS

// 볼린저 밴드 이탈 = 비정상 캔들. 종가(몸통)는 실시간 변동이 커서 **고가/저가** 기준으로 판정.
//  비정상 매수=현재봉 고가가 상단 밴드 초과, 비정상 매도=현재봉 저가가 하단 밴드 초과. 초과폭÷캔들 범위 비율로 강도 판정.
abnBbBasis = ta.sma(close, abnLen)
abnBbDev = ta.stdev(close, abnLen) * abnBbMult
abnBbUpper = abnBbBasis + abnBbDev
abnBbLower = abnBbBasis - abnBbDev
abnRangeSpan = math.max(high - low, syminfo.mintick)
abnUpperOut = math.max(high - abnBbUpper, 0.0)
abnLowerOut = math.max(abnBbLower - low, 0.0)
abnBearExt = abnUpperOut > 0 and abnUpperOut / abnRangeSpan >= abnBodyRatio
abnBullExt = abnLowerOut > 0 and abnLowerOut / abnRangeSpan >= abnBodyRatio
abnBearCandle = abnIsOB and abnBearExt
abnBullCandle = abnIsOS and abnBullExt
abnBearVis = abnUpperOut > 0 and abnUpperOut / abnRangeSpan >= abnVisualRatio
abnBullVis = abnLowerOut > 0 and abnLowerOut / abnRangeSpan >= abnVisualRatio
abnBarCol = abnBearCandle and abnBearVis ? abnOverboughtColor : abnBullCandle and abnBullVis ? abnOversoldColor : na
barcolor(abnShowBars ? abnBarCol : na, title="비정상 캔들 바색")

// 비정상 캔들 이후 ATR 추종 배경. RSI는 추종 품질 게이트.
abnAtr = ta.atr(abnLen)
abnOsc = ta.rsi(close, abnLen)
// 정상 복귀 트리거 = 이격도가 중립으로 복귀할 때 (되돌림 주의/확실이 해소되면 정상 캔들)
abnDisparityNeutral = overCount == 0 and underCount == 0
var int abnBullBar = na
var int abnBearBar = na
var float abnBullRefPrice = na
var float abnBullRefRsi = na
var float abnBullRefAtr = na
var float abnBearRefPrice = na
var float abnBearRefRsi = na
var float abnBearRefAtr = na
// 이격도 중립이면 추적 종료(먼저) → 새 비정상 캔들이면 재시작(최신 우선)
if not na(abnBullBar) and abnDisparityNeutral
    abnBullBar := na
if not na(abnBearBar) and abnDisparityNeutral
    abnBearBar := na
if abnBullCandle
    abnBullBar := bar_index
    abnBullRefPrice := low
    abnBullRefRsi := abnOsc
    abnBullRefAtr := abnAtr
if abnBearCandle
    abnBearBar := bar_index
    abnBearRefPrice := high
    abnBearRefRsi := abnOsc
    abnBearRefAtr := abnAtr
abnBullBars = not na(abnBullBar) ? bar_index - abnBullBar : na
abnBearBars = not na(abnBearBar) ? bar_index - abnBearBar : na
abnHasBull = not na(abnBullBars) and abnBullBars >= 0 and abnBullBars <= abnLookback
abnHasBear = not na(abnBearBars) and abnBearBars >= 0 and abnBearBars <= abnLookback
abnBullPriceMove = abnHasBull and not na(abnBullRefPrice) ? abnBullRefPrice - low : na
abnBullRsiMove = abnHasBull and not na(abnBullRefRsi) ? abnBullRefRsi - abnOsc : na
abnBullAtrNeed = abnHasBull and not na(abnBullRefAtr) ? abnBullRefAtr * abnAtrMult : na
abnBearPriceMove = abnHasBear and not na(abnBearRefPrice) ? high - abnBearRefPrice : na
abnBearRsiMove = abnHasBear and not na(abnBearRefRsi) ? abnOsc - abnBearRefRsi : na
abnBearAtrNeed = abnHasBear and not na(abnBearRefAtr) ? abnBearRefAtr * abnAtrMult : na
abnBullBgOn = abnHasBull and abnBullBars > 0 and not na(abnBullPriceMove) and not na(abnBullAtrNeed) and abnBullPriceMove >= abnBullAtrNeed and abnBullRsiMove <= abnRsiMoveLimit
abnBearBgOn = abnHasBear and abnBearBars > 0 and not na(abnBearPriceMove) and not na(abnBearAtrNeed) and abnBearPriceMove >= abnBearAtrNeed and abnBearRsiMove <= abnRsiMoveLimit
abnBullBgStrong = abnBullBgOn and abnBullPriceMove >= abnBullRefAtr * abnStrongAtrMult
abnBearBgStrong = abnBearBgOn and abnBearPriceMove >= abnBearRefAtr * abnStrongAtrMult

// 상태 래치: 이격도 중립 복귀 시 리셋. 비정상 캔들(±1)과 반등 감시(±2/±3)를 **각각** 래치해 동시 표시 가능.
var int abnCandleState = 0   // 1=비정상 매도, -1=비정상 매수, 0=없음
var int abnWatch = 0         // 2/3=롱 감시(강), -2/-3=숏 감시(강), 0=없음
if abnDisparityNeutral
    abnCandleState := 0
    abnWatch := 0
if abnBullCandle
    abnCandleState := 1
if abnBearCandle
    abnCandleState := -1
if abnBullBgStrong
    abnWatch := 3
else if abnBullBgOn
    abnWatch := 2
if abnBearBgStrong
    abnWatch := -3
else if abnBearBgOn
    abnWatch := -2
// 방향(빠른 신호용) = 캔들 우선, 없으면 감시 부호
abnSig = abnCandleState != 0 ? (abnCandleState > 0 ? 1 : -1) : abnWatch > 0 ? 1 : abnWatch < 0 ? -1 : 0
// 방향: 1=비정상 매도/롱 반등, -1=비정상 매수/숏 반등, 0=정상(이격도 중립). 진입 시 매수·매도 신호 모두 모멘텀 모드로 전환. (현재 봉 값으로 즉시 반영)
abnDirSig = abnSig > 0 ? 1 : abnSig < 0 ? -1 : 0

// 반등 감시 배경은 감시 래치가 유지되는 동안 표시
abnBg = abnWatch == 3 ? color.new(abnBullStrongColor, abnBgTransp) : abnWatch == 2 ? color.new(abnBullBaseColor, abnBgTransp) : abnWatch == -3 ? color.new(abnBearStrongColor, abnBgTransp) : abnWatch == -2 ? color.new(abnBearBaseColor, abnBgTransp) : na
bgcolor(abnShowBg ? abnBg : na, title="비정상 캔들 배경")

// 비정상 캔들 + 감시를 함께 표기(예: "비정상 매수 | 숏 감시"). 셀 색은 캔들(비정상) 우선, 없으면 감시, 없으면 정상.
abnCandleTxt = abnCandleState == 1 ? "비정상 매도" : abnCandleState == -1 ? "비정상 매수" : ""
abnWatchTxt = abnWatch == 3 ? "롱 감시 강화" : abnWatch == 2 ? "롱 감시" : abnWatch == -3 ? "숏 감시 강화" : abnWatch == -2 ? "숏 감시" : ""
abnCellText = (abnCandleTxt != "" and abnWatchTxt != "") ? abnCandleTxt + " | " + abnWatchTxt : abnCandleTxt != "" ? abnCandleTxt : abnWatchTxt != "" ? abnWatchTxt : close > open ? "정상 매수" : close < open ? "정상 매도" : "정상"
abnCellColor = abnCandleState == 1 ? color.new(abnOversoldColor, 20) : abnCandleState == -1 ? color.new(abnOverboughtColor, 20) : abnWatch == 3 ? color.new(abnBullStrongColor, 0) : abnWatch == 2 ? color.new(abnBullBaseColor, 0) : abnWatch == -3 ? color.new(abnBearStrongColor, 0) : abnWatch == -2 ? color.new(abnBearBaseColor, 0) : color.new(color.gray, 40)

// 모멘텀 모드 래치: 비정상 캔들/반등 감시 진입(컨텍스트 시작 엣지) 시 매수·매도 양방향 모두 무장, 정상 이격도 복귀(상태 종료, abnDirSig==0) 시 해제.
var bool momentum = false
buyCtxStart = abnDirSig > 0 and (na(abnDirSig[1]) or abnDirSig[1] <= 0)
sellCtxStart = abnDirSig < 0 and (na(abnDirSig[1]) or abnDirSig[1] >= 0)
if buyCtxStart or sellCtxStart
    momentum := true
if abnDirSig == 0
    momentum := false
// 표시 신호: 모멘텀이면 한 단계 빠른 기간(0.5×→A, 1×→B, 2×→C), 아니면 정상(0.5×→B, 1×→C, 2×→D)
buy05 = momentum ? bA : bB
sell05 = momentum ? sA : sB
buy10 = momentum ? bB : bC
sell10 = momentum ? sB : sC
buy20 = momentum ? bC : bD
sell20 = momentum ? sC : sD
vwBuy05 = momentum ? vbA : vbB
vwSell05 = momentum ? vsA : vsB
vwBuy10 = momentum ? vbB : vbC
vwSell10 = momentum ? vsB : vsC
vwBuy20 = momentum ? vbC : vbD
vwSell20 = momentum ? vsC : vsD


// =========================
// 트리거 가격(스킵 판정 + 테이블에서 공용) — 4세트(0.25/0.5/1/2×) 계산 후 모멘텀 모드면 한 단계 빠른 기간으로 시프트.
//  신호 = (후행스팬 조건) AND (전환선 vs 기준선 게이트). 다음 봉 종가가 돌파해야 할 기준 가격.
// =========================
f_trigger(float conv, float base, int convP, int baseP, int dispP) =>
    cBull = conv > base
    cBear = conv < base
    lagOff = math.max(dispP - 1, 0)
    refIdx = math.max(lagOff - 1, 0)
    lagBaseTrig = base[refIdx]
    cPrior = math.max(convP - 1, 1)
    bPrior = math.max(baseP - 1, 1)
    rLow = ta.lowest(cPrior)
    rHigh = ta.highest(cPrior)
    bMidNext = (ta.highest(bPrior) + ta.lowest(bPrior)) / 2
    cBuyP = 2 * bMidNext - rLow
    cSellP = 2 * bMidNext - rHigh
    bTrig = cBull ? lagBaseTrig : math.max(lagBaseTrig, cBuyP)
    sTrig = cBear ? lagBaseTrig : math.min(lagBaseTrig, cSellP)
    [bTrig, sTrig]
[btA, stA] = f_trigger(donC025, donB025, c025, b025, d025)
[btB, stB] = f_trigger(donC05, donB05, c05, b05, d05)
[btC, stC] = f_trigger(conversionLine, baseLine, conversionPeriods, basePeriods, displacement)
[btD, stD] = f_trigger(donC20, donB20, c20, b20, d20)
buyTrig05 = momentum ? btA : btB
sellTrig05 = momentum ? stA : stB
buyTrig10 = momentum ? btB : btC
sellTrig10 = momentum ? stB : stC
buyTrig20 = momentum ? btC : btD
sellTrig20 = momentum ? stC : stD

// =========================
// 스케일 캐스케이드 — 표시 신호는 4→8→16 컨버전 순으로만 나온다.
//  매수: 4컨버전(0.5×) 뒤에 8컨버전(1×), 8 뒤에 16(2×). 매도도 동일.
//  8/16 매수가 나온 뒤 첫 매도 신호가 나오면 사다리 리셋 → 다시 4 매수부터. 반대도 동일.
// =========================
var int buyStage = 0   // 0=4컨버전 대기, 1=4 발생(8 대기), 2=8 발생(16 대기), 3=16 발생
var int sellStage = 0
// 스케일별 신호 방향(테이블 '상승/하락 추세' 표시용, 실제 표시 신호 기준). 캐스케이드 게이트에도 쓰려고 앞에서 선언(이전 봉까지의 값).
var int dir05 = 0
var int dir10 = 0
var int dir20 = 0
// 스킵: 상위 배수의 트리거가 이미 현재 봉에서 충족(매수=종가≥트리거, 매도=종가≤트리거)되면 원시 신호를 기다리지 않고 바로 표시.
// '직전 배수가 같은 방향 신호'는 공유 사다리(buyStage/sellStage)로 판정 — 반대 신호가 나면 사다리가 리셋되므로 모멘텀/정상 무관하게 순차성 강제(중복 방지).
buySkip10 = buyStage == 1 and close >= buyTrig10
buySkip20 = buyStage == 2 and close >= buyTrig20
sellSkip10 = sellStage == 1 and close <= sellTrig10
sellSkip20 = sellStage == 2 and close <= sellTrig20
// 게이트된 표시 신호 = (stage 조건) and (그 스케일이 이미 같은 방향이 아님, dir!=방향).
//  → 같은 방향 신호가 그 스케일에 이미 떠 있으면(예: 2x 이미 상승 추세) 반대 신호가 그 스케일에 나오기 전엔 재발화 금지(중복 차단, 롱숏·전 스케일 공통).
gBuy05 = buy05 and buyStage == 0 and dir05 != 1
gBuy10 = ((buy10 and buyStage == 1) or buySkip10) and dir10 != 1
gBuy20 = ((buy20 and buyStage == 2) or buySkip20) and dir20 != 1
gSell05 = sell05 and sellStage == 0 and dir05 != -1
gSell10 = ((sell10 and sellStage == 1) or sellSkip10) and dir10 != -1
gSell20 = ((sell20 and sellStage == 2) or sellSkip20) and dir20 != -1
// 반대 방향 표시 신호가 나오면 상대 사다리 리셋(첫 반대 신호에)
if gSell05 or gSell10 or gSell20
    buyStage := 0
if gBuy05 or gBuy10 or gBuy20
    sellStage := 0
// 같은 방향 진행 단계 상승
if gBuy05
    buyStage := 1
if gBuy10
    buyStage := 2
if gBuy20
    buyStage := 3
if gSell05
    sellStage := 1
if gSell10
    sellStage := 2
if gSell20
    sellStage := 3
// dir 갱신(실제 표시 신호 기준 — 차트 삼각형과 테이블 '상승/하락 추세' 동기화). 위 게이트는 이 갱신 전(=직전 값)을 참조.
if gBuy05
    dir05 := 1
else if gSell05
    dir05 := -1
if gBuy10
    dir10 := 1
else if gSell10
    dir10 := -1
if gBuy20
    dir20 := 1
else if gSell20
    dir20 := -1
buyBlocked05 = dir05 == 1
sellBlocked05 = dir05 == -1
buyBlocked10 = dir10 == 1
sellBlocked10 = dir10 == -1
buyBlocked20 = dir20 == 1
sellBlocked20 = dir20 == -1

cloudOffset = displacement - 1
fillSourceA = plot(leadingSpanA, offset=cloudOffset, title="Cloud Fill Source A", color=color.new(leadingSpanAColor, 100), display=display.none)
fillSourceB = plot(leadingSpanB, offset=cloudOffset, title="Cloud Fill Source B", color=color.new(leadingSpanBColor, 100), display=display.none)

plot(showConversionLine ? conversionLine : na, title="Conversion Line", color=conversionLineColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showBaseLine ? baseLine : na, title="Base Line", color=baseLineColor, linewidth=2, display=display.all)
plot(showLaggingSpan ? close : na, offset=-cloudOffset, title="Lagging Span", color=laggingSpanColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showLeadingSpanA ? leadingSpanA : na, offset=cloudOffset, title="Leading Span A", color=leadingSpanAColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showLeadingSpanB ? leadingSpanB : na, offset=cloudOffset, title="Leading Span B", color=leadingSpanBColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showKumoUpper ? kumoUpper : na, offset=cloudOffset, title="Kumo Cloud Upper Line", color=kumoBoundaryColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showKumoLower ? kumoLower : na, offset=cloudOffset, title="Kumo Cloud Lower Line", color=kumoBoundaryColor, linewidth=lineWidth, display=display.all - display.price_scale)
fill(fillSourceA, fillSourceB, title="Cloud Fill", color=showCloudFill ? (leadingSpanA > leadingSpanB ? bullishCloudColor : bearishCloudColor) : na)

// =========================
// 장기 추세 — 이평선 리본 통합(MA 100/200 선 + backfill만)
// =========================
// MA 종류 4종(기본 거래량 가중 VWMA). MA100=파랑·MA200=보라. backfill: 우상향(MA100>MA200)=파랑, 우하향=보라(투명도 40).
showLongTrend = input.bool(true, title="장기 추세 표시", group="장기 추세")
ltMaType = input.string("VWMA", title="장기 추세 MA 종류", options=["SMA", "EMA", "WMA", "VWMA"], group="장기 추세")
ltLen1 = input.int(100, minval=1, title="장기 추세 MA #1 길이", group="장기 추세")
ltLen2 = input.int(200, minval=1, title="장기 추세 MA #2 길이", group="장기 추세")
ltColor1 = input.color(color.blue, title="MA #1(100) 색", group="장기 추세")
ltColor2 = input.color(color.purple, title="MA #2(200) 색", group="장기 추세")
ltFillTransp = input.int(60, minval=0, maxval=100, title="장기 추세 backfill 투명도", group="장기 추세")
f_ltMa(length) =>
    switch ltMaType
        "SMA" => ta.sma(close, length)
        "EMA" => ta.ema(close, length)
        "WMA" => ta.wma(close, length)
        "VWMA" => ta.vwma(close, length)
ltMa1 = f_ltMa(ltLen1)
ltMa2 = f_ltMa(ltLen2)
ltUp = ltMa1 > ltMa2   // 우상향 장기 추세(단기 MA > 장기 MA)
ltPlot1 = plot(showLongTrend ? ltMa1 : na, title="장기추세 MA #1(100)", color=ltColor1, linewidth=lineWidth, display=display.all - display.price_scale)
ltPlot2 = plot(showLongTrend ? ltMa2 : na, title="장기추세 MA #2(200)", color=ltColor2, linewidth=lineWidth, display=display.all - display.price_scale)
fill(ltPlot1, ltPlot2, title="장기추세 backfill", color=showLongTrend ? (ltUp ? color.new(ltColor1, ltFillTransp) : color.new(ltColor2, ltFillTransp)) : na)

// 장기 추세 강도/크로스 판정(테이블용) — 상태 8종: 골든/데드 크로스, 상승/강한 상승/약한 상승, 하락/강한 하락/약한 하락.
//  두께(MA100·200 간격) 확대=강한, 축소=약한, 그 사이(평탄대)=상승/하락. 반대 크로스 임박(간격 좁음)이면 약한 고정.
ltTrendLook = input.int(5, minval=1, title="장기 추세 폭 변화 판정 봉수", group="장기 추세")
ltFlatTol = input.float(0.25, minval=0.0, step=0.05, title="평탄 판정 ATR 배수(강↔약 사이 '상승/하락')", group="장기 추세")
ltCrossWarnPct = input.float(4.0, minval=0.05, step=0.05, title="크로스 주의 간격(%, 클수록 빨리)", group="장기 추세")
ltAtr = ta.atr(14)
ltGap = math.abs(ltMa1 - ltMa2)
ltGapPct = close != 0 ? ltGap / close * 100 : na
ltDeadCross = ta.crossunder(ltMa1, ltMa2)   // MA100이 MA200 하향 돌파 = 상승→하락
ltGoldCross = ta.crossover(ltMa1, ltMa2)     // MA100이 MA200 상향 돌파 = 하락→상승
// 확립 = 크로스 후 ltTrendLook 봉 경과(봉 기준). 그 전(빌드업)은 폭변화 룩백이 크로스를 가로질러 왜곡되므로 강/약 안 함.
ltBarsSince = ta.barssince(ltGoldCross or ltDeadCross)
ltFresh = na(ltBarsSince) or ltBarsSince < ltTrendLook
ltEstablished = not ltFresh
ltGapChg = (ltEstablished and not na(ltGap[ltTrendLook])) ? ltGap - ltGap[ltTrendLook] : na   // 폭 변화(양=확대, 음=축소)
ltDeadBand = not na(ltAtr) ? ltAtr * ltFlatTol : 0.0
ltWidening = not na(ltGapChg) and ltGapChg > ltDeadBand    // 확대 = 강함
ltNarrowing = not na(ltGapChg) and ltGapChg < -ltDeadBand  // 축소 = 약함
// 반대 크로스 임박 = 확립 후 + 간격이 좁고(≤주의%) 확대 중이 아님 → '약한'으로 고정(크로스 직전 블립 방지).
ltNearCross = ltEstablished and not na(ltGapPct) and ltGapPct <= ltCrossWarnPct and not ltWidening
// 상태 세그먼트: 크로스 → (빌드업/평탄) 상승·하락 → 확대=강한 → 축소·임박=약한 → 반대 크로스
ltDir = ltUp ? "상승" : "하락"
ltStateBase = not ltEstablished ? ltDir : ltNearCross ? (ltUp ? "약한 상승" : "약한 하락") : ltWidening ? (ltUp ? "강한 상승" : "강한 하락") : ltNarrowing ? (ltUp ? "약한 상승" : "약한 하락") : ltDir
// 마지막 크로스(골든/데드) 이후 변화율(%)과 경과 봉수 — 골든 후 상승%·데드 후 하락%, 몇 봉 지났는지.
// 크로스 시점의 MA100 값을 기준으로 이후 MA100이 몇 % 올랐/내렸는지(골든=상승%·데드=하락%).
var float ltCrossMa1 = na
if ltGoldCross or ltDeadCross
    ltCrossMa1 := ltMa1
ltMovePct = not na(ltCrossMa1) and ltCrossMa1 != 0 ? (ltMa1 / ltCrossMa1 - 1) * 100 : na
ltInfoTxt = (na(ltMovePct) or na(ltBarsSince)) ? "" : " (" + (ltMovePct >= 0 ? "+" : "") + str.tostring(ltMovePct, "0.0") + "% | " + str.tostring(ltBarsSince) + "봉)"
ltCellText = ltDeadCross ? "데드 크로스" : ltGoldCross ? "골든 크로스" : ltStateBase + ltInfoTxt
// 색: 골든 크로스=파랑·데드 크로스=보라 배경. 그 외 강함(확대)=선명(0)·약함(축소)=옅음(55)·추세=중간(30).
ltCellTransp = not ltEstablished ? 30 : (ltNearCross or ltNarrowing) ? 55 : ltWidening ? 0 : 30
ltCellColor = ltGoldCross ? color.new(ltColor1, 0) : ltDeadCross ? color.new(ltColor2, 0) : ltUp ? color.new(ltColor1, ltCellTransp) : color.new(ltColor2, ltCellTransp)

// 장기 지지/저항 — 종가가 MA100/MA200 위=지지·아래=저항. 글자는 흰색, 셀 배경색으로 상태 구분.
//  200선(장기) 기준 지지=파랑·저항=빨강, 100선이 일치하면 선명·엇갈리면 둔탁.
//  둘 다 지지=파랑 / 둘 다 저항=빨강 / 100저항·200지지=둔탁 파랑 / 100지지·200저항=둔탁 빨강.
// 몸통(min/max(open,close))이 선을 완전히 이탈한 경우만 지지(+1)/저항(-1), 걸치면 중립(0).
ltBodyHi = math.max(open, close)
ltBodyLo = math.min(open, close)
ltM1St = na(ltMa1) ? 0 : (ltBodyLo > ltMa1 ? 1 : ltBodyHi < ltMa1 ? -1 : 0)
ltM2St = na(ltMa2) ? 0 : (ltBodyLo > ltMa2 ? 1 : ltBodyHi < ltMa2 ? -1 : 0)
ltM1Txt = ltM1St == 1 ? "지지" : ltM1St == -1 ? "저항" : "중립"
ltM2Txt = ltM2St == 1 ? "지지" : ltM2St == -1 ? "저항" : "중립"
ltSrText = (na(ltMa1) or na(ltMa2)) ? "-" : "100선 " + ltM1Txt + " | 200선 " + ltM2Txt
// 색: 200선 기준 지지=파랑·저항=빨강·중립=회색, 100선 일치=선명·엇갈림=둔탁.
ltSrColor = (na(ltMa1) or na(ltMa2)) ? color.new(color.gray, 40) : ltM2St == 1 ? (ltM1St == 1 ? color.new(#2979FF, 0) : color.new(#6E7E9F, 0)) : ltM2St == -1 ? (ltM1St == -1 ? color.new(color.red, 30) : color.new(#A57A7A, 0)) : color.new(color.gray, 40)

// 신호 삼각형은 리본 압축/분출 다이아몬드보다 **뒤(코드상 나중)** 에 그려 삼각형이 위 레이어에 오도록
// 파일 하단(다이아몬드 plotshape 다음)에서 그린다.

alertcondition(gBuy10, title="Advanced Ichimoku Buy Signal", message="Advanced Ichimoku buy signal")
alertcondition(gSell10, title="Advanced Ichimoku Sell Signal", message="Advanced Ichimoku sell signal")

// =========================
// 이평 수축/확장 판정 (휩쏘 필터 + 분출 확인) — A / B / A and B 모드
// =========================
// A(이평 리본): 입력값 기반 리본(전환선~리딩B 길이)의 폭이 ATR 대비 좁으면 수축, 다시 벌어지는 첫 봉에 빠른선 vs 느린선 방향으로 확장.
// B(구름 두께): 선행스팬 A·B 간격(구름 두께)이 ATR 대비 좁으면 수축, 벌어지는 첫 봉에 구름 색(양운/음운) 방향으로 확장.
// A and B(기본): 두 기준이 모두 수축/확장(방향 일치)할 때만. 압축 → 분출 → 압축 … 순서.
ribbonMode = input.string("리본+구름", title="수축/확장 판정 모드", options=["이평 리본", "구름 두께", "리본+구름"], group="리본 추세(수축·분출)")
ribbonMaType = input.string("SMA", title="리본 이동평균 종류(A)", options=["SMA", "EMA", "WMA", "VWMA"], group="리본 추세(수축·분출)")
showChopWarn = input.bool(true, title="횡보 압축(수축) 표시", group="리본 추세(수축·분출)")
showExpansion = input.bool(true, title="분출(상승/하락 확장) 표시", group="리본 추세(수축·분출)")
ribbonConfirmOnClose = input.bool(false, title="봉마감 후 확정(끄면 현재봉 실시간)", group="리본 추세(수축·분출)")
ribbonAtrLength = input.int(14, minval=1, title="폭 ATR 기준", group="리본 추세(수축·분출)")
ribbonCompressAtrMult = input.float(0.8, minval=0.1, step=0.1, title="수축 판정 ATR 배수", group="리본 추세(수축·분출)")
ribbonExpandBars = input.int(1, minval=1, title="확장 판정 폭 증가 봉수(작을수록 빠름)", group="리본 추세(수축·분출)")

ribbonMa(length) =>
    switch ribbonMaType
        "SMA" => ta.sma(close, length)
        "EMA" => ta.ema(close, length)
        "WMA" => ta.wma(close, length)
        "VWMA" => ta.vwma(close, length)

rAtr = ta.atr(ribbonAtrLength)

// A 모드: 이치모쿠 입력값(전환선~리딩B)에 맞춘 7개 이평 리본
aStep = (leadingSpanBPeriods - conversionPeriods) / 6.0
aMaFast = ribbonMa(math.max(1, conversionPeriods))
aMa1 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep))))
aMa2 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 2))))
aMa3 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 3))))
aMa4 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 4))))
aMa5 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 5))))
aMaSlow = ribbonMa(math.max(1, leadingSpanBPeriods))
aTop = math.max(aMaFast, math.max(aMa1, math.max(aMa2, math.max(aMa3, math.max(aMa4, math.max(aMa5, aMaSlow))))))
aBottom = math.min(aMaFast, math.min(aMa1, math.min(aMa2, math.min(aMa3, math.min(aMa4, math.min(aMa5, aMaSlow))))))
aHeight = math.max(aTop - aBottom, syminfo.mintick)
aCompressed = aHeight < rAtr * ribbonCompressAtrMult
aExpanding = aHeight > aHeight[ribbonExpandBars]
aBull = aMaFast >= aMaSlow

// B 모드: 구름 두께(선행스팬 A vs B)
bWidth = math.max(kumoUpper - kumoLower, syminfo.mintick)
bCompressed = bWidth < rAtr * ribbonCompressAtrMult
bExpanding = bWidth > bWidth[ribbonExpandBars]
bBull = leadingSpanA >= leadingSpanB

// 모드별 수축/확장/방향 결합
isAMode = ribbonMode == "이평 리본"
isBMode = ribbonMode == "구름 두께"
compNow = isAMode ? aCompressed : isBMode ? bCompressed : (aCompressed and bCompressed)
expNow = isAMode ? aExpanding : isBMode ? bExpanding : (aExpanding and bExpanding)
bullNow = isAMode ? aBull : isBMode ? bBull : (aBull and bBull)
bearNow = isAMode ? not aBull : isBMode ? not bBull : (not aBull and not bBull)
rHeight = isBMode ? bWidth : aHeight   // 테이블 폭/ATR 표시용

rConfirmed = not ribbonConfirmOnClose or barstate.isconfirmed
rChopEnter = compNow and not compNow[1]

// 수축 진입 시 무장 → 확장 첫 봉에 방향 확정. 또한 직전 분출과 **반대 방향** 확장이면 압축 없이 바로 반전 분출.
var bool rArmed = false
var int rLastExpDir = 0   // 직전 분출 방향(1=상승, -1=하락, 0=없음)
var string ribbonState = "대기"
var float ribbonEventClose = na   // 마지막 이벤트(압축/분출) 발생 봉의 종가 — 이후 가격 변화% 기준
var int ribbonEventBar = na       // 마지막 이벤트 발생 봉 인덱스 — 몇 봉째인지 표시용
bool rBullExpansion = false
bool rBearExpansion = false
if rConfirmed
    if rChopEnter
        rArmed := true
        ribbonState := "횡보"
        ribbonEventClose := close
        ribbonEventBar := bar_index
    else if expNow and (bullNow or bearNow)
        expDir = bullNow ? 1 : -1
        // 발화 조건: 압축 후 무장(rArmed) 또는 직전 분출과 반대 방향(압축 없이 직접 반전)
        if rArmed or (rLastExpDir != 0 and expDir != rLastExpDir)
            rBullExpansion := bullNow
            rBearExpansion := bearNow
            ribbonState := bullNow ? "상승" : "하락"
            rArmed := false
            rLastExpDir := expDir
            ribbonEventClose := close
            ribbonEventBar := bar_index

ribbonChop = showChopWarn and rConfirmed and rChopEnter
ribbonBull = showExpansion and rBullExpansion
ribbonBear = showExpansion and rBearExpansion

// 현재 봉 아래 구름(displacement 밀림 → cloudOffset 과거 선행스팬으로 평가).
curSpanA = leadingSpanA[cloudOffset]
curSpanB = leadingSpanB[cloudOffset]
cloudTop = math.max(curSpanA, curSpanB)
cloudBottom = math.min(curSpanA, curSpanB)
cloudPosText = close > cloudTop ? "위" : close < cloudBottom ? "아래" : "안"
cloudColorText = curSpanA >= curSpanB ? "양운" : "음운"
// =========================
// 구름대 지지/저항 강도 — 지그재그 레그가 구름 안으로 들어올 때만 판단
//  지지: 전고점에서 꺾여 하락하던 가격이 구름 안으로 → 구름이 받쳐줄 강도. 저항: 전저점서 상승 중 구름 안.
//  강도 = 구름 두께(ATR 대비) 클수록 ↑, 접근 각도(ATR/봉) 가파를수록 ↓(모멘텀이 뚫기 쉬움).
// 러닝 지그재그(지연 없음): 현재 레그 극값에서 ATR 배수만큼 되돌리면 즉시 반전.
//  피벗 확정(길이만큼 지연)을 안 기다리므로, 전고점서 꺾여 내려오는 즉시 하락 레그로 인식된다.
// =========================
srRevMult = input.float(1.5, minval=0.1, step=0.1, title="구름 지그재그 반전 감도(ATR 배수, 베이스 라인 유사)", group="구름 지지/저항")
srRev = rAtr * srRevMult
var int srDir = 0          // 1=상승 레그(저점서 상승 중), -1=하락 레그(고점서 꺾여 하락 중)
var float srExtreme = na   // 현재 레그 진행 극값(상승=고점, 하락=저점)
var int srExtremeBar = na
var float srAnchor = na    // 직전 레그가 꺾인 지점(지지=전고점, 저항=전저점)
var int srAnchorBar = na
if srDir == 0
    srDir := close >= open ? 1 : -1
    srExtreme := close
    srExtremeBar := bar_index
if srDir == 1
    if high > srExtreme
        srExtreme := high
        srExtremeBar := bar_index
    else if srExtreme - low >= srRev   // 고점서 반전 감도만큼 하락 → 하락 레그로 전환
        srDir := -1
        srAnchor := srExtreme
        srAnchorBar := srExtremeBar
        srExtreme := low
        srExtremeBar := bar_index
else
    if low < srExtreme
        srExtreme := low
        srExtremeBar := bar_index
    else if high - srExtreme >= srRev  // 저점서 반전 감도만큼 상승 → 상승 레그로 전환
        srDir := 1
        srAnchor := srExtreme
        srAnchorBar := srExtremeBar
        srExtreme := high
        srExtremeBar := bar_index
inCloud = close <= cloudTop and close >= cloudBottom
cloudThickAtr = rAtr != 0 ? (cloudTop - cloudBottom) / rAtr : na
srLegBars = not na(srAnchorBar) ? math.max(bar_index - srAnchorBar, 1) : na
srSlopeAtr = (not na(srAnchor) and not na(srLegBars) and rAtr != 0) ? math.abs(close - srAnchor) / srLegBars / rAtr : na
srScore = (not na(cloudThickAtr) and not na(srSlopeAtr)) ? cloudThickAtr / (1 + srSlopeAtr * 3) : na   // 두께↑=강, 각도↑=약
isSupport = inCloud and srDir == -1   // 하락 중 구름 안 → 지지
isResist  = inCloud and srDir == 1    // 상승 중 구름 안 → 저항
f_srLabel(pfx) => na(srScore) ? pfx : srScore >= 0.8 ? pfx + " 강함" : srScore >= 0.4 ? pfx + " 보통" : pfx + " 약함"
srTransp = na(srScore) ? 40 : srScore >= 0.8 ? 0 : srScore >= 0.4 ? 30 : 55
cloudCellText = isSupport ? f_srLabel("지지") : isResist ? f_srLabel("저항") : cloudPosText + "·" + cloudColorText
cloudCellColor = isSupport ? color.new(color.green, srTransp) : isResist ? color.new(color.red, srTransp) : close > cloudTop ? color.new(color.green, 30) : close < cloudBottom ? color.new(color.red, 30) : color.new(color.gray, 40)

// 리본 상태 = 마지막으로 발생한 다이아몬드(상태머신) 기준이라 차트 표시와 동기화된다.
// 괄호 숫자 = 마지막 이벤트(압축/분출) 발생 봉 종가 대비 현재 종가의 가격 변화 %.
ribbonMovePct = not na(ribbonEventClose) and ribbonEventClose != 0 ? (close / ribbonEventClose - 1) * 100 : na
ribbonBars = not na(ribbonEventBar) ? bar_index - ribbonEventBar + 1 : na   // 이벤트 봉=1봉째
ribbonCellText = ribbonState + (na(ribbonMovePct) ? "" : " (" + (ribbonMovePct > 0 ? "+" : "") + str.tostring(ribbonMovePct, "0.0") + "%" + (na(ribbonBars) ? "" : " | " + str.tostring(ribbonBars) + "봉") + ")")
ribbonCellColor = ribbonState == "상승" ? color.new(color.blue, 30) : ribbonState == "하락" ? color.new(color.red, 30) : color.new(color.gray, 40)

// 이격도(Disparity)·비정상 캔들 블록은 모멘텀 모드 즉시 반영을 위해 상단(멀티스케일 신호 앞)에서 계산한다.

// =========================
// 우측 하단: 다음 봉 트리거 가격 + 구름대/리본 상태
// =========================
// 신호 = (후행스팬 조건) AND (전환선 vs 기준선 게이트). 다음 봉 종가가 돌파해야 할 기준 가격을 표시한다.
// 매수/매도 트리거 가격(buyTrig*/sellTrig*)은 위 스케일 캐스케이드 앞에서 계산한다(스킵 판정에 필요).

// 천 단위 쉼표 + 심볼 mintick 소수 자릿수
priceDecimals = syminfo.mintick >= 1 ? 0 : syminfo.mintick >= 0.1 ? 1 : syminfo.mintick >= 0.01 ? 2 : syminfo.mintick >= 0.001 ? 3 : syminfo.mintick >= 0.0001 ? 4 : 5
priceFmt = priceDecimals == 0 ? "#,##0" : priceDecimals == 1 ? "#,##0.0" : priceDecimals == 2 ? "#,##0.00" : priceDecimals == 3 ? "#,##0.000" : priceDecimals == 4 ? "#,##0.0000" : "#,##0.00000"
f_price(p) => str.tostring(p, priceFmt)
// 화살표는 현재 가격(close) 대비 트리거 가격 위치로 결정: 트리거가 현재가보다 높으면 ↑, 낮으면 ↓
f_arrow(refPrice) => refPrice > close ? "↑ " : "↓ "
// 청산가의 현재 종가 대비 % (롱 청산은 아래라 −, 숏 청산은 위라 +)
f_pct(p) =>
    d = (p - close) / close * 100
    (d > 0 ? "+" : "") + str.tostring(d, "0.0") + "%"

// 스윕(점선) = 샹들리에 ATR 트레일링(세력 스톱헌트 자리). 청산(직선) = 그 너머(버퍼+스윙 풀).
ceLength = input.int(22, title="스윕 룩백 길이", minval=1, group="스윕/청산")
ceAtrLen = input.int(22, title="스윕 ATR 길이", minval=1, group="스윕/청산")
ceMult = input.float(3.0, title="스윕 ATR 배수", minval=0.0, step=0.01, group="스윕/청산")
// 스윕 가격 모드(샹들리에 기반):
//  - 기본: 표준 샹들리에(룩백 고가/저가 − ATR)
//  - 거래량 가중: 거래량 큰 봉(VWMA)에 가중 → 거래 몰린 봉에서 스윕가를 끌어올림
//  - 최근봉 가중: 최근봉(WMA)에 가중 → 휩쏘 급등/급락 봉에서 스윕가를 빠르게·높게
//  - 거래량+최근봉: 두 가중을 함께(거래량 × 선형 최근봉)
ceMode = input.string("기본", title="스윕 가격 모드", options=["기본", "거래량 가중", "최근봉 가중", "거래량+최근봉"], group="스윕/청산")
ceWeightLen = input.int(10, title="가중 트레일 길이", minval=1, group="스윕/청산")
ceWeightMult = input.float(1.5, title="가중 트레일 ATR 배수", minval=0.0, step=0.01, group="스윕/청산")
// 청산(직선) = 스윕 너머. 세력이 스윕을 더 깊게 찌를 것을 예상해 청산선을 그만큼 바깥에 둔다.
sweepBufferMult = input.float(0.4, title="청산 버퍼 ATR 배수(스윕 너머)", minval=0.0, step=0.1, group="스윕/청산")
useSweepPivot = input.bool(true, title="청산에 스윙 풀(피벗) 반영", group="스윕/청산")
sweepPivotLen = input.int(5, minval=1, title="스윙 풀 좌우 봉수", group="스윕/청산")
sweepMaxGapMult = input.float(1.0, title="청산-스윕 최대 간격 ATR 배수", minval=0.1, step=0.1, group="스윕/청산")
trailLen = input.int(200, title="트레일 길이(봉)", minval=10, maxval=5000, group="스윕/청산")
showExitLines = input.bool(true, title="스윕·청산선 표시(트레일+수평선)", group="스윕/청산")
sweepLineWidth = input.int(1, title="스윕 선 두께", minval=1, group="스윕/청산")
clearLineWidth = input.int(2, title="청산 선 두께", minval=1, group="스윕/청산")
longExitLineColor = input.color(#2979FF, title="롱 선 색(스윕·청산)", group="스윕/청산")
shortExitLineColor = input.color(#FF1744, title="숏 선 색(스윕·청산)", group="스윕/청산")

atrCe = ta.atr(ceAtrLen)   // 한 번만 계산해 ceAtrVal·weightAtr·sweepAtr에서 재사용(중복 ta.atr 제거)
ceAtrVal = ceMult * atrCe
// 거래량 × 최근봉(선형) 가중 평균
f_volRecencyMa(src, len) =>
    float num = 0.0
    float den = 0.0
    for i = 0 to len - 1
        float w = volume[i] * (len - i)
        num += src[i] * w
        den += w
    den != 0 ? num / den : src
// 모드별 앵커 — 활성 모드에 필요한 것만 계산(기본 모드에선 VWMA/WMA/가중루프 모두 생략 → 속도↑). ceMode는 세션 상수.
// 가중 모드(거래량/최근봉/거래량+최근봉)는 형성 중인 현재봉을 제외하고 **직전 봉 기준**([1])으로 앵커를 잡는다.
longAnchorWNow = ceMode == "거래량 가중" ? ta.vwma(high, ceWeightLen) : ceMode == "최근봉 가중" ? ta.wma(high, ceWeightLen) : ceMode == "거래량+최근봉" ? f_volRecencyMa(high, ceWeightLen) : na
shortAnchorWNow = ceMode == "거래량 가중" ? ta.vwma(low, ceWeightLen) : ceMode == "최근봉 가중" ? ta.wma(low, ceWeightLen) : ceMode == "거래량+최근봉" ? f_volRecencyMa(low, ceWeightLen) : na
longAnchorW = longAnchorWNow[1]
shortAnchorW = shortAnchorWNow[1]
weightAtr = ceWeightMult * atrCe
longCERaw = ceMode == "기본" ? ta.highest(high, ceLength) - ceAtrVal : longAnchorW - weightAtr
shortCERaw = ceMode == "기본" ? ta.lowest(low, ceLength) + ceAtrVal : shortAnchorW + weightAtr
var float longCE = na
longCEPrev = nz(longCE[1], longCERaw)
longCE := close[1] > longCEPrev ? math.max(longCERaw, longCEPrev) : longCERaw
var float shortCE = na
shortCEPrev = nz(shortCE[1], shortCERaw)
shortCE := close[1] < shortCEPrev ? math.min(shortCERaw, shortCEPrev) : shortCERaw

// 청산(직선) = 스윕(longCE/shortCE) 너머. ATR 버퍼 + 옵션으로 가장 가까운 스윙 풀(피벗) 너머까지.
sweepAtr = atrCe
sweepPLow = ta.pivotlow(sweepPivotLen, sweepPivotLen)
sweepPHigh = ta.pivothigh(sweepPivotLen, sweepPivotLen)
var float lastSweepPLow = na
var float lastSweepPHigh = na
lastSweepPLow := not na(sweepPLow) ? sweepPLow : lastSweepPLow
lastSweepPHigh := not na(sweepPHigh) ? sweepPHigh : lastSweepPHigh
longClear = longCE - sweepBufferMult * sweepAtr
longClear := useSweepPivot and not na(lastSweepPLow) ? math.min(longClear, lastSweepPLow - syminfo.mintick) : longClear
longClear := math.max(longClear, longCE - sweepMaxGapMult * sweepAtr)   // 스윕과의 간격 상한(괴리감 방지)
shortClear = shortCE + sweepBufferMult * sweepAtr
shortClear := useSweepPivot and not na(lastSweepPHigh) ? math.max(shortClear, lastSweepPHigh + syminfo.mintick) : shortClear
shortClear := math.min(shortClear, shortCE + sweepMaxGapMult * sweepAtr)

// 스윕(점선)·청산(직선) 트레일 — plot이 아니라 polyline(선)으로 그려 점선/직선 스타일을 적용.
f_trailLine(float src, int lb, color col, int w, string sty, bool show) =>
    var polyline pl = na
    if barstate.islast
        polyline.delete(pl)
        pl := na
        if show
            pts = array.new<chart.point>()
            for i = lb to 0
                if not na(src[i])
                    array.push(pts, chart.point.from_index(bar_index - i, src[i]))
            pl := array.size(pts) > 1 ? polyline.new(pts, curved=false, closed=false, line_color=col, line_width=w, line_style=sty) : na
    pl
trailLb = math.min(bar_index, trailLen)
f_trailLine(longCE,     trailLb, longExitLineColor,  sweepLineWidth, line.style_dotted, showExitLines)
f_trailLine(shortCE,    trailLb, shortExitLineColor, sweepLineWidth, line.style_dotted, showExitLines)
f_trailLine(longClear,  trailLb, longExitLineColor,  clearLineWidth, line.style_solid,  showExitLines)
f_trailLine(shortClear, trailLb, shortExitLineColor, clearLineWidth, line.style_solid,  showExitLines)
var line longSweepLine = na
var line shortSweepLine = na
var line longClearLine = na
var line shortClearLine = na
if showExitLines and barstate.islast
    line.delete(longSweepLine)
    line.delete(shortSweepLine)
    line.delete(longClearLine)
    line.delete(shortClearLine)
    longSweepLine := line.new(bar_index, longCE, bar_index + 20, longCE, color=longExitLineColor, width=1, style=line.style_dotted)
    shortSweepLine := line.new(bar_index, shortCE, bar_index + 20, shortCE, color=shortExitLineColor, width=1, style=line.style_dotted)
    longClearLine := line.new(bar_index, longClear, bar_index + 20, longClear, color=longExitLineColor, width=1, style=line.style_solid)
    shortClearLine := line.new(bar_index, shortClear, bar_index + 20, shortClear, color=shortExitLineColor, width=1, style=line.style_solid)

// 기준선(베이스 라인) 현재값 수평 라인 — 현재 봉에서 오른쪽으로 연장, 1px
var line baseHLine = na
if showBaseLine and barstate.islast
    line.delete(baseHLine)
    baseHLine := line.new(bar_index, baseLine, bar_index + 20, baseLine, color=baseLineColor, width=1, style=line.style_solid)

// 롱/숏 포지션 청산가만 가격축(price scale)에 라벨 표시 (선은 위 line·polyline이 그리므로 여기선 라벨만)
plot(showExitLines ? longClear : na, title="롱 청산가 라벨", color=longExitLineColor, display=display.price_scale)
plot(showExitLines ? shortClear : na, title="숏 청산가 라벨", color=shortExitLineColor, display=display.price_scale)

// 가격이 없으면(같은 방향 신호가 이미 나와 막힘 = 그 방향 진행 중) 상승/하락으로 표시.
// 진행 중(상승/하락 추세)이면 그 스케일 기준선(baseRef) 대비 이격도(기준 100: 종가÷기준선×100)를 괄호로 표기.
// mom=모멘텀 모드면 트리거 가격/추세 텍스트 앞에 "M " 표기.
f_trigCell(blocked, p, isBuy, baseRef, mom) => (mom ? "M " : "") + (blocked ? (isBuy ? "상승 추세" : "하락 추세") + (na(baseRef) or baseRef == 0 ? "" : " (" + str.tostring(close / baseRef * 100, "0.0") + ")") : f_arrow(p) + f_price(p) + " (" + f_pct(p) + ")")
// 셀 강조: 방향 기준. 매수는 트리거가 현재가의 +nearPct% 이내(또는 이미 아래=조건 충족→확정),
// 매도는 트리거가 −nearPct% 이내(또는 이미 위=충족)면 포지션 색(상승=녹/하락=빨)으로 칠한다.
// 진행 중(상승/하락 추세)이면 구름대 셀과 같은 채도(투명도 30)의 포지션 색.
nearPct = input.float(2.0, title="트리거 근접 강조 임계(%)", minval=0.1, step=0.1, group="트리거 강조")
f_trigBg(blocked, p, isBuy) =>
    dirCol = isBuy ? color.green : color.red
    pct = close != 0 ? (p - close) / close * 100 : na
    hit = not blocked and not na(p) and not na(pct) and (isBuy ? pct <= nearPct : pct >= -nearPct)
    // 진행 중(상승/하락 추세)=선명 녹/적, 근접(작은 % 이내)=둔탁 녹/적, 그 외=회색
    blocked ? color.new(dirCol, 30) : hit ? (isBuy ? color.new(#6E8F72, 0) : color.new(#A57A7A, 0)) : color.new(color.gray, 40)

// =========================
// Auto VWAP 통합 — 계산 전용(차트 미표시). 밴드워킹(추세) vs 지지·저항 상태만 테이블 하단 행에 추가.
//  (동적 선색·밴드 % 라벨 없음 · 기본: 최근 봉 50 / Recent Bars / hlc3)
// =========================
vwapHideDWM = input.bool(false, title="1D 이상에서 VWAP 계산 제외", group="Auto VWAP", display=display.none)
vwapAnchorMode = input.string("Recent Bars", title="앵커 모드", options=["Session", "Recent Trading Days", "Recent Bars"], group="Auto VWAP")
vwapRecentDays = input.int(5, title="최근 거래일 수", minval=1, group="Auto VWAP", display=display.none)
vwapRecentBars = input.int(50, title="최근 봉 수", minval=1, group="Auto VWAP")
vwapSrc = input(title="소스", defval=hlc3, group="Auto VWAP")
vwapCalcMode = input.string("Log Standard Deviation", "밴드 계산 모드", options=["Log Standard Deviation", "Absolute Standard Deviation"], group="Auto VWAP", display=display.none)
vwapBandMult1 = input.float(1.0, title="밴드 배수 #1", group="Auto VWAP", step=0.5, minval=0, display=display.none)
vwapBandMult2 = input.float(2.0, title="밴드 배수 #2", group="Auto VWAP", step=0.5, minval=0, display=display.none)

vwapNewSession = barstate.isfirst or timeframe.change("D")
vwapSessTime = time("D")
vwapSessClose = time_close("D")
vwapIsLatestSession = vwapSessTime <= last_bar_time and vwapSessClose > last_bar_time

var array<float> vwSessPV = array.new_float()
var array<float> vwSessVol = array.new_float()
var array<float> vwSessP2V = array.new_float()
var array<float> vwSessLogPV = array.new_float()
var array<float> vwSessLog2V = array.new_float()
var array<float> vwSessInvalidLogVol = array.new_float()
var float vwCumPV = 0.0
var float vwCumVol = 0.0
var float vwCumP2V = 0.0
var float vwCumLogPV = 0.0
var float vwCumLog2V = 0.0
var float vwCumInvalidLogVol = 0.0

if vwapNewSession
    array.push(vwSessPV, vwCumPV)
    array.push(vwSessVol, vwCumVol)
    array.push(vwSessP2V, vwCumP2V)
    array.push(vwSessLogPV, vwCumLogPV)
    array.push(vwSessLog2V, vwCumLog2V)
    array.push(vwSessInvalidLogVol, vwCumInvalidLogVol)

vwLogSrc = vwapSrc > 0 ? math.log(vwapSrc) : na
vwCumPV += vwapSrc * volume
vwCumVol += volume
vwCumP2V += vwapSrc * vwapSrc * volume
vwCumLogPV += na(vwLogSrc) ? 0.0 : vwLogSrc * volume
vwCumLog2V += na(vwLogSrc) ? 0.0 : vwLogSrc * vwLogSrc * volume
vwCumInvalidLogVol += na(vwLogSrc) ? volume : 0.0

vwSessCount = array.size(vwSessPV)
vwAnchorIdx = vwapAnchorMode == "Session" ? vwSessCount - 1 : math.max(vwSessCount - vwapRecentDays, 0)
vwAnchorPV = vwapAnchorMode == "Recent Bars" ? nz(vwCumPV[vwapRecentBars], 0.0) : array.get(vwSessPV, vwAnchorIdx)
vwAnchorVol = vwapAnchorMode == "Recent Bars" ? nz(vwCumVol[vwapRecentBars], 0.0) : array.get(vwSessVol, vwAnchorIdx)
vwAnchorP2V = vwapAnchorMode == "Recent Bars" ? nz(vwCumP2V[vwapRecentBars], 0.0) : array.get(vwSessP2V, vwAnchorIdx)
vwAnchorLogPV = vwapAnchorMode == "Recent Bars" ? nz(vwCumLogPV[vwapRecentBars], 0.0) : array.get(vwSessLogPV, vwAnchorIdx)
vwAnchorLog2V = vwapAnchorMode == "Recent Bars" ? nz(vwCumLog2V[vwapRecentBars], 0.0) : array.get(vwSessLog2V, vwAnchorIdx)
vwAnchorInvalidLogVol = vwapAnchorMode == "Recent Bars" ? nz(vwCumInvalidLogVol[vwapRecentBars], 0.0) : array.get(vwSessInvalidLogVol, vwAnchorIdx)

vwWinPV = vwCumPV - vwAnchorPV
vwWinVol = vwCumVol - vwAnchorVol
vwWinP2V = vwCumP2V - vwAnchorP2V
vwWinLogPV = vwCumLogPV - vwAnchorLogPV
vwWinLog2V = vwCumLog2V - vwAnchorLog2V
vwWinInvalidLogVol = vwCumInvalidLogVol - vwAnchorInvalidLogVol

float vwapValue = na
float vwUpper1 = na
float vwLower1 = na
float vwUpper2 = na
float vwLower2 = na
vwShouldCalc = not (vwapHideDWM and timeframe.isdwm) and vwWinVol > 0 and (vwapAnchorMode != "Session" or vwapIsLatestSession)
if vwShouldCalc
    vwapValue := vwWinPV / vwWinVol
    vwStdAbs = math.sqrt(math.max(vwWinP2V / vwWinVol - math.pow(vwapValue, 2), 0))
    vwStdLog = math.sqrt(math.max(vwWinLog2V / vwWinVol - math.pow(vwWinLogPV / vwWinVol, 2), 0))
    vwCanLog = vwWinInvalidLogVol == 0 and vwapValue > 0
    if vwapCalcMode == "Absolute Standard Deviation"
        vwUpper1 := vwapValue + vwStdAbs * vwapBandMult1
        vwLower1 := vwapValue - vwStdAbs * vwapBandMult1
        vwUpper2 := vwapValue + vwStdAbs * vwapBandMult2
        vwLower2 := vwapValue - vwStdAbs * vwapBandMult2
    else if vwCanLog
        vwUpper1 := vwapValue * math.exp(vwStdLog * vwapBandMult1)
        vwLower1 := vwapValue * math.exp(-vwStdLog * vwapBandMult1)
        vwUpper2 := vwapValue * math.exp(vwStdLog * vwapBandMult2)
        vwLower2 := vwapValue * math.exp(-vwStdLog * vwapBandMult2)

// VWAP 상태 판정 (밴드워킹=추세 / 지지·저항=되돌림) — 차트엔 안 그리고 테이블에만 사용
vwHasVwap = vwShouldCalc and not na(vwapValue)
vwAbove = vwHasVwap and close > vwapValue
vwGapPct = vwHasVwap and vwapValue != 0 ? (close / vwapValue - 1.0) * 100.0 : na
vwPosText = not vwHasVwap ? "-" : vwAbove ? "VWAP 위" : "VWAP 아래"
// VWAP 지지/저항 — 위=지지·아래=저항, 괄호는 이격도(기준 100: 종가÷VWAP×100)와 유지 봉수. 이격도가 ±2σ 밖이면(너무 큼) 둔탁 색.
vwSrTooFar = vwHasVwap and (vwAbove ? (not na(vwUpper2) and close > vwUpper2) : (not na(vwLower2) and close < vwLower2))
vwAboveInt = vwHasVwap ? (vwAbove ? 1 : -1) : 0   // 1=VWAP 위(지지), -1=아래(저항), 0=없음
var int vwSrBars = 0   // 현재 지지/저항(위/아래) 상태가 유지된 봉수
if vwAboveInt == 0
    vwSrBars := 0
else if vwAboveInt == vwAboveInt[1]
    vwSrBars := vwSrBars + 1
else
    vwSrBars := 1
vwSrText = not vwHasVwap ? "-" : (vwAbove ? "지지" : "저항") + " (" + str.tostring(close / vwapValue * 100, "0.0") + " | " + str.tostring(vwSrBars) + "봉)"
vwSrColor = not vwHasVwap ? color.new(color.gray, 50) : vwAbove ? (vwSrTooFar ? color.new(#6E8F72, 0) : color.new(color.green, 30)) : (vwSrTooFar ? color.new(#A57A7A, 0) : color.new(color.red, 30))
vwNearLower = vwHasVwap and not na(vwLower1) and close < vwLower1
vwNearUpper = vwHasVwap and not na(vwUpper1) and close > vwUpper1
vwSlopeLen = 5
vwBw2 = vwHasVwap and not na(vwUpper2) and not na(vwLower2) ? vwUpper2 - vwLower2 : na
vwSlope = vwHasVwap and not na(vwapValue[vwSlopeLen]) ? vwapValue - vwapValue[vwSlopeLen] : na
// 평탄 판정 임계 = 밴드폭의 3%(기울기가 이보다 작으면 평탄) — 상승/하락 민감도 상향
vwFlatThresh = not na(vwBw2) ? vwBw2 * 0.03 : na
vwSlopeUp = not na(vwSlope) and not na(vwFlatThresh) and vwSlope > vwFlatThresh
vwSlopeDown = not na(vwSlope) and not na(vwFlatThresh) and vwSlope < -vwFlatThresh
vwSlopeFlat = vwHasVwap and not vwSlopeUp and not vwSlopeDown
vwBwExpanding = vwHasVwap and not na(vwBw2[vwSlopeLen]) and vwBw2 > vwBw2[vwSlopeLen]
vwBwContracting = vwHasVwap and not na(vwBw2[vwSlopeLen]) and vwBw2 < vwBw2[vwSlopeLen]
vwPreWalk = vwBwContracting or vwSlopeFlat or vwBwContracting[1] or vwBwContracting[2]
vwUpBreakout = vwPreWalk and close > open and not na(vwUpper2) and close > vwUpper2
vwDownBreakout = vwPreWalk and close < open and not na(vwLower2) and close < vwLower2
vwWalkSlopeLen = 3
vwLowerRising = vwHasVwap and not na(vwLower2[vwWalkSlopeLen]) and vwLower2 > vwLower2[vwWalkSlopeLen]
vwUpperFalling = vwHasVwap and not na(vwUpper2[vwWalkSlopeLen]) and vwUpper2 < vwUpper2[vwWalkSlopeLen]
var int vwWalk = 0
if vwWalk == 1 and (not vwHasVwap or vwUpperFalling)
    vwWalk := 0
if vwWalk == -1 and (not vwHasVwap or vwLowerRising)
    vwWalk := 0
if vwUpBreakout
    vwWalk := 1
if vwDownBreakout
    vwWalk := -1
vwUpperWalk = vwWalk == 1 or (vwBwExpanding and vwSlopeUp and vwNearUpper)
vwLowerWalk = vwWalk == -1 or (vwBwExpanding and vwSlopeDown and vwNearLower)
vwSupport = not vwUpperWalk and not vwLowerWalk and (vwBwContracting or vwSlopeFlat) and vwNearLower
vwResistance = not vwUpperWalk and not vwLowerWalk and (vwBwContracting or vwSlopeFlat) and vwNearUpper
vwSlopeText = not vwHasVwap ? "-" : vwSlopeUp ? "상승" : vwSlopeDown ? "하락" : "평탄(중심)"
vwBwStateText = not vwHasVwap ? "-" : vwBwExpanding ? "확장" : vwBwContracting ? "수축" : "유지"
vwBandState = vwLowerWalk ? "하단 밴드워킹" : vwUpperWalk ? "상단 밴드워킹" : vwSupport ? "하단 지지" : vwResistance ? "상단 저항" : "중앙(공방)"
// VWAP 상태 셀 색:
//  상승 → 녹(밴드워킹=선명 green, 그 외=둔탁 #6E8F72) / 하락 → 빨강(밴드워킹=선명 red, 그 외=둔탁 #A57A7A)
//  평탄(중심) → 밴드 상태별: 상단 밴드워킹·하단 지지=둔탁 녹, 하단 밴드워킹·상단 저항=둔탁 빨강, 중앙(공방)=회색. VWAP 없음=회색.
vwBandStateShort = (vwUpperWalk or vwLowerWalk) ? "밴드워킹" : vwBandState
vwBandColor = not vwHasVwap ? color.new(color.gray, 40) : vwSlopeUp ? ((vwUpperWalk or vwLowerWalk) ? color.new(color.green, 0) : color.new(#6E8F72, 0)) : vwSlopeDown ? ((vwUpperWalk or vwLowerWalk) ? color.new(color.red, 0) : color.new(#A57A7A, 0)) : vwUpperWalk ? color.new(#6E8F72, 0) : vwLowerWalk ? color.new(#A57A7A, 0) : vwSupport ? color.new(#6E8F72, 0) : vwResistance ? color.new(#A57A7A, 0) : color.new(color.gray, 30)

// =========================
// 비정상 캔들 상태/색/텍스트는 상단(멀티스케일 신호 앞)에서 이미 계산했다(모멘텀 즉시 반영). 여기선 생략.

// =========================
// 캔들 상태 (3) — 표시 전용(display only). 최근 3봉의 캔들스틱 패턴을 12개 상호배타 상태로 분류.
//  ★ 어떤 진입/청산/신호 변수에도 연결하지 않는다. 순수 테이블 표기용이다.
//  셀 텍스트 = "패턴명 | 다음봉예측". 셀 배경색 = CEO 지정 5단계(강세/약강세/강약세/약세/중립).
//  b0=현재확정봉, b1=직전, b2=2봉전. candleConfirmOnClose=true면 확정봉 기준(리페인팅 방지),
//  false면 현재 진행봉 기준(실시간, 봉 완성 전 변동 가능).
// =========================
candleShowState = input.bool(true, title="캔들 상태 (3) 표시", group="캔들 상태")
candleConfirmOnClose = input.bool(true, title="확정봉 기준(끄면 현재봉 실시간)", group="캔들 상태", tooltip="켜면 마지막으로 완성된 봉을 현재봉(b0)으로 보고 계산해 리페인팅을 막습니다. 끄면 형성 중인 봉을 b0으로 써서 실시간 반영되지만 봉 완성 전까지 값이 바뀔 수 있습니다.")
candleAtrLen = input.int(14, minval=1, title="캔들 ATR 길이(정규화)", group="캔들 상태")
candleDojiBodyRatio = input.float(0.10, minval=0.0, step=0.01, title="도지 몸통비율 한계", group="캔들 상태")
candleLongWickRatio = input.float(0.60, minval=0.0, step=0.05, title="긴 꼬리 비율 한계", group="캔들 상태")
candleSmallBodyRatio = input.float(0.35, minval=0.0, step=0.05, title="작은 몸통 비율 한계", group="캔들 상태")
candleStrongBodyRatio = input.float(0.60, minval=0.0, step=0.05, title="강한 몸통 비율 한계", group="캔들 상태")
candleMinRangeAtr = input.float(0.5, minval=0.0, step=0.1, title="최소 범위 ATR 배수(혼조 판정)", group="캔들 상태")

// candleAtrLen 전용 ATR — 기존 ta.atr(14=ltAtr)는 길이 고정이라 사용자 입력(candleAtrLen)을 못 따라간다. 정규화 기준을 입력에 맞추려 별도 인스턴스 사용.
candleAtrN = ta.atr(candleAtrLen)

// 3봉 캔들 분류. off = b0 오프셋(확정봉 모드면 1, 실시간 모드면 0). b0=close[off], b1=close[off+1], b2=close[off+2].
// 반환: [패턴명, 다음봉예측, 셀배경색]. 우선순위: 3·4 → 1·2 → 7·8 → 5·6 → 9·10 → 11 → 12 (첫 매칭 확정, 상호배타).
f_candleState(int off) =>
    // 봉 원자료
    o0 = open[off]
    c0 = close[off]
    h0 = high[off]
    l0 = low[off]
    o1 = open[off + 1]
    c1 = close[off + 1]
    h1 = high[off + 1]
    l1 = low[off + 1]
    o2 = open[off + 2]
    c2 = close[off + 2]
    h2 = high[off + 2]
    l2 = low[off + 2]
    atrN = candleAtrN
    // 범위(0 방어), 몸통, 꼬리, 몸통비율, 방향(+1/-1/0)
    r0 = math.max(h0 - l0, syminfo.mintick)
    r1 = math.max(h1 - l1, syminfo.mintick)
    r2 = math.max(h2 - l2, syminfo.mintick)
    body0 = math.abs(c0 - o0)
    body1 = math.abs(c1 - o1)
    body2 = math.abs(c2 - o2)
    br0 = body0 / r0
    br1 = body1 / r1
    br2 = body2 / r2
    dir0 = c0 > o0 ? 1 : c0 < o0 ? -1 : 0
    dir1 = c1 > o1 ? 1 : c1 < o1 ? -1 : 0
    dir2 = c2 > o2 ? 1 : c2 < o2 ? -1 : 0
    upWick0 = h0 - math.max(o0, c0)
    dnWick0 = math.min(o0, c0) - l0
    // 데이터 부족(초기 봉) 방어
    ready = not na(o0) and not na(o1) and not na(o2) and not na(atrN) and atrN > 0
    // b2 몸통 중앙(샛별/석별 회복 기준)
    mid2 = (o2 + c2) / 2
    // 패턴 판정 (우선순위 순서대로 첫 매칭)
    string patName = na
    string patPred = na
    // 3 샛별: b2 강한음봉 → b1 작은몸통 → b0 양봉이 b2 몸통중앙 이상 회복
    isMorningStar = dir2 == -1 and br2 >= candleStrongBodyRatio and br1 <= candleSmallBodyRatio and dir0 == 1 and c0 >= mid2
    // 4 석별: b2 강한양봉 → b1 작은몸통 → b0 음봉이 b2 몸통중앙 이하
    isEveningStar = dir2 == 1 and br2 >= candleStrongBodyRatio and br1 <= candleSmallBodyRatio and dir0 == -1 and c0 <= mid2
    // 1 상승장악형: b1 음봉 → b0 양봉이 b1 몸통 완전포함
    isBullEngulf = dir1 == -1 and dir0 == 1 and c0 >= o1 and o0 <= c1
    // 2 하락장악형: b1 양봉 → b0 음봉이 b1 몸통 완전포함
    isBearEngulf = dir1 == 1 and dir0 == -1 and c0 <= o1 and o0 >= c1
    // 7 적삼병: b2,b1,b0 모두 강한 양봉 + 종가 계단상승 + 윗꼬리 짧음
    upWick1 = h1 - math.max(o1, c1)
    upWick2 = h2 - math.max(o2, c2)
    shortUp0 = upWick0 / r0 <= (1 - candleStrongBodyRatio)
    shortUp1 = upWick1 / r1 <= (1 - candleStrongBodyRatio)
    shortUp2 = upWick2 / r2 <= (1 - candleStrongBodyRatio)
    isThreeSoldiers = dir2 == 1 and dir1 == 1 and dir0 == 1 and br2 >= candleStrongBodyRatio and br1 >= candleStrongBodyRatio and br0 >= candleStrongBodyRatio and c0 > c1 and c1 > c2 and shortUp0 and shortUp1 and shortUp2
    // 8 흑삼병: 모두 강한 음봉 + 종가 계단하락 + 아랫꼬리 짧음
    dnWick1 = math.min(o1, c1) - l1
    dnWick2 = math.min(o2, c2) - l2
    shortDn0 = dnWick0 / r0 <= (1 - candleStrongBodyRatio)
    shortDn1 = dnWick1 / r1 <= (1 - candleStrongBodyRatio)
    shortDn2 = dnWick2 / r2 <= (1 - candleStrongBodyRatio)
    isThreeCrows = dir2 == -1 and dir1 == -1 and dir0 == -1 and br2 >= candleStrongBodyRatio and br1 >= candleStrongBodyRatio and br0 >= candleStrongBodyRatio and c0 < c1 and c1 < c2 and shortDn0 and shortDn1 and shortDn2
    // 5 망치/역망치(강세반전): b0 작은몸통 + 한쪽 긴꼬리 + 반대꼬리 짧음, 직전 하락(close1<close2)
    smallBody0 = br0 <= candleSmallBodyRatio
    longDn0 = dnWick0 / r0 >= candleLongWickRatio and upWick0 / r0 <= (1 - candleLongWickRatio)   // 망치(긴 아랫꼬리)
    longUp0 = upWick0 / r0 >= candleLongWickRatio and dnWick0 / r0 <= (1 - candleLongWickRatio)   // 역망치(긴 윗꼬리)
    // ※ v1: "직전 추세"는 close 기반(close1 vs close2). 추후 이치모쿠 라인 정렬(전환/기준선·구름 위치)과 연동할 여지 있음.
    prevDown = c1 < c2
    prevUp = c1 > c2
    isHammer = smallBody0 and (longDn0 or longUp0) and prevDown
    // 6 교수형/유성(약세반전): b0 작은몸통 + 긴 윗꼬리(유성)/긴 아랫꼬리(교수형), 직전 상승(close1>close2)
    isHangShoot = smallBody0 and (longUp0 or longDn0) and prevUp
    // 9 내부봉: high0<=high1 and low0>=low1
    isInside = h0 <= h1 and l0 >= l1
    // 10 외부봉: high0>high1 and low0<low1 (장악형에 안 걸린 경우)
    isOutside = h0 > h1 and l0 < l1
    // 11 도지연속: 몸비0<=doji and 몸비1<=doji
    isDojiPair = br0 <= candleDojiBodyRatio and br1 <= candleDojiBodyRatio
    // 12 혼조: 위 미매칭 또는 range0/atrN < minRangeAtr
    lowRange = r0 / atrN < candleMinRangeAtr

    // 우선순위 판정: 3·4 → 1·2 → 7·8 → 5·6 → 9·10 → 11 → 12
    if not ready
        patName := "혼조"
        patPred := "신호없음"
    else if isMorningStar
        patName := "샛별"
        patPred := "강세반전(강)"
    else if isEveningStar
        patName := "석별"
        patPred := "약세반전(강)"
    else if isBullEngulf
        patName := "상승장악형"
        patPred := "강세반전"
    else if isBearEngulf
        patName := "하락장악형"
        patPred := "약세반전"
    else if isThreeSoldiers
        patName := "적삼병"
        patPred := "상승지속"
    else if isThreeCrows
        patName := "흑삼병"
        patPred := "하락지속"
    else if isHammer
        patName := "망치/역망치"
        patPred := "강세반전"
    else if isHangShoot
        patName := "교수형/유성"
        patPred := "약세반전"
    else if isInside
        patName := "내부봉"
        patPred := "돌파대기"
    else if isOutside
        patName := "외부봉"
        patPred := "변동성확대"
    else if isDojiPair
        patName := "도지연속"
        patPred := "관망"
    else
        patName := "혼조"
        patPred := "신호없음"
    // 셀 배경색 (CEO 지정 5단계)
    //  녹색=강한 강세(샛별·적삼병), 둔한 녹색=약강세(상승장악형·망치/역망치),
    //  빨강=강한 약세(석별·흑삼병), 둔한 빨강=약세(하락장악형·교수형/유성), 회색=중립(내부/외부/도지/혼조)
    color cellCol = switch patName
        "샛별" => color.new(color.green, 0)
        "적삼병" => color.new(color.green, 0)
        "상승장악형" => color.new(#6E8F72, 0)
        "망치/역망치" => color.new(#6E8F72, 0)
        "석별" => color.new(color.red, 0)
        "흑삼병" => color.new(color.red, 0)
        "하락장악형" => color.new(#A57A7A, 0)
        "교수형/유성" => color.new(#A57A7A, 0)
        => color.new(color.gray, 40)
    [patName + " | " + patPred, cellCol]

// 확정봉 모드면 off=1(직전 완성봉을 b0으로), 실시간 모드면 off=0(형성 중 봉을 b0으로).
candleOff = candleConfirmOnClose ? 1 : 0
[candleCellText, candleCellColor] = f_candleState(candleOff)

// 손익비(RR) — 현재 봉 기준. 롱: 위(숏 청산가)=목표·아래(롱 청산가)=손절 / 숏: 반대
rrUp = shortClear - close
rrDown = close - longClear
rrValid = rrUp > 0 and rrDown > 0
longRR = rrValid ? rrUp / rrDown : na
shortRR = rrValid ? rrDown / rrUp : na
rrUpPct = close != 0 ? math.abs(rrUp / close * 100) : na
rrDownPct = close != 0 ? math.abs(rrDown / close * 100) : na
f_rrText(rr, rewardPct, riskPct) => na(rr) ? "-" : str.tostring(rr, "0.00") + " (+" + str.tostring(rewardPct, "0.0") + "% / -" + str.tostring(riskPct, "0.0") + "%)"
f_rrColor(rr) => na(rr) ? color.new(color.gray, 40) : rr >= 1.5 ? color.new(color.green, 30) : rr >= 1.0 ? color.new(color.gray, 40) : color.new(color.red, 30)
// 현재가가 롱/숏 청산가 밖(이탈)이면 청산가 기준 손익비는 계산 불가.
//  단, 이격도 되돌림(주의/확실) 상태면 되돌림 방향(과열→숏, 과매도→롱)에 한해 폴백 계산:
//  손절=현재가 -4%(고정 리스크), 익절=되돌림 가격까지 거리 → 손익비 산출(텍스트에 '되돌림' 표기).
rrPbReward = not na(disparityPullbackPrice) and close != 0 ? math.abs(disparityPullbackPrice - close) / close * 100 : na
rrPbRisk = 4.0
rrPbRR = not na(rrPbReward) ? rrPbReward / rrPbRisk : na
f_rrPbText(rr, rewardPct) => "R " + str.tostring(rr, "0.00") + " (+" + str.tostring(rewardPct, "0.0") + "% / -" + str.tostring(rrPbRisk, "0.0") + "%)"
// VWAP+청산 기준 손익비(V): VWAP 상태 기울기 방향 + 그 방향 0.5×↑ 신호(buyStage/sellStage≥1)가 있으면,
//  손절=VWAP(추세 지지/저항)·목표=반대편 청산가로 손익비 산출(텍스트에 'V' 표기, 되돌림 R·정상보다 우선).
vHasVwap = not na(vwapValue)
vLongOn = vwSlopeUp and buyStage >= 1 and vHasVwap and shortClear > close and close > vwapValue
vShortOn = vwSlopeDown and sellStage >= 1 and vHasVwap and close > longClear and vwapValue > close
vLongRR = vLongOn ? (shortClear - close) / (close - vwapValue) : na
vShortRR = vShortOn ? (close - longClear) / (vwapValue - close) : na
vLongRewPct = vLongOn and close != 0 ? (shortClear - close) / close * 100 : na
vLongRiskPct = vLongOn and close != 0 ? (close - vwapValue) / close * 100 : na
vShortRewPct = vShortOn and close != 0 ? (close - longClear) / close * 100 : na
vShortRiskPct = vShortOn and close != 0 ? (vwapValue - close) / close * 100 : na
f_rrVText(rr, rewardPct, riskPct) => "V " + str.tostring(rr, "0.00") + " (+" + str.tostring(rewardPct, "0.0") + "% / -" + str.tostring(riskPct, "0.0") + "%)"
longRRText = vLongOn ? f_rrVText(vLongRR, vLongRewPct, vLongRiskPct) : rrValid ? f_rrText(longRR, rrUpPct, rrDownPct) : (underCount >= 1 and not na(rrPbRR) ? f_rrPbText(rrPbRR, rrPbReward) : "계산 불가")
shortRRText = vShortOn ? f_rrVText(vShortRR, vShortRewPct, vShortRiskPct) : rrValid ? f_rrText(shortRR, rrDownPct, rrUpPct) : (overCount >= 1 and not na(rrPbRR) ? f_rrPbText(rrPbRR, rrPbReward) : "계산 불가")
// 셀 색은 실제 표시하는 손익비(V 우선 → 청산가 기준 → 되돌림 폴백) 값으로 판정
longRREff = vLongOn ? vLongRR : rrValid ? longRR : (underCount >= 1 ? rrPbRR : na)
shortRREff = vShortOn ? vShortRR : rrValid ? shortRR : (overCount >= 1 ? rrPbRR : na)

var table triggerTable = table.new(position.top_right, 2, 23, border_width=1, border_color=color.new(color.gray, 50))
if barstate.islast
    table.cell(triggerTable, 0, 0, "다음 봉", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.small)
    table.cell(triggerTable, 1, 0, "트리거 가격", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.small)

    table.cell(triggerTable, 0, 1, "상승 전환(0.5×)", text_color=color.white, bgcolor=color.new(color.green, 30), text_size=size.small)
    table.cell(triggerTable, 1, 1, f_trigCell(buyBlocked05, buyTrig05, true, donB05, momentum), text_color=color.white, bgcolor=f_trigBg(buyBlocked05, buyTrig05, true), text_size=size.small)
    table.cell(triggerTable, 0, 2, "상승 전환(1×)", text_color=color.white, bgcolor=color.new(color.green, 30), text_size=size.small)
    table.cell(triggerTable, 1, 2, f_trigCell(buyBlocked10, buyTrig10, true, baseLine, momentum), text_color=color.white, bgcolor=f_trigBg(buyBlocked10, buyTrig10, true), text_size=size.small)
    table.cell(triggerTable, 0, 3, "상승 전환(2×)", text_color=color.white, bgcolor=color.new(color.green, 30), text_size=size.small)
    table.cell(triggerTable, 1, 3, f_trigCell(buyBlocked20, buyTrig20, true, donB20, momentum), text_color=color.white, bgcolor=f_trigBg(buyBlocked20, buyTrig20, true), text_size=size.small)

    table.cell(triggerTable, 0, 4, "하락 전환(0.5×)", text_color=color.white, bgcolor=color.new(color.red, 30), text_size=size.small)
    table.cell(triggerTable, 1, 4, f_trigCell(sellBlocked05, sellTrig05, false, donB05, momentum), text_color=color.white, bgcolor=f_trigBg(sellBlocked05, sellTrig05, false), text_size=size.small)
    table.cell(triggerTable, 0, 5, "하락 전환(1×)", text_color=color.white, bgcolor=color.new(color.red, 30), text_size=size.small)
    table.cell(triggerTable, 1, 5, f_trigCell(sellBlocked10, sellTrig10, false, baseLine, momentum), text_color=color.white, bgcolor=f_trigBg(sellBlocked10, sellTrig10, false), text_size=size.small)
    table.cell(triggerTable, 0, 6, "하락 전환(2×)", text_color=color.white, bgcolor=color.new(color.red, 30), text_size=size.small)
    table.cell(triggerTable, 1, 6, f_trigCell(sellBlocked20, sellTrig20, false, donB20, momentum), text_color=color.white, bgcolor=f_trigBg(sellBlocked20, sellTrig20, false), text_size=size.small)

    table.cell(triggerTable, 0, 7, "리본 추세", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 7, ribbonCellText, text_color=color.white, bgcolor=ribbonCellColor, text_size=size.small)

    table.cell(triggerTable, 0, 8, "비정상 매수/매도", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 8, abnCellText, text_color=color.white, bgcolor=abnCellColor, text_size=size.small)
    table.cell(triggerTable, 0, 9, "이격도 (" + str.tostring(disparityMaLen) + ")", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 9, disparityCellText, text_color=color.white, bgcolor=disparityCellColor, text_size=size.small)
    table.cell(triggerTable, 0, 10, "되돌림 가격", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 10, na(disparityPullbackPrice) ? "-" : f_price(disparityPullbackPrice) + " (" + f_pct(disparityPullbackPrice) + ")", text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)

    table.cell(triggerTable, 0, 11, "구름대", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 11, cloudCellText, text_color=color.white, bgcolor=cloudCellColor, text_size=size.small)

    table.cell(triggerTable, 0, 12, "VWAP 지지/저항", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 12, vwSrText, text_color=color.white, bgcolor=vwSrColor, text_size=size.small)
    // VWAP 상태 = 모양값(기울기 | 밴드폭) | 상태값. 셀 색은 밴드 상태 기준(밴드워킹 상단=초록·하단=빨강).
    table.cell(triggerTable, 0, 13, "VWAP 상태", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 13, vwSlopeText + " | " + vwBwStateText + " | " + vwBandStateShort, text_color=color.white, bgcolor=vwBandColor, text_size=size.small)

    table.cell(triggerTable, 0, 14, "장기 추세", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 14, ltCellText, text_color=color.white, bgcolor=ltCellColor, text_size=size.small)
    table.cell(triggerTable, 0, 15, "장기 지지/저항", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 15, ltSrText, text_color=color.white, bgcolor=ltSrColor, text_size=size.small)

    table.cell(triggerTable, 0, 16, "롱 스윕", text_color=color.white, bgcolor=color.new(longExitLineColor, 65), text_size=size.small)
    table.cell(triggerTable, 1, 16, f_price(longCE) + " (" + f_pct(longCE) + ")", text_color=color.white, bgcolor=color.new(longExitLineColor, 50), text_size=size.small)
    table.cell(triggerTable, 0, 17, "롱 청산", text_color=color.white, bgcolor=color.new(longExitLineColor, 40), text_size=size.small)
    table.cell(triggerTable, 1, 17, f_price(longClear) + " (" + f_pct(longClear) + ")", text_color=color.white, bgcolor=color.new(longExitLineColor, 20), text_size=size.small)
    table.cell(triggerTable, 0, 18, "숏 스윕", text_color=color.white, bgcolor=color.new(shortExitLineColor, 65), text_size=size.small)
    table.cell(triggerTable, 1, 18, f_price(shortCE) + " (" + f_pct(shortCE) + ")", text_color=color.white, bgcolor=color.new(shortExitLineColor, 50), text_size=size.small)
    table.cell(triggerTable, 0, 19, "숏 청산", text_color=color.white, bgcolor=color.new(shortExitLineColor, 40), text_size=size.small)
    table.cell(triggerTable, 1, 19, f_price(shortClear) + " (" + f_pct(shortClear) + ")", text_color=color.white, bgcolor=color.new(shortExitLineColor, 20), text_size=size.small)

    // 손익비(RR) — 롱/숏 청산가 기준. 현재가가 청산가 밖이면 "계산 불가"
    table.cell(triggerTable, 0, 20, "롱 손익비", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 20, longRRText, text_color=color.white, bgcolor=f_rrColor(longRREff), text_size=size.small)
    table.cell(triggerTable, 0, 21, "숏 손익비", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 21, shortRRText, text_color=color.white, bgcolor=f_rrColor(shortRREff), text_size=size.small)

    // 캔들 상태 (3) — 표시 전용. 좌열 라벨 스타일은 다른 행과 동일(gray 20). 우열은 "패턴명 | 다음봉예측" + 5단계 배경색.
    if candleShowState
        table.cell(triggerTable, 0, 22, "캔들 상태 (3)", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
        table.cell(triggerTable, 1, 22, candleCellText, text_color=color.white, bgcolor=candleCellColor, text_size=size.small)

// 이평 기반 상태 표식(+ 모양) (압축=보라 #9C27B0[상승·하락과 확실히 구분], 상승 분출=파랑, 하락 분출=빨강)
// 먼저 그려서 아래 신호 삼각형보다 뒤(아래 레이어)에 오게 한다.
plotshape(series=ribbonChop, title="횡보 압축 (아래)", style=shape.cross, location=location.belowbar, color=color.new(#9C27B0, 0), size=size.tiny)
plotshape(series=ribbonChop, title="횡보 압축 (위)", style=shape.cross, location=location.abovebar, color=color.new(#9C27B0, 0), size=size.tiny)
plotshape(series=ribbonBull, title="상승 분출", style=shape.cross, location=location.belowbar, color=color.new(color.blue, 0), size=size.tiny)
plotshape(series=ribbonBear, title="하락 분출", style=shape.cross, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny)

// 신호 삼각형 — 리본 표식 뒤에(나중에) 그려 위 레이어로. 스케일별 크기: 0.5×=가장 작음, 1×=작음, 2×=보통
// 모멘텀 모드로 발생한 신호는 청산선 색(롱=파랑, 숏=크림슨)으로 정상 신호(매수=아쿠아, 매도=핑크)와 구분.
momBuyColor = momentum ? longExitLineColor : defaultBuyColor
momSellColor = momentum ? shortExitLineColor : defaultSellColor
plotshape(showBuySignal and gBuy05, title="매수 0.5×", style=shape.triangleup, location=location.belowbar, color=momBuyColor, size=size.tiny)
plotshape(showBuySignal and gBuy10, title="매수 1×", style=shape.triangleup, location=location.belowbar, color=momBuyColor, size=size.small)
plotshape(showBuySignal and gBuy20, title="매수 2×", style=shape.triangleup, location=location.belowbar, color=momBuyColor, size=size.normal)
plotshape(showSellSignal and gSell05, title="매도 0.5×", style=shape.triangledown, location=location.abovebar, color=momSellColor, size=size.tiny)
plotshape(showSellSignal and gSell10, title="매도 1×", style=shape.triangledown, location=location.abovebar, color=momSellColor, size=size.small)
plotshape(showSellSignal and gSell20, title="매도 2×", style=shape.triangledown, location=location.abovebar, color=momSellColor, size=size.normal)
plotshape(showVwSignals and vwBuy05, title="매수 0.5× (거래량)", style=shape.triangleup, location=location.belowbar, color=color.new(momBuyColor, vwTransp), size=size.tiny)
plotshape(showVwSignals and vwBuy10, title="매수 1× (거래량)", style=shape.triangleup, location=location.belowbar, color=color.new(momBuyColor, vwTransp), size=size.small)
plotshape(showVwSignals and vwBuy20, title="매수 2× (거래량)", style=shape.triangleup, location=location.belowbar, color=color.new(momBuyColor, vwTransp), size=size.normal)
plotshape(showVwSignals and vwSell05, title="매도 0.5× (거래량)", style=shape.triangledown, location=location.abovebar, color=color.new(momSellColor, vwTransp), size=size.tiny)
plotshape(showVwSignals and vwSell10, title="매도 1× (거래량)", style=shape.triangledown, location=location.abovebar, color=color.new(momSellColor, vwTransp), size=size.small)
plotshape(showVwSignals and vwSell20, title="매도 2× (거래량)", style=shape.triangledown, location=location.abovebar, color=color.new(momSellColor, vwTransp), size=size.normal)

alertcondition(ribbonChop, title="횡보 압축", message="Ribbon compressed (chop) — Ichimoku signals unreliable.")
alertcondition(ribbonBull, title="상승 분출", message="Ribbon bullish expansion after compression.")
alertcondition(ribbonBear, title="하락 분출", message="Ribbon bearish expansion after compression.")
