//@version=6
indicator(title="Advanced Ichimoku", shorttitle="Adv Ichimoku", overlay=true, max_bars_back=5000)

donchian(len) =>
    math.avg(ta.lowest(len), ta.highest(len))

conversionPeriods = input.int(8, minval=1, title="컨버전 라인 길이", group="기본 설정")
basePeriods = input.int(22, minval=1, title="베이스 라인 길이", group="기본 설정")
leadingSpanBPeriods = input.int(44, minval=1, title="리딩 스팬 B 길이", group="기본 설정")
displacement = input.int(22, minval=1, title="레깅 스팬 길이", group="기본 설정")

showConversionLine = input.bool(true, title="컨버전 라인 표시", group="표시")
showBaseLine = input.bool(true, title="베이스 라인 표시", group="표시")
showLaggingSpan = input.bool(true, title="레깅 스팬 표시", group="표시")
showLeadingSpanA = input.bool(false, title="리딩 스팬 A 표시", group="표시")
showLeadingSpanB = input.bool(false, title="리딩 스팬 B 표시", group="표시")
showKumoUpper = input.bool(false, title="Kumo Cloud Upper Line 표시", group="표시")
showKumoLower = input.bool(false, title="Kumo Cloud Lower Line 표시", group="표시")
showCloudFill = input.bool(true, title="Cloud Fill 표시", group="표시")

showBuySignal = input.bool(true, title="매수 신호 표시", group="매수 신호")
showSellSignal = input.bool(true, title="매도 신호 표시", group="매도 신호")

// =========================
// 매매 신호 방식 6모드(택일) = 신호 소스(일반 도치안 / 거래량 가중 VWMA / 혼합) × 확정 방식(예측 vs 확정).
//  - "예측" 포함 → 다음 봉 가정으로 1봉 빨리 포착(예측 방식). 미포함 → 봉마감 확정 방식(원래 로직).
//  - "거래량 가중" 포함 → VWMA 신호(vwBuy/vwSell)만 표시. 미포함 → 일반 도치안 신호(fBuy/fSell)만 표시.
//  - "혼합" 포함 → 봉별 소스 스위칭: 그 봉이 비정상 거래량이면 VWMA 원시신호, 아니면 일반 원시신호로 계산.
//      혼합 소스는 일반 신호와 **동일한 게이트→pending→다음봉 확정→dir 파이프라인**을 그대로 경유한다(우회 없음).
//      → 차트 삼각형(fBuyXX)·테이블 추세(dirXX)가 혼합 파이프라인 하나만 참조해 정합. plotshape은 일반과 같은 경로.
//      목적: 장초·뉴스發 비정상 거래량 봉에서 거래량 가중 관점으로 추세 변화를 빠르게 캐치.
//      "혼합 확정 모드"=혼합+확정(구 '혼합 일반'을 개명, 로직 그대로·isPredict 유지). "혼합 예측 모드"=혼합+확정 경로 + 전환 행 색 예측 발화(후보 A).
//      예측/확정 축은 기존 isPredict가 처리. ⚠️ 개명 주의: 옛 '혼합 확정'(순수 확정)은 폐기되고, 옛 '혼합 일반'이 '혼합 확정'이 되었다.
//  기본 = "혼합 확정 모드"(구 '혼합 일반'을 개명 — 로직·isPredict 무변경). 신호 계산식은 무변경 — 어느 소스/방식을 쓸지 택일만(단, '혼합 예측'만 전환 행 색 예측 발화 추가).
//  ★ 입력 선언은 여기(신호 모드 그룹) → 캔들 색 표시 조건 2세트 순. Pine은 선언 순서로 옵션 패널을 그리므로 이 순서가 패널 배치.
signalMode = input.string("혼합 확정 모드", title="추세 진입 신호 방식", options=["일반 예측 모드", "일반 확정 모드", "거래량 가중 예측 모드", "거래량 가중 확정 모드", "혼합 확정 모드", "혼합 예측 모드"], group="매매 신호 방식", tooltip="혼합 확정 모드(기본, 구 '혼합 일반' 개명) = 혼합+확정. 혼합 예측 모드 = 혼합 확정 경로에 '전환 행 색 예측 발화'(추세 확인 테이블의 상승/하락 전환(스케일) 행 셀이 둔탁 녹/빨강 = 전환 예측·대기 상태 + 진행봉 방향 일치(양봉=롱·음봉=숏) 시 그 스케일 신호를 그 봉에서 즉시 발화·후보 A)를 추가. 혼합은 그 봉이 '비정상 거래량'이면 거래량 가중(VWMA) 원시신호를 즉시 발화, 아니면 일반 원시신호로 봉별 계산하되 게이트·확정 파이프라인은 일반과 동일하게 경유합니다. ⚠️ '혼합 예측'은 진행봉 실시간 예측이라 리페인팅 계열이며 전략 백테스트가 크게 변합니다.")
sigPredict = str.contains(signalMode, "예측") or str.contains(signalMode, "혼합 확정")   // 예측/확정 분기: 예측 계열 + 혼합 확정(구 '혼합 일반'=혼합 예측 파이프라인 보존). '혼합 예측'은 "예측" 부분문자열로 자동 true.
sigVw = str.contains(signalMode, "거래량 가중")      // 거래량 가중 전용 모드(VWMA 신호만, 파이프라인 우회). 혼합은 여기 포함 안 됨.
sigHybrid = str.contains(signalMode, "혼합")         // 혼합 모드(봉별 소스 스위칭 + 일반 파이프라인 경유)
isPredict = sigPredict

// =========================
lineWidth = 1
conversionLineColor = input.color(#FFEB3B, "컨버전 라인 색", group="색상")
baseLineColor = input.color(#00FF00, "베이스 라인 색", group="색상")
laggingSpanColor = input.color(#FF9800, "레깅 스팬 색", group="색상")
leadingSpanAColor = input.color(#7B9077, "리딩 스팬 A 색", group="색상")
leadingSpanBColor = input.color(#9A7272, "리딩 스팬 B 색", group="색상")
kumoBoundaryColor = input.color(#3F5AA9, "Kumo 경계선 색", group="색상")
bullCloudColor = input.color(#0B5D4F, "양운(상승 구름) 색", group="색상")
bearCloudColor = input.color(#6B1E28, "음운(하락 구름) 색", group="색상")
cloudTransp = input.int(45, "구름 투명도", minval=0, maxval=100, group="색상")
bullishCloudColor = color.new(bullCloudColor, cloudTransp)
bearishCloudColor = color.new(bearCloudColor, cloudTransp)
defaultSellColor = #FF5FA2
defaultBuyColor = #00ACC1

conversionLine = donchian(conversionPeriods)
baseLine = donchian(basePeriods)
leadingSpanA = math.avg(conversionLine, baseLine)
leadingSpanB = donchian(leadingSpanBPeriods)
kumoUpper = math.max(leadingSpanA, leadingSpanB)
kumoLower = math.min(leadingSpanA, leadingSpanB)

// 비정상 거래량 판정(⚠️ 전략 파라미터) — 혼합 모드에서 봉별 소스 스위칭 기준.
//  펀드 표준 정의 재사용: VOLUME-PRESSURE 지표(volume-pressure-tracker.pine)와 동일한 정의로 통일한다.
//   abnVolume = volume > ta.sma(volume, N) * (1 + mult)   (N=비교 캔들 수, mult=비정상 배수)
//  기본값 N=20 · mult=1.0 → 최근 20봉 평균 거래량의 2배 초과 시 '비정상'. (VOLUME-PRESSURE 기본값과 동일)
//  혼합 예측(혼합 일반)에서 '다음봉이 비정상'은 미래를 모르므로 현재봉 거래량으로 근사(예측 모드 관례) — 미래참조 아님(현재봉 volume 재사용).
abnVolLen = input.int(20, minval=1, title="비정상 거래량 비교 봉수(N)", group="매매 신호 방식", tooltip="혼합 모드 전용. 비정상 거래량 판정 = volume > SMA(volume, N) × (1 + 배수). VOLUME-PRESSURE 지표와 동일한 펀드 표준 정의. 전략 파라미터(수학자 리뷰 대상).")
abnVolMult = input.float(1.0, minval=0.0, step=0.1, title="비정상 거래량 배수(mult)", group="매매 신호 방식", tooltip="혼합 모드 전용. mult=1.0이면 평균의 2배 초과가 비정상. 값이 클수록 더 극단적인 거래량만 비정상으로 판정. 전략 파라미터(수학자 리뷰 대상).")
abnVolAvg = ta.sma(volume, abnVolLen)
// [D-1] abnVolume은 진행 중 현재봉 volume을 쓰므로 봉 완성 전까지 비정상 여부가 봉 내에서 토글될 수 있다(→ 소스 스위칭·pending 등록도 봉 내 변동 가능).
//  이는 예측(혼합 일반) 모드의 실시간 '빠른 캐치' 취지에 부합하는 의도된 동작이라 barstate.isconfirmed 가드를 일부러 걸지 않는다.
//  확정 발화 자체는 다음 봉 종가에서 확정되므로 발화 신호는 리페인팅되지 않음(대기 등록 단계의 진행봉 변동만 존재). 완전 무변동을 원하면 '혼합 확정' 모드 사용.
abnVolume = not na(abnVolAvg) and volume > abnVolAvg * (1 + abnVolMult)

// =========================
// [옵션 패널 재배치] 리본 추세(수축·분출) input 선언 — 테이블 섹션1(추세 확인)에 맞춰 여기로 이동(선언만).
//  ★ 실제 리본 계산 로직은 원위치 그대로다(하단 "이평 수축/확장 판정" 블록). 여기는 input 선언만 있어 패널 순서를 섹션1에 위치시킨다.
// =========================
ribbonMode = input.string("리본+구름", title="수축/확장 판정 모드", options=["이평 리본", "구름 두께", "리본+구름"], group="리본 추세(수축·분출)")
ribbonMaType = input.string("SMA", title="리본 이동평균 종류(A)", options=["SMA", "EMA", "WMA", "VWMA"], group="리본 추세(수축·분출)")
showChopWarn = input.bool(true, title="횡보 압축(수축) 표시", group="리본 추세(수축·분출)")
showExpansion = input.bool(true, title="분출(상승/하락 확장) 표시", group="리본 추세(수축·분출)")
ribbonConfirmOnClose = input.bool(false, title="봉마감 후 확정(끄면 현재봉 실시간)", group="리본 추세(수축·분출)")
ribbonAtrLength = input.int(14, minval=1, title="폭 ATR 기준", group="리본 추세(수축·분출)")
ribbonCompressAtrMult = input.float(0.8, minval=0.1, step=0.1, title="수축 판정 ATR 배수", group="리본 추세(수축·분출)")
ribbonExpandBars = input.int(1, minval=1, title="확장 판정 폭 증가 봉수(작을수록 빠름)", group="리본 추세(수축·분출)")

// =========================
// 멀티스케일 신호 — 래깅 설정값의 0.5× / 1× / 2× 스케일로 동일 로직 계산
// 한 함수가 일반(도న키언) 신호 + 거래량 가중(VWMA) 신호를 함께 반환한다. (후보 제거)
// 차트엔 1× 라인/구름만 그리고, 0.5×·2×는 신호 계산용으로만 쓴다.
// =========================
f_scale(p, mult) => math.max(1, int(math.round(p * mult)))

f_scaleSignals(float conv, float base, int convP, int baseP, int dispP) =>
    lagOff = math.max(dispP - 1, 0)
    lagBaseRef = base[lagOff]
    lagBull = not na(lagBaseRef) and (ta.crossover(close, lagBaseRef) or close > lagBaseRef)
    lagBear = not na(lagBaseRef) and (ta.crossunder(close, lagBaseRef) or close < lagBaseRef)
    convBull = ta.crossover(conv, base) or conv > base
    convBear = ta.crossunder(conv, base) or conv < base
    pBuy = (close + high) / 2
    pSell = (close + low) / 2
    pLagRef = base[math.max(lagOff - 1, 0)]
    pRawBuy = pBuy > pLagRef and convBull and low > low[1]
    pRawSell = pSell < pLagRef and convBear and high < high[1]
    rbEff = isPredict ? pRawBuy : (lagBull and convBull)
    rsEff = isPredict ? pRawSell : (lagBear and convBear)
    // 원시 매수·매도 신호를 그대로 상위로 반환한다. 함수 내부 방향 래치(구 var int lastDir)는 제거.
    //  중복 발화 차단은 상위 게이트(gBuyXX/gSellXX, dir!=방향)와 확정 래치(regXX + fXX + dir 잠금)가 완결적으로 담당.
    //  내부 래치는 상위 확정 dir와 비동기로 어긋나 방향 전환 시 원시 하락신호를 삼키는 버그 원인이었다.
    bSig = rbEff
    sSig = rsEff
    vConv = ta.vwma(close, convP)
    vBase = ta.vwma(close, baseP)
    vLagRef = vBase[lagOff]
    vLagBull = not na(vLagRef) and (ta.crossover(close, vLagRef) or close > vLagRef)
    vLagBear = not na(vLagRef) and (ta.crossunder(close, vLagRef) or close < vLagRef)
    vConvBull = ta.crossover(vConv, vBase) or vConv > vBase
    vConvBear = ta.crossunder(vConv, vBase) or vConv < vBase
    cN = math.max(1, convP - 1)
    bN = math.max(1, baseP - 1)
    pvConv = math.sum(close * volume, cN)
    vsConv = math.sum(volume, cN)
    pvBase = math.sum(close * volume, bN)
    vsBase = math.sum(volume, bN)
    vConvBuyN = (pvConv + pBuy * volume) / (vsConv + volume)
    vBaseBuyN = (pvBase + pBuy * volume) / (vsBase + volume)
    vConvSellN = (pvConv + pSell * volume) / (vsConv + volume)
    vBaseSellN = (pvBase + pSell * volume) / (vsBase + volume)
    vLagRefN = vBase[math.max(lagOff - 1, 0)]
    pvBuy = pBuy > vLagRefN and vConvBuyN > vBaseBuyN and low > low[1]
    pvSell = pSell < vLagRefN and vConvSellN < vBaseSellN and high < high[1]
    vRbEff = isPredict ? pvBuy : (vLagBull and vConvBull)
    vRsEff = isPredict ? pvSell : (vLagBear and vConvBear)
    var int vLastDir = 0
    vbSig = vRbEff and vLastDir != 1
    vsSig = vRsEff and vLastDir != -1
    if vbSig
        vLastDir := 1
    else if vsSig
        vLastDir := -1
    // vRbEff/vRsEff = VWMA '원시' 신호(내부 vLastDir 래치 이전). 혼합 모드가 일반 파이프라인(게이트→pending→확정)에
    //  정합적으로 편입되려면 vbSig/vsSig(자체 래치 우회 경로)가 아니라 이 원시 신호를 소스로 써야 한다.
    //  (거래량 가중 전용 모드는 vbSig/vsSig를 계속 쓴다 — 기존 동작 무변경.)
    [bSig, sSig, vbSig, vsSig, vRbEff, vRsEff]

// 스케일 기간·donchian — 정상 0.25/0.5/1/2× (1×=전역 재사용). 모멘텀 모드는 표시 스케일을 한 단계 빠른 기간으로 시프트.
c025 = f_scale(conversionPeriods, 0.25)
b025 = f_scale(basePeriods, 0.25)
d025 = f_scale(displacement, 0.25)
c05 = f_scale(conversionPeriods, 0.5)
b05 = f_scale(basePeriods, 0.5)
d05 = f_scale(displacement, 0.5)
c20 = f_scale(conversionPeriods, 2.0)
b20 = f_scale(basePeriods, 2.0)
d20 = f_scale(displacement, 2.0)
donC025 = donchian(c025)
donB025 = donchian(b025)
donC05 = donchian(c05)
donB05 = donchian(b05)
donC20 = donchian(c20)
donB20 = donchian(b20)
// 원시 신호 세트(정상 로직): A=0.25× B=0.5× C=1× D=2×. vrbX/vrsX = VWMA 원시신호(혼합 소스용).
[bA, sA, vbA, vsA, vrbA, vrsA] = f_scaleSignals(donC025, donB025, c025, b025, d025)
[bB, sB, vbB, vsB, vrbB, vrsB] = f_scaleSignals(donC05, donB05, c05, b05, d05)
[bC, sC, vbC, vsC, vrbC, vrsC] = f_scaleSignals(conversionLine, baseLine, conversionPeriods, basePeriods, displacement)
[bD, sD, vbD, vsD, vrbD, vrsD] = f_scaleSignals(donC20, donB20, c20, b20, d20)

// 혼합 원시신호(봉별 소스 스위칭) — 이 봉이 비정상 거래량이면 VWMA 원시(vrbX/vrsX), 아니면 일반 원시(bX/sX).
//  혼합 모드(sigHybrid)일 때만 아래 파이프라인 입력(buy05 등)이 이 값을 참조한다. 예측/확정은 각 소스가 이미 isPredict 반영.
//  ⚠️ 정합성 핵심: 여기서 소스만 봉별로 바꾸고, 이후 게이트/pending/확정/dir 파이프라인은 일반과 완전히 공통이다.
bAh = abnVolume ? vrbA : bA
sAh = abnVolume ? vrsA : sA
bBh = abnVolume ? vrbB : bB
sBh = abnVolume ? vrsB : sB
bCh = abnVolume ? vrbC : bC
sCh = abnVolume ? vrsC : sC
bDh = abnVolume ? vrbD : bD
sDh = abnVolume ? vrsD : sD
// 파이프라인이 실제 소비할 스케일별 원시신호 — 혼합이면 혼합 소스, 아니면 일반 소스(기존 4모드 동작 무변경).
bAe = sigHybrid ? bAh : bA
sAe = sigHybrid ? sAh : sA
bBe = sigHybrid ? bBh : bB
sBe = sigHybrid ? sBh : sB
bCe = sigHybrid ? bCh : bC
sCe = sigHybrid ? sCh : sC
bDe = sigHybrid ? bDh : bD
sDe = sigHybrid ? sDh : sD

// =========================
// [옵션 패널 재배치] 캔들 상태 input 선언 — 테이블 섹션2(캔들 및 되돌림 확인) 맨 앞에 맞춰 여기로 이동(선언만).
//  ★ 실제 캔들 상태(3) 7분류 계산 로직은 원위치 그대로다(하단 "캔들 상태 (3)" 블록). 여기는 input 선언만 있어 패널 순서를 섹션2에 위치시킨다.
// =========================
candleShowState = input.bool(true, title="캔들 상태 (3) 표시", group="캔들 상태")
candleConfirmOnClose = input.bool(false, title="확정봉 기준(끄면 현재봉 실시간)", group="캔들 상태", tooltip="기본=실시간(리페인팅 있음). 켜면 마지막으로 완성된 봉을 현재봉(b0)으로 보고 계산해 리페인팅을 막습니다. 끄면(기본) 형성 중인 봉을 b0으로 써서 실시간 반영되지만 봉 완성 전까지 값이 바뀔 수 있습니다.")
candleAtrLen = input.int(14, minval=1, title="캔들 ATR 길이(정규화)", group="캔들 상태")
candleNetBodyMin = input.float(0.8, minval=0.0, step=0.1, title="순몸통 최소(진행 판정)", group="캔들 상태", tooltip="3봉 순몸통 합(body 합)을 ATR로 나눈 값의 최소 임계. 진행(추세지속) 판정의 유일한 핵심 튜닝 노브입니다. 높일수록 진행 판정이 보수적.")
candleNetBodyStrong = input.float(1.5, minval=0.0, step=0.1, title="순몸통 강(계단 하나만 만족)", group="캔들 상태", tooltip="HH·HL(또는 LL·LH) 중 하나만 성립하고 3봉 방향이 모두 같을 때 요구하는 더 강한 순몸통 임계.")
candleMinRange3Atr = input.float(1.0, minval=0.0, step=0.1, title="3봉 총폭 최소 ATR 배수(혼조 판정)", group="캔들 상태", tooltip="최근 3봉 전체 고저폭을 ATR로 나눈 값이 이 미만이면 변동성 부족으로 혼조 처리합니다.")
candleStrongBodyRatio = input.float(0.55, minval=0.0, step=0.05, title="강한 몸통 비율 한계", group="캔들 상태", tooltip="샛별/석별의 첫 봉(b2) 강봉 판정 기준(범위 대비 몸통비율).")
candleLongWickRatio = input.float(0.55, minval=0.0, step=0.05, title="긴 꼬리 비율 한계", group="캔들 상태", tooltip="망치/유성의 긴 꼬리 판정 기준(범위 대비 꼬리비율).")
candleSmallBodyRatio = input.float(0.35, minval=0.0, step=0.05, title="작은 몸통 비율 한계", group="캔들 상태", tooltip="샛별/석별 가운데 봉(b1)·망치/유성 몸통(b0)의 작은 몸통 판정 기준.")
candleShortWickRatio = input.float(0.25, minval=0.0, maxval=1.0, step=0.05, title="극점돌파형 반대꼬리 짧음 한계", group="캔들 상태", tooltip="2봉 극점 돌파형 반전에서 반대쪽(하락=아래, 상승=위) 꼬리가 range 대비 이 비율 이하일 때 '강한 마감'으로 인정. 신규 튜닝 노브.")
candleRevBodyRatio = input.float(0.45, minval=0.35, maxval=0.55, step=0.05, title="반전형 중간몸통 하한", group="캔들 상태", tooltip="선행추세 반대 방향 반전봉의 몸통비율 하한. 장악형보다 완화된 중간몸통 반전 포착(예: 상승세 끝 큰 음봉→반전형 하락 예측). 잠정값(IONQ 근거)·다심볼 검증 대상.")

// =========================
// [상단 이동] 캔들 상태 계산(candleAtrN·f_candleState) — 원래 캔들 상태 로직부(이격도 이하)에 있었으나 상단으로 옮겨져 있다.
//  (과거엔 '혼합 예측 모드'의 캔들 예측 발화가 파이프라인에서 f_candleState(0)을 호출해 앞에 둘 필요가 있었으나, 발화 기준이
//   '추세 전환 행 셀 색(f_trigNear)'으로 재설계되며 파이프라인은 더 이상 f_candleState를 호출하지 않는다. 이 함수는 이제 '표시 전용'.)
//  함수는 input(위 캔들 상태 그룹)·내장값만 참조하는 자기완결 구조라 위치는 무해하다. candleOff 기반 표시용 호출(candleCellText 등)은 원위치에 둔다.
// =========================
// candleAtrLen 전용 ATR — 기존 ta.atr(14=ltAtr)는 길이 고정이라 사용자 입력(candleAtrLen)을 못 따라간다. 정규화 기준을 입력에 맞추려 별도 인스턴스 사용.
candleAtrN = ta.atr(candleAtrLen)

// 3봉 캔들 7분류. off = b0 오프셋(확정봉 모드면 1, 실시간 모드면 0). b0=close[off], b1=close[off+1], b2=close[off+2].
// 반환: [셀텍스트, 셀배경색, barcolor색, 분류명]. 판정 순서(첫 매칭 확정, 상호배타):
//   1 혼조게이트 → 2 반전형상승 → 3 반전형하락 → 4 상승진행 → 5 하락진행 → 6 추세형상승 → 7 추세형하락 → 8 혼조.
f_candleState(int off) =>
    // 봉 원자료
    o0 = open[off]
    c0 = close[off]
    h0 = high[off]
    l0 = low[off]
    o1 = open[off + 1]
    c1 = close[off + 1]
    h1 = high[off + 1]
    l1 = low[off + 1]
    o2 = open[off + 2]
    c2 = close[off + 2]
    h2 = high[off + 2]
    l2 = low[off + 2]
    atrN = candleAtrN
    // 데이터 부족(초기 봉)·ATR 0 방어
    ready = not na(o0) and not na(o1) and not na(o2) and not na(atrN) and atrN > 0
    // 범위(0 방어), 부호몸통(signed), 몸통비율, 방향(math.sign → +1/-1/0)
    r0 = math.max(h0 - l0, syminfo.mintick)
    r1 = math.max(h1 - l1, syminfo.mintick)
    r2 = math.max(h2 - l2, syminfo.mintick)
    body0 = c0 - o0
    body1 = c1 - o1
    body2 = c2 - o2
    br0 = math.abs(body0) / r0
    br1 = math.abs(body1) / r1
    br2 = math.abs(body2) / r2
    dir0 = int(math.sign(body0))
    dir1 = int(math.sign(body1))
    dir2 = int(math.sign(body2))
    upWick0 = h0 - math.max(o0, c0)
    dnWick0 = math.min(o0, c0) - l0
    // b2 몸통 중앙(샛별/석별 회복 기준)
    mid2 = (o2 + c2) / 2
    // 스코어링 파생 — 3봉 구조·순몸통·방향카운트·총폭·직전추세
    // atrN>0은 ready에서 가드되나 함수 초반 계산이라 안전하게 atrSafe 사용.
    atrSafe = na(atrN) or atrN <= 0 ? syminfo.mintick : atrN
    HH = h0 > h1 and h1 > h2
    HL = l0 > l1 and l1 > l2
    LH = h0 < h1 and h1 < h2
    LL = l0 < l1 and l1 < l2
    netBody = (body0 + body1 + body2) / atrSafe
    upCount = (dir0 == 1 ? 1 : 0) + (dir1 == 1 ? 1 : 0) + (dir2 == 1 ? 1 : 0)
    dnCount = (dir0 == -1 ? 1 : 0) + (dir1 == -1 ? 1 : 0) + (dir2 == -1 ? 1 : 0)
    range3 = (math.max(h0, h1, h2) - math.min(l0, l1, l2)) / atrSafe
    // 선행추세 확장: 종가 전용이 아니라 고점/저점 상승·하락 시도까지 포함(눌린 종가 봉에서도 반전 게이트 통과).
    priorUpX = (c1 > c2) or (h1 > h2)
    priorDownX = (c1 < c2) or (l1 < l2)
    // ★반전형 전용 배타 게이트(netPrior): priorUpX/priorDownX는 OR가 느슨해 동시 참(예: c1>c2 & l1<l2)이 흔하다.
    //  위꼬리(유성/역망치)·아래꼬리(망치/교수형) 반전형은 몸통 형태가 좌우 동일하고 게이트만 달라, 동시 참이면
    //  판정순서상 revUp(상승)이 revDn(하락)을 항상 선점 → "반전형 하락 예측"이 구조적으로 미발화하던 버그.
    //  선행추세 강도 스코어의 부호로 방향을 하나로 확정(동점=불명확→반전형 게이트 닫음). 상호배타 보장.
    //  ※ 적용 범위=반전형 전체(꼬리형 4종·장악형·샛별/석별·반전강봉)만. 진행·추세형(trendUp/trendDn)은 기존 priorUpX/priorDownX 유지→회귀 차단.
    priorUpScore = (c1 > c2 ? 1 : 0) + (h1 > h2 ? 1 : 0)
    priorDownScore = (c1 < c2 ? 1 : 0) + (l1 < l2 ? 1 : 0)
    priorNet = priorUpScore - priorDownScore
    priorUpExcl = priorNet > 0     // 선행추세 상승 우세(배타)
    priorDownExcl = priorNet < 0   // 선행추세 하락 우세(배타)
    // 반전 패턴(예측) 정의
    strongBody = candleStrongBodyRatio
    smallBody = candleSmallBodyRatio
    longWick = candleLongWickRatio
    // 긴 꼬리 파생: 한쪽 꼬리가 긴 임계 이상 + 반대쪽 꼬리는 (1-임계) 이하(작음). 망치/역망치/교수형/유성 공통 몸통 부품.
    longLowerWick = dnWick0 / r0 >= longWick and upWick0 / r0 <= (1 - longWick)
    longUpperWick = upWick0 / r0 >= longWick and dnWick0 / r0 <= (1 - longWick)
    // 장악형
    bullEngulf = dir1 == -1 and dir0 == 1 and c0 >= o1 and o0 <= c1
    bearEngulf = dir1 == 1 and dir0 == -1 and c0 <= o1 and o0 >= c1
    // CEO식 2봉 극점 돌파형: 직전 2봉 극점(저/고점)을 모두 돌파 + 반대꼬리 짧음(강한 마감) + 강몸통. → 추세형 예측으로 분류.
    bearBreak2 = dir0 == -1 and l0 < l1 and l0 < l2 and (dnWick0 / r0) <= candleShortWickRatio and br0 >= strongBody
    bullBreak2 = dir0 == 1 and h0 > h1 and h0 > h2 and (upWick0 / r0) <= candleShortWickRatio and br0 >= strongBody
    // 작은몸통 + 긴 꼬리 반전형(직전 방향 게이트로 상/하 구분):
    //  망치(강세)=선행하락+긴아래꼬리, 역망치(강세)=선행하락+긴위꼬리, 교수형(약세)=선행상승+긴아래꼬리, 유성(약세)=선행상승+긴위꼬리.
    revUpHammer = priorDownExcl and br0 <= smallBody and longLowerWick    // 망치
    revUpInvHammer = priorDownExcl and br0 <= smallBody and longUpperWick // 역망치
    revDnHanging = priorUpExcl and br0 <= smallBody and longLowerWick     // 교수형
    revDnShooting = priorUpExcl and br0 <= smallBody and longUpperWick    // 유성
    // 샛별(강세)·석별(약세)
    morningStar = dir2 == -1 and br2 >= strongBody and br1 <= smallBody and dir0 == 1 and c0 >= mid2
    eveningStar = dir2 == 1 and br2 >= strongBody and br1 <= smallBody and dir0 == -1 and c0 <= mid2
    // 반전강봉(중간~강 몸통 반전): 꼬리형(br≤smallBody)과 강몸통 폴백(br≥strongBody) 사이 중간몸통 사각지대 보완.
    //  선행추세 반대 방향 + 중간~강 몸통(br0>=candleRevBodyRatio) + 직전 봉 극점 확증 마감으로 방향 확증(장악형보다 완화).
    revDnBody = priorUpExcl and dir0 == -1 and br0 >= candleRevBodyRatio and c0 < l1   // 상승세 끝 중간~강 음봉, 직전 봉 저점 하회 마감
    revUpBody = priorDownExcl and dir0 == 1 and br0 >= candleRevBodyRatio and c0 > h1   // 하락세 끝 중간~강 양봉, 직전 봉 고점 상회 마감
    // 반전형 상승/하락 예측 성립 여부 및 근거 패턴명(샛별/석별→장악형→망치·역망치→반전강봉 / 석별→장악형→교수형·유성→반전강봉 우선순위)
    //  ★최종 게이트도 배타(priorUpExcl/priorDownExcl)로 통일 — 장악형·샛별/석별은 자체 게이트가 없어 최종 게이트가 방향을 확정한다.
    //   배타 게이트라 revUp·revDn이 동시에 참일 수 없어(priorNet 부호 하나로 결정) 판정순서 선점 편향이 제거된다.
    revUp = priorDownExcl and (morningStar or bullEngulf or revUpHammer or revUpInvHammer or revUpBody)
    revDn = priorUpExcl and (eveningStar or bearEngulf or revDnShooting or revDnHanging or revDnBody)
    revUpPat = morningStar ? "샛별" : bullEngulf ? "장악형" : revUpHammer ? "망치" : revUpInvHammer ? "역망치" : revUpBody ? "반전강봉" : na
    revDnPat = eveningStar ? "석별" : bearEngulf ? "장악형" : revDnShooting ? "유성" : revDnHanging ? "교수형" : revDnBody ? "반전강봉" : na
    // 추세형 상승/하락 예측(선행 추세 방향으로 2봉 극점 돌파형 강봉)
    trendUp = priorUpX and bullBreak2
    trendDn = priorDownX and bearBreak2
    // 진행 성립 여부 및 근거 패턴명(적삼병/흑삼병 = 3봉 동일방향 계단, 그 외 "진행")
    upProgress = ((HH and HL) and upCount >= 2 and netBody >= candleNetBodyMin) or ((HH or HL) and upCount == 3 and netBody >= candleNetBodyStrong)
    dnProgress = ((LL and LH) and dnCount >= 2 and netBody <= -candleNetBodyMin) or ((LL or LH) and dnCount == 3 and netBody <= -candleNetBodyStrong)
    // 강몸통 방향 폴백(순위 최하단, else 혼조 직전) — 2봉극점 미돌파·3봉계단 미충족으로 새던 명백한 강방향봉 흡수.
    //  단일 현재봉(b0)의 방향(dir0)·강몸통(br0>=strongBody)·3봉 순몸통 뚜렷(netBody)만 본다. dir0 부호 배타로 up/dn 동시참 불가.
    bodyFallbackDn = dir0 == -1 and br0 >= candleStrongBodyRatio and netBody <= -candleNetBodyMin
    bodyFallbackUp = dir0 == 1 and br0 >= candleStrongBodyRatio and netBody >= candleNetBodyMin

    // 판정 (상호배타, 첫 매칭 확정 — 반전형 예측 → 진행 → 추세형 예측 순)
    string clsName = na
    string clsPat = na
    if not ready or range3 < candleMinRange3Atr
        clsName := "혼조"
    else if revUp
        clsName := "반전형 상승 예측"
        clsPat := revUpPat
    else if revDn
        clsName := "반전형 하락 예측"
        clsPat := revDnPat
    else if upProgress
        clsName := "상승 진행"
        clsPat := (upCount == 3 ? "적삼병" : na)
    else if dnProgress
        clsName := "하락 진행"
        clsPat := (dnCount == 3 ? "흑삼병" : na)
    else if trendUp
        clsName := "추세형 상승 예측"
        clsPat := "2봉고점돌파"
    else if trendDn
        clsName := "추세형 하락 예측"
        clsPat := "2봉저점돌파"
    else if bodyFallbackUp
        clsName := "추세형 상승 예측"
        clsPat := "강몸통"
    else if bodyFallbackDn
        clsName := "추세형 하락 예측"
        clsPat := "강몸통"
    else
        clsName := "혼조"
    // 셀 배경색 (7분류) — 상승 진행/추세형 상승/반전형 상승/혼조/반전형 하락/추세형 하락/하락 진행
    color cellCol = switch clsName
        "상승 진행" => color.new(color.green, 0)
        "추세형 상승 예측" => color.new(#6E8F72, 0)
        "반전형 상승 예측" => color.new(#26A69A, 0)
        "반전형 하락 예측" => color.new(#EF5350, 0)
        "추세형 하락 예측" => color.new(#A57A7A, 0)
        "하락 진행" => color.new(color.red, 0)
        => color.new(color.gray, 40)
    // 근거 패턴 병기(특정 시): "분류명 | 패턴"
    cellText = na(clsPat) ? clsName : clsName + " | " + clsPat
    // barcolor용 색: 방향 있는 6개 분류는 셀색과 동일, 혼조는 na(색칠 안 함 → 원래 캔들 색 유지).
    color barCol = clsName == "혼조" ? na : cellCol
    // clsName도 반환 — 캔들 손절라인 행(표시 전용)이 같은 7분류 방향·색을 재사용하기 위함(재계산 없이 일관성 보장).
    [cellText, cellCol, barCol, clsName]

// =========================
// 이격도 (Disparity) — 종가가 선택한 이평선에서 몇 %인지. 기준선 100, 임계 ±N%면 되돌림 주의.
//  (모멘텀 모드 즉시 반영을 위해 멀티스케일 신호 앞에서 계산)
// =========================
disparityMaType = input.string("SMA", title="이격도 MA 종류", options=["SMA", "EMA", "WMA", "VWMA"], group="이격도")
disparityMaLen = input.int(20, minval=1, title="이격도 MA 길이", group="이격도")
disparityThreshold = input.float(10.0, minval=0.1, step=0.1, title="이격도 임계(±%, 고정)", group="이격도")
disparityStatLen = input.int(50, minval=5, title="이격도 통계 구간(적응형)", group="이격도")
disparityStatMult = input.float(1.5, minval=0.1, step=0.1, title="이격도 통계 시그마 배수", group="이격도")
// Ret 손익비(되돌림 기반) 손절 = 이격도 바깥쪽 엣지(disparityNeutralPct × retStopMult). 이익 목표와 같은 이격도 척도. 초기값 2.0은 잠정 — 백테스트로 확정 대상.
retStopMult = input.float(2.0, minval=0.1, step=0.1, title="Ret 손절 이격 배수", group="이격도", tooltip="Ret 손익비의 손절 = 되돌림 이익 목표(중립 안쪽 엣지)와 같은 이격도 척도의 바깥쪽 엣지. 손절 편차폭 = 중립폭(disparityNeutralPct) × 이 배수. 이격이 더 벌어져 되돌림이 무효화되는 지점. 초기 2.0은 잠정치(백테스트 확정 대상).")
// Ret 고정손절 폴백 — 순수 E(이격 바깥 엣지) 계산불가(가격이 바깥 엣지 너머라 손절 방향 뒤집힘) 시 고정 %로 대체. 본부추천 주의2%/확실4%·백테스트 확정 대상.
retFixedStopWarn = input.float(2.0, minval=0.1, step=0.1, title="Ret 고정손절% (되돌림 주의)", group="이격도", tooltip="순수 E(이격 바깥 엣지) 손절이 계산불가일 때 폴백. 되돌림 '주의' 국면에서 손절을 현재가 대비 고정 %로. 롱=close×(1−%/100)·숏=close×(1+%/100). 본부추천 2.0·백테스트 확정 대상.")
retFixedStopSure = input.float(4.0, minval=0.1, step=0.1, title="Ret 고정손절% (되돌림 확실)", group="이격도", tooltip="순수 E(이격 바깥 엣지) 손절이 계산불가일 때 폴백. 되돌림 '확실' 국면에서 손절을 현재가 대비 고정 %로. 롱=close×(1−%/100)·숏=close×(1+%/100). 본부추천 4.0·백테스트 확정 대상.")
disparityMa = switch disparityMaType
    "SMA" => ta.sma(close, disparityMaLen)
    "EMA" => ta.ema(close, disparityMaLen)
    "WMA" => ta.wma(close, disparityMaLen)
    "VWMA" => ta.vwma(close, disparityMaLen)
disparity = not na(disparityMa) and disparityMa != 0 ? close / disparityMa * 100 : na
// 되돌림 판정 = 고정 임계(±%) + 적응형(자기 표준편차 시그마), 방향별로 두 기준 충족 개수를 센다.
//  1개 충족 → '되돌림 주의'(둔탁색), 2개 모두 → '되돌림 확실'(선명색), 0개 → '중립'(회색).
disparityStd = ta.stdev(disparity, disparityStatLen)
disparityStatOk = not na(disparity) and not na(disparityStd) and disparityStd > 0
overFixed  = not na(disparity) and disparity - 100 >= disparityThreshold
overStat   = disparityStatOk and disparity - 100 >= disparityStatMult * disparityStd
underFixed = not na(disparity) and 100 - disparity >= disparityThreshold
underStat  = disparityStatOk and 100 - disparity >= disparityStatMult * disparityStd
overCount  = (overFixed ? 1 : 0) + (overStat ? 1 : 0)
underCount = (underFixed ? 1 : 0) + (underStat ? 1 : 0)
disparityState = (overCount == 2 or underCount == 2) ? "되돌림 확실" : (overCount >= 1 or underCount >= 1) ? "되돌림 주의" : "중립"
disparityCellText = na(disparity) ? "-" : str.tostring(disparity, "0.0") + " (" + disparityState + ")"
// 과열(위)=빨강계 / 과매도(아래)=초록계, 확실=선명(투명도 0) / 주의=둔탁(채도 낮은 톤)
disparityCellColor = overCount == 2 ? color.new(color.red, 0) : underCount == 2 ? color.new(color.green, 0) : overCount >= 1 ? color.new(#A57A7A, 0) : underCount >= 1 ? color.new(#6E8F72, 0) : color.new(color.gray, 40)
// 되돌림 가격 = 이격도가 '중립'으로 복귀하는 가격 band. 중립 경계 = MA × (1 ± 중립폭%/100).
// 중립폭 = min(고정 임계, 통계 σ) — 둘 중 더 빨리 발동하는(좁은) 쪽이 중립 경계라서.
disparityNeutralPct = disparityStatOk ? math.min(disparityThreshold, disparityStatMult * disparityStd) : disparityThreshold
disparityLowerEdge = not na(disparityMa) ? disparityMa * (1 - disparityNeutralPct / 100) : na
disparityUpperEdge = not na(disparityMa) ? disparityMa * (1 + disparityNeutralPct / 100) : na
// 단일 되돌림 가격: 과열(상승 중 하락 반등)이면 중립 상단(최대값), 과매도(하락 중 상승 반등)이면 중립 하단(최소값). 중립이면 없음.
disparityPullbackPrice = overCount >= 1 ? disparityUpperEdge : underCount >= 1 ? disparityLowerEdge : na

// =========================
// 비정상 캔들 — cRSI 과매수/과매도 + 볼린저 몸통 이탈 캔들, 이후 ATR 추종 배경.
//  기준 길이(cRSI 사이클·볼린저·ATR·RSI·추적 봉수)는 베이스 라인(basePeriods)에 연동해 최적화.
//  차트: 비정상 캔들 바색 + 배경(bgcolor). 테이블: 비정상 캔들/감시 상태.
//  (모멘텀 모드 즉시 반영을 위해 멀티스케일 신호 앞에서 계산)
// =========================
abnVibration = input.int(10, minval=1, title="비정상 캔들 cRSI Vibration", group="비정상 캔들")
abnOB = input.float(70.0, title="비정상 절대 과매수", group="비정상 캔들")
abnOS = input.float(30.0, title="비정상 절대 과매도", group="비정상 캔들")
abnBbMult = input.float(2.0, minval=0.1, step=0.1, title="비정상 볼린저 배수", group="비정상 캔들")
abnBodyRatio = input.float(0.3, minval=0.0, step=0.05, title="비정상 밴드 초과 비율(고저 기준)", group="비정상 캔들")
abnAtrMult = input.float(1.2, minval=0.1, step=0.1, title="비정상 배경 ATR 배수", group="비정상 캔들")
abnStrongAtrMult = input.float(1.8, minval=1.0, step=0.1, title="비정상 강한 배경 ATR 배수", group="비정상 캔들")
abnRsiMoveLimit = input.float(15.0, minval=0.1, step=0.1, title="비정상 RSI 이동 제한", group="비정상 캔들")
abnShowBg = input.bool(true, title="비정상 매수/매도 배경 표시", group="비정상 캔들", tooltip="비정상 매도=파랑, 비정상 매수=빨강 배경으로 세로 스트립을 칠합니다. (반등 감시 배경은 CEO 지시로 제거됨)")
// 비정상/감시 셀 색(테이블 '비정상 매수/매도' 셀 배경 전용 — 차트 캔들 바색·반등 감시 배경은 제거됨)
abnOverboughtColor = input.color(color.red, title="비정상 매수 셀 색", group="비정상 캔들")
abnOversoldColor = input.color(color.aqua, title="비정상 매도 셀 색", group="비정상 캔들")
abnBullBaseColor = input.color(color.green, title="롱 감시 셀 색", group="비정상 캔들")
abnBullStrongColor = input.color(color.blue, title="롱 감시 강화 셀 색", group="비정상 캔들")
abnBearBaseColor = input.color(#E65100, title="숏 감시 셀 색(어두운 주황)", group="비정상 캔들")
abnBearStrongColor = input.color(color.red, title="숏 감시 강화 셀 색", group="비정상 캔들")
// 비정상 매수/매도 세로 배경색(CEO 명시: 매도=파랑, 매수=빨강 — 방향 직관과 반대지만 지시대로)
abnSellBgColor = input.color(color.blue, title="비정상 매도 배경 색(파랑)", group="비정상 캔들")
abnBuyBgColor = input.color(color.red, title="비정상 매수 배경 색(빨강)", group="비정상 캔들")
abnBgTransp = input.int(82, minval=0, maxval=100, title="비정상 배경 투명도", group="비정상 캔들")

// 기준 길이 = 베이스 라인(basePeriods)에 연동 — 비정상 캔들 신호 최적화
abnLen = basePeriods
abnLookback = basePeriods
// cRSI (도미넌트 사이클 = 베이스 라인) → 절대 과매수/과매도
abnCycleLen = math.max(1, int(basePeriods / 2))
abnTorque = 2.0 / (abnVibration + 1.0)
abnPhasingLag = int((abnVibration - 1) / 2.0)
abnUp = ta.rma(math.max(ta.change(close), 0), abnCycleLen)
abnDown = ta.rma(-math.min(ta.change(close), 0), abnCycleLen)
abnRsiRaw = abnDown == 0 ? 100.0 : abnUp == 0 ? 0.0 : 100.0 - 100.0 / (1.0 + abnUp / abnDown)
var float abnCrsi = na
abnCrsi := abnTorque * (2.0 * abnRsiRaw - nz(abnRsiRaw[abnPhasingLag])) + (1.0 - abnTorque) * nz(abnCrsi[1])
abnIsOB = abnCrsi >= abnOB
abnIsOS = abnCrsi <= abnOS

// 볼린저 밴드 이탈 = 비정상 캔들. 종가(몸통)는 실시간 변동이 커서 **고가/저가** 기준으로 판정.
//  비정상 매수=현재봉 고가가 상단 밴드 초과, 비정상 매도=현재봉 저가가 하단 밴드 초과. 초과폭÷캔들 범위 비율로 강도 판정.
abnBbBasis = ta.sma(close, abnLen)
abnBbDev = ta.stdev(close, abnLen) * abnBbMult
abnBbUpper = abnBbBasis + abnBbDev
abnBbLower = abnBbBasis - abnBbDev
abnRangeSpan = math.max(high - low, syminfo.mintick)
abnUpperOut = math.max(high - abnBbUpper, 0.0)
abnLowerOut = math.max(abnBbLower - low, 0.0)
abnBearExt = abnUpperOut > 0 and abnUpperOut / abnRangeSpan >= abnBodyRatio
abnBullExt = abnLowerOut > 0 and abnLowerOut / abnRangeSpan >= abnBodyRatio
abnBearCandle = abnIsOB and abnBearExt
abnBullCandle = abnIsOS and abnBullExt
// (캔들 바색 제거 — CEO 지시) 비정상 캔들은 더 이상 바색으로 칠하지 않고, 아래 bgcolor(배경색)로만 표시한다. 캔들 바디 색은 캔들 상태(3) 분류가 담당.

// 비정상 캔들 이후 ATR 추종 배경. RSI는 추종 품질 게이트.
abnAtr = ta.atr(abnLen)
abnOsc = ta.rsi(close, abnLen)
// 정상 복귀 트리거 = 이격도가 중립으로 복귀할 때 (되돌림 주의/확실이 해소되면 정상 캔들)
abnDisparityNeutral = overCount == 0 and underCount == 0
var int abnBullBar = na
var int abnBearBar = na
var float abnBullRefPrice = na
var float abnBullRefRsi = na
var float abnBullRefAtr = na
var float abnBearRefPrice = na
var float abnBearRefRsi = na
var float abnBearRefAtr = na
// 이격도 중립이면 추적 종료(먼저) → 새 비정상 캔들이면 재시작(최신 우선)
if not na(abnBullBar) and abnDisparityNeutral
    abnBullBar := na
if not na(abnBearBar) and abnDisparityNeutral
    abnBearBar := na
if abnBullCandle
    abnBullBar := bar_index
    abnBullRefPrice := low
    abnBullRefRsi := abnOsc
    abnBullRefAtr := abnAtr
if abnBearCandle
    abnBearBar := bar_index
    abnBearRefPrice := high
    abnBearRefRsi := abnOsc
    abnBearRefAtr := abnAtr
abnBullBars = not na(abnBullBar) ? bar_index - abnBullBar : na
abnBearBars = not na(abnBearBar) ? bar_index - abnBearBar : na
abnHasBull = not na(abnBullBars) and abnBullBars >= 0 and abnBullBars <= abnLookback
abnHasBear = not na(abnBearBars) and abnBearBars >= 0 and abnBearBars <= abnLookback
abnBullPriceMove = abnHasBull and not na(abnBullRefPrice) ? abnBullRefPrice - low : na
abnBullRsiMove = abnHasBull and not na(abnBullRefRsi) ? abnBullRefRsi - abnOsc : na
abnBullAtrNeed = abnHasBull and not na(abnBullRefAtr) ? abnBullRefAtr * abnAtrMult : na
abnBearPriceMove = abnHasBear and not na(abnBearRefPrice) ? high - abnBearRefPrice : na
abnBearRsiMove = abnHasBear and not na(abnBearRefRsi) ? abnOsc - abnBearRefRsi : na
abnBearAtrNeed = abnHasBear and not na(abnBearRefAtr) ? abnBearRefAtr * abnAtrMult : na
abnBullBgOn = abnHasBull and abnBullBars > 0 and not na(abnBullPriceMove) and not na(abnBullAtrNeed) and abnBullPriceMove >= abnBullAtrNeed and abnBullRsiMove <= abnRsiMoveLimit
abnBearBgOn = abnHasBear and abnBearBars > 0 and not na(abnBearPriceMove) and not na(abnBearAtrNeed) and abnBearPriceMove >= abnBearAtrNeed and abnBearRsiMove <= abnRsiMoveLimit
abnBullBgStrong = abnBullBgOn and abnBullPriceMove >= abnBullRefAtr * abnStrongAtrMult
abnBearBgStrong = abnBearBgOn and abnBearPriceMove >= abnBearRefAtr * abnStrongAtrMult

// 상태 래치: 이격도 중립 복귀 시 리셋. 비정상 캔들(±1)과 반등 감시(±2/±3)를 **각각** 래치해 동시 표시 가능.
var int abnCandleState = 0   // 1=비정상 매도, -1=비정상 매수, 0=없음
var int abnWatch = 0         // 2/3=롱 감시(강), -2/-3=숏 감시(강), 0=없음
if abnDisparityNeutral
    abnCandleState := 0
    abnWatch := 0
if abnBullCandle
    abnCandleState := 1
if abnBearCandle
    abnCandleState := -1
if abnBullBgStrong
    abnWatch := 3
else if abnBullBgOn
    abnWatch := 2
if abnBearBgStrong
    abnWatch := -3
else if abnBearBgOn
    abnWatch := -2
// 방향(빠른 신호용) = 캔들 우선, 없으면 감시 부호
abnSig = abnCandleState != 0 ? (abnCandleState > 0 ? 1 : -1) : abnWatch > 0 ? 1 : abnWatch < 0 ? -1 : 0
// 방향: 1=비정상 매도/롱 반등, -1=비정상 매수/숏 반등, 0=정상(이격도 중립). 진입 시 매수·매도 신호 모두 모멘텀 모드로 전환. (현재 봉 값으로 즉시 반영)
abnDirSig = abnSig > 0 ? 1 : abnSig < 0 ? -1 : 0

// 세로 배경색(CEO 지시 재구성): 반등 감시(abnWatch) 배경은 제거하고, 비정상 캔들(abnCandleState)에만 칠한다.
//  비정상 매도(abnCandleState==1)=파랑, 비정상 매수(abnCandleState==-1)=빨강. 투명도는 기존 반등 감시 배경과 동일(옅게).
//  판정 래치(abnCandleState/abnWatch)는 무변경 — 배경이 참조하는 상태만 감시→비정상으로 바꾼 시각화 변경.
abnBg = abnCandleState == 1 ? color.new(abnSellBgColor, abnBgTransp) : abnCandleState == -1 ? color.new(abnBuyBgColor, abnBgTransp) : na
bgcolor(abnShowBg ? abnBg : na, title="비정상 매수/매도 배경")

// 비정상 캔들 + 감시를 함께 표기(예: "비정상 매수 | 숏 감시"). 셀 색은 캔들(비정상) 우선, 없으면 감시, 없으면 정상.
abnCandleTxt = abnCandleState == 1 ? "비정상 매도" : abnCandleState == -1 ? "비정상 매수" : ""
abnWatchTxt = abnWatch == 3 ? "롱 감시 강화" : abnWatch == 2 ? "롱 감시" : abnWatch == -3 ? "숏 감시 강화" : abnWatch == -2 ? "숏 감시" : ""
abnCellText = (abnCandleTxt != "" and abnWatchTxt != "") ? abnCandleTxt + " | " + abnWatchTxt : abnCandleTxt != "" ? abnCandleTxt : abnWatchTxt != "" ? abnWatchTxt : close > open ? "정상 매수" : close < open ? "정상 매도" : "정상"
abnCellColor = abnCandleState == 1 ? color.new(abnOversoldColor, 20) : abnCandleState == -1 ? color.new(abnOverboughtColor, 20) : abnWatch == 3 ? color.new(abnBullStrongColor, 0) : abnWatch == 2 ? color.new(abnBullBaseColor, 0) : abnWatch == -3 ? color.new(abnBearStrongColor, 0) : abnWatch == -2 ? color.new(abnBearBaseColor, 0) : color.new(color.gray, 40)

// 모멘텀 모드 래치: 비정상 캔들/반등 감시 진입(컨텍스트 시작 엣지) 시 매수·매도 양방향 모두 무장, 정상 이격도 복귀(상태 종료, abnDirSig==0) 시 해제.
var bool momentum = false
buyCtxStart = abnDirSig > 0 and (na(abnDirSig[1]) or abnDirSig[1] <= 0)
sellCtxStart = abnDirSig < 0 and (na(abnDirSig[1]) or abnDirSig[1] >= 0)
if buyCtxStart or sellCtxStart
    momentum := true
if abnDirSig == 0
    momentum := false
// 표시 신호: 모멘텀이면 한 단계 빠른 기간(0.5×→A, 1×→B, 2×→C), 아니면 정상(0.5×→B, 1×→C, 2×→D)
//  bXe/sXe = 파이프라인 소비 원시신호(혼합이면 봉별 스위칭된 소스, 아니면 일반). 게이트/확정 파이프라인은 이후 공통.
buy05 = momentum ? bAe : bBe
sell05 = momentum ? sAe : sBe
buy10 = momentum ? bBe : bCe
sell10 = momentum ? sBe : sCe
buy20 = momentum ? bCe : bDe
sell20 = momentum ? sCe : sDe
vwBuy05 = momentum ? vbA : vbB
vwSell05 = momentum ? vsA : vsB
vwBuy10 = momentum ? vbB : vbC
vwSell10 = momentum ? vsB : vsC
vwBuy20 = momentum ? vbC : vbD
vwSell20 = momentum ? vsC : vsD
// [E-1] 혼합 모드 즉시 발화용 VWMA '원시' 신호(모멘텀 시프트 적용) — vLastDir 래치 이전의 vRbEff/vRsEff(=vrbX/vrsX).
//  거래량 가중 전용 모드는 위 vwBuyXX(vbX, 내부 vLastDir 중복방지)를 쓰지만, 혼합 즉시 발화는 파이프라인 dir(dirXX)로
//  중복방지를 통일하기 위해 '원시'를 받아 아래 dir 잠금 블록에서 dirXX!=방향 게이트를 직접 건다(정상 봉 파이프라인과 단일 방향 상태 공유).
vwRawBuy05 = momentum ? vrbA : vrbB
vwRawSell05 = momentum ? vrsA : vrsB
vwRawBuy10 = momentum ? vrbB : vrbC
vwRawSell10 = momentum ? vrsB : vrsC
vwRawBuy20 = momentum ? vrbC : vrbD
vwRawSell20 = momentum ? vrsC : vrsD


// =========================
// 트리거 가격(스킵 판정 + 테이블에서 공용) — 4세트(0.25/0.5/1/2×) 계산 후 모멘텀 모드면 한 단계 빠른 기간으로 시프트.
//  신호 = (후행스팬 조건) AND (전환선 vs 기준선 게이트). 다음 봉 종가가 돌파해야 할 기준 가격.
// =========================
f_trigger(float conv, float base, int convP, int baseP, int dispP) =>
    cBull = conv > base
    cBear = conv < base
    lagOff = math.max(dispP - 1, 0)
    refIdx = math.max(lagOff - 1, 0)
    lagBaseTrig = base[refIdx]
    cPrior = math.max(convP - 1, 1)
    bPrior = math.max(baseP - 1, 1)
    rLow = ta.lowest(cPrior)
    rHigh = ta.highest(cPrior)
    bMidNext = (ta.highest(bPrior) + ta.lowest(bPrior)) / 2
    cBuyP = 2 * bMidNext - rLow
    cSellP = 2 * bMidNext - rHigh
    bTrig = cBull ? lagBaseTrig : math.max(lagBaseTrig, cBuyP)
    sTrig = cBear ? lagBaseTrig : math.min(lagBaseTrig, cSellP)
    [bTrig, sTrig]
// [C-1] VWMA 트리거 — 혼합 모드에서 abnVolume 봉이 VWMA 원시신호(vrbX/vrsX)를 쓸 때, 트리거·확정 관문도
//  같은 VWMA 소스로 정합시키기 위한 경로. VWMA 신호(f_scaleSignals의 VWMA 경로)와 동일한 vBase(=ta.vwma(close,baseP))를
//  재계산해 트리거 가격을 산출한다 → 게이트(신호)·pending·확정이 모두 같은 소스.
//   · 트리거 = vBase[refIdx](VWMA 기준선의 후행 관문가). 일반 f_trigger의 lagBaseTrig=base[refIdx]를 VWMA 선으로 치환한 것과 대칭.
//     이는 VWMA 신호의 후행스팬 조건 기준가(예측 경로 vLagRefN=vBase[refIdx])와 정확히 동일하다.
//   · VWMA 게이트 방향(vConv vs vBase)은 신호(gate) 단계에서 이미 판정되어 pending 등록 시점에 반영되므로,
//     트리거 함수는 후행스팬 관문가만 산출하면 정합에 충분하다(일반 f_trigger의 극값 폴백 cBuyP/cSellP는 VWMA에 직접
//     대응물이 없어 도입하지 않음 — 게이트가 관문에 이미 반영됨). 미래참조/리페인팅 없음(과거·현재봉 vBase만).
//  매수·매도 트리거 값이 동일(vBase[refIdx])하나, 파이프라인 대칭(buyTrig/sellTrig 별도 래치)을 위해 둘로 반환한다.
f_triggerVw(int convP, int baseP, int dispP) =>
    vBase = ta.vwma(close, baseP)
    lagOff = math.max(dispP - 1, 0)
    refIdx = math.max(lagOff - 1, 0)
    lagBaseTrig = vBase[refIdx]
    [lagBaseTrig, lagBaseTrig]
[btA, stA] = f_trigger(donC025, donB025, c025, b025, d025)
[btB, stB] = f_trigger(donC05, donB05, c05, b05, d05)
[btC, stC] = f_trigger(conversionLine, baseLine, conversionPeriods, basePeriods, displacement)
[btD, stD] = f_trigger(donC20, donB20, c20, b20, d20)
// VWMA 트리거 4세트(혼합 소스용). 매수·매도 트리거 값(래깅 관문가)은 동일하나 파이프라인 대칭을 위해 둘로 받는다.
[vbtA, vstA] = f_triggerVw(c025, b025, d025)
[vbtB, vstB] = f_triggerVw(c05, b05, d05)
[vbtC, vstC] = f_triggerVw(conversionPeriods, basePeriods, displacement)
[vbtD, vstD] = f_triggerVw(c20, b20, d20)
// 봉별 소스 스위칭 — 혼합 모드(sigHybrid)이고 이 봉이 비정상 거래량(abnVolume)이면 VWMA 트리거, 아니면 일반 트리거.
//  ⚠️ 정합 핵심: 신호 소스(bXe/sXe = abnVolume ? VWMA : 일반)와 완전히 같은 조건(sigHybrid and abnVolume)으로 스위칭 →
//   그 봉에 VWMA 신호가 났으면 트리거·확정도 VWMA 기준. 정상 봉·비혼합 모드는 일반 트리거(기존 4모드 동작 무변경).
useVwTrig = sigHybrid and abnVolume
btAe = useVwTrig ? vbtA : btA
stAe = useVwTrig ? vstA : stA
btBe = useVwTrig ? vbtB : btB
stBe = useVwTrig ? vstB : stB
btCe = useVwTrig ? vbtC : btC
stCe = useVwTrig ? vstC : stC
btDe = useVwTrig ? vbtD : btD
stDe = useVwTrig ? vstD : stD
buyTrig05 = momentum ? btAe : btBe
sellTrig05 = momentum ? stAe : stBe
buyTrig10 = momentum ? btBe : btCe
sellTrig10 = momentum ? stBe : stCe
buyTrig20 = momentum ? btCe : btDe
sellTrig20 = momentum ? stCe : stDe
// 트리거 소스 플래그(테이블 'V' 접두 표시용) — 이 봉의 각 스케일 트리거가 VWMA 소스인지. 모멘텀 시프트와 동일 매핑.
//  useVwTrig는 봉 단위(스케일 무관 동일 조건)라 스케일별 값이 같지만, 표시 스케일 시프트와 형태를 맞춰 개별 유지.
vwTrig05 = useVwTrig
vwTrig10 = useVwTrig
vwTrig20 = useVwTrig

// [이동됨] 트리거 근접 강조 임계 — 추세 확인 테이블의 '전환 행' 셀 색(둔탁 녹/적 = 전환 예측/대기)을 결정하는 f_trigBg가 참조하며,
//  '혼합 예측 모드' 발화가 신호 파이프라인(sBuyXX 계산 앞)에서 같은 근접 판정을 써야 하므로 파이프라인보다 앞으로 옮겼다(원래는 f_trigBg 정의 근처에 있었음).
nearPct = input.float(2.0, title="트리거 근접 강조 임계(%)", minval=0.1, step=0.1, group="트리거 강조")
// 전환 행 셀 색 판정 재현용 헬퍼 — 트리거 가격 p가 현재가 기준 근접 임계(nearPct) 이내인가(= f_trigBg의 hit 조건과 동일 식).
//  롱: (p-close)/close ≤ +nearPct% / 숏: (p-close)/close ≥ -nearPct%. 이 hit + '게이트(not blocked=dir!=방향)'가 곧 테이블 둔탁 녹/적 상태다.
f_trigNear(p, isBuy) =>
    pct = close != 0 ? (p - close) / close * 100 : na
    not na(p) and not na(pct) and (isBuy ? pct <= nearPct : pct >= -nearPct)

// =========================
// 시간 조정(N봉) 투영 — 트리거 셀 보조표기. "현재 종가가 유지된다고 가정할 때 몇 봉 더 지나야
//  해당 스케일의 상승/하락 전환(핵심 도치안 크로스)이 성립하는가"의 최소 k(N봉)를 추정한다.
// -------------------------------------------------------------------------
//  [투영 대상 조건] 핵심 도치안 전환선 vs 기준선 크로스만: 매수=convProj > baseProj, 매도=convProj < baseProj.
//    (트리거 가격의 래깅 성분·스케일 캐스케이드는 다봉·확률 의존이라 시간 투영이 애매 → 제외. 범위 = 핵심 conv/base 크로스.)
//  [가정] 미래 봉들의 고가·저가·종가 = 현재 종가(close)로 고정. 그러면 k봉 후 도치안 창은
//    과거 (len−k)봉의 실제 고저 + 미래 k개의 close(=단일 상수)로 구성된다.
//      hi_k = max( highest(high, len−k) , close ),  lo_k = min( lowest(low, len−k) , close )   (k<len)
//      convProj(k) = avg(hi_k[conv], lo_k[conv]),  baseProj(k) = avg(hi_k[base], lo_k[base])
//    k ≥ len 이면 창 전체가 close → conv=base=close → 크로스 불성립. 그래서 유효 horizon은 len 미만이 핵심.
//  [horizon] 각 스케일 base 기간(baseP)과 22 중 큰 값까지 탐색. 그 안에 성립 안 하면 "-"(계산 불가).
//    이미 그 방향 추세(blocked)면 트리거 셀은 "상승/하락 추세" 텍스트라 N봉을 붙이지 않는다(호출부에서 처리).
//  [미래참조/리페인팅] 전부 과거 데이터로 미래 창을 수학적으로 투영(현재 종가 상수 가정) → 미래참조 아님.
//    barstate.islast에서만 1회 계산(성능 안전). 확정봉 종가 기준이라 리페인팅 없음.
//  [성능] prefix 극값(pHi/pLo)은 스케일·방향과 무관한 순수 high/low 누적이므로, 6개 스케일 호출이
//    각자 재구축하지 않고 호출부(islast)에서 최대 need만큼 1회 구축한 공유 배열을 참조한다(6→1).
//    함수는 그 공유 배열의 앞부분(자기 need 범위)만 읽어 크로스 최소 k를 탐색 — 결과는 재구축 때와 완전 동일.
// =========================
// prefix 극값 배열 구축 헬퍼: pHi[j] = max(high[0..j]), pLo[j] = min(low[0..j]) 를 한 번 순회로 누적.
//  len = math.min(bar_index+1, maxNeed) 만큼만 만들면 각 스케일 호출의 need(≤maxNeed) 인덱스를 커버한다.
f_buildPrefixExtremes(int len, float[] pHi, float[] pLo) =>
    array.clear(pHi)
    array.clear(pLo)
    float runHi = na
    float runLo = na
    if len > 0
        for j = 0 to len - 1
            runHi := na(runHi) ? high[j] : math.max(runHi, high[j])
            runLo := na(runLo) ? low[j] : math.min(runLo, low[j])
            array.push(pHi, runHi)   // pHi[j] = max(high[0..j])  → 창 길이 (j+1)의 극값
            array.push(pLo, runLo)
// 공유 prefix 배열(pHi/pLo)을 받아 크로스 최소 k(N봉)만 탐색. prefix 값은 호출부에서 1회 구축한 것과 동일.
f_nbarsToCross(int convLen, int baseLen, bool isBuy, float[] pHi, float[] pLo) =>
    hz = math.max(baseLen, 22)
    // 과거 데이터가 (가장 긴 창 baseLen − 1)만큼 확보돼야 prefix 극값이 유효 → 부족하면 na
    need = math.max(convLen, baseLen)
    int result = na
    if bar_index >= need and not na(close)
        // k봉 후 conv 창(길이 m=convLen−k)의 극값 = pHi[m-1]/pLo[m-1] (m>0), m≤0 이면 창 전체 close.
        int found = na
        for k = 1 to hz
            int mC = convLen - k
            int mB = baseLen - k
            // 창 길이 m>0 이면 과거 m봉 극값과 close 비교, m≤0 이면 창 전체 close(=중립)
            float hiC = mC > 0 ? math.max(array.get(pHi, mC - 1), close) : close
            float loC = mC > 0 ? math.min(array.get(pLo, mC - 1), close) : close
            float hiB = mB > 0 ? math.max(array.get(pHi, mB - 1), close) : close
            float loB = mB > 0 ? math.min(array.get(pLo, mB - 1), close) : close
            float convProj = math.avg(hiC, loC)
            float baseProj = math.avg(hiB, loB)
            bool crossed = isBuy ? convProj > baseProj : convProj < baseProj
            if crossed and na(found)
                found := k
        result := found
    result

// =========================
// 스케일 캐스케이드 — 하위 스케일이 '해당 방향 추세 상태'일 때 상위 스케일이 발화한다.
//  매수 1×: 0.5×가 상승 추세(dir05==1)인 동안 1× 자기 트리거 충족 시. 매도 1×: 0.5×가 하락 추세(dir05==-1)인 동안.
//  매수 2×: 0.5×·1×가 둘 다 상승 추세(dir05==1 and dir10==1)인 동안 2× 자기 트리거 충족 시. 매도 2×: 0.5×·1× 둘 다 하락 추세.
//  → 지속 추세에서 1×가 상승 추세로 잠겨도(dir10==1) 새 0.5× 신호가 다시 뜨면 1×·2×가 정상 승격된다(구 buyStage 카운터 전제 버그 해소).
//  반대 신호가 그 스케일에 나오면 dir 부호가 뒤집혀 상위 전제가 풀린다(사다리 리셋과 동일 효과). 반대도 동일.
// =========================
// 스케일별 신호 방향(테이블 '상승/하락 추세' 표시용 + 캐스케이드 게이트 전제). 앞에서 선언(게이트는 이전 봉까지의 값=하위 추세 상태를 참조).
var int dir05 = 0
var int dir10 = 0
var int dir20 = 0
// 스킵: 상위 배수의 트리거가 이미 현재 봉에서 충족(매수=종가≥트리거, 매도=종가≤트리거)되면 원시 신호를 기다리지 않고 바로 표시.
// '하위 배수가 같은 방향 추세 상태'는 dir(전 봉까지)로 판정 — 반대 신호가 나면 dir 부호가 뒤집혀 상위 전제가 풀리므로 모멘텀/정상 무관하게 순차성 강제(중복 방지).
// [C-2 정합] skip은 buyTrig*/sellTrig*(=혼합 소스 반영된 btXe/stXe)를 참조하므로, 혼합 모드 abnVolume 봉에선 skip도 VWMA 트리거 기준으로
//  자동 정합된다(신호·gate·pending·확정·skip 전부 동일 소스). 별도 분기 불필요 — 트리거 변수를 공유하므로 정합이 구조적으로 보장됨.
buySkip10 = dir05 == 1 and close >= buyTrig10
buySkip20 = dir05 == 1 and dir10 == 1 and close >= buyTrig20
sellSkip10 = dir05 == -1 and close <= sellTrig10
sellSkip20 = dir05 == -1 and dir10 == -1 and close <= sellTrig20
// 게이트된 표시 신호 = (하위 추세 상태 전제) and (자기 트리거) and (그 스케일이 이미 같은 방향이 아님, dir!=방향).
//  전제: 1×는 0.5×가 그 방향 추세 중, 2×는 0.5×·1×가 둘 다 그 방향 추세 중. 각 스케일의 자기 트리거(buy/sell 또는 skip)는 유지.
//  같은 방향 재발화 차단(dir!=방향): 이미 그 방향이면(예: 2× 이미 상승 추세) 반대 신호가 그 스케일에 나오기 전엔 재발화 금지(중복 차단, 롱숏·전 스케일 공통).
gBuy05 = buy05 and dir05 != 1
gBuy10 = ((buy10 and dir05 == 1) or buySkip10) and dir10 != 1
gBuy20 = ((buy20 and dir05 == 1 and dir10 == 1) or buySkip20) and dir20 != 1
gSell05 = sell05 and dir05 != -1
gSell10 = ((sell10 and dir05 == -1) or sellSkip10) and dir10 != -1
gSell20 = ((sell20 and dir05 == -1 and dir10 == -1) or sellSkip20) and dir20 != -1

// =========================
// 다음 봉 확정 발화 — 게이트(gBuyXX/gSellXX)가 봉 N에서 참이면 즉시 발화하지 않고 '대기(pending)'로 래치.
//  봉 N+1(확정봉)에서 '확정 조건'이 유지되면 그 봉에서 발화(fBuyXX/fSellXX), 유지 안 되면 취소(신호 없음).
//  확정 조건 = 대기 시점의 트리거 가격을 다음 봉 종가가 유지 — 매수: close >= 대기 buyTrig, 매도: close <= 대기 sellTrig.
//   (트리거 가격은 대기 봉의 값을 래치해 다음 봉 종가와 비교 → 미래참조 없음·확정봉 종가 기준이라 리페인팅 없음. 1봉 지연은 의도된 휩쏘 필터.)
//  대기 중 반대 방향 게이트가 새로 참이 되면 그쪽으로 대기 전환(속임수 방향 전환 반영). 확정/취소 시 대기 해제.
//  발화·dir 잠금·plotshape·alert는 모두 확정봉(fBuyXX/fSellXX) 기준으로 동기화한다.
// =========================
// 대기 상태: 0=없음, 1=매수 대기, -1=매도 대기. 스케일별로 독립. 대기 시점 트리거 가격을 래치.
var int pend05 = 0
var int pend10 = 0
var int pend20 = 0
var float pendTrig05 = na
var float pendTrig10 = na
var float pendTrig20 = na
// 확정 검사: 직전 봉에서 대기였고, 이번 봉 종가가 대기 방향 트리거를 유지하면 발화.
fBuy05 = pend05[1] == 1 and not na(pendTrig05[1]) and close >= pendTrig05[1]
fSell05 = pend05[1] == -1 and not na(pendTrig05[1]) and close <= pendTrig05[1]
fBuy10 = pend10[1] == 1 and not na(pendTrig10[1]) and close >= pendTrig10[1]
fSell10 = pend10[1] == -1 and not na(pendTrig10[1]) and close <= pendTrig10[1]
fBuy20 = pend20[1] == 1 and not na(pendTrig20[1]) and close >= pendTrig20[1]
fSell20 = pend20[1] == -1 and not na(pendTrig20[1]) and close <= pendTrig20[1]

// =========================
// [E-1] 혼합 모드 비정상 거래량 봉 즉시 발화(다음봉 확정 우회) — CEO 요구: 비정상 봉이면 그 봉 기준으로 VWMA 매수/매도 신호를 즉시.
//  거래량 가중 전용 모드가 vwBuyXX(vLastDir)로 그 봉에서 바로 삼각형을 찍는 것과 동일하게, 혼합 모드의 abnVolume 봉도
//  pending→다음봉 확정 파이프라인을 '우회'하고 즉시 발화한다. 정상 봉은 아래 기존 파이프라인(fBuyXX)을 그대로 쓴다.
//  ⚠️ 중복방지 정합(핵심): 즉시 발화의 중복방지는 거래량 가중 전용 모드의 함수 내부 vLastDir이 아니라, 정상 봉 파이프라인과
//   '단일 방향 상태'(dirXX)를 공유해 건다. 그래야 정상↔비정상 봉 전환 경계에서 같은 방향 중복/누락이 구조적으로 안 생긴다.
//   - dir!=방향 게이트: 이미 그 방향이면 즉시 발화 금지(정상 봉 gBuyXX의 dir!=방향과 동일 기준).
//   - 스케일 캐스케이드 전제(하위 dir): 1×는 dir05, 2×는 dir05·dir10이 같은 방향 추세일 때만(순차성 강제·정상 봉과 동일).
//   - dir 참조는 아래 dir 갱신 '이전' 값(=직전 봉까지) — 정상 봉 게이트와 동일한 기준봉이라 한 봉에 여러 스케일 동시 발화 안 됨.
//  트리거/pending 관문은 걸지 않는다(즉시 발화 취지 = 그 봉에서 바로). 원시 VWMA 신호(vwRawBuyXX, 모멘텀 시프트 반영)만 요구.
hybImm = sigHybrid and abnVolume   // 이 봉이 혼합 모드 + 비정상 거래량 → 즉시 발화 대상(pending 파이프라인 우회)
iBuy05 = hybImm and vwRawBuy05 and dir05 != 1
iSell05 = hybImm and vwRawSell05 and dir05 != -1
iBuy10 = hybImm and vwRawBuy10 and dir05 == 1 and dir10 != 1
iSell10 = hybImm and vwRawSell10 and dir05 == -1 and dir10 != -1
iBuy20 = hybImm and vwRawBuy20 and dir05 == 1 and dir10 == 1 and dir20 != 1
iSell20 = hybImm and vwRawSell20 and dir05 == -1 and dir10 == -1 and dir20 != -1

// =========================
// [E-2] 혼합 예측 모드 — 전환 행 색 예측 발화(후보 A). CEO 확정 사양: 추세 확인 테이블의 '상승/하락 전환(스케일)' 행 셀 색이
//  둔탁 녹(#6E8F72)/둔탁 빨강(#A57A7A) = '전환 예측/대기' 상태이고 진행봉 방향이 일치하면 그 스케일 신호를 그 봉에서 즉시 발화한다.
//  ⚠️⚠️ 리페인팅 계열: 전환 행 셀 색은 진행봉(형성 중 현재봉)의 종가(close) 기준 근접(f_trigNear)으로 실시간 재계산되고, 진행봉 방향(close>open)도
//   봉 완성 전까지 바뀐다. 따라서 발화 신호가 봉 마감 전에 나타났다 사라질 수 있다(다음봉 확정 필터 우회). '혼합 확정 모드'에선 hybPredict=false라 비활성.
//   전략 백테스트도 이 경로가 켜지면 크게 변한다(수학자 리뷰·본부 확인 대상).
//  ★ 발화 기준 = '전환 행 셀 색'이다(CEO 최종 확정 사양). 테이블 셀 색은 f_trigBg(blocked, trig, isBuy)가 결정하며,
//   둔탁 녹/적 조건 = (not blocked = dir!=방향) and f_trigNear(trig, isBuy). ★★ CEO 명시: '보이는 둔적/둔녹이면 방향 맞는 캔들일 때 무조건 발화'.
//   → 원시 도치안 신호(buyXX/sellXX) 요구를 제거한다. 발화 = '테이블 셀이 둔적/둔녹으로 렌더되는 그 불리언 자체' + 방향 캔들. (부분집합 아님·정확히 동일 집합)
//   - not blocked(dir!=방향): 테이블 셀 색 f_trigBg가 넘기는 buyBlocked05=dir05==1 / sellBlocked05=dir05==-1 과 '동일 dir 값(갱신 이전=직전 봉까지)' 기준.
//     여기서도 같은 dir을 갱신 '이전'에 참조하므로(dir05/10/20은 아래 851+ 에서 갱신) 눈에 보이는 셀 색과 발화가 동일 기준봉·동일 불리언.
//   - 근접 hit = f_trigNear(스케일 트리거, 방향) — 테이블 f_trigBg가 쓰는 것과 동일 함수·동일 트리거 변수 → 눈에 보이는 셀 색과 발화 100% 일치.
//   - ⚠️ 캐스케이드 전제(1×=dir05, 2×=dir05·dir10)는 '테이블 셀 색 조건'에는 없다(f_trigBg는 not blocked + 근접만 봄). CEO 사양 = '셀 색 그대로'
//     이므로 여기 발화도 캐스케이드를 걸지 않는다(셀 색에 내재된 것만 활용 = 없음). 이전엔 gBuyXX/gSellXX가 캐스케이드+원시신호를 함께 걸었으나 둘 다 제거.
//   - 중복 발화 차단·dir 정합: not blocked(dir!=방향)이 같은 방향 재발화를 막고(테이블 둔적/둔녹도 이미 그 방향 추세면 '선명색'이라 미해당),
//     아래 pending 억제(not pBuyXX/not pSellXX)로 같은 봉 확정 이중 발화도 차단. hybImm(비정상봉 즉시)과는 dir 게이트 공유로 병존 안전.
//  스케일 매핑: 0.5×→전환(0.5×) 행(buyTrig05/sellTrig05), 1×→(1×) 행(buyTrig10/sellTrig10), 2×→(2×) 행(buyTrig20/sellTrig20). 롱숏 대칭.
hybPredict = sigHybrid and str.contains(signalMode, "예측")   // 혼합 예측 모드일 때만 전환 행 색 예측 발화 활성('혼합 확정'은 "예측" 미포함 → false)
predBull = close > open   // 진행봉 양봉(캔들방향 상승) — 롱 발화 조건
predBear = close < open   // 진행봉 음봉(캔들방향 하락) — 숏 발화 조건
// 각 스케일 상승/하락 전환 행이 둔탁 녹/적('전환 예측/대기')인가 = 근접 hit(f_trigNear). blocked(dir!=방향) 부분은 아래 pXxx 식에서 dir!=방향으로 직접 결합.
predUpNear05 = f_trigNear(buyTrig05, true)     // 상승 전환(0.5×) 행이 둔탁 녹으로 칠해지는 근접 상태
predUpNear10 = f_trigNear(buyTrig10, true)     // 상승 전환(1×)
predUpNear20 = f_trigNear(buyTrig20, true)     // 상승 전환(2×)
predDnNear05 = f_trigNear(sellTrig05, false)   // 하락 전환(0.5×) 행이 둔탁 빨강으로 칠해지는 근접 상태
predDnNear10 = f_trigNear(sellTrig10, false)   // 하락 전환(1×)
predDnNear20 = f_trigNear(sellTrig20, false)   // 하락 전환(2×)
// 발화 = 테이블 셀 둔적/둔녹 조건(= dir!=방향 and 근접 hit) + 방향 캔들. 원시신호(buyXX/sellXX) 요구 제거(CEO 최종 확정).
//  dir!=방향 = not blocked (테이블 f_trigBg에 넘기는 buyBlockedXX/sellBlockedXX와 동일 정의). 캐스케이드·원시신호는 걸지 않는다.
pBuy05 = hybPredict and predUpNear05 and predBull and dir05 != 1
pSell05 = hybPredict and predDnNear05 and predBear and dir05 != -1
pBuy10 = hybPredict and predUpNear10 and predBull and dir10 != 1
pSell10 = hybPredict and predDnNear10 and predBear and dir10 != -1
pBuy20 = hybPredict and predUpNear20 and predBull and dir20 != 1
pSell20 = hybPredict and predDnNear20 and predBear and dir20 != -1

// 대기 갱신 — 새 게이트가 이번 봉에 참이면 대기 등록/전환(대기 봉의 트리거 가격 래치). 매수·매도 상호배타.
//  게이트가 없으면 대기 해제(직전 대기는 확정 검사에 이미 [1]로 쓰였으므로 이번 봉엔 소멸 = 미확정 취소).
//  중복 발화 차단: 게이트(gBuyXX)는 dir 갱신 '이전'의 dir(=직전 봉 값)을 참조하므로, 이번 봉에서 확정 발화(fBuyXX)가
//   나는 봉에도 같은 방향 게이트가 다시 참이 되어 대기가 재등록된다. 그러면 다음 봉에서 재확정되어 확정봉+다음봉 2개 삼각형이 찍힌다.
//   → 이번 봉에 확정 발화가 난 방향은 같은 봉에서 재대기 금지(확정봉 단일 발화 보장). 반대 방향 등록/취소는 그대로 유지.
//  [E-1] 혼합 모드 비정상 봉(hybImm)은 즉시 발화 경로를 타므로 pending 등록을 '억제'한다(not hybImm). 그러면 그 봉엔 즉시 발화만
//   나고 pending은 0이 되어 정상 봉에서 진행 중이던 대기는 취소된다(비정상 봉의 즉시 신호가 그 이벤트를 대체 — 이중 발화 방지).
//  [E-2] 혼합 예측 모드의 전환 행 색 예측 발화(pBuyXX)가 난 봉도 즉시 발화 경로이므로 같은 스케일 pending 등록을 억제(not pBuyXX)한다.
//   그래야 그 봉의 전환 행 색 예측 즉시 발화 + 다음봉 확정(fBuyXX)의 이중 발화가 방지된다(hybImm과 동일 취지·스케일별 억제).
regBuy05 = gBuy05 and not fBuy05 and not hybImm and not pBuy05
regSell05 = gSell05 and not fSell05 and not hybImm and not pSell05
regBuy10 = gBuy10 and not fBuy10 and not hybImm and not pBuy10
regSell10 = gSell10 and not fSell10 and not hybImm and not pSell10
regBuy20 = gBuy20 and not fBuy20 and not hybImm and not pBuy20
regSell20 = gSell20 and not fSell20 and not hybImm and not pSell20
pend05 := regBuy05 ? 1 : regSell05 ? -1 : 0
pend10 := regBuy10 ? 1 : regSell10 ? -1 : 0
pend20 := regBuy20 ? 1 : regSell20 ? -1 : 0
pendTrig05 := regBuy05 ? buyTrig05 : regSell05 ? sellTrig05 : na
pendTrig10 := regBuy10 ? buyTrig10 : regSell10 ? sellTrig10 : na
pendTrig20 := regBuy20 ? buyTrig20 : regSell20 ? sellTrig20 : na

// [E-1] 최종 발화 신호 = 혼합 모드 비정상 봉(hybImm)이면 즉시 발화(iBuyXX/iSellXX), 아니면 기존 파이프라인 확정 발화(fBuyXX/fSellXX).
//  비정상 봉에선 fBuyXX(직전 정상 pending의 확정)를 무시하고 즉시 신호만 쓴다 — 이중 발화 방지, "비정상 봉만 즉시"라는 CEO 취지 준수.
//  정상 봉·비혼합 모드(거래량 가중 전용/일반)는 hybImm=false라 sBuyXX=fBuyXX로 기존 동작 완전 무변경.
//  차트 삼각형·테이블 추세(dirXX)·알림이 모두 이 sBuyXX/sSellXX 단일 소스를 참조 → 차트-테이블 정합.
// [E-2] 혼합 예측 발화(pBuyXX)는 위 두 경로에 '병존'한다 — 전환 행 색 예측 발화가 참이면 그 봉에서 즉시 발화(true), 아니면 기존 결합(hybImm ? 즉시 : 확정).
//  즉 비정상봉 즉시발화(hybImm/iBuyXX)는 그대로 살아 있고, 혼합 예측의 전환 행 색 예측 발화가 추가로 그 봉을 발화시킨다(둘 다 dirXX 게이트 공유 → 중복 안전).
//  '혼합 확정'·비혼합·정상봉은 pBuyXX=false라 종전 sBuyXX=hybImm?iBuyXX:fBuyXX로 완전 무변경.
sBuy05 = pBuy05 ? true : (hybImm ? iBuy05 : fBuy05)
sSell05 = pSell05 ? true : (hybImm ? iSell05 : fSell05)
sBuy10 = pBuy10 ? true : (hybImm ? iBuy10 : fBuy10)
sSell10 = pSell10 ? true : (hybImm ? iSell10 : fSell10)
sBuy20 = pBuy20 ? true : (hybImm ? iBuy20 : fBuy20)
sSell20 = pSell20 ? true : (hybImm ? iSell20 : fSell20)

// dir 갱신(실제 발화 신호 기준 — 차트 삼각형과 테이블 '상승/하락 추세' 동기화). 최종 발화(sBuyXX/sSellXX)에서 잠근다.
//  정상 봉은 확정봉(fBuyXX) 기준, 혼합 비정상 봉은 즉시 발화(iBuyXX) 기준 — 둘 다 단일 dirXX를 공유해 경계 정합.
//  위 게이트(gBuyXX)·즉시 게이트(iBuyXX)는 이 갱신 전(=직전 값) dir을 참조하므로, 하위 dir은 하위가 발화된 뒤에야 1/-1이 되어 상위가 발화/등록된다(봉 순서 정상).
// 반대 방향 발화가 나면 그 스케일 dir 부호가 뒤집혀 상위 스케일의 전제가 자연히 풀린다(구 사다리 리셋 대체).
if sBuy05
    dir05 := 1
else if sSell05
    dir05 := -1
if sBuy10
    dir10 := 1
else if sSell10
    dir10 := -1
if sBuy20
    dir20 := 1
else if sSell20
    dir20 := -1
buyBlocked05 = dir05 == 1
sellBlocked05 = dir05 == -1
buyBlocked10 = dir10 == 1
sellBlocked10 = dir10 == -1
buyBlocked20 = dir20 == 1
sellBlocked20 = dir20 == -1

cloudOffset = displacement - 1
fillSourceA = plot(leadingSpanA, offset=cloudOffset, title="Cloud Fill Source A", color=color.new(leadingSpanAColor, 100), display=display.none)
fillSourceB = plot(leadingSpanB, offset=cloudOffset, title="Cloud Fill Source B", color=color.new(leadingSpanBColor, 100), display=display.none)

plot(showConversionLine ? conversionLine : na, title="Conversion Line", color=conversionLineColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showBaseLine ? baseLine : na, title="Base Line", color=baseLineColor, linewidth=2, display=display.all)
plot(showLaggingSpan ? close : na, offset=-cloudOffset, title="Lagging Span", color=laggingSpanColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showLeadingSpanA ? leadingSpanA : na, offset=cloudOffset, title="Leading Span A", color=leadingSpanAColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showLeadingSpanB ? leadingSpanB : na, offset=cloudOffset, title="Leading Span B", color=leadingSpanBColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showKumoUpper ? kumoUpper : na, offset=cloudOffset, title="Kumo Cloud Upper Line", color=kumoBoundaryColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showKumoLower ? kumoLower : na, offset=cloudOffset, title="Kumo Cloud Lower Line", color=kumoBoundaryColor, linewidth=lineWidth, display=display.all - display.price_scale)
fill(fillSourceA, fillSourceB, title="Cloud Fill", color=showCloudFill ? (leadingSpanA > leadingSpanB ? bullishCloudColor : bearishCloudColor) : na)

// =========================
// 장기 추세 — 이평선 리본 통합(MA 100/200 선 + backfill만)
// =========================
// MA 종류 4종(기본 거래량 가중 VWMA). MA100=파랑·MA200=보라. backfill: 우상향(MA100>MA200)=파랑, 우하향=보라(투명도 40).
showLongTrend = input.bool(true, title="장기 추세 표시", group="장기 추세")
ltMaType = input.string("VWMA", title="장기 추세 MA 종류", options=["SMA", "EMA", "WMA", "VWMA"], group="장기 추세")
ltLen1 = input.int(100, minval=1, title="장기 추세 MA #1 길이", group="장기 추세")
ltLen2 = input.int(200, minval=1, title="장기 추세 MA #2 길이", group="장기 추세")
ltColor1 = input.color(color.blue, title="MA #1(100) 색", group="장기 추세")
ltColor2 = input.color(color.purple, title="MA #2(200) 색", group="장기 추세")
ltFillTransp = input.int(60, minval=0, maxval=100, title="장기 추세 backfill 투명도", group="장기 추세")
f_ltMa(length) =>
    switch ltMaType
        "SMA" => ta.sma(close, length)
        "EMA" => ta.ema(close, length)
        "WMA" => ta.wma(close, length)
        "VWMA" => ta.vwma(close, length)
ltMa1 = f_ltMa(ltLen1)
ltMa2 = f_ltMa(ltLen2)
ltUp = ltMa1 > ltMa2   // 우상향 장기 추세(단기 MA > 장기 MA)
ltPlot1 = plot(showLongTrend ? ltMa1 : na, title="장기추세 MA #1(100)", color=ltColor1, linewidth=lineWidth, display=display.all - display.price_scale)
ltPlot2 = plot(showLongTrend ? ltMa2 : na, title="장기추세 MA #2(200)", color=ltColor2, linewidth=lineWidth, display=display.all - display.price_scale)
fill(ltPlot1, ltPlot2, title="장기추세 backfill", color=showLongTrend ? (ltUp ? color.new(ltColor1, ltFillTransp) : color.new(ltColor2, ltFillTransp)) : na)

// 장기 추세 강도/크로스 판정(테이블용) — 상태 8종: 골든/데드 크로스, 상승/강한 상승/약한 상승, 하락/강한 하락/약한 하락.
//  두께(MA100·200 간격) 확대=강한, 축소=약한, 그 사이(평탄대)=상승/하락. 반대 크로스 임박(간격 좁음)이면 약한 고정.
ltTrendLook = input.int(5, minval=1, title="장기 추세 폭 변화 판정 봉수", group="장기 추세")
ltFlatTol = input.float(0.25, minval=0.0, step=0.05, title="평탄 판정 ATR 배수(강↔약 사이 '상승/하락')", group="장기 추세")
ltCrossWarnPct = input.float(4.0, minval=0.05, step=0.05, title="크로스 주의 간격(%, 클수록 빨리)", group="장기 추세")
ltAtr = ta.atr(14)
ltGap = math.abs(ltMa1 - ltMa2)
ltGapPct = close != 0 ? ltGap / close * 100 : na
ltDeadCross = ta.crossunder(ltMa1, ltMa2)   // MA100이 MA200 하향 돌파 = 상승→하락
ltGoldCross = ta.crossover(ltMa1, ltMa2)     // MA100이 MA200 상향 돌파 = 하락→상승
// 확립 = 크로스 후 ltTrendLook 봉 경과(봉 기준). 그 전(빌드업)은 폭변화 룩백이 크로스를 가로질러 왜곡되므로 강/약 안 함.
ltBarsSince = ta.barssince(ltGoldCross or ltDeadCross)
ltFresh = na(ltBarsSince) or ltBarsSince < ltTrendLook
ltEstablished = not ltFresh
ltGapChg = (ltEstablished and not na(ltGap[ltTrendLook])) ? ltGap - ltGap[ltTrendLook] : na   // 폭 변화(양=확대, 음=축소)
ltDeadBand = not na(ltAtr) ? ltAtr * ltFlatTol : 0.0
ltWidening = not na(ltGapChg) and ltGapChg > ltDeadBand    // 확대 = 강함
ltNarrowing = not na(ltGapChg) and ltGapChg < -ltDeadBand  // 축소 = 약함
// 반대 크로스 임박 = 확립 후 + 간격이 좁고(≤주의%) 확대 중이 아님 → '약한'으로 고정(크로스 직전 블립 방지).
ltNearCross = ltEstablished and not na(ltGapPct) and ltGapPct <= ltCrossWarnPct and not ltWidening
// 상태 세그먼트: 크로스 → (빌드업/평탄) 상승·하락 → 확대=강한 → 축소·임박=약한 → 반대 크로스
ltDir = ltUp ? "상승" : "하락"
ltStateBase = not ltEstablished ? ltDir : ltNearCross ? (ltUp ? "약한 상승" : "약한 하락") : ltWidening ? (ltUp ? "강한 상승" : "강한 하락") : ltNarrowing ? (ltUp ? "약한 상승" : "약한 하락") : ltDir
// 마지막 크로스(골든/데드) 이후 변화율(%)과 경과 봉수 — 골든 후 상승%·데드 후 하락%, 몇 봉 지났는지.
// 크로스 시점의 MA100 값을 기준으로 이후 MA100이 몇 % 올랐/내렸는지(골든=상승%·데드=하락%).
var float ltCrossMa1 = na
if ltGoldCross or ltDeadCross
    ltCrossMa1 := ltMa1
ltMovePct = not na(ltCrossMa1) and ltCrossMa1 != 0 ? (ltMa1 / ltCrossMa1 - 1) * 100 : na
ltInfoTxt = (na(ltMovePct) or na(ltBarsSince)) ? "" : " (" + (ltMovePct >= 0 ? "+" : "") + str.tostring(ltMovePct, "0.0") + "% | " + str.tostring(ltBarsSince) + "봉)"
ltCellText = ltDeadCross ? "데드 크로스" : ltGoldCross ? "골든 크로스" : ltStateBase + ltInfoTxt
// 색: 방향 계열로 통일 — 상승계열(ltUp)=파랑+녹 혼합 청록(teal), 하락계열=보라+빨강 혼합 자홍(crimson).
//  자홍은 리본 횡보수축의 순수 보라(color.purple)와 색상환상 확실히 구분되게 빨강기를 섞었다.
//  골든/데드 크로스 순간=선명(0). 그 외 강함(확대)=선명(0)·약함(축소)=옅음(55)·추세=중간(30)으로 강약 그라데이션 유지.
ltUpColor = #0E9C8A   // 상승계열 = 파랑기+녹색기 혼합 청록(teal)
ltDownColor = #C2185B // 하락계열 = 보라기+빨강기 혼합 자홍(crimson) — 리본 순수 보라와 구분
ltCellTransp = not ltEstablished ? 30 : (ltNearCross or ltNarrowing) ? 55 : ltWidening ? 0 : 30
ltCellColor = ltGoldCross ? color.new(ltUpColor, 0) : ltDeadCross ? color.new(ltDownColor, 0) : ltUp ? color.new(ltUpColor, ltCellTransp) : color.new(ltDownColor, ltCellTransp)

// 장기 지지/저항 — 각 장기선(MA100·MA200) 대비 현재가 이격도를 표기. 글자는 흰색, 셀 배경색으로 지지/저항 상태 구분.
//  200선(장기) 기준 지지=파랑·저항=빨강, 100선이 일치하면 선명·엇갈리면 둔탁.
//  둘 다 지지=파랑 / 둘 다 저항=빨강 / 100저항·200지지=둔탁 파랑 / 100지지·200저항=둔탁 빨강.
// ★ 셀 색 판정용 상태(ltM1St/ltM2St)는 무변경 — 몸통(min/max(open,close))이 선을 완전히 이탈한 경우만 지지(+1)/저항(-1), 걸치면 중립(0).
//   텍스트만 지지/저항 단어 대신 이격도 값으로 표기: 이격도 = 종가 ÷ 해당선 × 100(기준 100). 100 초과=현재가가 그 선 위(지지 성격)·미만=아래(저항 성격). 소수점 1자리.
//   ⚠️ 별도 '이격도 (N)' 행(disparity, 기본 MA20)과 무관 — 여기는 장기선(ltMa1=100·ltMa2=200) 기준. 장기추세 소스(ltMa1/ltMa2)를 그대로 재사용(새 MA 생성 없음).
ltBodyHi = math.max(open, close)
ltBodyLo = math.min(open, close)
ltM1St = na(ltMa1) ? 0 : (ltBodyLo > ltMa1 ? 1 : ltBodyHi < ltMa1 ? -1 : 0)
ltM2St = na(ltMa2) ? 0 : (ltBodyLo > ltMa2 ? 1 : ltBodyHi < ltMa2 ? -1 : 0)
ltM1Disp = (na(ltMa1) or ltMa1 == 0) ? na : close / ltMa1 * 100   // 100선 이격도(=종가÷MA100×100)
ltM2Disp = (na(ltMa2) or ltMa2 == 0) ? na : close / ltMa2 * 100   // 200선 이격도(=종가÷MA200×100)
ltSrText = (na(ltM1Disp) or na(ltM2Disp)) ? "-" : "100선 (" + str.tostring(ltM1Disp, "0") + ") | 200선 (" + str.tostring(ltM2Disp, "0") + ")"
// 색: 200선 기준 지지=파랑·저항=빨강·중립=회색, 100선 일치=선명·엇갈림=둔탁. (지지/저항 판정 ltM1St/ltM2St 기반 — 텍스트를 이격도로 바꿔도 색 규칙 무변경)
ltSrColor = (na(ltMa1) or na(ltMa2)) ? color.new(color.gray, 40) : ltM2St == 1 ? (ltM1St == 1 ? color.new(#2979FF, 0) : color.new(#6E7E9F, 0)) : ltM2St == -1 ? (ltM1St == -1 ? color.new(color.red, 30) : color.new(#A57A7A, 0)) : color.new(color.gray, 40)

// 신호 삼각형은 리본 압축/분출 다이아몬드보다 **뒤(코드상 나중)** 에 그려 삼각형이 위 레이어에 오도록
// 파일 하단(다이아몬드 plotshape 다음)에서 그린다.

// 알림도 최종 발화(sBuy10/sSell10) 기준 — 정상 봉은 다음 봉 확정 시(1봉 지연), 혼합 비정상 봉은 그 봉 즉시.
alertcondition(sBuy10, title="Advanced Ichimoku Buy Signal", message="Advanced Ichimoku buy signal")
alertcondition(sSell10, title="Advanced Ichimoku Sell Signal", message="Advanced Ichimoku sell signal")

// =========================
// 이평 수축/확장 판정 (휩쏘 필터 + 분출 확인) — A / B / A and B 모드
// =========================
// A(이평 리본): 입력값 기반 리본(전환선~리딩B 길이)의 폭이 ATR 대비 좁으면 수축, 다시 벌어지는 첫 봉에 빠른선 vs 느린선 방향으로 확장.
// B(구름 두께): 선행스팬 A·B 간격(구름 두께)이 ATR 대비 좁으면 수축, 벌어지는 첫 봉에 구름 색(양운/음운) 방향으로 확장.
// A and B(기본): 두 기준이 모두 수축/확장(방향 일치)할 때만. 압축 → 분출 → 압축 … 순서.
// [옵션 패널 재배치] 리본 추세 input 선언은 상단(멀티스케일 신호 앞, 섹션1 추세)으로 이동했다. 아래는 그 input을 쓰는 계산 로직(원위치 유지).
ribbonMa(length) =>
    switch ribbonMaType
        "SMA" => ta.sma(close, length)
        "EMA" => ta.ema(close, length)
        "WMA" => ta.wma(close, length)
        "VWMA" => ta.vwma(close, length)

rAtr = ta.atr(ribbonAtrLength)

// A 모드: 이치모쿠 입력값(전환선~리딩B)에 맞춘 7개 이평 리본
aStep = (leadingSpanBPeriods - conversionPeriods) / 6.0
aMaFast = ribbonMa(math.max(1, conversionPeriods))
aMa1 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep))))
aMa2 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 2))))
aMa3 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 3))))
aMa4 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 4))))
aMa5 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 5))))
aMaSlow = ribbonMa(math.max(1, leadingSpanBPeriods))
aTop = math.max(aMaFast, math.max(aMa1, math.max(aMa2, math.max(aMa3, math.max(aMa4, math.max(aMa5, aMaSlow))))))
aBottom = math.min(aMaFast, math.min(aMa1, math.min(aMa2, math.min(aMa3, math.min(aMa4, math.min(aMa5, aMaSlow))))))
aHeight = math.max(aTop - aBottom, syminfo.mintick)
aCompressed = aHeight < rAtr * ribbonCompressAtrMult
aExpanding = aHeight > aHeight[ribbonExpandBars]
aBull = aMaFast >= aMaSlow

// B 모드: 구름 두께(선행스팬 A vs B)
bWidth = math.max(kumoUpper - kumoLower, syminfo.mintick)
bCompressed = bWidth < rAtr * ribbonCompressAtrMult
bExpanding = bWidth > bWidth[ribbonExpandBars]
bBull = leadingSpanA >= leadingSpanB

// 모드별 수축/확장/방향 결합
isAMode = ribbonMode == "이평 리본"
isBMode = ribbonMode == "구름 두께"
compNow = isAMode ? aCompressed : isBMode ? bCompressed : (aCompressed and bCompressed)
expNow = isAMode ? aExpanding : isBMode ? bExpanding : (aExpanding and bExpanding)
bullNow = isAMode ? aBull : isBMode ? bBull : (aBull and bBull)
bearNow = isAMode ? not aBull : isBMode ? not bBull : (not aBull and not bBull)
rHeight = isBMode ? bWidth : aHeight   // 테이블 폭/ATR 표시용

rConfirmed = not ribbonConfirmOnClose or barstate.isconfirmed
rChopEnter = compNow and not compNow[1]

// 수축 진입 시 무장 → 확장 첫 봉에 방향 확정. 또한 직전 분출과 **반대 방향** 확장이면 압축 없이 바로 반전 분출.
var bool rArmed = false
var int rLastExpDir = 0   // 직전 분출 방향(1=상승, -1=하락, 0=없음)
var string ribbonState = "대기"
var float ribbonEventClose = na   // 마지막 이벤트(압축/분출) 발생 봉의 종가 — 이후 가격 변화% 기준
var int ribbonEventBar = na       // 마지막 이벤트 발생 봉 인덱스 — 몇 봉째인지 표시용
bool rBullExpansion = false
bool rBearExpansion = false
if rConfirmed
    if rChopEnter
        rArmed := true
        ribbonState := "횡보"
        ribbonEventClose := close
        ribbonEventBar := bar_index
    else if expNow and (bullNow or bearNow)
        expDir = bullNow ? 1 : -1
        // 발화 조건: 압축 후 무장(rArmed) 또는 직전 분출과 반대 방향(압축 없이 직접 반전)
        if rArmed or (rLastExpDir != 0 and expDir != rLastExpDir)
            rBullExpansion := bullNow
            rBearExpansion := bearNow
            ribbonState := bullNow ? "상승" : "하락"
            rArmed := false
            rLastExpDir := expDir
            ribbonEventClose := close
            ribbonEventBar := bar_index

ribbonChop = showChopWarn and rConfirmed and rChopEnter
ribbonBull = showExpansion and rBullExpansion
ribbonBear = showExpansion and rBearExpansion

// 현재 봉 아래 구름(displacement 밀림 → cloudOffset 과거 선행스팬으로 평가).
curSpanA = leadingSpanA[cloudOffset]
curSpanB = leadingSpanB[cloudOffset]
cloudTop = math.max(curSpanA, curSpanB)
cloudBottom = math.min(curSpanA, curSpanB)
cloudPosText = close > cloudTop ? "위" : close < cloudBottom ? "아래" : "안"
cloudColorText = curSpanA >= curSpanB ? "양운" : "음운"
// =========================
// 구름대 지지/저항 — 이치모쿠 표준 S/R 기하(가격의 구름 대비 위치가 1차, 접근 방향이 확인).
//  지지: 가격이 구름 **위쪽**에서 하락 레그로 되돌아 내려와 구름이 하방을 받치는 상황 → "지지".
//  저항: 가격이 구름 **아래쪽**에서 상승 레그로 올라와 구름이 상방을 막는 상황 → "저항".
//  (위치=1차 판정: 구름 위=지지 후보·구름 아래=저항 후보. 접근 방향(레그)=확인: 구름을 향해 접근할 때만 S/R로 인정.)
//  강도 = 구름 두께(ATR 대비) 클수록 ↑, 접근 각도(ATR/봉) 가파를수록 ↓(모멘텀이 뚫기 쉬움).
// 러닝 지그재그(지연 없음): 현재 레그 극값에서 ATR 배수만큼 되돌리면 즉시 반전.
//  피벗 확정(길이만큼 지연)을 안 기다리므로, 전고점서 꺾여 내려오는 즉시 하락 레그로 인식된다.
// =========================
srRevMult = input.float(1.5, minval=0.1, step=0.1, title="구름 지그재그 반전 감도(ATR 배수, 베이스 라인 유사)", group="구름 지지/저항")
// 구름 경계 ±이 배수×ATR 이내에서만 지지/저항 인정(멀리서 오탐 방지). 초기 2.0 잠정.
srProxMult = input.float(2.0, minval=0.1, step=0.1, title="구름 S/R 근접 배수(ATR)", group="구름 지지/저항")
srRev = rAtr * srRevMult
var int srDir = 0          // 1=상승 레그(저점서 상승 중), -1=하락 레그(고점서 꺾여 하락 중)
var float srExtreme = na   // 현재 레그 진행 극값(상승=고점, 하락=저점)
var int srExtremeBar = na
var float srAnchor = na    // 직전 레그가 꺾인 지점(지지=전고점, 저항=전저점)
var int srAnchorBar = na
if srDir == 0
    srDir := close >= open ? 1 : -1
    srExtreme := close
    srExtremeBar := bar_index
if srDir == 1
    if high > srExtreme
        srExtreme := high
        srExtremeBar := bar_index
    else if srExtreme - low >= srRev   // 고점서 반전 감도만큼 하락 → 하락 레그로 전환
        srDir := -1
        srAnchor := srExtreme
        srAnchorBar := srExtremeBar
        srExtreme := low
        srExtremeBar := bar_index
else
    if low < srExtreme
        srExtreme := low
        srExtremeBar := bar_index
    else if high - srExtreme >= srRev  // 저점서 반전 감도만큼 상승 → 상승 레그로 전환
        srDir := 1
        srAnchor := srExtreme
        srAnchorBar := srExtremeBar
        srExtreme := high
        srExtremeBar := bar_index
inCloud = close <= cloudTop and close >= cloudBottom
cloudThickAtr = rAtr != 0 ? (cloudTop - cloudBottom) / rAtr : na
// srSlopeAtr: 현재 종가가 앵커(직전 레그 반전점)에서 ATR 몇 배 벗어났나 — 무차원. 레그 이동폭의 ATR 배수.
//  (구식 /srLegBars/rAtr 은 단위 1/봉 → 차원 불일치였다. srLegBars 정규화 제거·무차원화.)
srSlopeAtr = (not na(srAnchor) and rAtr != 0) ? math.abs(close - srAnchor) / rAtr : na
// srScore = 무차원 두께 / (1 + 무차원 이동폭 × 계수) → 무차원/무차원 = 무차원(차원 일관).
//  두께↑=강, 이동폭↑(가파른 접근=모멘텀 강)=약. 계수 0.5는 새 정의 기준 잠정(미검증).
srScore = (not na(cloudThickAtr) and not na(srSlopeAtr)) ? cloudThickAtr / (1 + srSlopeAtr * 0.5) : na
// 위치(1차) + 접근 방향(확인). 지지 = 구름 위 + 하락 레그(위에서 되돌아 내려와 접근). 저항 = 구름 아래 + 상승 레그(아래서 올라와 접근).
priceAboveCloud = not na(cloudTop) and close > cloudTop
priceBelowCloud = not na(cloudBottom) and close < cloudBottom
// 근접 게이팅(CEO "만나면" 의도): 구름 경계에서 srProxMult×ATR 이내로 접근했을 때만 S/R 인정. 멀리서 오탐 방지.
nearSupport = priceAboveCloud and rAtr != 0 and (close - cloudTop) <= srProxMult * rAtr
nearResist  = priceBelowCloud and rAtr != 0 and (cloudBottom - close) <= srProxMult * rAtr
isSupport = nearSupport and srDir == -1   // 구름 위 + 근접 + 하락 레그로 되돌아 내려옴 → 구름이 하방 지지
isResist  = nearResist  and srDir == 1    // 구름 아래 + 근접 + 상승 레그로 올라옴 → 구름이 상방 저항
// 강도 3단계(지지/저항 대칭): srScore(두께/각도) 기준. 강함 ≥0.8 / 보통 ≥0.4 / 약함 <0.4(또는 na).
f_srLabel(pfx) => na(srScore) ? pfx : srScore >= 0.8 ? pfx + " 강함" : srScore >= 0.4 ? pfx + " 보통" : pfx + " 약함"
// 셀 색(지지=녹 / 저항=빨강, 강도 그라데이션. 대칭). 강함=선명·보통=중간·약함=둔탁.
supportWeakColor = #6E8F72   // 지지 약함 = 둔탁 녹
supportMidColor  = #3E9142   // 지지 보통 = 중간 녹
resistWeakColor  = #A57A7A   // 저항 약함 = 둔탁 빨강
resistMidColor   = #B14A4A   // 저항 보통 = 중간 빨강
f_srColor(bool support) =>
    na(srScore) ? color.new(color.gray, 40) : srScore >= 0.8 ? (support ? color.new(color.green, 0) : color.new(color.red, 0)) : srScore >= 0.4 ? (support ? color.new(supportMidColor, 0) : color.new(resistMidColor, 0)) : (support ? color.new(supportWeakColor, 0) : color.new(resistWeakColor, 0))
// 양운/음운 접두(cloudColorText: leadingSpanA vs B) — 예 "양운 지지 강함", "음운 저항 약함".
cloudCellText = isSupport ? cloudColorText + " " + f_srLabel("지지") : isResist ? cloudColorText + " " + f_srLabel("저항") : cloudPosText + "·" + cloudColorText
// 맥락(능동 S/R 아닐 때) 색: 위치×구름색 방향색. 위+양운=선명 녹, 위+음운=흐린 녹(약강세), 아래+음운=선명 빨, 아래+양운=흐린 빨(약약세), 구름 안=회색.
cloudContextColor = priceAboveCloud ? (cloudColorText == "양운" ? color.new(color.green, 0) : color.new(#6E8F72, 55)) : priceBelowCloud ? (cloudColorText == "음운" ? color.new(color.red, 0) : color.new(#A57A7A, 55)) : color.new(color.gray, 40)
cloudCellColor = isSupport ? f_srColor(true) : isResist ? f_srColor(false) : cloudContextColor

// 리본 상태 = 마지막으로 발생한 다이아몬드(상태머신) 기준이라 차트 표시와 동기화된다.
// 괄호 숫자 = 마지막 이벤트(압축/분출) 발생 봉 종가 대비 현재 종가의 가격 변화 %.
ribbonMovePct = not na(ribbonEventClose) and ribbonEventClose != 0 ? (close / ribbonEventClose - 1) * 100 : na
ribbonBars = not na(ribbonEventBar) ? bar_index - ribbonEventBar + 1 : na   // 이벤트 봉=1봉째
// 표시 라벨만 매핑(내부값 ribbonState는 비교/색 로직에서 그대로 사용). "횡보"→"횡보 수축", "상승"→"상승 분출", "하락"→"하락 분출", 그 외("대기")는 유지.
ribbonStateLabel = ribbonState == "상승" ? "상승 분출" : ribbonState == "하락" ? "하락 분출" : ribbonState == "횡보" ? "횡보 수축" : ribbonState
ribbonCellText = ribbonStateLabel + (na(ribbonMovePct) ? "" : " (" + (ribbonMovePct > 0 ? "+" : "") + str.tostring(ribbonMovePct, "0.0") + "%" + (na(ribbonBars) ? "" : " | " + str.tostring(ribbonBars) + "봉") + ")")
ribbonCellColor = ribbonState == "상승" ? color.new(color.blue, 30) : ribbonState == "하락" ? color.new(color.red, 30) : ribbonState == "횡보" ? color.new(color.purple, 30) : color.new(color.gray, 40)

// 이격도(Disparity)·비정상 캔들 블록은 모멘텀 모드 즉시 반영을 위해 상단(멀티스케일 신호 앞)에서 계산한다.

// =========================
// 우측 하단: 다음 봉 트리거 가격 + 구름대/리본 상태
// =========================
// 신호 = (후행스팬 조건) AND (전환선 vs 기준선 게이트). 다음 봉 종가가 돌파해야 할 기준 가격을 표시한다.
// 매수/매도 트리거 가격(buyTrig*/sellTrig*)은 위 스케일 캐스케이드 앞에서 계산한다(스킵 판정에 필요).

// 천 단위 쉼표 + 심볼 mintick 소수 자릿수
priceDecimals = syminfo.mintick >= 1 ? 0 : syminfo.mintick >= 0.1 ? 1 : syminfo.mintick >= 0.01 ? 2 : syminfo.mintick >= 0.001 ? 3 : syminfo.mintick >= 0.0001 ? 4 : 5
priceFmt = priceDecimals == 0 ? "#,##0" : priceDecimals == 1 ? "#,##0.0" : priceDecimals == 2 ? "#,##0.00" : priceDecimals == 3 ? "#,##0.000" : priceDecimals == 4 ? "#,##0.0000" : "#,##0.00000"
f_price(p) => str.tostring(p, priceFmt)
// 화살표는 현재 가격(close) 대비 트리거 가격 위치로 결정: 트리거가 현재가보다 높으면 ↑, 낮으면 ↓
f_arrow(refPrice) => refPrice > close ? "↑ " : "↓ "
// 청산가의 현재 종가 대비 % (롱 청산은 아래라 −, 숏 청산은 위라 +)
f_pct(p) =>
    d = (p - close) / close * 100
    (d > 0 ? "+" : "") + str.tostring(d, "0.0") + "%"

// 샹들리에 청산선 '값 계산'(Cha 손익비 전용) — 차트 페인팅(선·라벨)은 하지 않는다(청산선 페인팅은 auto-vwap 으로 이동됨).
//  스윕(샹들리에 ATR 트레일링) = longCE/shortCE. 청산선(그 너머 손절 기준선) = longClear/shortClear.
//  값은 확정값(close[1]·ta.highest/lowest·확정 피벗) 기반이라 리페인팅 없음. 아래 (1) Cha 손익비가 청산선 값을 손절선으로 사용.
ceLength = input.int(22, title="스윕 룩백 길이", minval=1, group="스윕/청산")
ceAtrLen = input.int(22, title="스윕 ATR 길이", minval=1, group="스윕/청산")
ceMult = input.float(3.0, title="스윕 ATR 배수", minval=0.0, step=0.01, group="스윕/청산")
// 스윕 가격 모드(샹들리에 기반):
//  - 기본: 표준 샹들리에(룩백 고가/저가 − ATR)
//  - 거래량 가중: 거래량 큰 봉(VWMA)에 가중 → 거래 몰린 봉에서 스윕가를 끌어올림
//  - 최근봉 가중: 최근봉(WMA)에 가중 → 휩쏘 급등/급락 봉에서 스윕가를 빠르게·높게
//  - 거래량+최근봉: 두 가중을 함께(거래량 × 선형 최근봉)
ceMode = input.string("기본", title="스윕 가격 모드", options=["기본", "거래량 가중", "최근봉 가중", "거래량+최근봉"], group="스윕/청산")
ceWeightLen = input.int(10, title="가중 트레일 길이", minval=1, group="스윕/청산")
ceWeightMult = input.float(1.5, title="가중 트레일 ATR 배수", minval=0.0, step=0.01, group="스윕/청산")
// 청산(직선) = 스윕 너머. 세력이 스윕을 더 깊게 찌를 것을 예상해 청산선을 그만큼 바깥에 둔다.
sweepBufferMult = input.float(0.4, title="청산 버퍼 ATR 배수(스윕 너머)", minval=0.0, step=0.1, group="스윕/청산")
useSweepPivot = input.bool(true, title="청산에 스윙 풀(피벗) 반영", group="스윕/청산")
sweepPivotLen = input.int(5, minval=1, title="스윙 풀 좌우 봉수", group="스윕/청산")
sweepMaxGapMult = input.float(1.0, title="청산-스윕 최대 간격 ATR 배수", minval=0.1, step=0.1, group="스윕/청산")

atrCe = ta.atr(ceAtrLen)   // 한 번만 계산해 ceAtrVal·weightAtr·sweepAtr에서 재사용(중복 ta.atr 제거)
ceAtrVal = ceMult * atrCe
// 거래량 × 최근봉(선형) 가중 평균
f_volRecencyMa(src, len) =>
    float num = 0.0
    float den = 0.0
    for i = 0 to len - 1
        float w = volume[i] * (len - i)
        num += src[i] * w
        den += w
    den != 0 ? num / den : src
// 모드별 앵커 — 활성 모드에 필요한 것만 계산(기본 모드에선 VWMA/WMA/가중루프 모두 생략 → 속도↑). ceMode는 세션 상수.
// 가중 모드(거래량/최근봉/거래량+최근봉)는 형성 중인 현재봉을 제외하고 **직전 봉 기준**([1])으로 앵커를 잡는다.
longAnchorWNow = ceMode == "거래량 가중" ? ta.vwma(high, ceWeightLen) : ceMode == "최근봉 가중" ? ta.wma(high, ceWeightLen) : ceMode == "거래량+최근봉" ? f_volRecencyMa(high, ceWeightLen) : na
shortAnchorWNow = ceMode == "거래량 가중" ? ta.vwma(low, ceWeightLen) : ceMode == "최근봉 가중" ? ta.wma(low, ceWeightLen) : ceMode == "거래량+최근봉" ? f_volRecencyMa(low, ceWeightLen) : na
longAnchorW = longAnchorWNow[1]
shortAnchorW = shortAnchorWNow[1]
weightAtr = ceWeightMult * atrCe
longCERaw = ceMode == "기본" ? ta.highest(high, ceLength) - ceAtrVal : longAnchorW - weightAtr
shortCERaw = ceMode == "기본" ? ta.lowest(low, ceLength) + ceAtrVal : shortAnchorW + weightAtr
var float longCE = na
longCEPrev = nz(longCE[1], longCERaw)
longCE := close[1] > longCEPrev ? math.max(longCERaw, longCEPrev) : longCERaw
var float shortCE = na
shortCEPrev = nz(shortCE[1], shortCERaw)
shortCE := close[1] < shortCEPrev ? math.min(shortCERaw, shortCEPrev) : shortCERaw

// 청산(직선) = 스윕(longCE/shortCE) 너머. ATR 버퍼 + 옵션으로 가장 가까운 스윙 풀(피벗) 너머까지.
sweepAtr = atrCe
sweepPLow = ta.pivotlow(sweepPivotLen, sweepPivotLen)
sweepPHigh = ta.pivothigh(sweepPivotLen, sweepPivotLen)
var float lastSweepPLow = na
var float lastSweepPHigh = na
lastSweepPLow := not na(sweepPLow) ? sweepPLow : lastSweepPLow
lastSweepPHigh := not na(sweepPHigh) ? sweepPHigh : lastSweepPHigh
longClear = longCE - sweepBufferMult * sweepAtr
longClear := useSweepPivot and not na(lastSweepPLow) ? math.min(longClear, lastSweepPLow - syminfo.mintick) : longClear
longClear := math.max(longClear, longCE - sweepMaxGapMult * sweepAtr)   // 스윕과의 간격 상한(괴리감 방지)
shortClear = shortCE + sweepBufferMult * sweepAtr
shortClear := useSweepPivot and not na(lastSweepPHigh) ? math.max(shortClear, lastSweepPHigh + syminfo.mintick) : shortClear
shortClear := math.min(shortClear, shortCE + sweepMaxGapMult * sweepAtr)

// 가격이 없으면(같은 방향 신호가 이미 나와 막힘 = 그 방향 진행 중) 상승/하락으로 표시.
// 진행 중(상승/하락 추세)이면 그 스케일 기준선(baseRef) 대비 이격도(기준 100: 종가÷기준선×100)를 괄호로 표기.
// mom=모멘텀 모드면 트리거 가격/추세 텍스트 앞에 "M " 표기.
// nbars = 시간 조정 투영 봉수(na면 horizon 안 성립 안 함 = "-"). blocked(추세 진행 중)이면 N봉 미표기(기존 텍스트 유지).
//  트리거 가격 표시 케이스에만 "{기존값} | N봉"(성립) 또는 "{기존값} | -"(계산 불가)로 부착.
// vwSrc=true면(혼합 모드에서 이 봉 트리거가 VWMA 소스) 셀 텍스트 맨 앞에 "V " 접두를 붙여 사용자가 소스를 식별.
//  접두 순서: "V " → "M "(모멘텀) → 본문. 추세 진행(blocked) 케이스에도 트리거 소스 표시 의미가 있어 동일하게 부착.
f_trigCell(blocked, p, isBuy, baseRef, mom, nbars, vwSrc) => (vwSrc ? "V " : "") + (mom ? "M " : "") + (blocked ? (isBuy ? "상승 추세" : "하락 추세") + (na(baseRef) or baseRef == 0 ? "" : " (" + str.tostring(close / baseRef * 100, "0.0") + ")") : f_arrow(p) + f_price(p) + " (" + f_pct(p) + ")" + " | " + (na(nbars) ? "-" : str.tostring(nbars) + "봉"))
// 셀 강조: 방향 기준. 매수는 트리거가 현재가의 +nearPct% 이내(또는 이미 아래=조건 충족→확정),
// 매도는 트리거가 −nearPct% 이내(또는 이미 위=충족)면 포지션 색(상승=녹/하락=빨)으로 칠한다.
// 진행 중(상승/하락 추세)이면 구름대 셀과 같은 채도(투명도 30)의 포지션 색.
// nearPct·f_trigNear는 신호 파이프라인 앞(트리거 정의 근처)으로 이동했다(혼합 예측 발화가 같은 근접 판정을 파이프라인에서 재사용).
f_trigBg(blocked, p, isBuy) =>
    dirCol = isBuy ? color.green : color.red
    hit = not blocked and f_trigNear(p, isBuy)   // 둔탁 녹/적(전환 예측/대기) = not blocked(dir!=방향) and 근접 hit — f_trigNear로 판정 통일(발화와 동일 소스)
    // 진행 중(상승/하락 추세)=선명 녹/적, 근접(작은 % 이내)=둔탁 녹/적, 그 외=회색
    blocked ? color.new(dirCol, 30) : hit ? (isBuy ? color.new(#6E8F72, 0) : color.new(#A57A7A, 0)) : color.new(color.gray, 40)

// =========================
// Auto VWAP 통합 — 계산 전용(차트 미표시). 밴드워킹(추세) vs 지지·저항 상태만 테이블 하단 행에 추가.
//  (동적 선색·밴드 % 라벨 없음 · 기본: 최근 봉 50 / Recent Bars / hlc3)
// =========================
vwapHideDWM = input.bool(false, title="1D 이상에서 VWAP 계산 제외", group="Auto VWAP", display=display.none)
vwapAnchorMode = input.string("Recent Bars", title="앵커 모드", options=["Session", "Recent Trading Days", "Recent Bars"], group="Auto VWAP")
vwapRecentDays = input.int(5, title="최근 거래일 수", minval=1, group="Auto VWAP", display=display.none)
vwapRecentBars = input.int(50, title="최근 봉 수", minval=1, group="Auto VWAP")
vwapSrc = input(title="소스", defval=hlc3, group="Auto VWAP")
vwapCalcMode = input.string("Log Standard Deviation", "밴드 계산 모드", options=["Log Standard Deviation", "Absolute Standard Deviation"], group="Auto VWAP", display=display.none)
vwapBandMult1 = input.float(1.0, title="밴드 배수 #1", group="Auto VWAP", step=0.5, minval=0, display=display.none)
vwapBandMult2 = input.float(2.0, title="밴드 배수 #2", group="Auto VWAP", step=0.5, minval=0, display=display.none)

vwapNewSession = barstate.isfirst or timeframe.change("D")
vwapSessTime = time("D")
vwapSessClose = time_close("D")
vwapIsLatestSession = vwapSessTime <= last_bar_time and vwapSessClose > last_bar_time

var array<float> vwSessPV = array.new_float()
var array<float> vwSessVol = array.new_float()
var array<float> vwSessP2V = array.new_float()
var array<float> vwSessLogPV = array.new_float()
var array<float> vwSessLog2V = array.new_float()
var array<float> vwSessInvalidLogVol = array.new_float()
var float vwCumPV = 0.0
var float vwCumVol = 0.0
var float vwCumP2V = 0.0
var float vwCumLogPV = 0.0
var float vwCumLog2V = 0.0
var float vwCumInvalidLogVol = 0.0

if vwapNewSession
    array.push(vwSessPV, vwCumPV)
    array.push(vwSessVol, vwCumVol)
    array.push(vwSessP2V, vwCumP2V)
    array.push(vwSessLogPV, vwCumLogPV)
    array.push(vwSessLog2V, vwCumLog2V)
    array.push(vwSessInvalidLogVol, vwCumInvalidLogVol)

vwLogSrc = vwapSrc > 0 ? math.log(vwapSrc) : na
vwCumPV += vwapSrc * volume
vwCumVol += volume
vwCumP2V += vwapSrc * vwapSrc * volume
vwCumLogPV += na(vwLogSrc) ? 0.0 : vwLogSrc * volume
vwCumLog2V += na(vwLogSrc) ? 0.0 : vwLogSrc * vwLogSrc * volume
vwCumInvalidLogVol += na(vwLogSrc) ? volume : 0.0

vwSessCount = array.size(vwSessPV)
vwAnchorIdx = vwapAnchorMode == "Session" ? vwSessCount - 1 : math.max(vwSessCount - vwapRecentDays, 0)
vwAnchorPV = vwapAnchorMode == "Recent Bars" ? nz(vwCumPV[vwapRecentBars], 0.0) : array.get(vwSessPV, vwAnchorIdx)
vwAnchorVol = vwapAnchorMode == "Recent Bars" ? nz(vwCumVol[vwapRecentBars], 0.0) : array.get(vwSessVol, vwAnchorIdx)
vwAnchorP2V = vwapAnchorMode == "Recent Bars" ? nz(vwCumP2V[vwapRecentBars], 0.0) : array.get(vwSessP2V, vwAnchorIdx)
vwAnchorLogPV = vwapAnchorMode == "Recent Bars" ? nz(vwCumLogPV[vwapRecentBars], 0.0) : array.get(vwSessLogPV, vwAnchorIdx)
vwAnchorLog2V = vwapAnchorMode == "Recent Bars" ? nz(vwCumLog2V[vwapRecentBars], 0.0) : array.get(vwSessLog2V, vwAnchorIdx)
vwAnchorInvalidLogVol = vwapAnchorMode == "Recent Bars" ? nz(vwCumInvalidLogVol[vwapRecentBars], 0.0) : array.get(vwSessInvalidLogVol, vwAnchorIdx)

vwWinPV = vwCumPV - vwAnchorPV
vwWinVol = vwCumVol - vwAnchorVol
vwWinP2V = vwCumP2V - vwAnchorP2V
vwWinLogPV = vwCumLogPV - vwAnchorLogPV
vwWinLog2V = vwCumLog2V - vwAnchorLog2V
vwWinInvalidLogVol = vwCumInvalidLogVol - vwAnchorInvalidLogVol

float vwapValue = na
float vwUpper1 = na
float vwLower1 = na
float vwUpper2 = na
float vwLower2 = na
vwShouldCalc = not (vwapHideDWM and timeframe.isdwm) and vwWinVol > 0 and (vwapAnchorMode != "Session" or vwapIsLatestSession)
if vwShouldCalc
    vwapValue := vwWinPV / vwWinVol
    vwStdAbs = math.sqrt(math.max(vwWinP2V / vwWinVol - math.pow(vwapValue, 2), 0))
    vwStdLog = math.sqrt(math.max(vwWinLog2V / vwWinVol - math.pow(vwWinLogPV / vwWinVol, 2), 0))
    vwCanLog = vwWinInvalidLogVol == 0 and vwapValue > 0
    if vwapCalcMode == "Absolute Standard Deviation"
        vwUpper1 := vwapValue + vwStdAbs * vwapBandMult1
        vwLower1 := vwapValue - vwStdAbs * vwapBandMult1
        vwUpper2 := vwapValue + vwStdAbs * vwapBandMult2
        vwLower2 := vwapValue - vwStdAbs * vwapBandMult2
    else if vwCanLog
        vwUpper1 := vwapValue * math.exp(vwStdLog * vwapBandMult1)
        vwLower1 := vwapValue * math.exp(-vwStdLog * vwapBandMult1)
        vwUpper2 := vwapValue * math.exp(vwStdLog * vwapBandMult2)
        vwLower2 := vwapValue * math.exp(-vwStdLog * vwapBandMult2)

// VWAP 상태 판정 (밴드워킹=추세 / 지지·저항=되돌림) — 차트엔 안 그리고 테이블에만 사용
vwHasVwap = vwShouldCalc and not na(vwapValue)
vwAbove = vwHasVwap and close > vwapValue
vwGapPct = vwHasVwap and vwapValue != 0 ? (close / vwapValue - 1.0) * 100.0 : na
vwPosText = not vwHasVwap ? "-" : vwAbove ? "VWAP 위" : "VWAP 아래"
// VWAP 지지/저항 — 위=지지·아래=저항, 괄호는 이격도(기준 100: 종가÷VWAP×100)와 유지 봉수. 이격도가 ±2σ 밖이면(너무 큼) 둔탁 색.
vwSrTooFar = vwHasVwap and (vwAbove ? (not na(vwUpper2) and close > vwUpper2) : (not na(vwLower2) and close < vwLower2))
vwAboveInt = vwHasVwap ? (vwAbove ? 1 : -1) : 0   // 1=VWAP 위(지지), -1=아래(저항), 0=없음
var int vwSrBars = 0   // 현재 지지/저항(위/아래) 상태가 유지된 봉수
if vwAboveInt == 0
    vwSrBars := 0
else if vwAboveInt == vwAboveInt[1]
    vwSrBars := vwSrBars + 1
else
    vwSrBars := 1
vwSrText = not vwHasVwap ? "-" : (vwAbove ? "지지" : "저항") + " (" + str.tostring(close / vwapValue * 100, "0.0") + " | " + str.tostring(vwSrBars) + "봉)"
vwSrColor = not vwHasVwap ? color.new(color.gray, 50) : vwAbove ? (vwSrTooFar ? color.new(#6E8F72, 0) : color.new(color.green, 30)) : (vwSrTooFar ? color.new(#A57A7A, 0) : color.new(color.red, 30))
vwNearLower = vwHasVwap and not na(vwLower1) and close < vwLower1
vwNearUpper = vwHasVwap and not na(vwUpper1) and close > vwUpper1
vwSlopeLen = 5
vwBw2 = vwHasVwap and not na(vwUpper2) and not na(vwLower2) ? vwUpper2 - vwLower2 : na
vwSlope = vwHasVwap and not na(vwapValue[vwSlopeLen]) ? vwapValue - vwapValue[vwSlopeLen] : na
// 평탄 판정 임계 = 밴드폭의 3%(기울기가 이보다 작으면 평탄) — 상승/하락 민감도 상향
vwFlatThresh = not na(vwBw2) ? vwBw2 * 0.03 : na
vwSlopeUp = not na(vwSlope) and not na(vwFlatThresh) and vwSlope > vwFlatThresh
vwSlopeDown = not na(vwSlope) and not na(vwFlatThresh) and vwSlope < -vwFlatThresh
vwSlopeFlat = vwHasVwap and not vwSlopeUp and not vwSlopeDown
vwBwExpanding = vwHasVwap and not na(vwBw2[vwSlopeLen]) and vwBw2 > vwBw2[vwSlopeLen]
vwBwContracting = vwHasVwap and not na(vwBw2[vwSlopeLen]) and vwBw2 < vwBw2[vwSlopeLen]
vwPreWalk = vwBwContracting or vwSlopeFlat or vwBwContracting[1] or vwBwContracting[2]
vwUpBreakout = vwPreWalk and close > open and not na(vwUpper2) and close > vwUpper2
vwDownBreakout = vwPreWalk and close < open and not na(vwLower2) and close < vwLower2
vwWalkSlopeLen = 3
vwLowerRising = vwHasVwap and not na(vwLower2[vwWalkSlopeLen]) and vwLower2 > vwLower2[vwWalkSlopeLen]
vwUpperFalling = vwHasVwap and not na(vwUpper2[vwWalkSlopeLen]) and vwUpper2 < vwUpper2[vwWalkSlopeLen]
var int vwWalk = 0
if vwWalk == 1 and (not vwHasVwap or vwUpperFalling)
    vwWalk := 0
if vwWalk == -1 and (not vwHasVwap or vwLowerRising)
    vwWalk := 0
if vwUpBreakout
    vwWalk := 1
if vwDownBreakout
    vwWalk := -1
vwUpperWalk = vwWalk == 1 or (vwBwExpanding and vwSlopeUp and vwNearUpper)
vwLowerWalk = vwWalk == -1 or (vwBwExpanding and vwSlopeDown and vwNearLower)
vwSupport = not vwUpperWalk and not vwLowerWalk and (vwBwContracting or vwSlopeFlat) and vwNearLower
vwResistance = not vwUpperWalk and not vwLowerWalk and (vwBwContracting or vwSlopeFlat) and vwNearUpper
vwSlopeText = not vwHasVwap ? "-" : vwSlopeUp ? "상승" : vwSlopeDown ? "하락" : "평탄(중심)"
// VWAP 밴드폭 표기 — 확장/수축 판정에 실제 쓰는 밴드(vwBw2 = vwUpper2 − vwLower2, 2σ 밴드 총폭)를
//  현재 vwap(50) 선(vwapValue) 기준으로 정규화한 % = vwBw2 / vwapValue × 100. 정수로 괄호 표기(예: "수축(80)").
//  정규화(% of VWAP)를 쓰는 이유: 심볼·가격대 무관 직관값이며, VWAP 지지/저항 셀의 close/vwapValue×100 관례와 정합.
//  na 가드: VWAP 없거나 vwapValue=0이면 괄호 생략(밴드폭 미산출). 확정 성격 값(vwBw2·vwapValue)만 참조 → 신규 리페인팅 없음.
vwBwPct = vwHasVwap and not na(vwBw2) and vwapValue != 0 ? vwBw2 / vwapValue * 100.0 : na
vwBwStateBase = not vwHasVwap ? "-" : vwBwExpanding ? "확장" : vwBwContracting ? "수축" : "유지"
vwBwStateText = vwBwStateBase == "-" or na(vwBwPct) ? vwBwStateBase : vwBwStateBase + "(" + str.tostring(math.round(vwBwPct)) + ")"
vwBandState = vwLowerWalk ? "하단 밴드워킹" : vwUpperWalk ? "상단 밴드워킹" : vwSupport ? "하단 지지" : vwResistance ? "상단 저항" : "중앙(공방)"
// VWAP 상태 셀 색:
//  상승 → 녹(밴드워킹=선명 green, 그 외=둔탁 #6E8F72) / 하락 → 빨강(밴드워킹=선명 red, 그 외=둔탁 #A57A7A)
//  평탄(중심) → 밴드 상태별: 상단 밴드워킹·하단 지지=둔탁 녹, 하단 밴드워킹·상단 저항=둔탁 빨강, 중앙(공방)=회색. VWAP 없음=회색.
vwBandStateShort = (vwUpperWalk or vwLowerWalk) ? "밴드워킹" : vwBandState
vwBandColor = not vwHasVwap ? color.new(color.gray, 40) : vwSlopeUp ? ((vwUpperWalk or vwLowerWalk) ? color.new(color.green, 0) : color.new(#6E8F72, 0)) : vwSlopeDown ? ((vwUpperWalk or vwLowerWalk) ? color.new(color.red, 0) : color.new(#A57A7A, 0)) : vwUpperWalk ? color.new(#6E8F72, 0) : vwLowerWalk ? color.new(#A57A7A, 0) : vwSupport ? color.new(#6E8F72, 0) : vwResistance ? color.new(#A57A7A, 0) : color.new(color.gray, 30)

// =========================
// VWAP 변곡 판정 — 보조지표 auto-vwap.pine "변곡 지점" 알고리즘을 이치모쿠 테이블 셀 전용으로 이식(차트 페인팅 없음, 전략 로직 불변).
//  ⚠️ 매매 전략(진입·청산·임계·산식)과 무관한 표시 전용이다. 아래 판정값은 오직 "VWAP 변곡" 테이블 행에만 쓴다.
//  구성(수학자 검토 반영):
//   - 변곡용 VWAP 세트(length = 청산선 ceLength = 22) : 기본 화면판정 세트(length=50, vwapValue 등)와 **독립**으로 신규 계산.
//     누적값(vwCum*)·세션 앵커(vwSess*)는 window 무관 공통값이라 재사용하고, window(±σ 밴드1/밴드2)만 length=22로 다시 잡는다.
//   - 변곡용 청산선 : 이치모쿠 기존 longClear/shortClear(ceLength=22, 확정값 기반) **그대로 재사용**(중복 계산 제거·값 정합).
//   - 베이스라인 : 이치모쿠 기존 baseLine(donchian(basePeriods)=Kijun 22) **그대로 재사용**(auto-vwap ipBaseLine 산식과 동일).
//   - 밴드워킹 억제 : "넓은 추세 국면"이라 length=50 세트로 판정하는 게 원본 의미(auto-vwap 주석 L211-213)와 정합 →
//       이치모쿠 기존 vwUpperWalk/vwLowerWalk(length=50) **그대로 재사용**(신규 계산 불필요).
//   - 수평필터 : 변곡용 청산선(longClear/shortClear) 기울기를 변곡용 스윕 ATR(atrCe, ceAtrLen 기반)로 정규화해 판정.
//  ⚠️ 리페인팅: 원본 변곡식은 진행봉 close/high/low/volume을 참조해 진행봉에서 깜빡인다(수학자 확인).
//   → 테이블 표기는 barstate.isconfirmed 확정봉에서만 var로 latch(스냅샷 고정). 진행봉 내 불변, 확정봉 단위 갱신(1봉 표시 지연은 표시 전용이라 허용).
// =========================
// 변곡 판정용 파라미터 그룹(표시 전용). 기존 input·전략 파라미터는 건드리지 않는다.
IP_GROUP = "VWAP 변곡"
ipShowInflection = input.bool(true, title="VWAP 변곡 판정 표시", group=IP_GROUP, tooltip="우측 상단 테이블 'VWAP 변곡' 행에 변곡 상태(롱/숏/양방 수축/무신호)를 표시합니다. 차트에는 아무것도 그리지 않습니다(테이블 전용).")
ipFlatFilter = input.bool(true, title="변곡 시 청산선 수평 필터(밴드워킹 억제)", group=IP_GROUP, active=ipShowInflection, tooltip="켜면 변곡 시점 청산선 기울기가 근사 수평일 때만 변곡으로 인정합니다(추세로 기운 청산선=밴드워킹 중이면 억제).")
ipFlatLookback = input.int(3, title="[변곡] 수평 판정 lookback 봉수", minval=1, group=IP_GROUP, active=ipShowInflection and ipFlatFilter, display=display.none, tooltip="청산선 기울기를 측정할 과거 봉 수(N). 최근 N봉 사이 청산선 값 변화량으로 판정. 기본 3.")
ipFlatSlopeMax = input.float(0.10, title="[변곡] 수평 허용 기울기(ATR 대비 배수)", minval=0.0, step=0.01, group=IP_GROUP, active=ipShowInflection and ipFlatFilter, display=display.none, tooltip="N봉 사이 청산선 변화량 ÷ ATR 이 이 값 이하이면 '수평'으로 간주. 기본 0.10(=ATR의 10%).")
ipBwSuppress = input.bool(true, title="추세(밴드워킹) 방향 반대 변곡 억제", group=IP_GROUP, active=ipShowInflection, tooltip="켜면 밴드워킹(추세) 방향과 반대되는 변곡을 억제합니다. 하락 밴드워킹 중이면 롱 변곡을, 상승 밴드워킹 중이면 숏 변곡을 억제(역추세 진입 억제). 이치모쿠 length=50 VWAP 세트의 밴드워킹 판정을 재사용합니다.")

// 변곡용 VWAP 세트(length = ceLength) — 누적값/세션앵커 재사용, window만 ceLength로 다시 계산.
//  반환: [vwap, upper1, lower1, upper2, lower2, shouldCalc]. 산식은 이치모쿠 length=50 계산부(L1296-1330)와 100% 동일, length만 다름.
computeIpVwapSet(int barsLen) =>
    aPV = vwapAnchorMode == "Recent Bars" ? nz(vwCumPV[barsLen], 0.0) : array.get(vwSessPV, vwAnchorIdx)
    aVol = vwapAnchorMode == "Recent Bars" ? nz(vwCumVol[barsLen], 0.0) : array.get(vwSessVol, vwAnchorIdx)
    aP2V = vwapAnchorMode == "Recent Bars" ? nz(vwCumP2V[barsLen], 0.0) : array.get(vwSessP2V, vwAnchorIdx)
    aLogPV = vwapAnchorMode == "Recent Bars" ? nz(vwCumLogPV[barsLen], 0.0) : array.get(vwSessLogPV, vwAnchorIdx)
    aLog2V = vwapAnchorMode == "Recent Bars" ? nz(vwCumLog2V[barsLen], 0.0) : array.get(vwSessLog2V, vwAnchorIdx)
    aInvLogVol = vwapAnchorMode == "Recent Bars" ? nz(vwCumInvalidLogVol[barsLen], 0.0) : array.get(vwSessInvalidLogVol, vwAnchorIdx)
    wPV = vwCumPV - aPV
    wVol = vwCumVol - aVol
    wP2V = vwCumP2V - aP2V
    wLogPV = vwCumLogPV - aLogPV
    wLog2V = vwCumLog2V - aLog2V
    wInvLogVol = vwCumInvalidLogVol - aInvLogVol
    float vwapL = na
    float up1L = na
    float lo1L = na
    float up2L = na
    float lo2L = na
    shouldL = not (vwapHideDWM and timeframe.isdwm) and wVol > 0 and (vwapAnchorMode != "Session" or vwapIsLatestSession)
    if shouldL
        vwapL := wPV / wVol
        stdAbsL = math.sqrt(math.max(wP2V / wVol - math.pow(vwapL, 2), 0))
        stdLogL = math.sqrt(math.max(wLog2V / wVol - math.pow(wLogPV / wVol, 2), 0))
        canLogL = wInvLogVol == 0 and vwapL > 0
        if vwapCalcMode == "Absolute Standard Deviation"
            up1L := vwapL + stdAbsL * vwapBandMult1
            lo1L := vwapL - stdAbsL * vwapBandMult1
            up2L := vwapL + stdAbsL * vwapBandMult2
            lo2L := vwapL - stdAbsL * vwapBandMult2
        else if canLogL
            up1L := vwapL * math.exp(stdLogL * vwapBandMult1)
            lo1L := vwapL * math.exp(-stdLogL * vwapBandMult1)
            up2L := vwapL * math.exp(stdLogL * vwapBandMult2)
            lo2L := vwapL * math.exp(-stdLogL * vwapBandMult2)
    [vwapL, up1L, lo1L, up2L, lo2L, shouldL]

// 변곡용 VWAP 세트(length = 청산선 ceLength). 요구사항 3: 변곡용 VWAP length = 청산선 N.
[ipVwapValue, ipUpper1, ipLower1, ipUpper2, ipLower2, ipShouldCalc] = computeIpVwapSet(ceLength)
// 수평 필터용 ATR — 변곡 판정 대상이 이치모쿠 청산선(longClear/shortClear, ceAtrLen 기반)이므로 그 스윕 ATR(atrCe)에 맞춘다.
isClearLineFlat(float lineVal, int lb, float atrVal, float maxRatio) =>
    float prevVal = lineVal[lb]
    na(lineVal) or na(prevVal) or na(atrVal) or atrVal <= 0 ? false : (math.abs(lineVal - prevVal) / atrVal) <= maxRatio
ipUpperFlatOk = not ipFlatFilter or isClearLineFlat(shortClear, ipFlatLookback, atrCe, ipFlatSlopeMax)
ipLowerFlatOk = not ipFlatFilter or isClearLineFlat(longClear, ipFlatLookback, atrCe, ipFlatSlopeMax)
// 변곡 판정: 변곡용 밴드2가 이치모쿠 청산선 안으로 진입 + 수평필터 AND.
//  숏(upper2): 변곡용 상단밴드2 < 숏 청산선(위쪽 청산선 안).  롱(lower2): 변곡용 하단밴드2 > 롱 청산선(아래쪽 청산선 안).
ipUpper2Inflection = ipShouldCalc and not na(ipUpper2) and not na(shortClear) and ipUpper2 < shortClear and ipUpperFlatOk
ipLower2Inflection = ipShouldCalc and not na(ipLower2) and not na(longClear) and ipLower2 > longClear and ipLowerFlatOk
// 베이스라인 1/2 게이트(auto-vwap 동일 의미): baseLine(Kijun 22)이 변곡용 VWAP~밴드1 구간의 1/2 지점 기준 안/밖.
//  롱 임계 = 변곡 VWAP ~ 상단밴드1 의 1/2 지점.  숏 임계 = 변곡 VWAP ~ 하단밴드1 의 1/2 지점(대칭).
float ipLongBaseThreshold = ipVwapValue + (ipUpper1 - ipVwapValue) / 2
float ipShortBaseThreshold = ipVwapValue - (ipVwapValue - ipLower1) / 2
ipBaseBelow = not na(baseLine) and not na(ipVwapValue) and not na(ipUpper1) and baseLine < ipLongBaseThreshold
ipBaseAbove = not na(baseLine) and not na(ipVwapValue) and not na(ipLower1) and baseLine > ipShortBaseThreshold
// 밴드워킹 방향 억제 — 이치모쿠 기존 length=50 세트(vwUpperWalk/vwLowerWalk) 재사용(수학자 권고).
//  숏 = 상승 밴드워킹(vwUpperWalk) 아닐 때만.  롱 = 하락 밴드워킹(vwLowerWalk) 아닐 때만.
ipUpperBwOk = not ipBwSuppress or not vwUpperWalk
ipLowerBwOk = not ipBwSuppress or not vwLowerWalk
// 최종 변곡 성립(원본 auto-vwap upper2Marker/lower2Marker와 동일 구성). 진행봉 참조 → latch 전 원시 판정.
ipUpper2MarkerRaw = ipUpper2Inflection and ipBaseAbove and ipUpperBwOk   // 숏 변곡
ipLower2MarkerRaw = ipLower2Inflection and ipBaseBelow and ipLowerBwOk   // 롱 변곡
// 리페인팅 방지: 확정봉(barstate.isconfirmed)에서만 최종 판정을 var로 latch. 진행봉엔 직전 확정 스냅샷을 유지.
var bool ipUpperMarker = false
var bool ipLowerMarker = false
if barstate.isconfirmed
    ipUpperMarker := ipUpper2MarkerRaw
    ipLowerMarker := ipLower2MarkerRaw
// 테이블 셀 텍스트/색 — 롱 변곡(녹)/숏 변곡(빨강)/양방 수축(회색·방향성 없음)/무신호(회색).
ipInflectionText = ipLowerMarker and ipUpperMarker ? "양방 수축" : ipLowerMarker ? "롱 변곡" : ipUpperMarker ? "숏 변곡" : "-"
ipInflectionColor = ipLowerMarker and ipUpperMarker ? color.new(color.gray, 40) : ipLowerMarker ? color.new(color.green, 0) : ipUpperMarker ? color.new(color.red, 0) : color.new(color.gray, 40)

// =========================
// 비정상 캔들 상태/색/텍스트는 상단(멀티스케일 신호 앞)에서 이미 계산했다(모멘텀 즉시 반영). 여기선 생략.

// =========================
// 캔들 상태 (3) — 표시 전용(display only). 최근 3봉을 7분류 스코어링으로 분류.
//  ★ 어떤 진입/청산/신호 변수에도 연결하지 않는다. 순수 테이블 표기 + 현재봉 캔들 바색용이다.
//  7분류(상호배타): 하락 진행 / 추세형 하락 예측 / 반전형 하락 예측 / 혼조 / 반전형 상승 예측 / 추세형 상승 예측 / 상승 진행.
//   - 진행(momentum): 3봉 구조(HH/HL·LL/LH)와 순몸통(netBody, ATR 정규화) 스코어로 추세 지속을 판정.
//   - 반전형 예측(reversal): 직전 하락/상승 뒤 반전 패턴(장악/망치·역망치/유성·교수형/샛별·석별)이면 방향 반전을 예측(진행보다 우선).
//   - 추세형 예측(trend): 선행 추세 방향으로 2봉 극점(고/저) 돌파형 강봉이면 추세 방향 지속을 예측(진행 뒤 순위).
//   - 혼조: 데이터 부족·3봉 총폭 부족·미매칭(도지연속 포함) 흡수.
//  판정 순서(첫 매칭 확정, 상호배타): 혼조게이트 → 반전형상승 → 반전형하락 → 상승진행 → 하락진행 → 추세형상승 → 추세형하락 → 혼조.
//  7분류: ①상승진행 ②하락진행 ③추세형상승예측 ④추세형하락예측 ⑤반전형상승예측 ⑥반전형하락예측 ⑦혼조.
//  셀 텍스트 = "분류명 | 근거패턴"(근거 특정 안 되면 분류명만). 셀 배경색 = 7색(switch 7분기).
//  b0=현재확정봉, b1=직전, b2=2봉전. candleConfirmOnClose=true면 확정봉 기준(리페인팅 방지),
//  false면 현재 진행봉 기준(실시간, 봉 완성 전 변동 가능).
// =========================
// [옵션 패널 재배치] 캔들 상태 input 선언은 상단(이격도 앞, 섹션2 캔들·되돌림)으로 이동했다. 아래는 그 input을 쓰는 계산 로직(원위치 유지).

// [이동됨] candleAtrN 정의와 f_candleState() 함수는 상단(캔들 상태 input 선언 직후·이격도 앞)으로 이동돼 있다.
//  (과거엔 '캔들 예측 발화'가 파이프라인에서 f_candleState(0)을 호출해 필요했으나, 발화 기준이 '전환 행 셀 색'으로 바뀌며 파이프라인은 더 이상 호출하지 않는다.)
//  이 함수는 이제 표시 전용. 아래 candleOff 기반 표시용 호출(candleCellText 등)은 원위치 유지.
// 확정봉 모드면 off=1(직전 완성봉을 b0으로), 실시간 모드면 off=0(형성 중 봉을 b0으로).
candleOff = candleConfirmOnClose ? 1 : 0
[candleCellText, candleCellColor, candleBarColor, candleClsName] = f_candleState(candleOff)

// =========================
// 캔들 손절라인 (표시 전용) — 캔들 상태(3) 바로 아래 행.
//  ★ 어떤 진입/청산/손익비/캐스케이드 변수에도 연결하지 않는다. 순수 테이블 표기다.
//  방향은 캔들 상태(3)의 7분류(candleClsName)를 그대로 재사용 → 같은 3봉·같은 candleOff·같은 색.
//   - 하락 계열(하락 진행/추세형 하락 예측/반전형 하락 예측): 손절라인 = 3봉 최고점 max(h0,h1,h2). 표기 "S +금액 (+N%)".
//   - 상승 계열(상승 진행/추세형 상승 예측/반전형 상승 예측): 손절라인 = 3봉 최저점 min(l0,l1,l2). 표기 "L -금액 (-N%)".
//   - 혼조: 손절라인 없음 → "-", 회색.
//  현재가 = close[candleOff](캔들 상태 판정과 동일 기준봉). 3봉 극점도 candleOff 반영(같은 3봉).
//  금액 = 손절가 − 현재가(하락=양수/상승=음수), N% = (손절가/현재가 − 1)×100. 0 나눗셈 가드(현재가>0).
candleStopHigh3 = math.max(high[candleOff], high[candleOff + 1], high[candleOff + 2])
candleStopLow3 = math.min(low[candleOff], low[candleOff + 1], low[candleOff + 2])
candleStopRef = close[candleOff]
candleIsDown = candleClsName == "하락 진행" or candleClsName == "추세형 하락 예측" or candleClsName == "반전형 하락 예측"
candleIsUp = candleClsName == "상승 진행" or candleClsName == "추세형 상승 예측" or candleClsName == "반전형 상승 예측"
// 손절가 선택: 하락 계열=3봉 최고점, 상승 계열=3봉 최저점, 그 외(혼조)=na.
candleStopPrice = candleIsDown ? candleStopHigh3 : candleIsUp ? candleStopLow3 : na
// 셀 텍스트: "S/L 부호금액 (부호N%)". 현재가·손절가 유효 + 현재가>0(0 나눗셈 가드)일 때만, 아니면 "-".
f_candleStopCell() =>
    valid = not na(candleStopPrice) and not na(candleStopRef) and candleStopRef > 0
    if not valid
        "-"
    else
        gap = candleStopPrice - candleStopRef
        pct = (candleStopPrice / candleStopRef - 1) * 100
        tag = candleIsDown ? "S " : "L "
        gapStr = (gap >= 0 ? "+" : "") + f_price(gap)
        pctStr = (pct >= 0 ? "+" : "") + str.tostring(pct, "0.0") + "%"
        tag + gapStr + " (" + pctStr + ")"
candleStopCellText = f_candleStopCell()
// 셀 색: 캔들 상태(3)와 동일(같은 7분류 색). 혼조는 회색.
candleStopCellColor = candleClsName == "혼조" ? color.new(color.gray, 40) : candleCellColor
// =========================
// 캔들 상태(3) 분류 결과로 현재봉 캔들 바디 색칠(파트 B #4). 방향 있는 6개 분류만 셀색과 동일 색으로 칠하고 혼조(na)면 원래 캔들 색 유지.
//  ★ 캔들 색은 캔들 상태 7분류 방향색(candleBarColor)을 조건 게이트 없이 그대로 표시한다.
//   상승/하락 계열이면 그 방향색, 혼조면 na(색 없음). 표시 여부는 표시 토글(candleShowState)만 연동.
//  실시간 모드(candleConfirmOnClose=false)면 봉 완성 전 색 변동(리페인팅) — 표시 전용이라 감수.
barcolor(candleShowState ? candleBarColor : na, title="캔들 상태 바색")

// =========================
// 손익비(RR) — 2종·3행: Cha(청산선)·Ret(되돌림).
//  (VWAP(밴드2) 손익비는 CEO 지시로 제거됨 — 표시 전용·매매 미사용.)
//  각 손익비는 서로 독립 계산되어 각자의 행에 표시된다(우선순위 통합 없음).
//  RR = 목표까지 거리(reward) ÷ 손절까지 거리(risk). reward>0·risk>0일 때만 유효, 아니면 "계산 불가".
// =========================
// 공통 RR 텍스트: "비율 (+목표%/-손절%)". 접두(pfx)로 Cha/VWAP/Ret·L/S 구분.
f_rrText(pfx, rr, rewardPct, riskPct) => na(rr) ? "계산 불가" : pfx + str.tostring(rr, "0.00") + " (+" + str.tostring(rewardPct, "0.0") + "% / -" + str.tostring(riskPct, "0.0") + "%)"
// Ret 고정손절 폴백 전용: 괄호 안 손절 자리를 "고정 -X.X%"로 렌더(괄호 밖 태그 없음). 순수 E는 f_rrText 그대로.
f_rrTextFixed(pfx, rr, rewardPct, fixedPct) => na(rr) ? "계산 불가" : pfx + str.tostring(rr, "0.00") + " (+" + str.tostring(rewardPct, "0.0") + "% / 고정 -" + str.tostring(fixedPct, "0.0") + "%)"
// Cha·VWAP 손익비 색(동일 로직): ≥1.5 유리(초록)·≥1.0 중립(회색)·<1 불리(빨강)·na 계산불가(회색).
f_rrColor(rr) => na(rr) ? color.new(color.gray, 40) : rr >= 1.5 ? color.new(color.green, 30) : rr >= 1.0 ? color.new(color.gray, 40) : color.new(color.red, 30)
// Ret 손익비 색(별도 등급 — Cha/VWAP와 임계 다름): ≥5 녹색·3~5 둔탁녹·<3 회색·na 계산불가(회색). <3=회색은 본부 기본값(저RR 보조, 조정 가능).
f_retRrColor(rr) => na(rr) ? color.new(color.gray, 40) : rr >= 5 ? color.new(color.green, 0) : rr >= 3 ? color.new(#6E8F72, 0) : color.new(color.gray, 40)

// (1) Cha 롱/숏 손익비 — 롱숏 청산선 기준. 진입=현재 종가.
//  Cha 롱: 목표=숏 청산선(위)·손절=롱 청산선(아래). 종가가 두 청산선 사이일 때만 유효.
//  Cha 숏: 목표=롱 청산선(아래)·손절=숏 청산선(위). "이 범주(청산선 범위)를 지나면"(종가가 밖) 계산 불가.
//  청산선 값(shortClear/longClear)은 위 스윕/청산 값 계산부(페인팅 없음·확정값 기반·리페인팅 없음)에서 참조.
chaUp = shortClear - close     // 위쪽(숏 청산선까지) 거리
chaDown = close - longClear    // 아래쪽(롱 청산선까지) 거리
chaValid = chaUp > 0 and chaDown > 0   // 종가가 롱·숏 청산선 사이(범주 안)일 때만 유효
chaLongRR = chaValid ? chaUp / chaDown : na
chaShortRR = chaValid ? chaDown / chaUp : na
chaUpPct = close != 0 ? math.abs(chaUp / close * 100) : na
chaDownPct = close != 0 ? math.abs(chaDown / close * 100) : na
chaLongText = chaValid ? f_rrText("", chaLongRR, chaUpPct, chaDownPct) : "계산 불가"
chaShortText = chaValid ? f_rrText("", chaShortRR, chaDownPct, chaUpPct) : "계산 불가"

// (2) Ret 롱숏 손익비(1행 통합) — 되돌림 가격 기준(보조). 회색.
//  구조: 순수 E안(이격 바깥 엣지) 우선, 계산불가 시 고정손절 폴백.
//  [순수 E안] 이익·손절 모두 disparityMa 기준 이격도%로 같은 척도.
//   - 이익 목표 = 중립 '안쪽' 엣지(disparityPullbackPrice) = disparityMa × (1 ± disparityNeutralPct/100).
//   - 손절     = 같은 방향 '바깥쪽' 엣지 = disparityMa × (1 ± disparityStopPct/100), disparityStopPct = disparityNeutralPct × retStopMult.
//     (이격이 더 벌어져 되돌림이 무효화되는 지점 — 되돌림 이익 프레임워크와 동일 척도).
//   롱(과매도, underCount≥1): retStopPrice = disparityMa × (1 − disparityStopPct/100)  // 현재가 아래(더 벌어짐)
//   숏(과열,   overCount≥1): retStopPrice = disparityMa × (1 + disparityStopPct/100)  // 현재가 위
//   방향 검증: 롱은 손절가가 현재가 아래·숏은 위여야 유효. 가격이 이미 바깥 엣지 너머면 방향이 뒤집혀 순수 E 계산불가.
//   RR(순수) = retReward/retRisk (둘 다 종가 대비 % — retReward=|되돌림가−close|/close·retRisk=|손절가−close|/close).
//  [고정손절 폴백] 되돌림 주의/확실(disparityPullbackPrice not na)인데 순수 E가 계산불가일 때만 발동.
//   손절%를 disparityState로 분기(주의→retFixedStopWarn·확실→retFixedStopSure). 손절가 = 롱 close×(1−%/100)·숏 close×(1+%/100) → 항상 현재가 바깥이라 유효.
//   RR(폴백) = retReward / 고정손절%. 이익 목표는 순수 E와 동일(disparityPullbackPrice).
//   → 되돌림 주의/확실 국면에서는 (순수 E 유효 시 E값, 아니면 폴백)으로 항상 계산됨 — 계산불가가 사라진다.
//  방향 접두: 과매도(롱 방향, underCount≥1)면 "L "·과열(숏 방향, overCount≥1)면 "S ".
//  계산 불가(na)로 남는 경우: disparityPullbackPrice na(중립=되돌림 없음, 정상) · disparityMa na 또는 0 · close==0 · retReward≤0. (중립일 때만 계산불가)
disparityStopPct = disparityNeutralPct * retStopMult
retMaOk = not na(disparityMa) and disparityMa != 0
retStopPriceRaw = retMaOk ? (underCount >= 1 ? disparityMa * (1 - disparityStopPct / 100) : overCount >= 1 ? disparityMa * (1 + disparityStopPct / 100) : na) : na
// 손절 방향 검증: 롱은 손절가가 현재가 아래, 숏은 위여야 유효. 아니면 na(→ 폴백 대상).
retStopPrice = not na(retStopPriceRaw) ? (underCount >= 1 ? (retStopPriceRaw < close ? retStopPriceRaw : na) : overCount >= 1 ? (retStopPriceRaw > close ? retStopPriceRaw : na) : na) : na
retReward = not na(disparityPullbackPrice) and close != 0 ? math.abs(disparityPullbackPrice - close) / close * 100 : na
retRisk = not na(retStopPrice) and close != 0 ? math.abs(retStopPrice - close) / close * 100 : na
// risk가 mintick 이하로 좁으면(RR 무한대·왜곡) 계산 불가 처리.
retRiskOk = not na(retRisk) and not na(retStopPrice) and math.abs(retStopPrice - close) > syminfo.mintick and retRisk > 0
retRRPure = (not na(retReward) and retRiskOk and retReward > 0) ? retReward / retRisk : na
retPfx = underCount >= 1 ? "L " : overCount >= 1 ? "S " : ""
// 고정손절 폴백: 되돌림 주의/확실(disparityPullbackPrice not na)인데 순수 E(retRRPure) na일 때만.
retFixedPct = disparityState == "되돌림 확실" ? retFixedStopSure : retFixedStopWarn
retUseFixed = na(retRRPure) and not na(disparityPullbackPrice) and not na(retReward) and retReward > 0 and retPfx != ""
retRRFixed = retUseFixed and retFixedPct > 0 ? retReward / retFixedPct : na
// 폴백 셀: 괄호 안 손절 자리를 "고정 -X.X%"로 통합 렌더(외부 태그 제거). 순수 E 유효 케이스는 f_rrText 그대로.
retText = not na(retRRPure) ? f_rrText(retPfx, retRRPure, retReward, retRisk) : (not na(retRRFixed) ? f_rrTextFixed(retPfx, retRRFixed, retReward, retFixedPct) : "계산 불가")
// 셀 색이 참조할 실제 표시 RR = 순수 E 우선, 없으면 폴백(retText와 동일 우선순위). 둘 다 na면 na(회색).
retRR = not na(retRRPure) ? retRRPure : retRRFixed

var table triggerTable = table.new(position.top_right, 2, 25, border_width=1, border_color=color.new(color.gray, 50))
if barstate.islast
    // ── 섹션 1: [추세 확인] (row 0, 병합 헤더) — 기존 "항목|값" 헤더를 섹션 헤더로 대체.
    //    스타일 통일: merge_cells · 딥 네이비 배경 #1B2A4A · 흰 글자 · size.small (값 열은 빈 문자열 후 병합).
    table.cell(triggerTable, 0, 0, "추세 확인", text_color=color.white, bgcolor=color.new(#1B2A4A, 0), text_size=size.small)
    table.cell(triggerTable, 1, 0, "", text_color=color.white, bgcolor=color.new(#1B2A4A, 0), text_size=size.small)
    table.merge_cells(triggerTable, 0, 0, 1, 0)

    // N봉(시간 조정) 투영 — 모멘텀 모드면 트리거와 동일하게 한 단계 빠른 기간(conv/base 길이)으로 시프트.
    //  0.5×: 정상 (c05,b05) / 모멘텀 (c025,b025) · 1×: 정상 (conv,base) / 모멘텀 (c05,b05) · 2×: 정상 (c20,b20) / 모멘텀 (conv,base)
    int nbConv05 = momentum ? c025 : c05
    int nbBase05 = momentum ? b025 : b05
    int nbConv10 = momentum ? c05 : conversionPeriods
    int nbBase10 = momentum ? b05 : basePeriods
    int nbConv20 = momentum ? conversionPeriods : c20
    int nbBase20 = momentum ? basePeriods : b20
    // prefix 극값 배열을 6개 스케일 호출 중 최대 need만큼 1회 구축(공유). 각 호출은 자기 need 범위만 참조.
    int nbMaxNeed = math.max(math.max(math.max(nbConv05, nbBase05), math.max(nbConv10, nbBase10)), math.max(nbConv20, nbBase20))
    int nbLen = math.min(bar_index + 1, nbMaxNeed)
    var float[] nbPHi = array.new_float(0)
    var float[] nbPLo = array.new_float(0)
    f_buildPrefixExtremes(nbLen, nbPHi, nbPLo)
    table.cell(triggerTable, 0, 1, "상승 전환(0.5×)", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 1, f_trigCell(buyBlocked05, buyTrig05, true, donB05, momentum, f_nbarsToCross(nbConv05, nbBase05, true, nbPHi, nbPLo), vwTrig05), text_color=color.white, bgcolor=f_trigBg(buyBlocked05, buyTrig05, true), text_size=size.small)
    table.cell(triggerTable, 0, 2, "상승 전환(1×)", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 2, f_trigCell(buyBlocked10, buyTrig10, true, baseLine, momentum, f_nbarsToCross(nbConv10, nbBase10, true, nbPHi, nbPLo), vwTrig10), text_color=color.white, bgcolor=f_trigBg(buyBlocked10, buyTrig10, true), text_size=size.small)
    table.cell(triggerTable, 0, 3, "상승 전환(2×)", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 3, f_trigCell(buyBlocked20, buyTrig20, true, donB20, momentum, f_nbarsToCross(nbConv20, nbBase20, true, nbPHi, nbPLo), vwTrig20), text_color=color.white, bgcolor=f_trigBg(buyBlocked20, buyTrig20, true), text_size=size.small)

    table.cell(triggerTable, 0, 4, "하락 전환(0.5×)", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 4, f_trigCell(sellBlocked05, sellTrig05, false, donB05, momentum, f_nbarsToCross(nbConv05, nbBase05, false, nbPHi, nbPLo), vwTrig05), text_color=color.white, bgcolor=f_trigBg(sellBlocked05, sellTrig05, false), text_size=size.small)
    table.cell(triggerTable, 0, 5, "하락 전환(1×)", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 5, f_trigCell(sellBlocked10, sellTrig10, false, baseLine, momentum, f_nbarsToCross(nbConv10, nbBase10, false, nbPHi, nbPLo), vwTrig10), text_color=color.white, bgcolor=f_trigBg(sellBlocked10, sellTrig10, false), text_size=size.small)
    table.cell(triggerTable, 0, 6, "하락 전환(2×)", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 6, f_trigCell(sellBlocked20, sellTrig20, false, donB20, momentum, f_nbarsToCross(nbConv20, nbBase20, false, nbPHi, nbPLo), vwTrig20), text_color=color.white, bgcolor=f_trigBg(sellBlocked20, sellTrig20, false), text_size=size.small)

    table.cell(triggerTable, 0, 7, "리본 추세", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 7, ribbonCellText, text_color=color.white, bgcolor=ribbonCellColor, text_size=size.small)

    // ── 섹션 2: [캔들 및 되돌림 확인] (row 8, 병합 헤더) — 캔들 상태 → 비정상 → 이격도 → 되돌림.
    table.cell(triggerTable, 0, 8, "캔들 및 되돌림 확인", text_color=color.white, bgcolor=color.new(#1B2A4A, 0), text_size=size.small)
    table.cell(triggerTable, 1, 8, "", text_color=color.white, bgcolor=color.new(#1B2A4A, 0), text_size=size.small)
    table.merge_cells(triggerTable, 0, 8, 1, 8)

    // 캔들 상태 (3) — 표시 전용. 이 섹션 맨 앞(비정상 매수/매도 바로 위, row 9). 우열은 "분류명 | 근거패턴" + 7분류 배경색(현재봉 캔들 바색과 동일).
    if candleShowState
        table.cell(triggerTable, 0, 9, "캔들 상태 (3)", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
        table.cell(triggerTable, 1, 9, candleCellText, text_color=color.white, bgcolor=candleCellColor, text_size=size.small)

    // 캔들 손절라인 (row 10) — 표시 전용. 캔들 상태(3) 바로 아래. 방향은 캔들 상태 7분류 재사용(하락=3봉 최고점 S+·상승=3봉 최저점 L−·혼조 −). 셀 색 = 캔들 상태(3)와 동일.
    table.cell(triggerTable, 0, 10, "캔들 손절라인", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 10, candleStopCellText, text_color=color.white, bgcolor=candleStopCellColor, text_size=size.small)

    table.cell(triggerTable, 0, 11, "비정상 매수/매도", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 11, abnCellText, text_color=color.white, bgcolor=abnCellColor, text_size=size.small)
    table.cell(triggerTable, 0, 12, "이격도 (" + str.tostring(disparityMaLen) + ")", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 12, disparityCellText, text_color=color.white, bgcolor=disparityCellColor, text_size=size.small)
    table.cell(triggerTable, 0, 13, "되돌림 가격", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 13, na(disparityPullbackPrice) ? "-" : f_price(disparityPullbackPrice) + " (" + f_pct(disparityPullbackPrice) + ")", text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)

    // ── 섹션 3: [지지/저항 확인] (row 14, 병합 헤더) — 구름대 → VWAP 지지/저항 → VWAP 상태 → 장기 추세 → 장기 지지/저항.
    table.cell(triggerTable, 0, 14, "지지/저항 확인", text_color=color.white, bgcolor=color.new(#1B2A4A, 0), text_size=size.small)
    table.cell(triggerTable, 1, 14, "", text_color=color.white, bgcolor=color.new(#1B2A4A, 0), text_size=size.small)
    table.merge_cells(triggerTable, 0, 14, 1, 14)

    table.cell(triggerTable, 0, 15, "구름대", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 15, cloudCellText, text_color=color.white, bgcolor=cloudCellColor, text_size=size.small)

    table.cell(triggerTable, 0, 16, "VWAP 지지/저항", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 16, vwSrText, text_color=color.white, bgcolor=vwSrColor, text_size=size.small)
    // VWAP 변곡(N) — N=청산선 길이 ceLength(변곡용 VWAP length과 동일). 상태=롱/숏/양방 수축/무신호. 확정봉 latch(리페인팅 방지). 표시 전용.
    table.cell(triggerTable, 0, 17, "VWAP 변곡(" + str.tostring(ceLength) + ")", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 17, ipShowInflection ? ipInflectionText : "-", text_color=color.white, bgcolor=ipShowInflection ? ipInflectionColor : color.new(color.gray, 40), text_size=size.small)
    // VWAP 상태(N) — N=기본 화면판정 VWAP 길이 vwapRecentBars. 모양값(기울기 | 확장·수축(밴드폭%) | 상태값). 셀 색은 밴드 상태 기준(밴드워킹 상단=초록·하단=빨강).
    table.cell(triggerTable, 0, 18, "VWAP 상태(" + str.tostring(vwapRecentBars) + ")", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 18, vwSlopeText + " | " + vwBwStateText + " | " + vwBandStateShort, text_color=color.white, bgcolor=vwBandColor, text_size=size.small)

    table.cell(triggerTable, 0, 19, "장기 추세", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 19, ltCellText, text_color=color.white, bgcolor=ltCellColor, text_size=size.small)
    table.cell(triggerTable, 0, 20, "장기 지지/저항", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 20, ltSrText, text_color=color.white, bgcolor=ltSrColor, text_size=size.small)

    // ── 섹션 4: [손익비 현황 확인] (row 21, 병합 헤더) — 텍스트만 수정, 스타일 동일.
    table.cell(triggerTable, 0, 21, "손익비 현황 확인", text_color=color.white, bgcolor=color.new(#1B2A4A, 0), text_size=size.small)
    table.cell(triggerTable, 1, 21, "", text_color=color.white, bgcolor=color.new(#1B2A4A, 0), text_size=size.small)
    table.merge_cells(triggerTable, 0, 21, 1, 21)

    // 손익비(RR) 3행 — Cha(청산선, 주 손익비·색 로직) / Ret(되돌림, 회색). (VWAP(밴드2) 2행은 CEO 지시로 제거.)
    //  (1) Cha 롱/숏 — 청산선 범위 밖이면 "계산 불가", 셀 색 = f_rrColor(유리/중립/불리/계산불가).
    table.cell(triggerTable, 0, 22, "Cha 롱 손익비", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 22, chaLongText, text_color=color.white, bgcolor=f_rrColor(chaLongRR), text_size=size.small)
    table.cell(triggerTable, 0, 23, "Cha 숏 손익비", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 23, chaShortText, text_color=color.white, bgcolor=f_rrColor(chaShortRR), text_size=size.small)
    //  (2) Ret 롱숏 — 되돌림 가격 기준(1행 통합), 셀 색 = f_retRrColor(≥5 녹/3~5 둔탁녹/<3·na 회색). L=과매도(롱)·S=과열(숏)·없으면 "계산 불가".
    table.cell(triggerTable, 0, 24, "Ret 롱숏 손익비", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 24, retText, text_color=color.white, bgcolor=f_retRrColor(retRR), text_size=size.small)

// 이평 기반 상태 표식(+ 모양) (압축=보라 #9C27B0[상승·하락과 확실히 구분], 상승 분출=파랑, 하락 분출=빨강)
// 먼저 그려서 아래 신호 삼각형보다 뒤(아래 레이어)에 오게 한다.
plotshape(series=ribbonChop, title="횡보 압축 (아래)", style=shape.cross, location=location.belowbar, color=color.new(#9C27B0, 0), size=size.tiny)
plotshape(series=ribbonChop, title="횡보 압축 (위)", style=shape.cross, location=location.abovebar, color=color.new(#9C27B0, 0), size=size.tiny)
plotshape(series=ribbonBull, title="상승 분출", style=shape.cross, location=location.belowbar, color=color.new(color.blue, 0), size=size.tiny)
plotshape(series=ribbonBear, title="하락 분출", style=shape.cross, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny)

// 신호 삼각형 — 리본 표식 뒤에(나중에) 그려 위 레이어로. 스케일별 크기: 0.5×=가장 작음, 1×=작음, 2×=보통
// 모멘텀 모드로 발생한 신호는 전용 색(롱=파랑, 숏=크림슨)으로 정상 신호(매수=아쿠아, 매도=핑크)와 구분.
//  (구: 스윕/청산 블록의 청산선 색을 재사용했으나, 청산선 페인팅이 auto-vwap 으로 이동하며 그 input이 제거돼
//   여기 전용 색 input 으로 분리. 기본값(#2979FF/#FF1744)은 종전과 동일해 외관 불변.)
momBuySignalColor = input.color(#2979FF, title="모멘텀 매수 신호 색", group="신호 표시", tooltip="모멘텀 모드에서 발생한 매수 신호 삼각형 색(롱=파랑). 정상 신호(아쿠아)와 구분용. 표시 전용.")
momSellSignalColor = input.color(#FF1744, title="모멘텀 매도 신호 색", group="신호 표시", tooltip="모멘텀 모드에서 발생한 매도 신호 삼각형 색(숏=크림슨). 정상 신호(핑크)와 구분용. 표시 전용.")
momBuyColor = momentum ? momBuySignalColor : defaultBuyColor
momSellColor = momentum ? momSellSignalColor : defaultSellColor
// 신호 삼각형은 최종 발화(sBuyXX/sSellXX) 기준 — 정상 봉은 확정봉(fBuyXX, 다음 봉 확정 시·1봉 지연·휩쏘 필터), 혼합 비정상 봉은 그 봉 즉시(iBuyXX).
// 소스 택일(sigVw): 거래량 가중 전용 모드(sigVw)=VWMA 신호(vwBuyXX/vwSellXX, 파이프라인 우회)만. 그 외(not sigVw)=파이프라인/최종 발화 신호(sBuyXX/sSellXX)만.
//  혼합 모드(sigHybrid)는 sigVw=false라 여기서 not sigVw 경로로 sBuyXX/sSellXX 삼각형을 그린다. 비정상 봉은 sBuyXX=iBuyXX(즉시), 정상 봉은 sBuyXX=fBuyXX.
//  sBuyXX는 혼합 파이프라인/즉시 발화 dir을 함께 반영하므로 차트 삼각형과 테이블 추세(dirXX)가 같은 소스를 참조 → 정합.
//  예측/확정 방식은 sigPredict(=isPredict)가 신호 계산 단계에서 이미 반영 — 여기선 소스 택일만. 계산식·파이프라인 무변경(비정상 봉 즉시 발화 경로만 신규).
plotshape(showBuySignal and not sigVw and sBuy05, title="매수 0.5×", style=shape.triangleup, location=location.belowbar, color=momBuyColor, size=size.tiny)
plotshape(showBuySignal and not sigVw and sBuy10, title="매수 1×", style=shape.triangleup, location=location.belowbar, color=momBuyColor, size=size.small)
plotshape(showBuySignal and not sigVw and sBuy20, title="매수 2×", style=shape.triangleup, location=location.belowbar, color=momBuyColor, size=size.normal)
plotshape(showSellSignal and not sigVw and sSell05, title="매도 0.5×", style=shape.triangledown, location=location.abovebar, color=momSellColor, size=size.tiny)
plotshape(showSellSignal and not sigVw and sSell10, title="매도 1×", style=shape.triangledown, location=location.abovebar, color=momSellColor, size=size.small)
plotshape(showSellSignal and not sigVw and sSell20, title="매도 2×", style=shape.triangledown, location=location.abovebar, color=momSellColor, size=size.normal)
plotshape(showBuySignal and sigVw and vwBuy05, title="매수 0.5× (거래량)", style=shape.triangleup, location=location.belowbar, color=color.new(momBuyColor, 0), size=size.tiny)
plotshape(showBuySignal and sigVw and vwBuy10, title="매수 1× (거래량)", style=shape.triangleup, location=location.belowbar, color=color.new(momBuyColor, 0), size=size.small)
plotshape(showBuySignal and sigVw and vwBuy20, title="매수 2× (거래량)", style=shape.triangleup, location=location.belowbar, color=color.new(momBuyColor, 0), size=size.normal)
plotshape(showSellSignal and sigVw and vwSell05, title="매도 0.5× (거래량)", style=shape.triangledown, location=location.abovebar, color=color.new(momSellColor, 0), size=size.tiny)
plotshape(showSellSignal and sigVw and vwSell10, title="매도 1× (거래량)", style=shape.triangledown, location=location.abovebar, color=color.new(momSellColor, 0), size=size.small)
plotshape(showSellSignal and sigVw and vwSell20, title="매도 2× (거래량)", style=shape.triangledown, location=location.abovebar, color=color.new(momSellColor, 0), size=size.normal)

alertcondition(ribbonChop, title="횡보 압축", message="Ribbon compressed (chop) — Ichimoku signals unreliable.")
alertcondition(ribbonBull, title="상승 분출", message="Ribbon bullish expansion after compression.")
alertcondition(ribbonBear, title="하락 분출", message="Ribbon bearish expansion after compression.")
