//@version=6
indicator("Abnormal-Price-Tracker-Helper", shorttitle="Abnormal-Price-Tracker-Helper", overlay=false)

// ==========================
// INPUT
// ==========================
src = input.source(close, "Source")

// cRSI
domcycle = input.int(20, minval=10, title="cRSI Dominant Cycle")
vibration = input.int(10, minval=1, title="cRSI Vibration")
leveling = input.float(10.0, minval=1.0, maxval=50.0, title="cRSI Leveling %")

// MFI
mfiLength = input.int(14, minval=1, title="MFI Length")

// ==========================
// LINE OPTIONS
// ==========================
showCrsiLine = input.bool(false, title="Show cRSI Line")
crsiColor = input.color(color.aqua, title="cRSI Color")
mfiColor = input.color(color.yellow, title="MFI Color")
crsiWidth = input.int(1, minval=1, maxval=5, title="cRSI Line Width")
mfiWidth = input.int(1, minval=1, maxval=5, title="MFI Line Width")
crsiBandColor = input.color(color.aqua, title="cRSI Band Color")
crsiBandWidth = input.int(1, minval=1, maxval=5, title="cRSI Band Width")
crsiBandFillColor = input.color(color.blue, title="cRSI Band Fill Color")
crsiBandFillTransparency = input.int(88, minval=0, maxval=100, title="cRSI Band Fill Transparency")

// ==========================
// REVERSAL RISK FILTER OPTIONS
// ==========================
gapThreshold = input.float(18.0, minval=1.0, title="Gap Threshold")
weakGapThreshold = input.float(10.0, minval=0.0, title="Weak Gap Threshold")
strongGapThreshold = input.float(14.0, minval=0.0, title="Strong Gap Threshold")
bullZone = input.float(55.0, minval=0.0, maxval=100.0, title="Bearish Risk cRSI Zone")
bearZone = input.float(45.0, minval=0.0, maxval=100.0, title="Bullish Risk cRSI Zone")
volumeAvgLength = input.int(3, minval=1, title="Volume Average Length")
volumeMultiplier = input.float(1.0, minval=0.1, step=0.1, title="Volume Multiplier")
trendLength = input.int(5, minval=2, title="Trend Length")
priceStretchThreshold = input.float(1.5, minval=0.1, step=0.1, title="Price Stretch (%)")
useGapFade = input.bool(true, title="Use Gap Fade Condition")
gapFadeLookback = input.int(1, minval=1, maxval=5, title="Gap Fade Lookback")

// ==========================
// cRSI CALCULATION
// ==========================
cyclelen = math.max(1, int(domcycle / 2))
cyclicmemory = domcycle * 2
torque = 2.0 / (vibration + 1)
phasingLag = int((vibration - 1) / 2.0)

sourceChange = ta.change(src)
up = ta.rma(math.max(sourceChange, 0), cyclelen)
down = ta.rma(-math.min(sourceChange, 0), cyclelen)
rsi = down == 0 ? 100 : up == 0 ? 0 : 100 - 100 / (1 + up / down)

var float crsi = na
crsi := torque * (2 * rsi - nz(rsi[phasingLag])) + (1 - torque) * nz(crsi[1])

// ==========================
// DYNAMIC BANDS
// ==========================
float db = na
float ub = na
bandPercent = math.max(0.0, math.min(100.0, leveling))
inverseBandPercent = 100.0 - bandPercent

db := ta.percentile_nearest_rank(crsi, cyclicmemory, bandPercent)
ub := ta.percentile_nearest_rank(crsi, cyclicmemory, inverseBandPercent)

// ==========================
// MFI
// ==========================
overboughtLevel = 80.0
oversoldLevel = 20.0

mfi = ta.mfi(hlc3, mfiLength)
isMfiOverbought = mfi >= overboughtLevel
isMfiOversold = mfi <= oversoldLevel
mfiOverboughtFillColor = color.rgb(255, 90, 90)
mfiOversoldFillColor = color.rgb(90, 255, 120)

// ==========================
// PRICE / VOLUME / REVERSAL STATE
// ==========================
gap = math.abs(crsi - mfi)
bearishGapBg = crsi > mfi and gap >= gapThreshold
bullishGapBg = mfi > crsi and gap >= gapThreshold

volAvg = ta.sma(volume, volumeAvgLength)
volumeOkay = volume > volAvg * volumeMultiplier
isBullCandle = close > open
isBearCandle = close < open

priceEma = ta.ema(close, trendLength)
priceStretchPct = priceEma != 0 ? (close - priceEma) / priceEma * 100.0 : 0.0
priceExtendedUp = close > close[trendLength] and priceStretchPct >= priceStretchThreshold
priceExtendedDown = close < close[trendLength] and priceStretchPct <= -priceStretchThreshold

bearishGap = crsi - mfi
bullishGap = mfi - crsi

bearishGapScore = bearishGap > strongGapThreshold ? 2 : bearishGap > weakGapThreshold ? 1 : 0
bullishGapScore = bullishGap > strongGapThreshold ? 2 : bullishGap > weakGapThreshold ? 1 : 0

bearishZonePass = crsi >= bullZone or (not na(ub) and crsi >= ub)
bullishZonePass = crsi <= bearZone or (not na(db) and crsi <= db)

bearishGapFade = bearishGap < bearishGap[gapFadeLookback]
bullishGapFade = bullishGap < bullishGap[gapFadeLookback]

crsiTurningDown = crsi < crsi[1]
crsiTurningUp = crsi > crsi[1]
mfiTurningDown = mfi < mfi[1]
mfiTurningUp = mfi > mfi[1]

// ==========================
// SCORE
// Max score = 7
// ==========================
bearishRiskScore = 0
bearishRiskScore += bearishGapBg ? 1 : 0
bearishRiskScore += bearishGapScore
bearishRiskScore += priceExtendedUp ? 1 : 0
bearishRiskScore += volumeOkay ? 1 : 0
bearishRiskScore += bearishZonePass ? 1 : 0
bearishRiskScore += ((useGapFade and bearishGapFade) or (not useGapFade and crsiTurningDown)) ? 1 : 0
bearishRiskScore += (crsiTurningDown or mfiTurningDown) ? 1 : 0

bullishRiskScore = 0
bullishRiskScore += bullishGapBg ? 1 : 0
bullishRiskScore += bullishGapScore
bullishRiskScore += priceExtendedDown ? 1 : 0
bullishRiskScore += volumeOkay ? 1 : 0
bullishRiskScore += bullishZonePass ? 1 : 0
bullishRiskScore += ((useGapFade and bullishGapFade) or (not useGapFade and crsiTurningUp)) ? 1 : 0
bullishRiskScore += (crsiTurningUp or mfiTurningUp) ? 1 : 0

bearishRiskRaw = bearishGapBg and isBullCandle and bearishRiskScore >= 4 and bullishRiskScore < 4
bullishRiskRaw = bullishGapBg and isBearCandle and bullishRiskScore >= 4 and bearishRiskScore < 4

bearishMfiFilterPass = mfi > oversoldLevel
bullishMfiFilterPass = mfi < overboughtLevel

// ==========================
// CONFIRMED SIGNAL
// ==========================
finalBearishRiskConfirmed = barstate.isconfirmed and bearishRiskRaw and bearishMfiFilterPass
finalBullishRiskConfirmed = barstate.isconfirmed and bullishRiskRaw and bullishMfiFilterPass

// ==========================
// ALERTS
// ==========================
alertcondition(finalBearishRiskConfirmed, title="Bearish Reversal Risk", message="Bearish reversal risk detected")
alertcondition(finalBullishRiskConfirmed, title="Bullish Reversal Risk", message="Bullish reversal risk detected")

// ==========================
// REFERENCE LINES
// ==========================
hline(overboughtLevel, "Overbought", color=color.gray, linestyle=hline.style_dashed, linewidth=1)
hline(oversoldLevel, "Oversold", color=color.gray, linestyle=hline.style_dashed, linewidth=1)

// ==========================
// PLOTS
// ==========================
lowBandPlot = plot(db, "cRSI Low Band", color=crsiBandColor, linewidth=crsiBandWidth, display=display.pane)
highBandPlot = plot(ub, "cRSI High Band", color=crsiBandColor, linewidth=crsiBandWidth, display=display.pane)
mfiPlot = plot(mfi, "MFI", color=mfiColor, linewidth=mfiWidth)
overboughtFillBase = plot(isMfiOverbought ? overboughtLevel : na, "Overbought Fill Base", color=color.new(mfiOverboughtFillColor, 100), linewidth=1, style=plot.style_linebr, display=display.pane)
oversoldFillBase = plot(isMfiOversold ? oversoldLevel : na, "Oversold Fill Base", color=color.new(mfiOversoldFillColor, 100), linewidth=1, style=plot.style_linebr, display=display.pane)
plot(showCrsiLine ? crsi : na, "cRSI", color=crsiColor, linewidth=crsiWidth)
fill(lowBandPlot, highBandPlot, color=color.new(crsiBandFillColor, crsiBandFillTransparency))
fill(overboughtFillBase, mfiPlot, color=mfiOverboughtFillColor, fillgaps=false)
fill(oversoldFillBase, mfiPlot, color=mfiOversoldFillColor, fillgaps=false)
