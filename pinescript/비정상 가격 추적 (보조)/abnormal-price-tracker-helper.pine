//@version=6
indicator("abnormal-price-tracker-helper", shorttitle="abnormal-price-tracker-helper", overlay=false, max_labels_count=500)

// ==========================
// INPUT
// ==========================
src = input.source(close, "Source")

// cRSI
domcycle = input.int(20, minval=10, title="cRSI Dominant Cycle")
vibration = input.int(10, minval=1, title="cRSI Vibration")
leveling = input.float(10.0, minval=1.0, maxval=50.0, title="cRSI Leveling %")

// MFI
mfiLength = input.int(14, minval=1, title="MFI Length")

// ==========================
// LINE OPTIONS
// ==========================
crsiColor = input.color(color.yellow, title="cRSI Color")
mfiColor = input.color(color.blue, title="MFI Color")
crsiWidth = input.int(1, minval=1, maxval=5, title="cRSI Line Width")
mfiWidth = input.int(1, minval=1, maxval=5, title="MFI Line Width")

// ==========================
// GAP BACKGROUND OPTIONS
// ==========================
showGapBg = input.bool(true, title="Show Gap Background")
gapThreshold = input.float(18.0, minval=1.0, title="Gap Background Threshold")
gapCrsiColor = input.color(color.yellow, title="Gap Color (cRSI > MFI)")
gapMfiColor = input.color(color.blue, title="Gap Color (MFI > cRSI)")
gapTransparency = input.int(85, minval=0, maxval=100, title="Gap Background Transparency")

// ==========================
// REVERSAL RISK OPTIONS
// ==========================
showRiskLabels = input.bool(true, title="Show Reversal Risk Labels")
weakGapThreshold = input.float(10.0, minval=0.0, title="Weak Gap Threshold")
strongGapThreshold = input.float(14.0, minval=0.0, title="Strong Gap Threshold")
bullZone = input.float(55.0, minval=0.0, maxval=100.0, title="Bearish Risk cRSI Zone")
bearZone = input.float(45.0, minval=0.0, maxval=100.0, title="Bullish Risk cRSI Zone")
volumeAvgLength = input.int(3, minval=1, title="Volume Average Length")
volumeMultiplier = input.float(1.0, minval=0.1, step=0.1, title="Volume Multiplier")
trendLength = input.int(5, minval=2, title="Trend Length")
priceStretchThreshold = input.float(1.5, minval=0.1, step=0.1, title="Price Stretch (%)")
useGapFade = input.bool(true, title="Use Gap Fade Condition")
gapFadeLookback = input.int(1, minval=1, maxval=5, title="Gap Fade Lookback")
riskLabelTransparency = input.int(0, minval=0, maxval=100, title="Risk Label Transparency")
bearishLabelOffset = input.float(6.0, minval=0.0, maxval=30.0, title="Bearish Label Offset")
bullishLabelOffset = input.float(6.0, minval=0.0, maxval=30.0, title="Bullish Label Offset")

// ==========================
// COLORS
// ==========================
bearishRiskColor = color.new(color.red, riskLabelTransparency)
bullishRiskColor = color.new(color.green, riskLabelTransparency)

// ==========================
// cRSI CALCULATION
// ==========================
cyclelen = math.max(1, int(domcycle / 2))
cyclicmemory = domcycle * 2
torque = 2.0 / (vibration + 1)
phasingLag = int((vibration - 1) / 2.0)

up = ta.rma(math.max(ta.change(src), 0), cyclelen)
down = ta.rma(-math.min(ta.change(src), 0), cyclelen)
rsi = down == 0 ? 100 : up == 0 ? 0 : 100 - 100 / (1 + up / down)

var float crsi = na
crsi := torque * (2 * rsi - nz(rsi[phasingLag])) + (1 - torque) * nz(crsi[1])

// ==========================
// DYNAMIC BANDS
// ==========================
float lmax = -999999.0
float lmin = 999999.0
int validCount = 0

for i = 0 to cyclicmemory - 1
    val = crsi[i]
    if not na(val)
        validCount += 1
        if val > lmax
            lmax := val
        if val < lmin
            lmin := val

mstep = validCount > 0 ? (lmax - lmin) / 100.0 : na
aperc = leveling / 100.0

float db = na
if validCount > 0 and not na(mstep)
    if mstep == 0
        db := lmin
    else
        for steps = 0 to 100
            testvalue = lmin + mstep * steps
            below = 0
            for m = 0 to cyclicmemory - 1
                sample = crsi[m]
                below += not na(sample) and sample < testvalue ? 1 : 0
            ratio = below / validCount
            if ratio >= aperc
                db := testvalue
                break

float ub = na
if validCount > 0 and not na(mstep)
    if mstep == 0
        ub := lmax
    else
        for steps = 0 to 100
            testvalue = lmax - mstep * steps
            above = 0
            for m = 0 to cyclicmemory - 1
                sample = crsi[m]
                above += not na(sample) and sample >= testvalue ? 1 : 0
            ratio = above / validCount
            if ratio >= aperc
                ub := testvalue
                break

// ==========================
// MFI
// ==========================
mfi = ta.mfi(hlc3, mfiLength)

// ==========================
// GAP BACKGROUND
// ==========================
gap = math.abs(crsi - mfi)
bearishGapBg = crsi > mfi and gap >= gapThreshold
bullishGapBg = mfi > crsi and gap >= gapThreshold

bgcolor(showGapBg ? bearishGapBg ? color.new(gapCrsiColor, gapTransparency) : bullishGapBg ? color.new(gapMfiColor, gapTransparency) : na : na)

// ==========================
// PRICE / VOLUME / REVERSAL STATE
// ==========================
volAvg = ta.sma(volume, volumeAvgLength)
volumeOkay = volume > volAvg * volumeMultiplier
isBullCandle = close > open
isBearCandle = close < open

priceEma = ta.ema(close, trendLength)
priceStretchPct = priceEma != 0 ? (close - priceEma) / priceEma * 100.0 : 0.0
priceExtendedUp = close > close[trendLength] and priceStretchPct >= priceStretchThreshold
priceExtendedDown = close < close[trendLength] and priceStretchPct <= -priceStretchThreshold

bearishGap = crsi - mfi
bullishGap = mfi - crsi

bearishGapScore = bearishGap > strongGapThreshold ? 2 : bearishGap > weakGapThreshold ? 1 : 0
bullishGapScore = bullishGap > strongGapThreshold ? 2 : bullishGap > weakGapThreshold ? 1 : 0

bearishZonePass = crsi >= bullZone or (not na(ub) and crsi >= ub)
bullishZonePass = crsi <= bearZone or (not na(db) and crsi <= db)

bearishGapFade = bearishGap < bearishGap[gapFadeLookback]
bullishGapFade = bullishGap < bullishGap[gapFadeLookback]

crsiTurningDown = crsi < crsi[1]
crsiTurningUp = crsi > crsi[1]
mfiTurningDown = mfi < mfi[1]
mfiTurningUp = mfi > mfi[1]

// ==========================
// SCORE
// Max score = 7
// ==========================
bearishRiskScore = 0
bearishRiskScore += bearishGapBg ? 1 : 0
bearishRiskScore += bearishGapScore
bearishRiskScore += priceExtendedUp ? 1 : 0
bearishRiskScore += volumeOkay ? 1 : 0
bearishRiskScore += bearishZonePass ? 1 : 0
bearishRiskScore += ((useGapFade and bearishGapFade) or (not useGapFade and crsiTurningDown)) ? 1 : 0
bearishRiskScore += (crsiTurningDown or mfiTurningDown) ? 1 : 0

bullishRiskScore = 0
bullishRiskScore += bullishGapBg ? 1 : 0
bullishRiskScore += bullishGapScore
bullishRiskScore += priceExtendedDown ? 1 : 0
bullishRiskScore += volumeOkay ? 1 : 0
bullishRiskScore += bullishZonePass ? 1 : 0
bullishRiskScore += ((useGapFade and bullishGapFade) or (not useGapFade and crsiTurningUp)) ? 1 : 0
bullishRiskScore += (crsiTurningUp or mfiTurningUp) ? 1 : 0

// ==========================
// STRENGTH
// 3 = strongest
// 2 = medium
// 1 = weakest
// ==========================
bearishRiskStrength = bearishRiskScore >= 7 ? 3 : bearishRiskScore >= 5 ? 2 : bearishRiskScore >= 4 ? 1 : 0
bullishRiskStrength = bullishRiskScore >= 7 ? 3 : bullishRiskScore >= 5 ? 2 : bullishRiskScore >= 4 ? 1 : 0

bearishRiskRaw = bearishGapBg and isBullCandle and bearishRiskStrength > 0 and bullishRiskStrength == 0
bullishRiskRaw = bullishGapBg and isBearCandle and bullishRiskStrength > 0 and bearishRiskStrength == 0

// ==========================
// CONFIRMED SIGNAL
// ==========================
finalBearishRiskConfirmed = barstate.isconfirmed and bearishRiskRaw
finalBullishRiskConfirmed = barstate.isconfirmed and bullishRiskRaw

// ==========================
// LABEL TEXT
// ==========================
bearishLabelText = bearishRiskStrength >= 2 ? "H" : "L"
bullishLabelText = bullishRiskStrength >= 2 ? "H" : "L"

// ==========================
// LABEL POSITION
// ==========================
bearishLabelPos = math.min(100.0, crsi + bearishLabelOffset)
bullishLabelPos = math.max(0.0, crsi - bullishLabelOffset)

// ==========================
// LABELS
// ==========================
if showRiskLabels and finalBearishRiskConfirmed
    label.new(bar_index, bearishLabelPos, bearishLabelText, style=label.style_label_down, color=bearishRiskColor, textcolor=color.white, size=size.small)

if showRiskLabels and finalBullishRiskConfirmed
    label.new(bar_index, bullishLabelPos, bullishLabelText, style=label.style_label_up, color=bullishRiskColor, textcolor=color.white, size=size.small)

// ==========================
// ALERTS
// ==========================
alertcondition(finalBearishRiskConfirmed, title="Bearish Reversal Risk", message="Bearish reversal risk detected")
alertcondition(finalBullishRiskConfirmed, title="Bullish Reversal Risk", message="Bullish reversal risk detected")

alertcondition(finalBearishRiskConfirmed and bearishRiskStrength >= 2, title="Bearish Reversal Risk (H)", message="Bearish reversal risk (H) detected")
alertcondition(finalBearishRiskConfirmed and bearishRiskStrength == 1, title="Bearish Reversal Risk (L)", message="Bearish reversal risk (L) detected")

alertcondition(finalBullishRiskConfirmed and bullishRiskStrength >= 2, title="Bullish Reversal Risk (H)", message="Bullish reversal risk (H) detected")
alertcondition(finalBullishRiskConfirmed and bullishRiskStrength == 1, title="Bullish Reversal Risk (L)", message="Bullish reversal risk (L) detected")

// ==========================
// REFERENCE LINES
// ==========================
hline(80, "Overbought", color=color.red)
hline(50, "Middle", color=color.gray)
hline(20, "Oversold", color=color.green)

// ==========================
// PLOTS
// ==========================
lowBandPlot = plot(db, "cRSI Low Band", color=color.gray)
highBandPlot = plot(ub, "cRSI High Band", color=color.gray)
plot(crsi, "cRSI", color=crsiColor, linewidth=crsiWidth)
plot(mfi, "MFI", color=mfiColor, linewidth=mfiWidth)
fill(lowBandPlot, highBandPlot, color=color.new(color.gray, 75))
