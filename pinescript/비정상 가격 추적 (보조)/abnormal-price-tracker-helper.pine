//@version=6
indicator("Abnormal-Price-Tracker-Helper", shorttitle="Abnormal-Price-Tracker-Helper", overlay=false)

// ==========================
// INPUT
// ==========================
baseGroup = "기본"
displayGroup = "표시"
bandGroup = "RSI 밴드"
riskGroup = "반전 위험"

src = input.source(close, "Source", group=baseGroup)
rsiLength = input.int(14, minval=1, title="RSI Length", group=baseGroup)
mfiLength = input.int(14, minval=1, title="MFI Length", group=baseGroup)

showRsiLine = input.bool(true, title="RSI 선 표시", group=displayGroup)
showMfiLine = input.bool(true, title="MFI 선 표시", group=displayGroup)
rsiColor = input.color(color.rgb(233, 30, 99), title="RSI Color", group=displayGroup)
mfiColor = input.color(color.rgb(33, 182, 203), title="MFI Color", group=displayGroup)

rsiBandColor = input.color(color.new(color.silver, 35), title="기본 밴드 색상", group=bandGroup)
narrowBandStateColor = input.color(color.rgb(255, 152, 0), title="좁은 밴드 색상", group=bandGroup)
narrowBandWidthThreshold = input.float(20.0, minval=0.0, step=0.1, title="좁은 밴드 폭 기준", group=bandGroup)
wideBandStateColor = input.color(color.rgb(168, 85, 247), title="넓은 밴드 색상", group=bandGroup)
wideBandWidthThreshold = input.float(40.0, minval=0.0, step=0.1, title="넓은 밴드 폭 기준", group=bandGroup)

gapThreshold = input.float(14.0, minval=1.0, title="Gap Background Threshold", group=riskGroup)
weakGapThreshold = input.float(10.0, minval=0.0, title="Weak Gap Threshold", group=riskGroup)
strongGapThreshold = input.float(18.0, minval=0.0, title="Strong Gap Threshold", group=riskGroup)
bullZone = input.float(55.0, minval=0.0, maxval=100.0, title="Bearish Risk RSI Zone", group=riskGroup)
bearZone = input.float(45.0, minval=0.0, maxval=100.0, title="Bullish Risk RSI Zone", group=riskGroup)
volumeAvgLength = input.int(20, minval=1, title="Volume Average Length", group=riskGroup)
volumeMultiplier = input.float(1.1, minval=0.1, step=0.1, title="Volume Multiplier", group=riskGroup)
trendLength = input.int(20, minval=2, title="Trend Length", group=riskGroup)
priceStretchThreshold = input.float(2.0, minval=0.1, step=0.1, title="Price Stretch (%)", group=riskGroup)
useGapFade = input.bool(true, title="Use Gap Fade Condition", group=riskGroup)
gapFadeLookback = input.int(2, minval=1, maxval=5, title="Gap Fade Lookback", group=riskGroup)
minRiskStrength = input.int(2, minval=1, maxval=3, title="보조 최소 강도", group=riskGroup)

defaultLineWidth = 2
defaultBandWidth = 1
defaultBandFillTransparency = 88
defaultStateFillTransparency = 88
fixedBandPercent = 10.0

formatPanelNumber(value) =>
    na(value) ? "N/A" : str.tostring(value, "#.##")

// ==========================
// RSI / MFI CALCULATION
// ==========================
rsiValue = ta.rsi(src, rsiLength)
mfi = ta.mfi(hlc3, mfiLength)

overboughtLevel = 80.0
oversoldLevel = 20.0
isMfiOverbought = mfi >= overboughtLevel
isMfiOversold = mfi <= oversoldLevel
mfiOverboughtFillColor = color.rgb(255, 90, 90)
mfiOversoldFillColor = color.rgb(90, 255, 120)

// ==========================
// DYNAMIC RSI BANDS
// ==========================
rsiBandLookback = int(math.max(40, rsiLength * 2))
inverseBandPercent = 100.0 - fixedBandPercent

db = ta.percentile_nearest_rank(rsiValue, rsiBandLookback, fixedBandPercent)
ub = ta.percentile_nearest_rank(rsiValue, rsiBandLookback, inverseBandPercent)

rsiBandRange = not na(ub) and not na(db) ? ub - db : na
isRsiBandNarrow = not na(rsiBandRange) and rsiBandRange <= narrowBandWidthThreshold
isRsiBandWide = not na(rsiBandRange) and rsiBandRange >= wideBandWidthThreshold
activeRsiBandLineColor = isRsiBandNarrow ? narrowBandStateColor : isRsiBandWide ? wideBandStateColor : rsiBandColor
activeRsiBandFillColor = isRsiBandNarrow ? color.new(narrowBandStateColor, defaultStateFillTransparency) : isRsiBandWide ? color.new(wideBandStateColor, defaultStateFillTransparency) : color.new(rsiBandColor, defaultBandFillTransparency)

// ==========================
// PRICE / VOLUME / REVERSAL STATE
// ==========================
gap = math.abs(rsiValue - mfi)
bearishGapBg = rsiValue > mfi and gap >= gapThreshold
bullishGapBg = mfi > rsiValue and gap >= gapThreshold

volAvg = ta.sma(volume, volumeAvgLength)
volumeOkay = volume > volAvg * volumeMultiplier
isBullCandle = close > open
isBearCandle = close < open

priceEma = ta.ema(close, trendLength)
priceStretchPct = priceEma != 0 ? (close - priceEma) / priceEma * 100.0 : 0.0
priceExtendedUp = close > close[trendLength] and priceStretchPct >= priceStretchThreshold
priceExtendedDown = close < close[trendLength] and priceStretchPct <= -priceStretchThreshold

bearishGap = rsiValue - mfi
bullishGap = mfi - rsiValue

bearishGapScore = bearishGap > strongGapThreshold ? 2 : bearishGap > weakGapThreshold ? 1 : 0
bullishGapScore = bullishGap > strongGapThreshold ? 2 : bullishGap > weakGapThreshold ? 1 : 0

bearishZonePass = rsiValue >= bullZone or (not na(ub) and rsiValue >= ub)
bullishZonePass = rsiValue <= bearZone or (not na(db) and rsiValue <= db)

bearishGapFade = bearishGap < bearishGap[gapFadeLookback]
bullishGapFade = bullishGap < bullishGap[gapFadeLookback]

rsiTurningDown = rsiValue < rsiValue[1]
rsiTurningUp = rsiValue > rsiValue[1]
mfiTurningDown = mfi < mfi[1]
mfiTurningUp = mfi > mfi[1]

// ==========================
// SCORE
// Max score = 7
// ==========================
bearishRiskScore = 0
bearishRiskScore += bearishGapBg ? 1 : 0
bearishRiskScore += bearishGapScore
bearishRiskScore += priceExtendedUp ? 1 : 0
bearishRiskScore += volumeOkay ? 1 : 0
bearishRiskScore += bearishZonePass ? 1 : 0
bearishRiskScore += ((useGapFade and bearishGapFade) or (not useGapFade and rsiTurningDown)) ? 1 : 0
bearishRiskScore += (rsiTurningDown or mfiTurningDown) ? 1 : 0

bullishRiskScore = 0
bullishRiskScore += bullishGapBg ? 1 : 0
bullishRiskScore += bullishGapScore
bullishRiskScore += priceExtendedDown ? 1 : 0
bullishRiskScore += volumeOkay ? 1 : 0
bullishRiskScore += bullishZonePass ? 1 : 0
bullishRiskScore += ((useGapFade and bullishGapFade) or (not useGapFade and rsiTurningUp)) ? 1 : 0
bullishRiskScore += (rsiTurningUp or mfiTurningUp) ? 1 : 0

bearishRiskStrength = bearishRiskScore >= 7 ? 3 : bearishRiskScore >= 5 ? 2 : bearishRiskScore >= 4 ? 1 : 0
bullishRiskStrength = bullishRiskScore >= 7 ? 3 : bullishRiskScore >= 5 ? 2 : bullishRiskScore >= 4 ? 1 : 0

bearishRiskRaw = bearishGapBg and isBullCandle and bearishRiskStrength >= minRiskStrength and bullishRiskStrength == 0
bullishRiskRaw = bullishGapBg and isBearCandle and bullishRiskStrength >= minRiskStrength and bearishRiskStrength == 0

bearishMfiFilterPass = mfi > oversoldLevel
bullishMfiFilterPass = mfi < overboughtLevel

// ==========================
// CONFIRMED SIGNAL
// ==========================
finalBearishRiskConfirmed = barstate.isconfirmed and bearishRiskRaw and bearishMfiFilterPass
finalBullishRiskConfirmed = barstate.isconfirmed and bullishRiskRaw and bullishMfiFilterPass

// ==========================
// ALERTS
// ==========================
alertcondition(finalBearishRiskConfirmed, title="Bearish Reversal Risk", message="Bearish reversal risk detected")
alertcondition(finalBullishRiskConfirmed, title="Bullish Reversal Risk", message="Bullish reversal risk detected")

// ==========================
// REFERENCE LINES
// ==========================
hline(overboughtLevel, "Overbought", color=color.gray, linestyle=hline.style_dashed, linewidth=1)
hline(oversoldLevel, "Oversold", color=color.gray, linestyle=hline.style_dashed, linewidth=1)

// ==========================
// PLOTS
// ==========================
lowBandPlot = plot(db, "RSI Low Band", color=activeRsiBandLineColor, linewidth=defaultBandWidth, display=display.pane)
highBandPlot = plot(ub, "RSI High Band", color=activeRsiBandLineColor, linewidth=defaultBandWidth, display=display.pane)
rsiPlot = plot(showRsiLine ? rsiValue : na, "RSI", color=rsiColor, linewidth=defaultLineWidth, display=display.pane)
mfiPlot = plot(showMfiLine ? mfi : na, "MFI", color=mfiColor, linewidth=defaultLineWidth, display=display.pane)
overboughtFillBase = plot((showMfiLine and isMfiOverbought) ? overboughtLevel : na, "Overbought Fill Base", color=color.new(mfiOverboughtFillColor, 100), linewidth=1, style=plot.style_linebr, display=display.pane)
oversoldFillBase = plot((showMfiLine and isMfiOversold) ? oversoldLevel : na, "Oversold Fill Base", color=color.new(mfiOversoldFillColor, 100), linewidth=1, style=plot.style_linebr, display=display.pane)
fill(lowBandPlot, highBandPlot, color=activeRsiBandFillColor)
fill(overboughtFillBase, mfiPlot, color=showMfiLine ? mfiOverboughtFillColor : na, fillgaps=false)
fill(oversoldFillBase, mfiPlot, color=showMfiLine ? mfiOversoldFillColor : na, fillgaps=false)

// ==========================
// TOP RIGHT INFO PANEL
// ==========================
panelBg = color.new(color.rgb(16, 22, 34), 12)
panelFrameColor = color.new(color.white, 92)
panelBandGapText = formatPanelNumber(rsiBandRange)
panelBandGapTextColor = isRsiBandNarrow ? narrowBandStateColor : isRsiBandWide ? wideBandStateColor : color.white
var table infoTable = table.new(position.top_right, 1, 2, border_width=1, border_color=panelFrameColor, frame_width=1, frame_color=panelFrameColor)

if barstate.islast
    table.cell(infoTable, 0, 0, "RSI 밴드", text_color=color.white, bgcolor=panelBg, text_size=size.tiny, text_halign=text.align_center)
    table.cell(infoTable, 0, 1, panelBandGapText, text_color=panelBandGapTextColor, bgcolor=panelBg, text_size=size.tiny, text_halign=text.align_center)
