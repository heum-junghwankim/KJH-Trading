//@version=6
//
// Copyright (C) 2017 CC BY, whentotrade / Lars von Thienen
// Source:
// Book: Decoding The Hidden Market Rhythm - Part 1: Dynamic Cycles (2017)
// Chapter 4: "Fine-tuning technical indicators for more details on the cRSI Indicator
//
// Usage:
// You need to derive the dominant cycle as input parameter for the cycle length as described in chapter 4.
//
// License:
// This work is licensed under a Creative Commons Attribution 4.0 International License.
// You are free to share the material in any medium or format and remix, transform, and build upon the material for any purpose,
// even commercially. You must give appropriate credit to the authors book and website, provide a link to the license, and indicate
// if changes were made. You may do so in any reasonable manner, but not in any way that suggests the licensor endorses you or your use.
//
indicator(title="RSI cyclic smoothed", shorttitle="cRSI")

src = close
domcycle = input.int(20, minval=10, title="Dominant Cycle Length")
crsi = 0.0
cyclelen = int(domcycle / 2)
vibration = 10
leveling = 10.0
cyclicmemory = domcycle * 2

// 밴드폭 배경색 옵션
showBandWidthBg = input.bool(true, title="Show Band Width Background")
narrowBandThreshold = input.float(20.0, minval=0.0, title="Narrow Band Width Threshold")
wideBandThreshold = input.float(35.0, minval=0.0, title="Wide Band Width Threshold")
bgOpacity = input.int(15, minval=0, maxval=100, title="밴드 배경 불투명성 (0=투명, 100=진함)")

// 수축 구간 밴드 돌파 원 마커 옵션
oversoldLevel   = input.float(30.0, minval=0.0, maxval=100.0, title="과매도 참고 레벨", group="수축 돌파 마커")
overboughtLevel = input.float(70.0, minval=0.0, maxval=100.0, title="과매수 참고 레벨", group="수축 돌파 마커")
showBreakMarker = input.bool(true, title="수축 돌파 원 마커 표시", group="수축 돌파 마커", tooltip="밴드폭 수축(주황) 구간에서, 하단밴드가 과매도 인근일 때 cRSI가 상단밴드를 상향 돌파하면 상단밴드 위치에 골든(녹색 원), 상단밴드가 과매수 인근일 때 cRSI가 하단밴드를 하향 돌파하면 하단밴드 위치에 데드(빨강 원)를 표시.")
nearMargin      = input.float(5.0, minval=0.0, title="과매도/과매수 인근 마진", group="수축 돌파 마커", tooltip="하단밴드가 (과매도 레벨 ±마진) 범위, 상단밴드가 (과매수 레벨 ±마진) 범위일 때 '인근'으로 판정(선 위·아래 양방향). 기본 5.0.")

// 선 색상 (사용자 지정 가능, 기본값은 기존 하드코딩 색 유지)
crsiColor = input.color(#FFFFFF, title="cRSI 선 색", group="선 색상")
showCmfi = input.bool(false, title="cMFI 표시", group="선 색상", tooltip="순환 평활 MFI(cMFI) 선 표시 여부. 기본 미표시.")
cmfiColor = input.color(#B388FF, title="cMFI 선 색", group="선 색상")
lowBandColor = input.color(#4DD0E1, title="하단밴드(LowBand) 색", group="선 색상")
highBandColor = input.color(#4DD0E1, title="상단밴드(HighBand) 색", group="선 색상")

h1 = hline(oversoldLevel, color=color.silver, linestyle=hline.style_dashed)
h2 = hline(overboughtLevel, color=color.silver, linestyle=hline.style_dashed)

torque = 2.0 / (vibration + 1)
phasingLag = int((vibration - 1) / 2)

up = ta.rma(math.max(ta.change(src), 0), cyclelen)
down = ta.rma(-math.min(ta.change(src), 0), cyclelen)
rsi = down == 0 ? 100 : up == 0 ? 0 : 100 - 100 / (1 + up / down)
crsi := torque * (2 * rsi - rsi[phasingLag]) + (1 - torque) * nz(crsi[1])

// 순환 평활 MFI (cMFI)
// cRSI와 동일 파이프라인을 그대로 재사용하되, 입력만 RSI → MFI로 교체한다.
//  - 주기: cRSI와 같은 cyclelen 사용 (ta.mfi(hlc3, cyclelen))
//  - 평활: cRSI와 동일한 torque / phasingLag (vibration 기반) 재귀식 적용
// 신규 파라미터 없이 cRSI 파라미터(domcycle→cyclelen, vibration)를 공유하므로 "동일 간격/주기"가 보장된다.
cmfi = 0.0
mfiRaw = ta.mfi(hlc3, cyclelen)
cmfi := torque * (2 * mfiRaw - mfiRaw[phasingLag]) + (1 - torque) * nz(cmfi[1])

lmax = -999999.0
lmin = 999999.0
for i = 0 to cyclicmemory - 1 by 1
    if nz(crsi[i], -999999.0) > lmax
        lmax := nz(crsi[i])
        lmax
    else
        if nz(crsi[i], 999999.0) < lmin
            lmin := nz(crsi[i])
            lmin

mstep = (lmax - lmin) / 100
aperc = leveling / 100

db = 0.0
for steps = 0 to 100 by 1
    testvalue = lmin + mstep * steps
    below = 0
    for m = 0 to cyclicmemory - 1 by 1
        below := below + (crsi[m] < testvalue ? 1 : 0)
        below

    ratio = below / cyclicmemory
    if ratio >= aperc
        db := testvalue
        break
    else
        continue

ub = 0.0
for steps = 0 to 100 by 1
    testvalue = lmax - mstep * steps
    above = 0
    for m = 0 to cyclicmemory - 1 by 1
        above := above + (crsi[m] >= testvalue ? 1 : 0)
        above

    ratio = above / cyclicmemory
    if ratio >= aperc
        ub := testvalue
        break
    else
        continue

// 밴드폭 계산
bandWidth = ub - db
narrowLimit = math.min(narrowBandThreshold, wideBandThreshold)
wideLimit = math.max(narrowBandThreshold, wideBandThreshold)

// 밴드폭이 좁으면 진한 주황색(수축), 넓으면 보라색(확장) 배경
bandBgColor = not showBandWidthBg or bar_index < cyclicmemory ? na :
     bandWidth <= narrowLimit ? #D35400 :
     bandWidth >= wideLimit ? color.purple : na

// 불투명성(opacity) 입력을 v6 방식으로 색상에 baking(0=투명, 100=진함). 투명도(transp) = 100 - opacity.
bgcolor(color.new(bandBgColor, 100 - bgOpacity))

// 밴드 상·하단(ub/db)은 우측 프라이스 스케일 라벨에 값 표시. cMFI만 우측 축 라벨 숨김.
lowband = plot(db, "LowBand", lowBandColor, display = display.all)
highband = plot(ub, "HighBand", highBandColor, display = display.all)
plot(crsi, "CRSI", crsiColor, display = display.all)
// Pine v6 plot()은 dashed 라인을 직접 지원하지 않음(style은 line/stepline/histogram/cross/circles/area/columns/linebr).
// cMFI는 매 봉 갱신되는 동적 series라 line.new(dashed)는 비효율 → plot.style_circles로 점선(작은 원 연속) 느낌을 낸다.
plot(cmfi, "cMFI", cmfiColor, style = plot.style_circles, display = showCmfi ? display.all - display.price_scale : display.none)

// =========================
// 우측 상단 상태판 (매수 신호 신뢰도)
// =========================
atLowCrsi  = crsi <= db
atHighCrsi = crsi >= ub
narrowBw   = bandWidth <= narrowLimit
wideBw     = bandWidth >= wideLimit
bwText     = narrowBw ? "수축" : wideBw ? "확장" : "중립"

// 모멘텀(기울기) 계산: 확정 과거참조(crsi[phasingLag])만 사용 → 리페인팅 없음
// phasingLag = int((vibration-1)/2) = 4봉(vibration=10). 평활 지연값 재사용.
crsiSlope = crsi - crsi[phasingLag]
slopeEps  = 2.0

// 수축(주황) 상태에서의 밴드 돌파는 "추세 돌파"로 보고, 밴드 안으로 복귀할 때까지 방향 유지
// (돌파 이후 밴드가 확장(보라)되어도 복귀 전까지는 같은 방향)
narrowRecently = narrowBw or narrowBw[1] or narrowBw[2]
brokeDown = atLowCrsi and not atLowCrsi[1]
brokeUp   = atHighCrsi and not atHighCrsi[1]
var int crsiBreak = 0
// 복귀: 밴드 안으로 돌아오면 해제
if crsiBreak == -1 and crsi > db
    crsiBreak := 0
if crsiBreak == 1 and crsi < ub
    crsiBreak := 0
// 수축 중 돌파 발생 시 방향 상태 진입
if narrowRecently and brokeDown
    crsiBreak := -1
if narrowRecently and brokeUp
    crsiBreak := 1

// =========================
// 모멘텀 5분류 (테이블 3행 표시용)
// 우선순위: 크로스 지속(crsiBreak) > 위치+기울기 조합.
//  판정 소스는 지속 래치 crsiBreak (goldenBreak/deadBreak 1회 이벤트는 사용하지 않음 — 원 마커로 별도 표현).
//  "강" 게이트: 크로스 지속이면 무조건 강. 크로스 없으면 위치가 극단(과매도에서 상승/과매수에서 하락=반전)이거나
//   밴드 안(중립 위치)일 때만 강, 그 외(반대 극단)엔 일반 상승/하락.
// 상태 서술만 하며 매매 지시어는 쓰지 않는다.
upStrong   = crsiBreak == 1  or ((atLowCrsi or (not atLowCrsi and not atHighCrsi)) and crsiSlope > slopeEps)
downStrong = crsiBreak == -1 or ((atHighCrsi or (not atLowCrsi and not atHighCrsi)) and crsiSlope < -slopeEps)
momoText  = crsiBreak == 1 ? "상승 강" :
     crsiBreak == -1 ? "하락 강" :
     math.abs(crsiSlope) <= slopeEps ? "중립" :
     crsiSlope > slopeEps ? (upStrong ? "상승 강" : "상승") :
     crsiSlope < -slopeEps ? (downStrong ? "하락 강" : "하락") : "중립"
momoColor = crsiBreak == 1 ? color.new(color.green, 0) :
     crsiBreak == -1 ? color.new(color.red, 0) :
     math.abs(crsiSlope) <= slopeEps ? color.new(color.gray, 40) :
     crsiSlope > slopeEps ? (upStrong ? color.new(color.green, 0) : #6E8F72) :
     crsiSlope < -slopeEps ? (downStrong ? color.new(color.red, 0) : #A57A7A) : color.new(color.gray, 40)

// cRSI 다이버전스 (확장(보라) 구간에서만 신뢰): 상승=롱, 하락=숏
divLbL = 5
divLbR = 5
divRangeMax = 60
divRangeMin = 5
plFound = not na(ta.pivotlow(crsi, divLbL, divLbR))
phFound = not na(ta.pivothigh(crsi, divLbL, divLbR))
inRangeBull = ta.barssince(plFound[1]) >= divRangeMin and ta.barssince(plFound[1]) <= divRangeMax
inRangeBear = ta.barssince(phFound[1]) >= divRangeMin and ta.barssince(phFound[1]) <= divRangeMax
oscHL   = crsi[divLbR] > ta.valuewhen(plFound, crsi[divLbR], 1) and inRangeBull
priceLL = low[divLbR] < ta.valuewhen(plFound, low[divLbR], 1)
bullDiv = plFound and priceLL and oscHL
oscLH   = crsi[divLbR] < ta.valuewhen(phFound, crsi[divLbR], 1) and inRangeBear
priceHH = high[divLbR] > ta.valuewhen(phFound, high[divLbR], 1)
bearDiv = phFound and priceHH and oscLH

// 확장(보라) 구간의 다이버전스를 상태로 래치
// 종료: 의도한 방향으로 밴드를 돌파했다가 다시 밴드 안으로 복귀하면 다이버전스 끝
//  (하락=하단 돌파 후 복귀 / 상승=상단 돌파 후 복귀), 수축 전환 시에도 해제
var int crsiDiv = 0
var bool divBrokeOut = false
if bullDiv and wideBw
    crsiDiv := 1
    divBrokeOut := false
if bearDiv and wideBw
    crsiDiv := -1
    divBrokeOut := false
// 돌파 기록: 상승=상단(ub) 돌파 / 하락=하단(db) 돌파
if crsiDiv == 1 and atHighCrsi
    divBrokeOut := true
if crsiDiv == -1 and atLowCrsi
    divBrokeOut := true
// 돌파 후 밴드 안으로 복귀하면 종료
if crsiDiv == 1 and divBrokeOut and crsi < ub
    crsiDiv := 0
    divBrokeOut := false
if crsiDiv == -1 and divBrokeOut and crsi > db
    crsiDiv := 0
    divBrokeOut := false
// 수축으로 전환되면 해제(폴백)
if narrowBw
    crsiDiv := 0
    divBrokeOut := false

plotshape(bullDiv and wideBw ? crsi[divLbR] : na, title="cRSI 상승 다이버전스", style=shape.triangleup, location=location.absolute, color=color.green, size=size.tiny, offset=-divLbR)
plotshape(bearDiv and wideBw ? crsi[divLbR] : na, title="cRSI 하락 다이버전스", style=shape.triangledown, location=location.absolute, color=color.red, size=size.tiny, offset=-divLbR)

// =========================
// 수축(주황) 구간 밴드 돌파 원 마커
// =========================
// 밴드폭 수축(narrowBw, 당봉 주황) 상태에서:
//  - 하단밴드(db)가 과매도 인근(과매도 레벨 ±마진 = 선 위·아래 근처) + cRSI가 상단밴드(ub)를 상향 돌파 → 골든크로스(상단밴드 ub 위치에 녹색 원)
//  - 상단밴드(ub)가 과매수 인근(과매수 레벨 ±마진 = 선 위·아래 근처) + cRSI가 하단밴드(db)를 하향 돌파 → 데드크로스(하단밴드 db 위치에 빨강 원)
// 크로스는 확정봉(barstate.isconfirmed) 기준으로만 확정해 미마감봉 점멸을 방지한다.
lowBandOversold   = oversoldLevel - nearMargin <= db and db <= oversoldLevel + nearMargin
highBandOverbought = overboughtLevel - nearMargin <= ub and ub <= overboughtLevel + nearMargin
goldenBreak = showBreakMarker and barstate.isconfirmed and narrowBw and ta.crossover(crsi, ub) and lowBandOversold
deadBreak   = showBreakMarker and barstate.isconfirmed and narrowBw and ta.crossunder(crsi, db) and highBandOverbought
plot(goldenBreak ? ub : na, title="수축 골든크로스", style=plot.style_circles, color=color.new(color.green, 0), linewidth=4, display=display.pane)
plot(deadBreak ? db : na, title="수축 데드크로스", style=plot.style_circles, color=color.new(color.red, 0), linewidth=4, display=display.pane)

// 우선순위: 수축 돌파 지속 > 확장 다이버전스 > 일반 과매수·과매도 되돌림
posVerdict = crsiBreak == -1 ? "숏 유리(하단돌파)" : crsiBreak == 1 ? "롱 유리(상단돌파)" : crsiDiv == 1 ? "롱 유리(상승 다이버전스)" : crsiDiv == -1 ? "숏 유리(하락 다이버전스)" : atHighCrsi ? "숏 유리(과매수)" : atLowCrsi ? "롱 유리(과매도)" : narrowBw ? "중립(수축)" : "중립"
posColor   = crsiBreak == -1 ? color.new(color.red, 0) : crsiBreak == 1 ? color.new(color.green, 0) : crsiDiv == 1 ? color.new(color.green, 0) : crsiDiv == -1 ? color.new(color.red, 0) : atHighCrsi ? color.new(color.red, 0) : atLowCrsi ? color.new(color.green, 0) : color.new(color.gray, 40)

var table crsiStatus = table.new(position.top_right, 2, 3, border_width=1, border_color=color.new(color.gray, 50))
if barstate.islast
    table.cell(crsiStatus, 0, 0, "cRSI", text_color=color.white, bgcolor=color.new(#1B2A4A, 0), text_size=size.small)
    table.cell(crsiStatus, 1, 0, posVerdict, text_color=color.white, bgcolor=posColor, text_size=size.small)
    table.cell(crsiStatus, 0, 1, "cRSI 값", text_color=color.white, text_size=size.small)
    table.cell(crsiStatus, 1, 1, str.tostring(crsi, "#.0") + " (" + str.tostring(bandWidth, "#.0") + " " + bwText + ")", text_color=color.white, bgcolor=narrowBw ? color.new(#D35400, 0) : wideBw ? color.new(color.purple, 0) : color.new(color.gray, 50), text_size=size.small)
    table.cell(crsiStatus, 0, 2, "모멘텀", text_color=color.white, text_size=size.small)
    table.cell(crsiStatus, 1, 2, momoText, text_color=color.white, bgcolor=momoColor, text_size=size.small)
