//@version=6
indicator("Advanced-Volume-Delta", shorttitle="AVD", format=format.volume, precision=0, overlay=true)

// =========================
// Buy / Sell Volume 계산
// =========================
buyVolume  = high == low ? 0 : volume * (close - low) / (high - low)
sellVolume = high == low ? 0 : volume * (high - close) / (high - low)

// =========================
// 볼륨 델타 요약 설정
// =========================
showDeltaSummary = input.bool(true, "볼륨 델타 요약 표시", group="Volume Delta")
deltaMode = input.string("세션", "집계 기준", options=["세션", "특정 봉 수"], group="Volume Delta")
deltaLookbackBars = input.int(20, "봉 수", minval=1, group="Volume Delta")
deltaTablePositionInput = input.string("우측 상단", "표시 위치", options=["좌측 상단", "우측 상단", "좌측 하단", "우측 하단"], group="Volume Delta")
buyColor = input.color(color.lime, "매수 색상", group="Volume Delta")
sellColor = input.color(color.rgb(251, 64, 64), "매도 색상", group="Volume Delta")
headerColor = input.color(color.orange, "헤더 배경색", group="Volume Delta")
fieldBgColor = input.color(color.black, "일반 필드 배경색", group="Volume Delta")
backgroundTransparency = input.int(80, "배경 투명도", minval=0, maxval=100, group="Volume Delta")

tablePosition(positionInput) =>
    switch positionInput
        "좌측 상단" => position.top_left
        "우측 상단" => position.top_right
        "좌측 하단" => position.bottom_left
        => position.bottom_right

formatPercent(value) =>
    na(value) ? "n/a" : str.tostring(value, "0.0") + "%"

formatSignedPercent(value) =>
    na(value) ? "n/a" : (value > 0 ? "+" : value < 0 ? "-" : "") + str.tostring(math.abs(value), "0.0") + "%"

formatSignedVolume(value) =>
    (value > 0 ? "+" : value < 0 ? "-" : "") + str.tostring(math.abs(value), format.volume)

directionPoints(value, weakThreshold, strongThreshold) =>
    if na(value)
        0
    else if value >= strongThreshold
        2
    else if value >= weakThreshold
        1
    else if value <= -strongThreshold
        -2
    else if value <= -weakThreshold
        -1
    else
        0

biasText(score) =>
    if score >= 4
        "강한 매수 우위"
    else if score >= 2
        "매수 우위"
    else if score <= -4
        "강한 매도 우위"
    else if score <= -2
        "매도 우위"
    else
        "중립"

biasColor(score, bullishColor, bearishColor) =>
    if score > 0
        bullishColor
    else if score < 0
        bearishColor
    else
        color.silver

rollingSum(source, length) =>
    cumulative = ta.cum(source)
    cumulative - nz(cumulative[length], 0.0)

useSessionDelta = deltaMode == "세션"
isNewSession = timeframe.change("D")
useOnlyConfirmedBars = not barstate.isconfirmed

var float sessionBuyVolume = 0.0
var float sessionSellVolume = 0.0
var float sessionStartPrice = na

if barstate.isconfirmed
    if barstate.isfirst or isNewSession
        sessionBuyVolume := buyVolume
        sessionSellVolume := sellVolume
        sessionStartPrice := open
    else
        sessionBuyVolume += buyVolume
        sessionSellVolume += sellVolume

confirmedWindowStartPrice = useOnlyConfirmedBars ? nz(open[deltaLookbackBars], nz(open[1], open)) : nz(open[deltaLookbackBars - 1], open)
confirmedWindowBuyVolume = useOnlyConfirmedBars ? nz(rollingSum(buyVolume, deltaLookbackBars)[1], rollingSum(buyVolume, deltaLookbackBars)) : rollingSum(buyVolume, deltaLookbackBars)
confirmedWindowSellVolume = useOnlyConfirmedBars ? nz(rollingSum(sellVolume, deltaLookbackBars)[1], rollingSum(sellVolume, deltaLookbackBars)) : rollingSum(sellVolume, deltaLookbackBars)

windowStartPrice = useSessionDelta ? sessionStartPrice : confirmedWindowStartPrice
windowBuyVolume = useSessionDelta ? sessionBuyVolume : confirmedWindowBuyVolume
windowSellVolume = useSessionDelta ? sessionSellVolume : confirmedWindowSellVolume
windowTotalVolume = windowBuyVolume + windowSellVolume
windowBuyRatio = windowTotalVolume > 0 ? windowBuyVolume / windowTotalVolume * 100.0 : na
windowSellRatio = windowTotalVolume > 0 ? windowSellVolume / windowTotalVolume * 100.0 : na
windowDeltaVolume = windowBuyVolume - windowSellVolume
windowDeltaRatio = windowTotalVolume > 0 ? windowDeltaVolume / windowTotalVolume * 100.0 : na
windowClosePrice = useOnlyConfirmedBars ? nz(close[1], close) : close
windowPriceChangeRatio = not na(windowStartPrice) and windowStartPrice != 0 ? (windowClosePrice - windowStartPrice) / windowStartPrice * 100.0 : na
deltaWindowLabel = useSessionDelta ? "세션" : str.tostring(deltaLookbackBars) + "봉"

var table deltaSummaryTable = table.new(tablePosition(deltaTablePositionInput), 2, 7, border_width=1)
var float latestWindowTotalVolume = na
var float latestWindowBuyVolume = na
var float latestWindowBuyRatio = na
var float latestWindowSellVolume = na
var float latestWindowSellRatio = na
var float latestWindowDeltaVolume = na
var float latestWindowDeltaRatio = na
var float latestWindowPriceChangeRatio = na
var int latestCompositeBiasScore = 0
var string latestCompositeBiasText = "중립"
headerBgColor = color.new(headerColor, backgroundTransparency)
fieldBackgroundColor = color.new(fieldBgColor, backgroundTransparency)
deltaTextSize = size.small
referenceDeltaColor = windowDeltaVolume > 0 ? buyColor : windowDeltaVolume < 0 ? sellColor : color.silver

// Keep a hidden reference series so the overlay script can still expose values in the data window.
plot(windowDeltaVolume, title="Volume Delta Reference", color=color.new(referenceDeltaColor, 100), display=display.none)

if barstate.islast
    int flowBiasPoints = 0
    int priceBiasPoints = 0
    int compositeBiasScore = 0
    string compositeBiasText = "중립"

    flowBiasPoints := directionPoints(windowDeltaRatio, 4.0, 10.0)
    priceBiasPoints := directionPoints(windowPriceChangeRatio, 0.3, 1.0)
    compositeBiasScore := flowBiasPoints + priceBiasPoints
    compositeBiasText := biasText(compositeBiasScore)
    latestWindowTotalVolume := windowTotalVolume
    latestWindowBuyVolume := windowBuyVolume
    latestWindowBuyRatio := windowBuyRatio
    latestWindowSellVolume := windowSellVolume
    latestWindowSellRatio := windowSellRatio
    latestWindowDeltaVolume := windowDeltaVolume
    latestWindowDeltaRatio := windowDeltaRatio
    latestWindowPriceChangeRatio := windowPriceChangeRatio
    latestCompositeBiasScore := compositeBiasScore
    latestCompositeBiasText := compositeBiasText

if showDeltaSummary
    displayedTotalVolume = na(latestWindowTotalVolume) ? windowTotalVolume : latestWindowTotalVolume
    displayedBuyVolume = na(latestWindowBuyVolume) ? windowBuyVolume : latestWindowBuyVolume
    displayedBuyRatio = na(latestWindowBuyRatio) ? windowBuyRatio : latestWindowBuyRatio
    displayedSellVolume = na(latestWindowSellVolume) ? windowSellVolume : latestWindowSellVolume
    displayedSellRatio = na(latestWindowSellRatio) ? windowSellRatio : latestWindowSellRatio
    displayedDeltaVolume = na(latestWindowDeltaVolume) ? windowDeltaVolume : latestWindowDeltaVolume
    displayedDeltaRatio = na(latestWindowDeltaRatio) ? windowDeltaRatio : latestWindowDeltaRatio
    displayedPriceChangeRatio = na(latestWindowPriceChangeRatio) ? windowPriceChangeRatio : latestWindowPriceChangeRatio
    displayedDeltaColor = displayedDeltaVolume > 0 ? buyColor : displayedDeltaVolume < 0 ? sellColor : color.silver
    displayedPriceChangeColor = displayedPriceChangeRatio > 0 ? buyColor : displayedPriceChangeRatio < 0 ? sellColor : color.silver

    table.cell(deltaSummaryTable, 0, 0, "구분", text_color=color.white, bgcolor=headerBgColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 1, 0, deltaWindowLabel, text_color=color.white, bgcolor=headerBgColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 0, 1, "총합", text_color=color.white, bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 1, 1, str.tostring(displayedTotalVolume, format.volume), text_color=color.white, bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 0, 2, "매수", text_color=buyColor, bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 1, 2, str.tostring(displayedBuyVolume, format.volume) + " (" + formatPercent(displayedBuyRatio) + ")", text_color=buyColor, bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 0, 3, "매도", text_color=sellColor, bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 1, 3, str.tostring(displayedSellVolume, format.volume) + " (" + formatPercent(displayedSellRatio) + ")", text_color=sellColor, bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 0, 4, "델타", text_color=displayedDeltaColor, bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 1, 4, formatSignedVolume(displayedDeltaVolume) + " (" + formatSignedPercent(displayedDeltaRatio) + ")", text_color=displayedDeltaColor, bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 0, 5, "가격 변화", text_color=displayedPriceChangeColor, bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 1, 5, formatSignedPercent(displayedPriceChangeRatio), text_color=displayedPriceChangeColor, bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 0, 6, "평가", text_color=color.white, bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
    table.cell(deltaSummaryTable, 1, 6, latestCompositeBiasText, text_color=biasColor(latestCompositeBiasScore, buyColor, sellColor), bgcolor=fieldBackgroundColor, text_size=deltaTextSize)
else
    table.clear(deltaSummaryTable, 0, 0, 1, 6)
