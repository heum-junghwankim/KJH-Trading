//@version=6
indicator(title="Advanced Ichimoku", shorttitle="Adv Ichimoku", overlay=true)

donchian(len) =>
    math.avg(ta.lowest(len), ta.highest(len))

conversionPeriods = input.int(8, minval=1, title="컨버전 라인 길이", group="기본 설정")
basePeriods = input.int(22, minval=1, title="베이스 라인 길이", group="기본 설정")
leadingSpanBPeriods = input.int(44, minval=1, title="리딩 스팬 B 길이", group="기본 설정")
displacement = input.int(22, minval=1, title="레깅 스팬 길이", group="기본 설정")

showConversionLine = input.bool(true, title="컨버전 라인 표시", group="표시")
showBaseLine = input.bool(true, title="베이스 라인 표시", group="표시")
showLaggingSpan = input.bool(true, title="레깅 스팬 표시", group="표시")
showLeadingSpanA = input.bool(false, title="리딩 스팬 A 표시", group="표시")
showLeadingSpanB = input.bool(false, title="리딩 스팬 B 표시", group="표시")
showKumoUpper = input.bool(false, title="Kumo Cloud Upper Line 표시", group="표시")
showKumoLower = input.bool(false, title="Kumo Cloud Lower Line 표시", group="표시")
showCloudFill = input.bool(true, title="Cloud Fill 표시", group="표시")

showBuySignal = input.bool(true, title="매수 신호 표시", group="매수 신호")
showSellSignal = input.bool(true, title="매도 신호 표시", group="매도 신호")
showBuyCandidate = input.bool(true, title="매수 후보 표시", group="후보 신호")
showSellCandidate = input.bool(true, title="매도 후보 표시", group="후보 신호")

lineWidth = 1
signalSize = size.small
conversionLineColor = input.color(#E91E63, "컨버전 라인 색", group="색상")
baseLineColor = input.color(#00FF00, "베이스 라인 색", group="색상")
laggingSpanColor = input.color(#FFEB3B, "레깅 스팬 색", group="색상")
leadingSpanAColor = input.color(#7B9077, "리딩 스팬 A 색", group="색상")
leadingSpanBColor = input.color(#9A7272, "리딩 스팬 B 색", group="색상")
kumoBoundaryColor = input.color(#3F5AA9, "Kumo 경계선 색", group="색상")
bullCloudColor = input.color(#0B5D4F, "양운(상승 구름) 색", group="색상")
bearCloudColor = input.color(#6B1E28, "음운(하락 구름) 색", group="색상")
cloudTransp = input.int(45, "구름 투명도", minval=0, maxval=100, group="색상")
bullishCloudColor = color.new(bullCloudColor, cloudTransp)
bearishCloudColor = color.new(bearCloudColor, cloudTransp)
defaultBuyColor = #4FC3F7
defaultSellColor = #FF5FA2
buyCandidateColor = color.new(defaultBuyColor, 0)
sellCandidateColor = color.new(defaultSellColor, 0)

conversionLine = donchian(conversionPeriods)
baseLine = donchian(basePeriods)
leadingSpanA = math.avg(conversionLine, baseLine)
leadingSpanB = donchian(leadingSpanBPeriods)
kumoUpper = math.max(leadingSpanA, leadingSpanB)
kumoLower = math.min(leadingSpanA, leadingSpanB)

laggingOffset = displacement - 1
// 래깅 스팬(현재 종가)을 그 위치의 기준선(베이스)과 비교: close vs baseLine[laggingOffset]
laggingBaseRef = baseLine[laggingOffset]
hasLaggingReference = not na(laggingBaseRef)
laggingBullishCross = hasLaggingReference and ta.crossover(close, laggingBaseRef)
laggingBearishCross = hasLaggingReference and ta.crossunder(close, laggingBaseRef)
laggingBullishState = hasLaggingReference and close > laggingBaseRef
laggingBearishState = hasLaggingReference and close < laggingBaseRef

conversionBullishCross = ta.crossover(conversionLine, baseLine)
conversionBearishCross = ta.crossunder(conversionLine, baseLine)
conversionBullishState = conversionLine > baseLine
conversionBearishState = conversionLine < baseLine

rawBuySignal = (laggingBullishCross or laggingBullishState) and (conversionBullishCross or conversionBullishState)
rawSellSignal = (laggingBearishCross or laggingBearishState) and (conversionBearishCross or conversionBearishState)

// 신호 모드: 확정(원래 로직) / 예측(다음 봉 가정으로 1봉 빨리 포착). 기본 = 확정.
signalMode = input.string("확정 모드", title="신호 모드", options=["확정 모드", "예측 모드"], group="신호 모드")
isPredict = signalMode == "예측 모드"
// 예측 가정: 다음 봉 종가 = 매수 (현재 종가+고가)/2, 매도 (현재 종가+저가)/2 · 모멘텀(저가↑/고가↓)
predBuyPrice = (close + high) / 2
predSellPrice = (close + low) / 2
predLagRef = baseLine[math.max(laggingOffset - 1, 0)]
predRawBuy = predBuyPrice > predLagRef and (conversionBullishCross or conversionBullishState) and low > low[1]
predRawSell = predSellPrice < predLagRef and (conversionBearishCross or conversionBearishState) and high < high[1]
rawBuyEff = isPredict ? predRawBuy : rawBuySignal
rawSellEff = isPredict ? predRawSell : rawSellSignal

var int lastSignalDirection = 0
buySignal = rawBuyEff and lastSignalDirection != 1
sellSignal = rawSellEff and lastSignalDirection != -1

if buySignal
    lastSignalDirection := 1
else if sellSignal
    lastSignalDirection := -1

// 후보 = (래깅 스팬이 컨버전 라인을 같거나 돌파) AND (컨버전 라인이 기준선을 같거나 돌파)
//  → 신호(래깅이 기준선 돌파)보다 빠른 조기 경고. ②(컨버전 vs 기준선)는 신호와 공통.
laggingConvRef = conversionLine[laggingOffset]
hasLaggingConvRef = not na(laggingConvRef)
laggingConvBullish = hasLaggingConvRef and (ta.crossover(close, laggingConvRef) or close > laggingConvRef)
laggingConvBearish = hasLaggingConvRef and (ta.crossunder(close, laggingConvRef) or close < laggingConvRef)
rawBuyCandidate = laggingConvBullish and (conversionBullishCross or conversionBullishState)
rawSellCandidate = laggingConvBearish and (conversionBearishCross or conversionBearishState)
// 모멘텀 필터: 매수 후보는 종가가 이전 봉 이상(상승)일 때만, 매도 후보는 이전 봉 이하(하락)일 때만 표시
buyCandidateSignal = rawBuyCandidate and close >= close[1] and lastSignalDirection != 1 and not buySignal and not sellSignal
sellCandidateSignal = rawSellCandidate and close <= close[1] and lastSignalDirection != -1 and not buySignal and not sellSignal

// =========================
// 거래량 가중(VWMA) 변형 — 신호/후보 마커만 추가로 표시 (반투명)
// =========================
// 기본 라인/구름/테이블은 표준(도న키언) 그대로 두고, 컨버전·기준선을 VWMA로 바꾼 버전의
// 매수/매도 후보·신호만 별도 마커로 함께 보여준다. (같은 로직, 라인은 그리지 않음)
showVwSignals = input.bool(true, title="거래량 가중 신호/후보 표시", group="거래량 가중 신호")
vwTransp = input.int(50, minval=0, maxval=100, title="거래량 가중 투명도", group="거래량 가중 신호")

vwConv = ta.vwma(close, conversionPeriods)
vwBase = ta.vwma(close, basePeriods)
vwLagBaseRef = vwBase[laggingOffset]
vwLagBull = not na(vwLagBaseRef) and (ta.crossover(close, vwLagBaseRef) or close > vwLagBaseRef)
vwLagBear = not na(vwLagBaseRef) and (ta.crossunder(close, vwLagBaseRef) or close < vwLagBaseRef)
vwConvBull = ta.crossover(vwConv, vwBase) or vwConv > vwBase
vwConvBear = ta.crossunder(vwConv, vwBase) or vwConv < vwBase
// 예측 모드 VWMA: 다음 봉 종가=예측가, 거래량=현재 거래량 가정으로 다음 봉 VWMA(전환·기준선) 재계산
vwPvConv = math.sum(close * volume, conversionPeriods - 1)
vwVSumConv = math.sum(volume, conversionPeriods - 1)
vwPvBase = math.sum(close * volume, basePeriods - 1)
vwVSumBase = math.sum(volume, basePeriods - 1)
vwConvBuyN = (vwPvConv + predBuyPrice * volume) / (vwVSumConv + volume)
vwBaseBuyN = (vwPvBase + predBuyPrice * volume) / (vwVSumBase + volume)
vwConvSellN = (vwPvConv + predSellPrice * volume) / (vwVSumConv + volume)
vwBaseSellN = (vwPvBase + predSellPrice * volume) / (vwVSumBase + volume)
vwLagRefN = vwBase[math.max(laggingOffset - 1, 0)]
predVwBuy = predBuyPrice > vwLagRefN and vwConvBuyN > vwBaseBuyN and low > low[1]
predVwSell = predSellPrice < vwLagRefN and vwConvSellN < vwBaseSellN and high < high[1]
vwRawBuyEff = isPredict ? predVwBuy : (vwLagBull and vwConvBull)
vwRawSellEff = isPredict ? predVwSell : (vwLagBear and vwConvBear)
var int vwLastDir = 0
vwBuySignal = vwRawBuyEff and vwLastDir != 1
vwSellSignal = vwRawSellEff and vwLastDir != -1
if vwBuySignal
    vwLastDir := 1
else if vwSellSignal
    vwLastDir := -1
vwLagConvRef = vwConv[laggingOffset]
vwLagConvBull = not na(vwLagConvRef) and (ta.crossover(close, vwLagConvRef) or close > vwLagConvRef)
vwLagConvBear = not na(vwLagConvRef) and (ta.crossunder(close, vwLagConvRef) or close < vwLagConvRef)
vwBuyCandidate = vwLagConvBull and vwConvBull and close >= close[1] and vwLastDir != 1 and not vwBuySignal and not vwSellSignal
vwSellCandidate = vwLagConvBear and vwConvBear and close <= close[1] and vwLastDir != -1 and not vwBuySignal and not vwSellSignal

cloudOffset = displacement - 1
fillSourceA = plot(leadingSpanA, offset=cloudOffset, title="Cloud Fill Source A", color=color.new(leadingSpanAColor, 100), display=display.none)
fillSourceB = plot(leadingSpanB, offset=cloudOffset, title="Cloud Fill Source B", color=color.new(leadingSpanBColor, 100), display=display.none)

plot(showConversionLine ? conversionLine : na, title="Conversion Line", color=conversionLineColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showBaseLine ? baseLine : na, title="Base Line", color=baseLineColor, linewidth=lineWidth, display=display.all)
plot(showLaggingSpan ? close : na, offset=-cloudOffset, title="Lagging Span", color=laggingSpanColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showLeadingSpanA ? leadingSpanA : na, offset=cloudOffset, title="Leading Span A", color=leadingSpanAColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showLeadingSpanB ? leadingSpanB : na, offset=cloudOffset, title="Leading Span B", color=leadingSpanBColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showKumoUpper ? kumoUpper : na, offset=cloudOffset, title="Kumo Cloud Upper Line", color=kumoBoundaryColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showKumoLower ? kumoLower : na, offset=cloudOffset, title="Kumo Cloud Lower Line", color=kumoBoundaryColor, linewidth=lineWidth, display=display.all - display.price_scale)
fill(fillSourceA, fillSourceB, title="Cloud Fill", color=showCloudFill ? (leadingSpanA > leadingSpanB ? bullishCloudColor : bearishCloudColor) : na)

plotshape(showBuyCandidate and buyCandidateSignal, title="매수 후보", style=shape.circle, location=location.belowbar, color=buyCandidateColor, size=size.tiny)
plotshape(showSellCandidate and sellCandidateSignal, title="매도 후보", style=shape.circle, location=location.abovebar, color=sellCandidateColor, size=size.tiny)
plotshape(showBuySignal and buySignal, title="매수 신호", style=shape.triangleup, location=location.belowbar, color=defaultBuyColor, size=signalSize)
plotshape(showSellSignal and sellSignal, title="매도 신호", style=shape.triangledown, location=location.abovebar, color=defaultSellColor, size=signalSize)

plotshape(showVwSignals and vwBuyCandidate, title="매수 후보 (거래량)", style=shape.circle, location=location.belowbar, color=color.new(defaultBuyColor, vwTransp), size=size.tiny)
plotshape(showVwSignals and vwSellCandidate, title="매도 후보 (거래량)", style=shape.circle, location=location.abovebar, color=color.new(defaultSellColor, vwTransp), size=size.tiny)
plotshape(showVwSignals and vwBuySignal, title="매수 신호 (거래량)", style=shape.triangleup, location=location.belowbar, color=color.new(defaultBuyColor, vwTransp), size=signalSize)
plotshape(showVwSignals and vwSellSignal, title="매도 신호 (거래량)", style=shape.triangledown, location=location.abovebar, color=color.new(defaultSellColor, vwTransp), size=signalSize)

alertcondition(buySignal, title="Advanced Ichimoku Buy Signal", message="Advanced Ichimoku buy signal")
alertcondition(sellSignal, title="Advanced Ichimoku Sell Signal", message="Advanced Ichimoku sell signal")

// =========================
// 리본 압축/분출 (이평 20~50 기반, 휩쏘 필터 + 분출 확인)
// =========================
// 20~50 이동평균이 ATR 대비 좁게 뭉치면 '횡보 압축'(회색), 압축이 풀리는 첫 봉에
// MA20 vs MA50 방향으로 '상승 분출'(파랑)/'하락 분출'(빨강)을 다이아몬드로 표시한다.
// 압축 → 분출 → 압축 → 분출 … 순서로만 진행(분출 후 다시 압축이 와야 다음 분출 허용).
ribbonMaType = input.string("SMA", title="리본 이동평균 종류", options=["SMA", "EMA", "WMA", "VWMA"], group="리본 압축/분출")
showChopWarn = input.bool(true, title="횡보 압축 표시", group="리본 압축/분출")
showExpansion = input.bool(true, title="분출(상승/하락) 표시", group="리본 압축/분출")
ribbonConfirmOnClose = input.bool(true, title="봉마감 후 확정", group="리본 압축/분출")
ribbonAtrLength = input.int(14, minval=1, title="리본폭 ATR 기준", group="리본 압축/분출")
ribbonCompressAtrMult = input.float(0.8, minval=0.1, step=0.1, title="압축 판정 ATR 배수", group="리본 압축/분출")
ribbonExpandBars = input.int(1, minval=1, title="분출 판정 폭 증가 봉수(작을수록 빠름)", group="리본 압축/분출")

ribbonMa(length) =>
    switch ribbonMaType
        "SMA" => ta.sma(close, length)
        "EMA" => ta.ema(close, length)
        "WMA" => ta.wma(close, length)
        "VWMA" => ta.vwma(close, length)

rMa20 = ribbonMa(20)
rMa25 = ribbonMa(25)
rMa30 = ribbonMa(30)
rMa35 = ribbonMa(35)
rMa40 = ribbonMa(40)
rMa45 = ribbonMa(45)
rMa50 = ribbonMa(50)
rTop = math.max(rMa20, math.max(rMa25, math.max(rMa30, math.max(rMa35, math.max(rMa40, math.max(rMa45, rMa50))))))
rBottom = math.min(rMa20, math.min(rMa25, math.min(rMa30, math.min(rMa35, math.min(rMa40, math.min(rMa45, rMa50))))))
rHeight = math.max(rTop - rBottom, syminfo.mintick)
rAtr = ta.atr(ribbonAtrLength)
rCompressed = rHeight < rAtr * ribbonCompressAtrMult
rConfirmed = not ribbonConfirmOnClose or barstate.isconfirmed
rChopEnter = rCompressed and not rCompressed[1]
rExpanding = rHeight > rHeight[ribbonExpandBars]

// 압축 진입 시 무장 → 폭이 다시 늘기 시작하는(분출) 첫 봉에 바로 표시(완전 해소를 기다리지 않아 더 빠름)
// ribbonState: 마지막으로 발생한 이벤트(다이아몬드)를 기억해 테이블 표시를 차트와 동기화한다.
var bool rArmed = false
var string ribbonState = "대기"
bool rBullExpansion = false
bool rBearExpansion = false
if rConfirmed
    if rChopEnter
        rArmed := true
        ribbonState := "횡보 압축"
    else if rArmed and rExpanding
        rBullExpansion := rMa20 >= rMa50
        rBearExpansion := rMa20 < rMa50
        ribbonState := rBullExpansion ? "상승 분출" : "하락 분출"
        rArmed := false

ribbonChop = showChopWarn and rConfirmed and rChopEnter
ribbonBull = showExpansion and rBullExpansion
ribbonBear = showExpansion and rBearExpansion

// 현재 봉 구름대 상태(가격 위치 + 두께 + 색). 구름은 displacement만큼 앞으로 밀려 그려지므로
// 현재 봉 아래 구름은 cloudOffset 만큼 과거의 선행스팬 값으로 평가한다. 괄호 숫자 = 두께/ATR 배수.
curSpanA = leadingSpanA[cloudOffset]
curSpanB = leadingSpanB[cloudOffset]
cloudTop = math.max(curSpanA, curSpanB)
cloudBottom = math.min(curSpanA, curSpanB)
cloudThickAtr = (cloudTop - cloudBottom) / rAtr
cloudPosText = close > cloudTop ? "위" : close < cloudBottom ? "아래" : "안"
cloudColorText = curSpanA >= curSpanB ? "양운" : "음운"
cloudCellText = cloudPosText + "·" + cloudColorText + " (" + str.tostring(cloudThickAtr, "0.0") + ")"
cloudCellColor = close > cloudTop ? color.new(color.green, 30) : close < cloudBottom ? color.new(color.red, 30) : color.new(color.gray, 40)

// 리본 상태 = 마지막으로 발생한 다이아몬드(상태머신) 기준이라 차트 표시와 동기화된다.
// 괄호 숫자 = 현재 리본폭/ATR 배수(압축 배수보다 작으면 압축 구간).
ribbonWidthRatio = rHeight / rAtr
ribbonCellText = ribbonState + " (" + str.tostring(ribbonWidthRatio, "0.00") + ")"
ribbonCellColor = ribbonState == "상승 분출" ? color.new(color.blue, 30) : ribbonState == "하락 분출" ? color.new(color.red, 30) : color.new(color.gray, 40)

// =========================
// 우측 하단: 다음 봉 트리거 가격 + 구름대/리본 상태
// =========================
// 신호 = (후행스팬 조건) AND (전환선 vs 기준선 게이트). 후행스팬 조건은 '다음 봉 종가'가
// 특정 과거 종가를 돌파하는지로 정해지므로, 다음 봉이 돌파해야 할 그 기준 가격을 표시한다.
// 같은 방향 신호가 직전에 이미 나온 상태(중복방지)에서는 그 방향 트리거가를 '-'로 표시한다.
// 조건1: 래깅 스팬(다음 봉 종가)이 그 위치의 기준선을 돌파 → 기준값 = baseLine[laggingOffset-1] (고정 과거값)
nextSignalRefIdx = math.max(laggingOffset - 1, 0)
laggingBaseTrigger = baseLine[nextSignalRefIdx]
// 후보 트리거 = 다음 봉 래깅 스팬이 닿는 컨버전 라인 (래깅이 컨버전을 돌파하는 다음 봉 종가)
candidateConvTrigger = conversionLine[nextSignalRefIdx]

// 조건2: 전환선이 (다음 봉)기준선을 돌파. 다음 봉 가격이 들어오면 기준선·전환선이 둘 다 바뀐다.
// 교차 구간(다음 봉 가격이 21봉 극단을 넘지 않는 영역)에서는 기준선 = 직전 21봉 (최고+최저)/2 로
// 고정되고 전환선만 가격을 따라 움직이므로, 그 둘이 만나는 다음 봉 종가를 역산한다.
convPrior = conversionPeriods - 1
basePrior = basePeriods - 1
recentLow = ta.lowest(convPrior)
recentHigh = ta.highest(convPrior)
baseMidNext = (ta.highest(basePrior) + ta.lowest(basePrior)) / 2   // 다음 봉 기준선(가격이 극단 아닐 때)
convBuyPrice = 2 * baseMidNext - recentLow    // 신고가로 전환선을 다음 봉 기준선까지 끌어올리는 가격
convSellPrice = 2 * baseMidNext - recentHigh  // 신저가로 전환선을 다음 봉 기준선까지 끌어내리는 가격

// 신호 = 조건1(래깅 vs 기준선) AND 조건2(전환선 vs 기준선). 다음 봉 종가가 둘 다 만족해야 하므로
// 매수는 둘 중 더 높은 가격, 매도는 둘 중 더 낮은 가격이 트리거. (전환선이 이미 그 방향이면 조건1만)
buySignalTrigger = conversionBullishState ? laggingBaseTrigger : math.max(laggingBaseTrigger, convBuyPrice)
sellSignalTrigger = conversionBearishState ? laggingBaseTrigger : math.min(laggingBaseTrigger, convSellPrice)

// 후보 트리거 = (래깅이 컨버전 돌파) AND (컨버전이 기준선 돌파). 신호와 같은 결합 방식,
// 단 ①조건 기준값이 기준선이 아니라 컨버전 라인(candidateConvTrigger).
// 모멘텀 필터: 매수 후보는 다음 봉 종가가 현재 종가 이상, 매도 후보는 현재 종가 이하여야 하므로 close를 바닥/천장으로 결합
buyCandidateTrigger = math.max(conversionBullishState ? candidateConvTrigger : math.max(candidateConvTrigger, convBuyPrice), close)
sellCandidateTrigger = math.min(conversionBearishState ? candidateConvTrigger : math.min(candidateConvTrigger, convSellPrice), close)

f_price(p) => str.tostring(p, format.mintick)
// 화살표는 현재 가격(close) 대비 트리거 가격 위치로 결정: 트리거가 현재가보다 높으면 ↑, 낮으면 ↓
f_arrow(refPrice) => refPrice > close ? "↑ " : "↓ "
// 청산가의 현재 종가 대비 % (롱 청산은 아래라 −, 숏 청산은 위라 +)
f_pct(p) =>
    d = (p - close) / close * 100
    (d > 0 ? "+" : "") + str.tostring(d, "0.0") + "%"
buyBlocked = lastSignalDirection == 1
sellBlocked = lastSignalDirection == -1

// 샹들리에 ATR 트레일링 청산가 (현재 봉 기준 롱/숏 청산) — 테이블 표시용, 차트엔 그리지 않음
ceLength = input.int(22, title="청산 룩백 길이", minval=1, group="청산(샹들리에)")
ceAtrLen = input.int(22, title="청산 ATR 길이", minval=1, group="청산(샹들리에)")
ceMult = input.float(3.0, title="청산 ATR 배수", minval=0.0, step=0.01, group="청산(샹들리에)")
ceAtrVal = ceMult * ta.atr(ceAtrLen)
longCERaw = ta.highest(high, ceLength) - ceAtrVal
var float longCE = na
longCEPrev = nz(longCE[1], longCERaw)
longCE := close[1] > longCEPrev ? math.max(longCERaw, longCEPrev) : longCERaw
shortCERaw = ta.lowest(low, ceLength) + ceAtrVal
var float shortCE = na
shortCEPrev = nz(shortCE[1], shortCERaw)
shortCE := close[1] < shortCEPrev ? math.min(shortCERaw, shortCEPrev) : shortCERaw

// 전환가 = 후보·신호 트리거 중 더 가까운 값 (상승=더 낮은 값, 하락=더 높은 값)
buyTransition = math.min(buyCandidateTrigger, buySignalTrigger)
sellTransition = math.max(sellCandidateTrigger, sellSignalTrigger)

var table triggerTable = table.new(position.bottom_right, 2, 7, border_width=1, border_color=color.new(color.gray, 50))
if barstate.islast
    table.cell(triggerTable, 0, 0, "다음 봉", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.small)
    table.cell(triggerTable, 1, 0, "트리거 가격", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.small)

    table.cell(triggerTable, 0, 1, "상승 전환", text_color=color.white, bgcolor=color.new(color.green, 30), text_size=size.small)
    table.cell(triggerTable, 1, 1, buyBlocked ? "-" : f_arrow(buyTransition) + f_price(buyTransition), text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)

    table.cell(triggerTable, 0, 2, "하락 전환", text_color=color.white, bgcolor=color.new(color.red, 30), text_size=size.small)
    table.cell(triggerTable, 1, 2, sellBlocked ? "-" : f_arrow(sellTransition) + f_price(sellTransition), text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)

    table.cell(triggerTable, 0, 3, "구름대", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 3, cloudCellText, text_color=color.white, bgcolor=cloudCellColor, text_size=size.small)

    table.cell(triggerTable, 0, 4, "이평 리본", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 4, ribbonCellText, text_color=color.white, bgcolor=ribbonCellColor, text_size=size.small)

    table.cell(triggerTable, 0, 5, "롱 청산", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 5, f_price(longCE) + " (" + f_pct(longCE) + ")", text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)

    table.cell(triggerTable, 0, 6, "숏 청산", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 6, f_price(shortCE) + " (" + f_pct(shortCE) + ")", text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)

plotshape(series=ribbonChop, title="횡보 압축 (아래)", style=shape.diamond, location=location.belowbar, color=color.new(color.gray, 0), size=size.tiny)
plotshape(series=ribbonChop, title="횡보 압축 (위)", style=shape.diamond, location=location.abovebar, color=color.new(color.gray, 0), size=size.tiny)
plotshape(series=ribbonBull, title="상승 분출", style=shape.diamond, location=location.belowbar, color=color.new(color.blue, 0), size=size.tiny)
plotshape(series=ribbonBear, title="하락 분출", style=shape.diamond, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny)

alertcondition(ribbonChop, title="횡보 압축", message="Ribbon compressed (chop) — Ichimoku signals unreliable.")
alertcondition(ribbonBull, title="상승 분출", message="Ribbon bullish expansion after compression.")
alertcondition(ribbonBear, title="하락 분출", message="Ribbon bearish expansion after compression.")
