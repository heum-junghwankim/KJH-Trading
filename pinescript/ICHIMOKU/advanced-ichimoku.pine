//@version=6
indicator(title="Advanced Ichimoku", shorttitle="Adv Ichimoku", overlay=true)

donchian(len) =>
    math.avg(ta.lowest(len), ta.highest(len))

conversionPeriods = input.int(8, minval=1, title="컨버전 라인 길이", group="기본 설정")
basePeriods = input.int(22, minval=1, title="베이스 라인 길이", group="기본 설정")
leadingSpanBPeriods = input.int(44, minval=1, title="리딩 스팬 B 길이", group="기본 설정")
displacement = input.int(22, minval=1, title="레깅 스팬 길이", group="기본 설정")

showConversionLine = input.bool(true, title="컨버전 라인 표시", group="표시")
showBaseLine = input.bool(true, title="베이스 라인 표시", group="표시")
showLaggingSpan = input.bool(true, title="레깅 스팬 표시", group="표시")
showLeadingSpanA = input.bool(false, title="리딩 스팬 A 표시", group="표시")
showLeadingSpanB = input.bool(false, title="리딩 스팬 B 표시", group="표시")
showKumoUpper = input.bool(false, title="Kumo Cloud Upper Line 표시", group="표시")
showKumoLower = input.bool(false, title="Kumo Cloud Lower Line 표시", group="표시")
showCloudFill = input.bool(true, title="Cloud Fill 표시", group="표시")

showBuySignal = input.bool(true, title="매수 신호 표시", group="매수 신호")
showSellSignal = input.bool(true, title="매도 신호 표시", group="매도 신호")

lineWidth = 1
conversionLineColor = input.color(#E91E63, "컨버전 라인 색", group="색상")
baseLineColor = input.color(#00FF00, "베이스 라인 색", group="색상")
laggingSpanColor = input.color(#FFEB3B, "레깅 스팬 색", group="색상")
leadingSpanAColor = input.color(#7B9077, "리딩 스팬 A 색", group="색상")
leadingSpanBColor = input.color(#9A7272, "리딩 스팬 B 색", group="색상")
kumoBoundaryColor = input.color(#3F5AA9, "Kumo 경계선 색", group="색상")
bullCloudColor = input.color(#0B5D4F, "양운(상승 구름) 색", group="색상")
bearCloudColor = input.color(#6B1E28, "음운(하락 구름) 색", group="색상")
cloudTransp = input.int(45, "구름 투명도", minval=0, maxval=100, group="색상")
bullishCloudColor = color.new(bullCloudColor, cloudTransp)
bearishCloudColor = color.new(bearCloudColor, cloudTransp)
defaultBuyColor = #4FC3F7
defaultSellColor = #FF5FA2

conversionLine = donchian(conversionPeriods)
baseLine = donchian(basePeriods)
leadingSpanA = math.avg(conversionLine, baseLine)
leadingSpanB = donchian(leadingSpanBPeriods)
kumoUpper = math.max(leadingSpanA, leadingSpanB)
kumoLower = math.min(leadingSpanA, leadingSpanB)

// 신호 모드: 확정(원래 로직) / 예측(다음 봉 가정으로 1봉 빨리 포착). 기본 = 확정.
signalMode = input.string("확정 모드", title="신호 모드", options=["확정 모드", "예측 모드"], group="신호 모드")
isPredict = signalMode == "예측 모드"
showVwSignals = input.bool(true, title="거래량 가중 신호 표시", group="거래량 가중 신호")
vwTransp = input.int(50, minval=0, maxval=100, title="거래량 가중 투명도", group="거래량 가중 신호")

// =========================
// 멀티스케일 신호 — 래깅 설정값의 0.5× / 1× / 2× 스케일로 동일 로직 계산
// 한 함수가 일반(도న키언) 신호 + 거래량 가중(VWMA) 신호를 함께 반환한다. (후보 제거)
// 차트엔 1× 라인/구름만 그리고, 0.5×·2×는 신호 계산용으로만 쓴다.
// =========================
f_scale(p, mult) => math.max(1, int(math.round(p * mult)))

f_scaleSignals(int convP, int baseP, int dispP) =>
    conv = donchian(convP)
    base = donchian(baseP)
    lagOff = math.max(dispP - 1, 0)
    lagBaseRef = base[lagOff]
    lagBull = not na(lagBaseRef) and (ta.crossover(close, lagBaseRef) or close > lagBaseRef)
    lagBear = not na(lagBaseRef) and (ta.crossunder(close, lagBaseRef) or close < lagBaseRef)
    convBull = ta.crossover(conv, base) or conv > base
    convBear = ta.crossunder(conv, base) or conv < base
    pBuy = (close + high) / 2
    pSell = (close + low) / 2
    pLagRef = base[math.max(lagOff - 1, 0)]
    pRawBuy = pBuy > pLagRef and convBull and low > low[1]
    pRawSell = pSell < pLagRef and convBear and high < high[1]
    rbEff = isPredict ? pRawBuy : (lagBull and convBull)
    rsEff = isPredict ? pRawSell : (lagBear and convBear)
    var int lastDir = 0
    bSig = rbEff and lastDir != 1
    sSig = rsEff and lastDir != -1
    if bSig
        lastDir := 1
    else if sSig
        lastDir := -1
    vConv = ta.vwma(close, convP)
    vBase = ta.vwma(close, baseP)
    vLagRef = vBase[lagOff]
    vLagBull = not na(vLagRef) and (ta.crossover(close, vLagRef) or close > vLagRef)
    vLagBear = not na(vLagRef) and (ta.crossunder(close, vLagRef) or close < vLagRef)
    vConvBull = ta.crossover(vConv, vBase) or vConv > vBase
    vConvBear = ta.crossunder(vConv, vBase) or vConv < vBase
    cN = math.max(1, convP - 1)
    bN = math.max(1, baseP - 1)
    pvConv = math.sum(close * volume, cN)
    vsConv = math.sum(volume, cN)
    pvBase = math.sum(close * volume, bN)
    vsBase = math.sum(volume, bN)
    vConvBuyN = (pvConv + pBuy * volume) / (vsConv + volume)
    vBaseBuyN = (pvBase + pBuy * volume) / (vsBase + volume)
    vConvSellN = (pvConv + pSell * volume) / (vsConv + volume)
    vBaseSellN = (pvBase + pSell * volume) / (vsBase + volume)
    vLagRefN = vBase[math.max(lagOff - 1, 0)]
    pvBuy = pBuy > vLagRefN and vConvBuyN > vBaseBuyN and low > low[1]
    pvSell = pSell < vLagRefN and vConvSellN < vBaseSellN and high < high[1]
    vRbEff = isPredict ? pvBuy : (vLagBull and vConvBull)
    vRsEff = isPredict ? pvSell : (vLagBear and vConvBear)
    var int vLastDir = 0
    vbSig = vRbEff and vLastDir != 1
    vsSig = vRsEff and vLastDir != -1
    if vbSig
        vLastDir := 1
    else if vsSig
        vLastDir := -1
    [bSig, sSig, vbSig, vsSig]

[buy05, sell05, vwBuy05, vwSell05] = f_scaleSignals(f_scale(conversionPeriods, 0.5), f_scale(basePeriods, 0.5), f_scale(displacement, 0.5))
[buy10, sell10, vwBuy10, vwSell10] = f_scaleSignals(conversionPeriods, basePeriods, displacement)
[buy20, sell20, vwBuy20, vwSell20] = f_scaleSignals(f_scale(conversionPeriods, 2.0), f_scale(basePeriods, 2.0), f_scale(displacement, 2.0))

// 스케일별 신호 방향(중복 표시 차단용) — 각 스케일 트리거 칸의 '-' 처리에 사용
var int dir05 = 0
if buy05
    dir05 := 1
else if sell05
    dir05 := -1
var int dir10 = 0
if buy10
    dir10 := 1
else if sell10
    dir10 := -1
var int dir20 = 0
if buy20
    dir20 := 1
else if sell20
    dir20 := -1
buyBlocked05 = dir05 == 1
sellBlocked05 = dir05 == -1
buyBlocked10 = dir10 == 1
sellBlocked10 = dir10 == -1
buyBlocked20 = dir20 == 1
sellBlocked20 = dir20 == -1

cloudOffset = displacement - 1
fillSourceA = plot(leadingSpanA, offset=cloudOffset, title="Cloud Fill Source A", color=color.new(leadingSpanAColor, 100), display=display.none)
fillSourceB = plot(leadingSpanB, offset=cloudOffset, title="Cloud Fill Source B", color=color.new(leadingSpanBColor, 100), display=display.none)

plot(showConversionLine ? conversionLine : na, title="Conversion Line", color=conversionLineColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showBaseLine ? baseLine : na, title="Base Line", color=baseLineColor, linewidth=lineWidth, display=display.all)
plot(showLaggingSpan ? close : na, offset=-cloudOffset, title="Lagging Span", color=laggingSpanColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showLeadingSpanA ? leadingSpanA : na, offset=cloudOffset, title="Leading Span A", color=leadingSpanAColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showLeadingSpanB ? leadingSpanB : na, offset=cloudOffset, title="Leading Span B", color=leadingSpanBColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showKumoUpper ? kumoUpper : na, offset=cloudOffset, title="Kumo Cloud Upper Line", color=kumoBoundaryColor, linewidth=lineWidth, display=display.all - display.price_scale)
plot(showKumoLower ? kumoLower : na, offset=cloudOffset, title="Kumo Cloud Lower Line", color=kumoBoundaryColor, linewidth=lineWidth, display=display.all - display.price_scale)
fill(fillSourceA, fillSourceB, title="Cloud Fill", color=showCloudFill ? (leadingSpanA > leadingSpanB ? bullishCloudColor : bearishCloudColor) : na)

// 일반 신호 (불투명) — 스케일별 크기: 0.5×=가장 작음, 1×=작음, 2×=보통
plotshape(showBuySignal and buy05, title="매수 0.5×", style=shape.triangleup, location=location.belowbar, color=defaultBuyColor, size=size.tiny)
plotshape(showBuySignal and buy10, title="매수 1×", style=shape.triangleup, location=location.belowbar, color=defaultBuyColor, size=size.small)
plotshape(showBuySignal and buy20, title="매수 2×", style=shape.triangleup, location=location.belowbar, color=defaultBuyColor, size=size.normal)
plotshape(showSellSignal and sell05, title="매도 0.5×", style=shape.triangledown, location=location.abovebar, color=defaultSellColor, size=size.tiny)
plotshape(showSellSignal and sell10, title="매도 1×", style=shape.triangledown, location=location.abovebar, color=defaultSellColor, size=size.small)
plotshape(showSellSignal and sell20, title="매도 2×", style=shape.triangledown, location=location.abovebar, color=defaultSellColor, size=size.normal)

// 거래량 가중(VWMA) 신호 (반투명) — 동일 스케일/크기
plotshape(showVwSignals and vwBuy05, title="매수 0.5× (거래량)", style=shape.triangleup, location=location.belowbar, color=color.new(defaultBuyColor, vwTransp), size=size.tiny)
plotshape(showVwSignals and vwBuy10, title="매수 1× (거래량)", style=shape.triangleup, location=location.belowbar, color=color.new(defaultBuyColor, vwTransp), size=size.small)
plotshape(showVwSignals and vwBuy20, title="매수 2× (거래량)", style=shape.triangleup, location=location.belowbar, color=color.new(defaultBuyColor, vwTransp), size=size.normal)
plotshape(showVwSignals and vwSell05, title="매도 0.5× (거래량)", style=shape.triangledown, location=location.abovebar, color=color.new(defaultSellColor, vwTransp), size=size.tiny)
plotshape(showVwSignals and vwSell10, title="매도 1× (거래량)", style=shape.triangledown, location=location.abovebar, color=color.new(defaultSellColor, vwTransp), size=size.small)
plotshape(showVwSignals and vwSell20, title="매도 2× (거래량)", style=shape.triangledown, location=location.abovebar, color=color.new(defaultSellColor, vwTransp), size=size.normal)

alertcondition(buy10, title="Advanced Ichimoku Buy Signal", message="Advanced Ichimoku buy signal")
alertcondition(sell10, title="Advanced Ichimoku Sell Signal", message="Advanced Ichimoku sell signal")

// =========================
// 이평 수축/확장 판정 (휩쏘 필터 + 분출 확인) — A / B / A and B 모드
// =========================
// A(이평 리본): 입력값 기반 리본(전환선~리딩B 길이)의 폭이 ATR 대비 좁으면 수축, 다시 벌어지는 첫 봉에 빠른선 vs 느린선 방향으로 확장.
// B(구름 두께): 선행스팬 A·B 간격(구름 두께)이 ATR 대비 좁으면 수축, 벌어지는 첫 봉에 구름 색(양운/음운) 방향으로 확장.
// A and B(기본): 두 기준이 모두 수축/확장(방향 일치)할 때만. 압축 → 분출 → 압축 … 순서.
ribbonMode = input.string("리본+구름", title="수축/확장 판정 모드", options=["이평 리본", "구름 두께", "리본+구름"], group="리본 압축/분출")
ribbonMaType = input.string("SMA", title="리본 이동평균 종류(A)", options=["SMA", "EMA", "WMA", "VWMA"], group="리본 압축/분출")
showChopWarn = input.bool(true, title="횡보 압축(수축) 표시", group="리본 압축/분출")
showExpansion = input.bool(true, title="분출(상승/하락 확장) 표시", group="리본 압축/분출")
ribbonConfirmOnClose = input.bool(true, title="봉마감 후 확정", group="리본 압축/분출")
ribbonAtrLength = input.int(14, minval=1, title="폭 ATR 기준", group="리본 압축/분출")
ribbonCompressAtrMult = input.float(0.8, minval=0.1, step=0.1, title="수축 판정 ATR 배수", group="리본 압축/분출")
ribbonExpandBars = input.int(1, minval=1, title="확장 판정 폭 증가 봉수(작을수록 빠름)", group="리본 압축/분출")

ribbonMa(length) =>
    switch ribbonMaType
        "SMA" => ta.sma(close, length)
        "EMA" => ta.ema(close, length)
        "WMA" => ta.wma(close, length)
        "VWMA" => ta.vwma(close, length)

rAtr = ta.atr(ribbonAtrLength)

// A 모드: 이치모쿠 입력값(전환선~리딩B)에 맞춘 7개 이평 리본
aStep = (leadingSpanBPeriods - conversionPeriods) / 6.0
aMaFast = ribbonMa(math.max(1, conversionPeriods))
aMa1 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep))))
aMa2 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 2))))
aMa3 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 3))))
aMa4 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 4))))
aMa5 = ribbonMa(math.max(1, int(math.round(conversionPeriods + aStep * 5))))
aMaSlow = ribbonMa(math.max(1, leadingSpanBPeriods))
aTop = math.max(aMaFast, math.max(aMa1, math.max(aMa2, math.max(aMa3, math.max(aMa4, math.max(aMa5, aMaSlow))))))
aBottom = math.min(aMaFast, math.min(aMa1, math.min(aMa2, math.min(aMa3, math.min(aMa4, math.min(aMa5, aMaSlow))))))
aHeight = math.max(aTop - aBottom, syminfo.mintick)
aCompressed = aHeight < rAtr * ribbonCompressAtrMult
aExpanding = aHeight > aHeight[ribbonExpandBars]
aBull = aMaFast >= aMaSlow

// B 모드: 구름 두께(선행스팬 A vs B)
bWidth = math.max(kumoUpper - kumoLower, syminfo.mintick)
bCompressed = bWidth < rAtr * ribbonCompressAtrMult
bExpanding = bWidth > bWidth[ribbonExpandBars]
bBull = leadingSpanA >= leadingSpanB

// 모드별 수축/확장/방향 결합
isAMode = ribbonMode == "이평 리본"
isBMode = ribbonMode == "구름 두께"
compNow = isAMode ? aCompressed : isBMode ? bCompressed : (aCompressed and bCompressed)
expNow = isAMode ? aExpanding : isBMode ? bExpanding : (aExpanding and bExpanding)
bullNow = isAMode ? aBull : isBMode ? bBull : (aBull and bBull)
bearNow = isAMode ? not aBull : isBMode ? not bBull : (not aBull and not bBull)
rHeight = isBMode ? bWidth : aHeight   // 테이블 폭/ATR 표시용

rConfirmed = not ribbonConfirmOnClose or barstate.isconfirmed
rChopEnter = compNow and not compNow[1]

// 수축 진입 시 무장 → 폭이 다시 늘기 시작하는(확장) 첫 봉에 방향 확정. (A and B는 방향 일치 시에만)
var bool rArmed = false
var string ribbonState = "대기"
bool rBullExpansion = false
bool rBearExpansion = false
if rConfirmed
    if rChopEnter
        rArmed := true
        ribbonState := "횡보 압축"
    else if rArmed and expNow and (bullNow or bearNow)
        rBullExpansion := bullNow
        rBearExpansion := bearNow
        ribbonState := bullNow ? "상승 분출" : "하락 분출"
        rArmed := false

ribbonChop = showChopWarn and rConfirmed and rChopEnter
ribbonBull = showExpansion and rBullExpansion
ribbonBear = showExpansion and rBearExpansion

// 현재 봉 구름대 상태(가격 위치 + 두께 + 색). 구름은 displacement만큼 앞으로 밀려 그려지므로
// 현재 봉 아래 구름은 cloudOffset 만큼 과거의 선행스팬 값으로 평가한다. 괄호 숫자 = 두께/ATR 배수.
curSpanA = leadingSpanA[cloudOffset]
curSpanB = leadingSpanB[cloudOffset]
cloudTop = math.max(curSpanA, curSpanB)
cloudBottom = math.min(curSpanA, curSpanB)
cloudThickAtr = (cloudTop - cloudBottom) / rAtr
cloudPosText = close > cloudTop ? "위" : close < cloudBottom ? "아래" : "안"
cloudColorText = curSpanA >= curSpanB ? "양운" : "음운"
cloudCellText = cloudPosText + "·" + cloudColorText + " (" + str.tostring(cloudThickAtr, "0.0") + ")"
cloudCellColor = close > cloudTop ? color.new(color.green, 30) : close < cloudBottom ? color.new(color.red, 30) : color.new(color.gray, 40)

// 리본 상태 = 마지막으로 발생한 다이아몬드(상태머신) 기준이라 차트 표시와 동기화된다.
// 괄호 숫자 = 현재 리본폭/ATR 배수(압축 배수보다 작으면 압축 구간).
ribbonWidthRatio = rHeight / rAtr
ribbonCellText = ribbonState + " (" + str.tostring(ribbonWidthRatio, "0.00") + ")"
ribbonCellColor = ribbonState == "상승 분출" ? color.new(color.blue, 30) : ribbonState == "하락 분출" ? color.new(color.red, 30) : color.new(color.gray, 40)

// =========================
// 우측 하단: 다음 봉 트리거 가격 + 구름대/리본 상태
// =========================
// 신호 = (후행스팬 조건) AND (전환선 vs 기준선 게이트). 다음 봉 종가가 돌파해야 할 기준 가격을 표시한다.
// 매수/매도 트리거 가격을 0.5× / 1× / 2× 세 스케일로 각각 계산해 테이블에 표시한다.
// 같은 방향 신호가 직전에 이미 나온 상태(중복방지)에서는 그 방향 트리거가를 '-'로 표시한다.
f_trigger(int convP, int baseP, int dispP) =>
    cLine = donchian(convP)
    bLine = donchian(baseP)
    cBull = cLine > bLine
    cBear = cLine < bLine
    lagOff = math.max(dispP - 1, 0)
    refIdx = math.max(lagOff - 1, 0)
    lagBaseTrig = bLine[refIdx]
    cPrior = math.max(convP - 1, 1)
    bPrior = math.max(baseP - 1, 1)
    rLow = ta.lowest(cPrior)
    rHigh = ta.highest(cPrior)
    bMidNext = (ta.highest(bPrior) + ta.lowest(bPrior)) / 2
    cBuyP = 2 * bMidNext - rLow
    cSellP = 2 * bMidNext - rHigh
    bTrig = cBull ? lagBaseTrig : math.max(lagBaseTrig, cBuyP)
    sTrig = cBear ? lagBaseTrig : math.min(lagBaseTrig, cSellP)
    [bTrig, sTrig]

[buyTrig05, sellTrig05] = f_trigger(f_scale(conversionPeriods, 0.5), f_scale(basePeriods, 0.5), f_scale(displacement, 0.5))
[buyTrig10, sellTrig10] = f_trigger(conversionPeriods, basePeriods, displacement)
[buyTrig20, sellTrig20] = f_trigger(f_scale(conversionPeriods, 2.0), f_scale(basePeriods, 2.0), f_scale(displacement, 2.0))

f_price(p) => str.tostring(p, format.mintick)
// 화살표는 현재 가격(close) 대비 트리거 가격 위치로 결정: 트리거가 현재가보다 높으면 ↑, 낮으면 ↓
f_arrow(refPrice) => refPrice > close ? "↑ " : "↓ "
// 청산가의 현재 종가 대비 % (롱 청산은 아래라 −, 숏 청산은 위라 +)
f_pct(p) =>
    d = (p - close) / close * 100
    (d > 0 ? "+" : "") + str.tostring(d, "0.0") + "%"

// 샹들리에 ATR 트레일링 청산가 (현재 봉 기준 롱/숏 청산) — 차트에 수평선 + 테이블 표시
ceLength = input.int(22, title="청산 룩백 길이", minval=1, group="청산(샹들리에)")
ceAtrLen = input.int(22, title="청산 ATR 길이", minval=1, group="청산(샹들리에)")
ceMult = input.float(3.0, title="청산 ATR 배수", minval=0.0, step=0.01, group="청산(샹들리에)")
// 청산 가격 모드(샹들리에 기반):
//  - 기본: 표준 샹들리에(룩백 고가/저가 − ATR)
//  - 거래량 가중: 거래량 큰 봉(VWMA)에 가중 → 거래 몰린 봉에서 청산가를 끌어올림
//  - 최근봉 가중: 최근봉(WMA)에 가중 → 휩쏘 급등/급락 봉에서 청산가를 빠르게·높게
//  - 거래량+최근봉: 두 가중을 함께(거래량 × 선형 최근봉)
// 기본은 룩백 극값(highest/lowest), 가중 모드는 가중 트레일 길이·배수로 계산한 가중평균 앵커를 그대로 쓴다(모드마다 위치가 달라짐).
ceMode = input.string("기본", title="청산 가격 모드", options=["기본", "거래량 가중", "최근봉 가중", "거래량+최근봉"], group="청산(샹들리에)")
ceWeightLen = input.int(10, title="가중 트레일 길이", minval=1, group="청산(샹들리에)")
ceWeightMult = input.float(1.5, title="가중 트레일 ATR 배수", minval=0.0, step=0.01, group="청산(샹들리에)")
showExitLines = input.bool(true, title="청산 수평선 표시(1px)", group="청산(샹들리에)")
longExitLineColor = input.color(color.green, title="롱 청산선 색", group="청산(샹들리에)")
shortExitLineColor = input.color(color.red, title="숏 청산선 색", group="청산(샹들리에)")

ceAtrVal = ceMult * ta.atr(ceAtrLen)
// 거래량 × 최근봉(선형) 가중 평균
f_volRecencyMa(src, len) =>
    float num = 0.0
    float den = 0.0
    for i = 0 to len - 1
        float w = volume[i] * (len - i)
        num += src[i] * w
        den += w
    den != 0 ? num / den : src
longVwma = ta.vwma(high, ceWeightLen)
longWma  = ta.wma(high, ceWeightLen)
longVR   = f_volRecencyMa(high, ceWeightLen)
shortVwma = ta.vwma(low, ceWeightLen)
shortWma  = ta.wma(low, ceWeightLen)
shortVR   = f_volRecencyMa(low, ceWeightLen)
// 모드별 앵커 선택 — 기본은 룩백 극값, 가중 모드는 가중평균 앵커를 그대로 사용(− 가중 ATR 버퍼)
longAnchorW = ceMode == "거래량 가중" ? longVwma : ceMode == "최근봉 가중" ? longWma : longVR
shortAnchorW = ceMode == "거래량 가중" ? shortVwma : ceMode == "최근봉 가중" ? shortWma : shortVR
weightAtr = ceWeightMult * ta.atr(ceAtrLen)
longCERaw = ceMode == "기본" ? ta.highest(high, ceLength) - ceAtrVal : longAnchorW - weightAtr
shortCERaw = ceMode == "기본" ? ta.lowest(low, ceLength) + ceAtrVal : shortAnchorW + weightAtr
var float longCE = na
longCEPrev = nz(longCE[1], longCERaw)
longCE := close[1] > longCEPrev ? math.max(longCERaw, longCEPrev) : longCERaw
var float shortCE = na
shortCEPrev = nz(shortCE[1], shortCERaw)
shortCE := close[1] < shortCEPrev ? math.min(shortCERaw, shortCEPrev) : shortCERaw

// 청산 가격 수평선 (1px, 우측 확장) — 현재 봉 청산가 레벨
var line longExitLine = na
var line shortExitLine = na
if showExitLines and barstate.islast
    line.delete(longExitLine)
    line.delete(shortExitLine)
    longExitLine := line.new(bar_index - 1, longCE, bar_index, longCE, extend=extend.right, color=longExitLineColor, width=1)
    shortExitLine := line.new(bar_index - 1, shortCE, bar_index, shortCE, extend=extend.right, color=shortExitLineColor, width=1)

// 트리거 셀 텍스트: 중복차단이면 '-', 아니면 화살표+가격
f_trigCell(blocked, p) => blocked ? "-" : f_arrow(p) + f_price(p)

var table triggerTable = table.new(position.bottom_right, 2, 12, border_width=1, border_color=color.new(color.gray, 50))
if barstate.islast
    table.cell(triggerTable, 0, 0, "다음 봉", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.small)
    table.cell(triggerTable, 1, 0, "트리거 가격", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.small)

    table.cell(triggerTable, 0, 1, "상승 전환(0.5×)", text_color=color.white, bgcolor=color.new(color.green, 30), text_size=size.small)
    table.cell(triggerTable, 1, 1, f_trigCell(buyBlocked05, buyTrig05), text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)
    table.cell(triggerTable, 0, 2, "상승 전환(1×)", text_color=color.white, bgcolor=color.new(color.green, 30), text_size=size.small)
    table.cell(triggerTable, 1, 2, f_trigCell(buyBlocked10, buyTrig10), text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)
    table.cell(triggerTable, 0, 3, "상승 전환(2×)", text_color=color.white, bgcolor=color.new(color.green, 30), text_size=size.small)
    table.cell(triggerTable, 1, 3, f_trigCell(buyBlocked20, buyTrig20), text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)

    table.cell(triggerTable, 0, 4, "하락 전환(0.5×)", text_color=color.white, bgcolor=color.new(color.red, 30), text_size=size.small)
    table.cell(triggerTable, 1, 4, f_trigCell(sellBlocked05, sellTrig05), text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)
    table.cell(triggerTable, 0, 5, "하락 전환(1×)", text_color=color.white, bgcolor=color.new(color.red, 30), text_size=size.small)
    table.cell(triggerTable, 1, 5, f_trigCell(sellBlocked10, sellTrig10), text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)
    table.cell(triggerTable, 0, 6, "하락 전환(2×)", text_color=color.white, bgcolor=color.new(color.red, 30), text_size=size.small)
    table.cell(triggerTable, 1, 6, f_trigCell(sellBlocked20, sellTrig20), text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)

    table.cell(triggerTable, 0, 7, "구름대", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 7, cloudCellText, text_color=color.white, bgcolor=cloudCellColor, text_size=size.small)

    table.cell(triggerTable, 0, 8, "이평 리본", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 8, ribbonCellText, text_color=color.white, bgcolor=ribbonCellColor, text_size=size.small)

    table.cell(triggerTable, 0, 9, "롱 청산", text_color=color.white, bgcolor=color.new(longExitLineColor, 55), text_size=size.small)
    table.cell(triggerTable, 1, 9, f_price(longCE) + " (" + f_pct(longCE) + ")", text_color=color.white, bgcolor=color.new(longExitLineColor, 35), text_size=size.small)

    table.cell(triggerTable, 0, 10, "숏 청산", text_color=color.white, bgcolor=color.new(shortExitLineColor, 55), text_size=size.small)
    table.cell(triggerTable, 1, 10, f_price(shortCE) + " (" + f_pct(shortCE) + ")", text_color=color.white, bgcolor=color.new(shortExitLineColor, 35), text_size=size.small)

    table.cell(triggerTable, 0, 11, "청산 모드", text_color=color.white, bgcolor=color.new(color.gray, 20), text_size=size.small)
    table.cell(triggerTable, 1, 11, ceMode, text_color=color.white, bgcolor=color.new(color.gray, 40), text_size=size.small)

plotshape(series=ribbonChop, title="횡보 압축 (아래)", style=shape.diamond, location=location.belowbar, color=color.new(color.gray, 0), size=size.tiny)
plotshape(series=ribbonChop, title="횡보 압축 (위)", style=shape.diamond, location=location.abovebar, color=color.new(color.gray, 0), size=size.tiny)
plotshape(series=ribbonBull, title="상승 분출", style=shape.diamond, location=location.belowbar, color=color.new(color.blue, 0), size=size.tiny)
plotshape(series=ribbonBear, title="하락 분출", style=shape.diamond, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny)

alertcondition(ribbonChop, title="횡보 압축", message="Ribbon compressed (chop) — Ichimoku signals unreliable.")
alertcondition(ribbonBull, title="상승 분출", message="Ribbon bullish expansion after compression.")
alertcondition(ribbonBear, title="하락 분출", message="Ribbon bearish expansion after compression.")
